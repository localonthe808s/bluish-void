    var daylightMins = Math.floor((daylightMs % (1000 * 60 * 60)) / (1000 * 60));
    if (tlDaylight) tlDaylight.textContent = daylightHours + "h " + daylightMins + "m";

    // Calculate daylight change from yesterday
    // Use Open-Meteo data for both today AND yesterday so refraction/elevation models match.
    // The function-scope `daily` is sliced single-day; `_fullDaily` has 11 entries
    // (past_days=1 + 10 forecast) with today at `_bdi` and yesterday at `_bdi-1`.
    try {
    if (tlDaylightChange){
      var srYesterday = null, ssYesterday = null;
      // _fullDaily and _bdi are declared inside the GH IIFE — not visible here.
      // Use window globals which are the same source: past_days=1 means index 0=yesterday.
      var _fdY = window._dailyData || null;
      var _bdiY = window._tlBaseDay || 0;
      if (_fdY && _bdiY > 0 && _fdY.sunrise && _fdY.sunrise[_bdiY-1] && _fdY.sunset && _fdY.sunset[_bdiY-1]) {
        srYesterday = new Date(_fdY.sunrise[_bdiY-1]);
        ssYesterday = new Date(_fdY.sunset[_bdiY-1]);
      } else if (typeof solarEventTimeLocal === 'function' && typeof dayLocal !== 'undefined') {
        var yesterdayLocal = new Date(dayLocal.getTime() - 86400000);
        srYesterday = solarEventTimeLocal(yesterdayLocal, LOCATION.lat, LOCATION.lon, -0.833, true);
        ssYesterday = solarEventTimeLocal(yesterdayLocal, LOCATION.lat, LOCATION.lon, -0.833, false);
      }

      if (srYesterday && ssYesterday){
        var yesterdayMs = ssYesterday.getTime() - srYesterday.getTime();
        var diffMs = daylightMs - yesterdayMs;
        var diffSecs = Math.round(diffMs / 1000);
        var diffMins = Math.floor(Math.abs(diffSecs) / 60);
        var remainSecs = Math.abs(diffSecs) % 60;
        
        var sign = diffSecs >= 0 ? "+" : "-";
        var timeStr = diffMins > 0 ? (sign + diffMins + "m " + remainSecs + "s") : (sign + remainSecs + "s");
        
