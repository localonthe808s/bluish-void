    if (ph) {
      h += FS('Formation & History');
      h += '<div style="display:flex;gap:10px;align-items:flex-start;padding:10px 12px;background:rgba(43,34,244,.04);border-radius:8px;border-left:3px solid #a8a292;">'+
        '<div style="font-size:18px;line-height:1;flex-shrink:0;">\u23f3</div>'+
        '<div style="font-size:11px;color:rgba(43,34,244,.75);line-height:1.55;flex:1;">'+ph+'</div>'+
      '</div>';
    }

    // ── MOONS (card list) ──
    var pm = PLANET_MOONS[planetKey];
    if (pm) {
      h += FS('Moons (' + pm.count + ')');
