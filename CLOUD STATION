        // auroraOvalMap — schematic polar projection (north-pole-centered)
        // showing the auroral oval as a green/yellow ring at the threshold
        // latitude, with the user's location marked. Latitude maps from
        // pole (center) to 30°N (edge); during quiet times the oval sits
        // at ~67°N, during storms it expands equatorward.
        var auroraOvalMap = function(yourLat, threshold, kp) {
          var size = 140;
          var cx = size/2, cy = size/2;
          // Tighter outer radius so dot + label fit inside the disk with
          // margin to spare. Reduced from rOuter=size/2-6 → -14.
          var rOuter = size/2 - 14;
          var latToR = function(lat){
            var clamped = Math.max(30, Math.min(90, Math.abs(lat)));
            return ((90 - clamped) / 60) * rOuter;
          };
          var rThreshold = latToR(threshold);
          var ovalThickness = Math.max(6, Math.min(22, 6 + (kp - 2) * 2.5));
          var rUser = latToR(yourLat);
          var s = '<svg width="'+size+'" height="'+size+'" viewBox="0 0 '+size+' '+size+'" style="display:block;margin:6px auto 4px;">';
          s += '<defs><radialGradient id="aoSky" cx="50%" cy="50%" r="50%">'+
            '<stop offset="0%" stop-color="rgba(20,18,60,1)"/>'+
            '<stop offset="100%" stop-color="rgba(40,38,90,1)"/>'+
          '</radialGradient></defs>';
          s += '<circle cx="'+cx+'" cy="'+cy+'" r="'+rOuter+'" fill="url(#aoSky)"/>';
          // Latitude grid
          s += '<circle cx="'+cx+'" cy="'+cy+'" r="'+latToR(60).toFixed(1)+'" fill="none" stroke="rgba(255,255,255,.10)" stroke-width="0.5"/>';
          s += '<circle cx="'+cx+'" cy="'+cy+'" r="'+latToR(75).toFixed(1)+'" fill="none" stroke="rgba(255,255,255,.10)" stroke-width="0.5"/>';
          // Auroral oval ring with diffuse green-yellow halo
          s += '<defs><radialGradient id="aoOval" cx="50%" cy="50%" r="50%">'+
            '<stop offset="'+Math.max(0,(rThreshold-ovalThickness/2)/rOuter*100).toFixed(1)+'%" stop-color="rgba(40,200,100,0)"/>'+
            '<stop offset="'+(rThreshold/rOuter*100).toFixed(1)+'%" stop-color="rgba(120,255,150,.85)"/>'+
            '<stop offset="'+Math.min(100,(rThreshold+ovalThickness/2)/rOuter*100).toFixed(1)+'%" stop-color="rgba(40,200,100,0)"/>'+
          '</radialGradient></defs>';
          s += '<circle cx="'+cx+'" cy="'+cy+'" r="'+rOuter+'" fill="url(#aoOval)" filter="blur(2px)"/>';
          s += '<circle cx="'+cx+'" cy="'+cy+'" r="'+rThreshold.toFixed(1)+'" fill="none" stroke="rgba(160,255,180,.55)" stroke-width="1.2"/>';
          // Pole crosshair
          s += '<g stroke="rgba(255,255,255,.4)" stroke-width="0.8">'+
            '<line x1="'+(cx-2)+'" y1="'+cy+'" x2="'+(cx+2)+'" y2="'+cy+'"/>'+
            '<line x1="'+cx+'" y1="'+(cy-2)+'" x2="'+cx+'" y2="'+(cy+2)+'"/>'+
          '</g>';
          // Cardinal N label
          s += '<text x="'+cx+'" y="10" text-anchor="middle" font-size="8" font-weight="700" fill="rgba(255,255,255,.55)" style="fill:rgba(255,255,255,.55);">N</text>';
          // User position
          var userDotY = cy + rUser;
          var userInOval = Math.abs(yourLat) >= threshold;
          s += '<circle cx="'+cx+'" cy="'+userDotY.toFixed(1)+'" r="3.5" fill="'+(userInOval?'#88ff99':'#ff8866')+'" stroke="#fff" stroke-width="1.5"/>';
          // User latitude label — placed ABOVE the dot, INSIDE the disk so
