  // ── Track boot phases for intro screen ──
  window._bootPhase = { tier1: false, tier2: false, tier3: false, tier4: false };

  // ── MANUAL-LOCATION-FIRST STRATEGY ──
  // No auto GPS or IP detection (Wix HTML embed iframe blocks geolocation
  // and IP is too coarse to be useful). Boot from the user's last manual
  // search if cached, otherwise the default location. Search picker writes
  // the cache so the user only types their location once per device.
  (function geoThenBoot(){
    var STORAGE_KEY = 'bv_lastLoc_v4';
    var CACHE_TTL_MS = 30 * 24 * 60 * 60 * 1000; // 30 days for manual picks

    function loadCache(){
      try {
        var raw = localStorage.getItem(STORAGE_KEY);
        if (!raw) return null;
        var d = JSON.parse(raw);
        if (!d || d.lat == null || d.lon == null || !d.savedAt) return null;
        if (Date.now() - d.savedAt > CACHE_TTL_MS) return null;
        return d;
      } catch(e){ return null; }
    }

    function buildLocFromCache(c){
      var nearestRadar = { id: "KOKX", name: "NWS Upton", region: "NORTHEAST" };
      if (typeof RADAR_SITES !== "undefined"){
        var bestDist = Infinity;
        for (var r = 0; r < RADAR_SITES.length; r++){
          var rlat = RADAR_SITES[r].lat, rlon = RADAR_SITES[r].lon;
          var dd = Math.sqrt(Math.pow(c.lat - rlat, 2) + Math.pow(c.lon - rlon, 2));
          if (dd < bestDist){ bestDist = dd; nearestRadar = RADAR_SITES[r]; }
        }
      }
      var goesSat = c.lon < -105 ? "G18" : "G19";
      var goesSector = c.lon < -105 ? "wus" : (c.lat > 38 ? "ne" : "se");
      return {
        id: "custom", name: c.name, lat: c.lat, lon: c.lon, tz: c.tz,
        radar: nearestRadar.id, radarName: nearestRadar.name,
        radarRegion: nearestRadar.region,
        goes: { sat: goesSat, sector: goesSector }
      };
    }

    // Apply cached manual-search location before runTieredBoot fires data fetches
    var cached = loadCache();
    if (cached){
      var loc = buildLocFromCache(cached);
      var cIdx = -1;
      for (var i = 0; i < LOCATIONS.length; i++){
        if (LOCATIONS[i].id === "custom"){ cIdx = i; break; }
      }
      if (cIdx >= 0) LOCATIONS[cIdx] = loc;
      else LOCATIONS.push(loc);
      LOCATION = loc;
      if (loc.tz) TZ = loc.tz;
      if (cached.meta) window._geoMeta = cached.meta;
      if (typeof locNameEl !== 'undefined' && locNameEl) locNameEl.textContent = loc.name;
    }

    // Search picker calls this after switching to persist the choice across visits.
    window._saveLocCache = function(loc, meta){
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
          lat: loc.lat, lon: loc.lon, name: loc.name, tz: loc.tz,
          meta: meta || null, savedAt: Date.now()
        }));
      } catch(e){}
    };

    runTieredBoot();
  })();

  function runTieredBoot(){

    // ─── TIER 1: Core weather + radar (immediate — always loads) ───
    loadWeatherForLocation(LOCATION);
    startRadarNwsLoop();
    initNowMicroTabs();
    initLocationSwitcher();
    window._bootPhase.tier1 = true;

    // ─── TIER 2-4: DEFERRED — initiated by clicking widget covers ───
    // The heavy init functions (GOES, space weather, hazard maps) are
    // called by window._revealWidget() when user taps a widget cover.
    // This lets the page load fast with just weather + 7-day, and each
    // section boots cleanly when the user is ready for it.

    // Lightweight things that don't need covers:
    setTimeout(function(){
      loadWeatherAlerts();
      loadAirQuality();
      loadPollen();
    }, 800);

    // ─── GOES/Radar: loads on boot (no cover) ───
    setTimeout(function(){
      try { startGoesAutoplay(); } catch(e){}
      try { initGfsWidget(); } catch(e){}
      try { initFcastWidgets(); } catch(e){}
      try { initNationalRadarMap(); } catch(e){}
    }, 1200);

    // ─── Pre-init hazard map so tiles are cached before user clicks ───
    // Defer until after intro screen dismisses (~5s) to avoid starving the animation
    setTimeout(function(){
      if (!window._hazardInited) {
        window._hazardInited = true;
        try { initUnifiedHazardMap(); } catch(e){ console.error('hazard pre-init', e); }
        setTimeout(function(){ try { initGeologyMaps(); } catch(e){} }, 500);
      }
    }, 6000);

    // ─── Hazard badge counts: fetch on boot (no map needed) ───
    // Also prefetch full fire + quake GeoJSON so map init is fast
    // Stagger hazard prefetches to avoid saturating connections
    function _prefetchFire(){
      fetch('https://services9.arcgis.com/RHVPKKiFTONKtxq3/arcgis/rest/services/USA_Wildfires_v1/FeatureServer/0/query?where=1%3D1&outFields=*&outSR=4326&f=geojson')
        .then(function(r){ return r.json(); })
        .then(function(d){
          if(d && d.features){
            window._prefetchedNIFC = d;
            SH.ok('nifc');
            var el = document.getElementById('hazard-badge-fire');
            if(el){ el.textContent = d.features.length.toLocaleString(); el.style.display = 'inline-flex'; }
            if (!window._activeFires || window._activeFires.length === 0) {
              var fires = d.features || [];
              fires.forEach(function(f){ if(f.properties) f.properties._country = 'US'; });
              window._activeFires = fires;
            }
            function tryPrecomputeSmoke(){
              if(window._wxCurrent && window._wxHourly && window._wxNearestIdx != null && window._activeFires && window._activeFires.length > 0){
                try { buildSmokeIntelligence(); } catch(e){}
              }
            }
            tryPrecomputeSmoke();
            setTimeout(tryPrecomputeSmoke, 3000);
            setTimeout(tryPrecomputeSmoke, 6000);
          }
          // Chain: Canadian fires after US fires complete
          _prefetchCanadianFire();
        }).catch(function(){ _prefetchCanadianFire(); });
    }

    function _prefetchCanadianFire(){
      fetch('https://cwfis.cfs.nrcan.gc.ca/geoserver/public/wfs?service=WFS&version=1.1.0&request=GetFeature&typeName=public:activefires_current&outputFormat=application/json&maxFeatures=5000')
        .then(function(r){ return r.json(); })
        .then(function(data){
          if(!data || !data.features || !window._activeFires) return;
          var added = 0;
          data.features.forEach(function(f){
            var props = f.properties || {};
            var lat = parseFloat(props.lat), lon = parseFloat(props.lon);
            if(isNaN(lat) || isNaN(lon)) return;
            if(props.agency === 'conus') return;
            var status = props.stage_of_control || '';
            if(status === 'EX' || status === 'Out') return;
            window._activeFires.push({
              type:'Feature', geometry:{type:'Point',coordinates:[lon,lat]},
              properties:{_country:'CA',
                _name:(props.firename||'Unknown')+(props.agency?' ('+props.agency.toUpperCase()+')':''),
                _acres:parseFloat(props.hectares)||0, _unit:'ha',
                IncidentName:props.firename||'Unknown',
                DailyAcres:Math.round((parseFloat(props.hectares)||0)*2.471),
                GISAcres:Math.round((parseFloat(props.hectares)||0)*2.471),
                PercentContained:status==='UC'?90:status==='BH'?50:0}
            });
            added++;
          });
          if(added){
            var el = document.getElementById('hazard-badge-fire');
            if(el){ el.textContent = (window._activeFires||[]).filter(function(x){return x&&x.properties&&x.properties._country!=='SAT';}).length.toLocaleString(); el.style.display = 'inline-flex'; }
          }
        }).catch(function(){});
    }

    function _prefetchQuakes(){
      fetch('https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/all_day.geojson')
        .then(function(r){ return r.json(); })
        .then(function(d){
          if(d && d.features){
            window._prefetchedQuakes = d;
            SH.ok('usgs-eq');
            var el = document.getElementById('hazard-badge-quake');
            if(el){ el.textContent = d.features.length.toLocaleString(); el.style.display = 'inline-flex'; }
            window._quakeFeatures = d.features;
          }
        }).catch(function(){});
    }

    function _prefetchTornado(){
      fetch('https://www.spc.noaa.gov/climo/reports/today_torn.csv')
        .then(function(r){ return r.text(); })
        .then(function(t){
          var lines = t.trim().split('\n');
          var count = Math.max(0, lines.length - 1);
          window._prefetchedTornCSV = t;
          var el = document.getElementById('hazard-badge-tornado');
          if(el && count > 0){ el.textContent = count.toLocaleString(); el.style.display = 'inline-flex'; }
          window._tornadoCount = count;
          if(count > 0){
            var locs = [];
            for(var li = 1; li < lines.length && locs.length < 3; li++){
              var cols = lines[li].split(',');
              if(cols.length >= 5){
                var loc = (cols[2]||'').trim();
                var st = (cols[4]||'').trim();
                if(loc || st) locs.push(loc + (st ? ', '+st : ''));
              }
            }
            window._tornadoLocations = locs;
          }
        }).catch(function(){});
    }

    function _prefetchFlood(){
      fetch('https://api.allorigins.win/get?url='+encodeURIComponent('https://water.noaa.gov/resources/data/hml/hml_observed_water_level_data_geojson_above_action.geojson'))
        .then(function(r){ return r.json(); })
        .then(function(w){ return JSON.parse(w.contents); })
        .then(function(d){
          if(d && d.features){
            window._prefetchedFlood = d;
            var el = document.getElementById('hazard-badge-flood');
            if(el && d.features.length > 0){ el.textContent = d.features.length.toLocaleString(); el.style.display = 'inline-flex'; }
            window._floodGaugesAboveNormal = d.features.length;
          }
        }).catch(function(){});
    }

    // Stagger: 2 at boot, then 2 more after 1.5s, last after 3s
    setTimeout(function(){ _prefetchFire(); _prefetchTornado(); }, 1500);
    setTimeout(function(){ _prefetchQuakes(); _prefetchFlood(); }, 3000);

    // ─── AUTO-REVEAL SPACE WIDGETS: stagger after critical path ───
    // Remove covers and init space widgets automatically so they load
    // without user interaction. Staggered to avoid saturating connections.
    (function autoRevealSpace(){
      var spaceWidgets = ['pfss','suvi','lasco2','lasco3','enlil','aurora','geospace'];
      var delay = 4000; // start 4s after boot (weather + GOES loaded)
      var stagger = 1200; // 1.2s between each widget
      
      spaceWidgets.forEach(function(section, i){
        setTimeout(function(){
          if (window._revealedSections[section]) return; // already revealed by user click
          var cover = document.querySelector('.widget-cover[data-cover="' + section + '"]');
          if (cover) {
            window._revealWidget(section, cover);
          }
        }, delay + i * stagger);
      });
    })();

    // ─── Hazard widget: click ANYWHERE on it to init ───
    (function(){
      var hw = document.getElementById('hazard-widget');
      if (!hw) return;
      function initHazardOnClick(){
        if (window._hazardInited) return;
        window._hazardInited = true;
        hw.removeEventListener('click', initHazardOnClick, true);
        // Keep preview visible behind map until tiles load
        var prev = document.getElementById('hazard-preview-img');
        // Init the map
        try { initUnifiedHazardMap(); } catch(e){ console.error('hazard init', e); }
        setTimeout(function(){ try { initGeologyMaps(); } catch(e){} }, 200);
        // Show overlay controls now that map is active
        var fireOv = document.getElementById('hazard-fire-overlays');
        if (fireOv) fireOv.style.display = '';
        // Dismiss the scroll guard now that the map exists
        var guard = document.getElementById('hazard-scroll-guard');
        if (guard) guard.classList.remove('visible');
      }
      hw.addEventListener('click', initHazardOnClick, true);
    })();

    // ─── REFRESH INTERVALS (set up once, not duplicated) ───
    setInterval(updateSolarMini, 5 * 60 * 1000);
    setInterval(loadAirQuality, 15 * 60 * 1000);
    setInterval(loadPollen, 15 * 60 * 1000);
    setInterval(loadWeatherAlerts, 5 * 60 * 1000);
    setInterval(function(){ if (tornadoMap && hazardActiveTab === 'tornado') loadTornadoReports(); }, 10 * 60 * 1000);

    // ─── SOURCE HEALTH: Register all data sources ───
    // HAZARDS widget
    SH.register('nifc', 'NIFC Wildfires', 'hazard');
    SH.register('firms', 'NASA FIRMS', 'hazard');
    SH.register('usgs-eq', 'USGS Earthquakes', 'hazard');
    SH.register('spc-reports', 'SPC Storm Reports', 'hazard');
    SH.register('ahps', 'AHPS River Gauges', 'hazard');
    SH.register('usgs-water', 'USGS Water Services', 'hazard');
    SH.register('blitz', 'Blitzortung Lightning', 'hazard');
    SH.register('wpc-ero', 'WPC Excessive Rainfall', 'hazard');
    SH.register('macrostrat', 'Macrostrat Geology', 'hazard');
    SH.register('epa', 'EPA Toxics', 'hazard');
    SH.setLiveTag('hazard', 'hazard-live');

    // SPACE widget sources — each LIVE tag gets its own widget group
    SH.register('swpc-geo-vel', 'Geospace Velocity', 'geospace');
    SH.register('swpc-geo-den', 'Geospace Density', 'geospace');
    SH.register('swpc-geo-pre', 'Geospace Pressure', 'geospace');
    SH.setLiveTag('geospace', 'geo-vel-live');

    // SWPC plasma/xray/kp report health via geospace and periodic scanner
    // (no dedicated LIVE tag for the solar mini bar)

    SH.register('sdo', 'SDO Solar Imagery', 'pfss');
    SH.register('swpc-pfss', 'PFSS Mag Field', 'pfss');
    SH.setLiveTag('pfss', 'pfss-live');

    SH.register('swpc-suvi', 'SUVI Thematic', 'suvi');
    SH.setLiveTag('suvi', 'suvi-map-live');

    SH.register('soho-c2', 'SOHO LASCO C2', 'lasco-c2');
    SH.setLiveTag('lasco-c2', 'lasco-c2-live');

    SH.register('soho-c3', 'SOHO LASCO C3', 'lasco-c3');
    SH.setLiveTag('lasco-c3', 'lasco-c3-live');

    SH.register('swpc-enlil', 'ENLIL Solar Wind', 'enlil');
    SH.setLiveTag('enlil', 'enlil-live');

    SH.register('swpc-aurora', 'Aurora Forecast', 'aurora');
    SH.setLiveTag('aurora', 'aurora-live');

    // CLOUDS/RADAR widget
    SH.register('goes', 'GOES Satellite', 'clouds');
    SH.register('rainviewer', 'RainViewer Radar', 'clouds');
    SH.register('nws-radar', 'NWS MRMS Radar', 'clouds');
    SH.setLiveTag('clouds', 'goes-live');

    // Wire LIVE tags to be clickable
    setTimeout(function(){
      var tagMap = {
        'hazard-live': 'hazard',
        'goes-live': 'clouds',
        'pfss-live': 'pfss',
        'suvi-map-live': 'suvi',
        'lasco-c2-live': 'lasco-c2',
        'lasco-c3-live': 'lasco-c3',
        'enlil-live': 'enlil',
        'aurora-live': 'aurora',
        'geo-vel-live': 'geospace'
      };
      Object.keys(tagMap).forEach(function(tagId){
        var tag = document.getElementById(tagId);
        if (!tag) return;
        tag.setAttribute('data-health', 'ok');
        tag.style.cursor = 'pointer';
        tag.addEventListener('click', function(e){
          e.stopPropagation();
          toggleHealthDisplay(tag, tagMap[tagId]);
        });
      });

      // Mark on-demand sources as idle (not pending) 
      ['macrostrat','epa','blitz','wpc-ero','rainviewer','nws-radar'].forEach(function(id){
        var s = SH.sources[id];
        if (s && s.status === 'pending') { s.status = 'ok'; s.lastOk = Date.now(); }
      });
      // Update all widget health indicators
      Object.keys(SH.widgets).forEach(function(wid){ SH._updateWidget(wid); });
    }, 2000);

    // Periodic health scan — checks global data existence to auto-mark sources
    setInterval(function(){
      if (window._activeFires && window._activeFires.length > 0) SH.ok('nifc');
      if (window._swData && window._swData.speed != null) SH.ok('swpc-plasma');
      if (window._swData && window._swData.kp != null) SH.ok('swpc-kp');
      if (window._swData && window._swData.xrayClass) SH.ok('swpc-xray');
    }, 30000);
  }

  // ============ WIDGET COVER REVEAL SYSTEM ============
  // Each widget has its own cover. Click removes only THAT cover and inits that widget.
  window._revealedSections = {};
  window._revealWidget = function(section, coverEl){
    // Remove only THIS cover
    coverEl.classList.add('removing');
    setTimeout(function(){
      if (coverEl.parentNode) coverEl.parentNode.removeChild(coverEl);
    }, 450);

    // Don't init twice
    if (window._revealedSections[section]) return;
    window._revealedSections[section] = true;

    // Run the init for this specific widget
    switch(section){
      case 'goes':
        try { startGoesAutoplay(); } catch(e){}
        try { initGfsWidget(); } catch(e){}
        try { initFcastWidgets(); } catch(e){}
        try { initNationalRadarMap(); } catch(e){}
        break;
      case 'hazard':
        try { initUnifiedHazardMap(); } catch(e){}
        setTimeout(function(){
          try { initGeologyMaps(); } catch(e){}
        }, 200);
        break;
      case 'pfss':
        try { initPfss(); } catch(e){}
        break;
      case 'suvi':
        try { initSuviMap(); } catch(e){}
        break;
      case 'lasco2':
      case 'lasco3':
        // LASCO images are loaded by initSpaceWeatherAnimations
        if (!window._revealedSections._spaceAnim){
          window._revealedSections._spaceAnim = true;
          try { initSpaceWeatherAnimations(); } catch(e){}
        }
        break;
      case 'enlil':
        // Enlil loaded by initSpaceWeatherAnimations
        if (!window._revealedSections._spaceAnim){
          window._revealedSections._spaceAnim = true;
          try { initSpaceWeatherAnimations(); } catch(e){}
        }
        break;
      case 'aurora':
        try { startAuroraBlackBackground(); } catch(e){}
        try { updateSolarMini(); } catch(e){}
        break;
      case 'geospace':
        // Geospace loaded by initSpaceWeatherAnimations
        if (!window._revealedSections._spaceAnim){
          window._revealedSections._spaceAnim = true;
          try { initSpaceWeatherAnimations(); } catch(e){}
        }
        break;
    }
  };

  // ============ TAB VISIBILITY — GLOBAL SLEEP/WAKE ============
  // When user switches to another browser tab, pause all animations and
  // network-hitting intervals. Resume when they return. This prevents
  // wasted CPU and bandwidth when the page isn't visible.
  // ============ SCROLL PERFORMANCE: DISABLE BACKDROP-FILTER DURING SCROLL ============
  // backdrop-filter:blur() on 20+ widgets forces the browser to re-composite
  // a blur effect for each one on every scroll frame. This is the #1 cause of
  // scroll jank. We add .scroll-active to <html> during scroll (kills all blurs
  // via CSS) and remove it 150ms after scroll stops.
  (function initScrollPerf(){
    var scrollTimer = null;
    var htmlEl = document.documentElement;
    window.addEventListener('scroll', function(){
      if (!scrollTimer) {
        htmlEl.classList.add('scroll-active');
      } else {
        clearTimeout(scrollTimer);
      }
      scrollTimer = setTimeout(function(){
        htmlEl.classList.remove('scroll-active');
        scrollTimer = null;
      }, 150);
    }, {passive: true});
  })();

  (function initTabVisibility(){
    var tabSleeping = false;
    var savedTimers = {};

    document.addEventListener('visibilitychange', function(){
      if (document.hidden && !tabSleeping) {
        tabSleeping = true;
        // Pause GOES animation
        if (typeof goesAnimId !== 'undefined' && goesAnimId) {
          cancelAnimationFrame(goesAnimId); savedTimers.goesAnimId = goesAnimId; goesAnimId = null;
        }
        // Pause smoke animation
        if (typeof _smokeAnimFrame !== 'undefined' && _smokeAnimFrame) {
          cancelAnimationFrame(_smokeAnimFrame); savedTimers.smokeAnim = true; _smokeAnimFrame = null;
        }
        // Pause aurora
        if (typeof auroraAnim !== 'undefined' && auroraAnim.timer) {
          clearTimeout(auroraAnim.timer); auroraAnim.timer = null; savedTimers.aurora = true;
        }
        // Pause SUVI
        if (typeof suviMapAnim !== 'undefined' && suviMapAnim.timer) {
          clearTimeout(suviMapAnim.timer); suviMapAnim.timer = null; savedTimers.suvi = true;
        }
        // Pause national radar loop + refresh
        if (typeof nationalRadarTimer !== 'undefined' && nationalRadarTimer) {
          clearTimeout(nationalRadarTimer); nationalRadarTimer = null; savedTimers.natRadar = true;
        }
        if (typeof nationalRadarRefreshTimer !== 'undefined' && nationalRadarRefreshTimer) {
          clearInterval(nationalRadarRefreshTimer); nationalRadarRefreshTimer = null; savedTimers.natRadarRefresh = true;
        }
        // Pause local radar + hydrometeor refresh
        if (typeof radarRefreshTimer !== 'undefined' && radarRefreshTimer) {
          clearInterval(radarRefreshTimer); radarRefreshTimer = null; savedTimers.localRadar = true;
        }
        if (typeof hydroRefreshTimer !== 'undefined' && hydroRefreshTimer) {
          clearInterval(hydroRefreshTimer); hydroRefreshTimer = null; savedTimers.hydro = true;
        }
        // Pause GFS playback
        if (typeof gfsState !== 'undefined' && gfsState.playTimer) {
          clearInterval(gfsState.playTimer); gfsState.playTimer = null; savedTimers.gfs = true;
        }
        // Pause forecast playback
        if (typeof fcastState !== 'undefined' && fcastState.timer) {
          clearInterval(fcastState.timer); fcastState.timer = null; fcastState.playing = false; savedTimers.fcast = true;
        }
      } else if (!document.hidden && tabSleeping) {
        tabSleeping = false;
        // Resume GOES
        if (savedTimers.goesAnimId && typeof startGoesAutoplay !== 'undefined') {
          try { if (typeof goesImages !== 'undefined' && goesImages.length > 0) startGoesAutoplay(); } catch(e){}
        }
        // Resume smoke
        if (savedTimers.smokeAnim && typeof startSmokeAnimation !== 'undefined') {
          try { if (typeof _smokeTransportVisible !== 'undefined' && _smokeTransportVisible) startSmokeAnimation(); } catch(e){}
        }
        // Resume aurora
        if (savedTimers.aurora && typeof startAuroraAnimation !== 'undefined') {
          try { startAuroraAnimation(); } catch(e){}
        }
        // Resume national radar loop + refresh
        if (savedTimers.natRadar && typeof startNationalRadarLoop !== 'undefined') {
          try { startNationalRadarLoop(); } catch(e){}
        }
        if (savedTimers.natRadarRefresh && typeof loadNationalRadarFrames !== 'undefined') {
          try { if(nationalRadarRefreshTimer) clearInterval(nationalRadarRefreshTimer); nationalRadarRefreshTimer = setInterval(loadNationalRadarFrames, 5 * 60 * 1000); } catch(e){}
        }
        // Resume local radar + hydrometeor refresh
        if (savedTimers.localRadar) {
          try {
            if(radarRefreshTimer) clearInterval(radarRefreshTimer);
            var radarImg = document.getElementById("radar-img");
            if (radarImg) {
              radarRefreshTimer = setInterval(function(){
                radarImg.src = radarImg.src.replace(/\?cb=\d+/, '?cb=' + Date.now());
              }, 2 * 60 * 1000);
            }
          } catch(e){}
        }
        if (savedTimers.hydro && typeof loadHydrometeorImage !== 'undefined') {
          try { if(hydroRefreshTimer) clearInterval(hydroRefreshTimer); hydroRefreshTimer = setInterval(loadHydrometeorImage, 5 * 60 * 1000); } catch(e){}
        }
        // Resume GFS
        if (savedTimers.gfs && typeof gfsTogglePlay !== 'undefined') {
          try { if (typeof gfsState !== 'undefined' && gfsState.playing) gfsTogglePlay(); } catch(e){}
        }
        // Resume forecast
        if (savedTimers.fcast && typeof fcastRadarTogglePlay !== 'undefined') {
          try { if (typeof fcastState !== 'undefined' && fcastState.playing) fcastRadarTogglePlay(); } catch(e){}
        }
        savedTimers = {};
      }
    });
  })();

  // ============ WIDGET SLEEP/WAKE SYSTEM ============
  // Uses IntersectionObserver to pause animations and heavy processing
  // for widgets that are scrolled off-screen. Resumes when they scroll back.
  // This eliminates the #1 cause of scroll jank: heavy widgets running
  // rAF loops, tile loads, and data refreshes while invisible.
  (function initWidgetSleepWake(){
    if (!window.IntersectionObserver) return; // IE11 fallback: everything stays awake

    // Debounce map: prevents rapid sleep/wake thrashing during fast scroll
    var wakeTimers = {};

    // Sleep/wake handlers for each widget zone
    var zones = {
      // GOES satellite / radar — has rAF loop + canvas drawing
      // Instead of cancelling rAF (causes restart lag), set a flag to skip drawing
