        "rgba(" + midBlueR + "," + midBlueG + "," + midBlueB + "," + midBlueOp + ") " + (midday - 3).toFixed(1) + "%, " +
        "rgba(" + midBlueR + "," + midBlueG + "," + midBlueB + "," + midBlueOp + ") " + (midday + 3).toFixed(1) + "%, " +
