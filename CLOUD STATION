          var rowMoonBg = (window._moonPreload && window._moonPreload.loaded) ? "url('" + window._moonPreload.url + "') center/150%" : "radial-gradient(circle at 40% 40%,#c8c4b8,#888478,#3a3830)";
          planetsHtml += '<div class="today-tl-planet-indicator" id="today-tl-row-moon-dot" style="background:'+rowMoonBg+';box-shadow:0 0 4px rgba(200,210,230,.4);"></div>';
