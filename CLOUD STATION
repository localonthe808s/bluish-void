          var spdCol  = sw.speed > 700 ? '#ff9900' : sw.speed > 500 ? '#e8c060' : '#88aaff';
          h += '<div style="font-size:10px;color:'+spdCol+';font-weight:700;margin-top:-2px;">' + sw.speed + ' km/s \u00b7 ' + spdLabel + '</div>';
        } else {
          h += '<div style="display:flex;justify-content:space-between;align-items:baseline;font-size:10px;color:rgba(43,34,244,.45);margin:6px 0;"><span>WIND SPEED</span><span>Loading\u2026</span></div>';
        }
        // Bz
        if (sw.bz != null) {
          h += '<div style="margin-top:8px;">' + bzBar(sw.bz) + '</div>';
          var bzVal = (sw.bz >= 0 ? '+' : '') + sw.bz.toFixed(1) + ' nT';
          var bzWord = sw.bz < -10 ? 'Strong south \u00b7 aurora-favorable'
                     : sw.bz < -3 ? 'South \u00b7 favorable'
                     : sw.bz > 3  ? 'North \u00b7 suppressing'
                     : 'Neutral';
          var bzCol = sw.bz < -3 ? '#1a8a4a' : sw.bz > 3 ? '#3344cc' : 'rgba(43,34,244,.55)';
          h += '<div style="font-size:10px;color:' + bzCol + ';font-weight:700;margin-top:-2px;">' + bzVal + ' \u00b7 ' + bzWord + '</div>';
        } else {
          h += '<div style="display:flex;justify-content:space-between;align-items:baseline;font-size:10px;color:rgba(43,34,244,.45);margin:8px 0 6px;"><span>IMF Bz</span><span>Loading\u2026</span></div>';
        }
        // Density + Bt + flare class kept compact as text rows
        var compactRows = '';
        if (sw.density != null) compactRows += gL('Density', sw.density.toFixed(1) + ' p/cm\u00b3');
        if (sw.bt != null) compactRows += gL('IMF Bt', sw.bt.toFixed(1) + ' nT total');
        if (sw.xrayClass) {
          var flareCol = sw.xrayClass.charAt(0) === 'X' ? '#ff3300'
                        : sw.xrayClass.charAt(0) === 'M' ? '#ff9900'
                        : sw.xrayClass.charAt(0) === 'C' ? '#cc8800'
                        : 'rgba(43,34,244,.5)';
          var flareNote = sw.xrayClass.charAt(0) === 'X' ? ' \u00b7 Major flare'
                         : sw.xrayClass.charAt(0) === 'M' ? ' \u00b7 Moderate'
                         : sw.xrayClass.charAt(0) === 'C' ? ' \u00b7 Minor'
                         : '';
          compactRows += gL('Solar X-ray', '<span style="color:' + flareCol + ';font-weight:700;">' + sw.xrayClass + '</span>' + flareNote);
        }
        if (compactRows) h += compactRows;
        // Footnote when nothing loaded \u2014 clarifies the section isn't broken
        if (sw.speed == null && sw.bz == null && sw.density == null && sw.bt == null && !sw.xrayClass) {
          h += '<div style="font-size:9px;color:rgba(43,34,244,.4);margin-top:4px;font-style:italic;">Real-time data fetched from NOAA SWPC every few minutes \u2014 refresh in a moment if still loading.</div>';
        }

        // \u2500\u2500 NOW: Aurora Visibility \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
        // Polar mini-map shows the auroral oval ring + user's latitude;
        // the linear bar below gives a precise readout of where you are
        // vs the visibility threshold.
        h += FS('Aurora Visibility');
        var auroraLat = 67;
        if (currentKp >= 9) auroraLat = 30;
        else if (currentKp >= 8) auroraLat = 35;
        else if (currentKp >= 7) auroraLat = 40;
        else if (currentKp >= 6) auroraLat = 45;
        else if (currentKp >= 5) auroraLat = 50;
        else if (currentKp >= 4) auroraLat = 55;
        else if (currentKp >= 3) auroraLat = 60;
        h += auroraOvalMap(LOCATION.lat, auroraLat, currentKp);
        h += latitudeBar(LOCATION.lat, auroraLat);
        var canSeeAurora = LOCATION.lat >= auroraLat;
        // Compass + caption \u2014 shown only when aurora is visible
        if (canSeeAurora) {
          h += lookCompass(LOCATION.lat, auroraLat);
          h += '<div style="font-size:11px;padding:6px 9px;background:rgba(26,138,74,.06);border-radius:6px;margin-top:4px;color:#1a8a4a;">\u2705 Aurora potentially visible during dark hours. Get away from light pollution.</div>';
        } else {
          h += '<div style="font-size:11px;padding:6px 9px;background:rgba(43,34,244,.04);border-radius:6px;margin-top:6px;color:rgba(43,34,244,.5);">\u274c Aurora unlikely at this Kp. Need Kp ' + Math.ceil(9 - (LOCATION.lat - 30) / 4.5) + '+ for visibility from your latitude.</div>';
        }

        // \u2500\u2500 NOW: Tonight's Conditions \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
        // Cloud cover at user location + moon brightness. Both data
        // sources are best-effort; moon falls back to the
        // approximateMoonPhase calculation when _moonPhase isn't set.
        var moonIllum = null, moonIcon = '', moonName = '';
        var _moonPhaseVal = (window._moonPhase != null) ? window._moonPhase
                          : (typeof approximateMoonPhase === 'function' ? approximateMoonPhase(new Date()) : null);
        if (_moonPhaseVal != null && typeof moonInfo === 'function') {
          var _miInfo = moonInfo(_moonPhaseVal);
          if (_miInfo) { moonIllum = _miInfo.illum; moonIcon = _miInfo.icon; moonName = _miInfo.name; }
        }
        var nowCloud = null;
        if (window._wxCurrent && window._wxCurrent.cloudCover != null) nowCloud = window._wxCurrent.cloudCover;
        if (moonIllum != null || nowCloud != null) {
          h += FS("Tonight's Conditions");
          if (nowCloud != null) {
            var cloudCol = nowCloud < 30 ? '#1a8a4a' : nowCloud < 60 ? '#cc8800' : '#cc4422';
            var cloudLab = nowCloud < 30 ? 'Clear sky' : nowCloud < 60 ? 'Partly cloudy' : 'Overcast \u2014 clouds will block aurora';
            h += gL('Cloud cover', '<span style="color:' + cloudCol + ';">' + nowCloud + '% \u00b7 ' + cloudLab + '</span>');
          }
          if (moonIllum != null) {
            var moonCol = moonIllum < 25 ? '#1a8a4a' : moonIllum < 60 ? '#cc8800' : '#cc4422';
            var moonLab = moonIllum < 25 ? 'Dark \u2014 ideal' : moonIllum < 60 ? 'Some moonlight' : 'Bright moon \u2014 washes faint aurora';
            h += gL('Moon', '<span style="color:' + moonCol + ';">' + (moonIcon ? moonIcon + ' ' : '') + Math.round(moonIllum) + '% \u00b7 ' + moonLab + '</span>');
          }
        }

        // \u2500\u2500 NOW: 24-Hour Outlook (was the FORECAST tab) \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
        // Sparkline replaces the Range/Peak text rows.
        if (kpData && kpData.length > 1) {
          h += FS('24-Hour Outlook');
          h += forecastSparkline(kpData);
          var maxKp = 0, minKp = 9;
          kpData.forEach(function(k) { if (k.kp > maxKp) maxKp = k.kp; if (k.kp < minKp) minKp = k.kp; });
          var stormHours = kpData.filter(function(k){ return k.kp >= 5; }).length;
          var rangeStr = 'Kp ' + minKp.toFixed(1) + ' \u2013 ' + maxKp.toFixed(1) + ' \u00b7 peak ' + maxKp.toFixed(1);
          if (stormHours > 0) rangeStr += ' \u00b7 <span style="color:#ff9900;">' + stormHours + ' G1+ periods</span>';
          h += '<div style="font-size:10px;color:rgba(43,34,244,.6);margin-top:2px;">' + rangeStr + '</div>';
        }

        // \u2500\u2500 INFO: Impact on Observing \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
        h += FS('Impact on Observing');
        if (currentKp < 3) h += '<div style="' + infoTextStyle + '">\u2705 No geomagnetic impact on observing. Skies unaffected by aurora.</div>';
        else if (currentKp < 5) h += '<div style="' + infoTextStyle + '">\u26a0\ufe0f Slight increase in airglow may reduce contrast on faint targets at high latitudes. Good for aurora photography!</div>';
        else h += '<div style="' + infoTextStyle + '">\u26a0\ufe0f Active aurora can wash out faint deep-sky targets in northern sky. Shift targets to southern sky. GREAT for aurora photography and visual observation!</div>';

        // \u2500\u2500 INFO: G-Scale Reference \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
        // Visual cards highlight the current level (any G with Kp \u2264 current
        // is shown active).
        h += FS('G-Scale Reference');
        h += gScaleCards(currentKp);

        // \u2500\u2500 INFO: Aurora Colors Guide \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
        h += FS('Aurora Colors');
        h += '<div style="' + infoTextStyle + '">' +
          '<span style="color:#1a8a4a;font-weight:700;">Green</span> \u2014 most common, oxygen at ~100 km altitude. The dominant aurora color naked-eye.<br>' +
          '<span style="color:#cc3344;font-weight:700;">Red</span> \u2014 rare, oxygen at 200+ km during strong storms (Kp \u2265 6). Often appears <em>above</em> green curtains.<br>' +
          '<span style="color:#7744cc;font-weight:700;">Blue / Violet</span> \u2014 nitrogen (ionized N\u2082\u207a), only during very intense activity. Often along the leading edge of curtains.<br>' +
          '<span style="color:#cc6688;font-weight:700;">Pink</span> \u2014 bottom edge of curtains where green oxygen mixes with blue/violet nitrogen.' +
        '</div>';

        // \u2500\u2500 INFO: Photography Tips \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
        h += FS('Photography Tips');
        h += '<div style="' + infoTextStyle + '">' +
          '<b>Camera</b> \u2014 full manual mode. ISO 1600\u20133200, aperture f/2.8 or faster, shutter 5\u201320 s.<br>' +
          '<b>Focus</b> \u2014 manual focus to infinity (autofocus fails in dark). Test on a bright star first.<br>' +
          '<b>White balance</b> \u2014 3500\u20134000 K to keep greens true (auto WB shifts toward magenta).<br>' +
          '<b>Stability</b> \u2014 tripod required; use 2-second timer or remote shutter to avoid shake.<br>' +
          '<b>Composition</b> \u2014 include foreground (trees, water reflection, mountain) for scale.' +
        '</div>';

        // \u2500\u2500 INFO: Understanding Kp \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
        h += FS('Understanding Kp');
        h += '<div style="' + infoTextStyle + '">The <b>Kp index</b> measures global geomagnetic disturbance on a 0\u20139 scale. It is derived from ground-based magnetometers every 3 hours. Values \u22655 indicate geomagnetic storms (G1\u2013G5). The primary driver is the <b>solar wind</b> \u2014 coronal mass ejections (CMEs) and high-speed streams from coronal holes. When the interplanetary magnetic field (IMF) turns <b>southward</b> (negative Bz), it couples with Earth\'s magnetic field and energizes particles into the auroral oval. The more negative Bz and the longer it stays south, the more intense the aurora.</div>';

        // liveStats \u2014 replaces the inline "Kp 3.0 Unsettled" header with
        // the modern hero strip used by all other planet/weather popups.
        var _kpPeakStr = '';
        if (kpData && kpData.length > 1) {
          var _peakKp = 0;
          kpData.forEach(function(k){ if (k.kp > _peakKp) _peakKp = k.kp; });
          _kpPeakStr = 'Kp ' + _peakKp.toFixed(1);
        }
        var _kpLive =
          '<div><span>KP</span><span>' + currentKp.toFixed(1) + ' \u00b7 ' + geoLabel + '</span></div>' +
          '<div><span>YOUR LAT</span><span>' + LOCATION.lat.toFixed(1) + '\u00b0N</span></div>' +
          '<div><span>VISIBLE</span><span>~' + auroraLat + '\u00b0N</span></div>' +
          (_kpPeakStr ? '<div><span>24H PEAK</span><span>' + _kpPeakStr + '</span></div>' : '');

        window._openInsightModal({
          title: 'Geomagnetic Activity',
          subtitle: 'Kp index \u00b7 Aurora \u00b7 Storm impact',
          liveStats: _kpLive,
          h: h,
          tabDefs: [
            { id:'now',  label:'NOW'  },
            { id:'info', label:'INFO' }
          ],
          tabMap: function(title) {
            var s = (title || '').toLowerCase();
            // INFO: educational/reference content
            if (/impact|understanding|g-scale|colors|photography/.test(s)) return 1;
            // NOW: everything live (conditions, solar wind, visibility,
            // tonight, 24h outlook)
            return 0;
          },
          footer: 'NOAA SWPC \u00b7 Wing Kp model \u00b7 ACE/DSCOVR \u00b7 GOES X-ray'
        });
      };
      // Show current Kp value in bar label
      var kpValEl = document.getElementById("today-tl-kp-val");
      if (kpValEl && kpData && kpData.length > 0) {
        var nowT = Date.now();
        var closestKp = kpData[0];
        for (var ck = 0; ck < kpData.length; ck++) {
          if (kpData[ck].t.getTime() <= nowT) closestKp = kpData[ck];
        }
        kpValEl.textContent = closestKp.kp.toFixed(1);

        // ── KP LEGEND MARKERS ──
        // Add "NOW" marker and "AURORA" threshold marker on the Kp 0-9 legend
        var kpLegend = document.getElementById('today-tl-kp-legend');
        if (kpLegend) {
          // Remove old markers
          var oldMarkers = kpLegend.querySelectorAll('.kp-legend-marker');
          oldMarkers.forEach(function(m){ m.remove(); });

          // The legend has: span("Kp 0"), 10 boxes (indices 0-9), span("9")
          // Each box = one Kp unit. We need to position markers relative to boxes.
          var boxes = kpLegend.querySelectorAll('.today-tl-kp-box');
          if (boxes.length === 10) {
            var legendRect = kpLegend.getBoundingClientRect();
            var firstBox = boxes[0].getBoundingClientRect();
            var lastBox = boxes[9].getBoundingClientRect();
            var scaleLeft = firstBox.left - legendRect.left;
            var scaleWidth = (lastBox.left + lastBox.width) - firstBox.left;

            // Current Kp position (0-9 mapped across scale)
            var curKpVal = closestKp.kp;
            var curPct = (curKpVal / 9) * scaleWidth;
            var nowMarker = document.createElement('div');
            nowMarker.className = 'kp-legend-marker';
            nowMarker.style.cssText = 'position:absolute;left:'+(scaleLeft + curPct)+'px;top:4px;height:24px;width:2px;background:#fff;border-radius:1px;z-index:5;box-shadow:0 0 6px rgba(255,255,255,.9),0 0 12px rgba(255,255,255,.5);pointer-events:none;';
            // Label above
            var nowLabel = document.createElement('div');
            nowLabel.className = 'kp-legend-marker';
            nowLabel.style.cssText = 'position:absolute;left:'+(scaleLeft + curPct)+'px;top:-10px;transform:translateX(-50%);font-size:6.5px;font-weight:800;color:#fff;text-shadow:0 0 4px rgba(255,255,255,.8);white-space:nowrap;pointer-events:none;letter-spacing:.4px;';
            nowLabel.textContent = 'NOW';
            kpLegend.appendChild(nowMarker);
            kpLegend.appendChild(nowLabel);

            // Aurora threshold for user's latitude
            // Rough Kp needed: higher lat = lower Kp needed
            var lat = LOCATION.lat;
            var auroraKp = 9; // default very high
            if (lat >= 67) auroraKp = 0;
            else if (lat >= 60) auroraKp = 3;
            else if (lat >= 55) auroraKp = 4;
            else if (lat >= 50) auroraKp = 5;
            else if (lat >= 45) auroraKp = 6;
            else if (lat >= 40) auroraKp = 7;
            else if (lat >= 35) auroraKp = 8;
            else if (lat >= 30) auroraKp = 9;

            if (auroraKp <= 9) {
              var aurPct = (auroraKp / 9) * scaleWidth;
              var aurMarker = document.createElement('div');
              aurMarker.className = 'kp-legend-marker';
              aurMarker.style.cssText = 'position:absolute;left:'+(scaleLeft + aurPct)+'px;top:4px;height:24px;width:2px;background:#fff;border-radius:1px;z-index:5;box-shadow:0 0 6px rgba(255,255,255,.9),0 0 12px rgba(255,255,255,.5);pointer-events:none;';
              // Label above (matching NOW style)
              var aurLabel = document.createElement('div');
              aurLabel.className = 'kp-legend-marker';
              aurLabel.style.cssText = 'position:absolute;left:'+(scaleLeft + aurPct)+'px;top:-10px;transform:translateX(-50%);font-size:6.5px;font-weight:800;color:#fff;text-shadow:0 0 4px rgba(255,255,255,.8);white-space:nowrap;pointer-events:none;letter-spacing:.4px;';
              aurLabel.textContent = '✦ AURORA';
              kpLegend.appendChild(aurMarker);
              kpLegend.appendChild(aurLabel);
            }
          }
        }
      }
    }

    // Render cloud track — triple-layer (High / Mid / Low)
    if (tlCloudTrack && hourly && hourly.cloudcover){
      var hoursPerSegment = isMobile ? 2 : 1;
      var hasLayers = hourly.cloud_cover_low && hourly.cloud_cover_mid && hourly.cloud_cover_high;

      // Build segment data at finer resolution
      var cloudSegments = [];
      for (var h = 0; h < 24; h += hoursPerSegment){
        var segStart = new Date(dayLocal.getFullYear(), dayLocal.getMonth(), dayLocal.getDate(), h, 0, 0, 0);
        var segEnd = new Date(dayLocal.getFullYear(), dayLocal.getMonth(), dayLocal.getDate(), h + hoursPerSegment, 0, 0, 0);
        var sT=0,sL=0,sM=0,sH=0,cnt=0;
        for (var chi = 0; chi < hourly.time.length; chi++){
          var dt = new Date(hourly.time[chi]);
          if (dt >= segStart && dt < segEnd){
            if (typeof hourly.cloudcover[chi] === "number") { sT += hourly.cloudcover[chi]; cnt++; }
            if (hasLayers) {
              sL += (hourly.cloud_cover_low[chi]||0);
              sM += (hourly.cloud_cover_mid[chi]||0);
              sH += (hourly.cloud_cover_high[chi]||0);
            }
          }
        }
        cloudSegments.push({
          total: cnt>0 ? Math.round(sT/cnt) : 0,
          low: cnt>0 ? Math.round(sL/cnt) : 0,
          mid: cnt>0 ? Math.round(sM/cnt) : 0,
          high: cnt>0 ? Math.round(sH/cnt) : 0,
          w: (hoursPerSegment / 24) * 100
        });
      }

      if (hasLayers) {
        // Layered cloud bar: 3 sub-rows stacked vertically (high=top, mid=middle, low=bottom)
        // Each segment's opacity scales with coverage. Colors differentiate layers:
        //   High = cool blue/white (cirrus/ice), Mid = warm tan/amber (alto), Low = dark gray (stratus/blocking)
        // Color scheme: sky blue (clear 0%) → dark cloud grey (overcast 100%)
        // Clear sky:  rgb(135, 190, 235)  — pleasant sky blue
        // Overcast:   rgb(58, 62, 70)     — dark storm cloud grey
        var skyR=135,skyG=190,skyB=235;   // 0% cloud
        var cldR=58, cldG=62, cldB=70;    // 100% cloud
        var layerDefs = [
          {key:'high', label:'H'},
          {key:'mid',  label:'M'},
          {key:'low',  label:'L'}
        ];
        var layerHtml = '';
        layerDefs.forEach(function(layer){
          layerHtml += '<div style="display:flex;flex:1;overflow:hidden;position:relative;min-height:14px;">';
          cloudSegments.forEach(function(seg){
            var v = seg[layer.key];
            var frac = Math.min(1, Math.max(0, v/100));
            var r = Math.round(skyR + (cldR-skyR)*frac);
            var g = Math.round(skyG + (cldG-skyG)*frac);
            var b = Math.round(skyB + (cldB-skyB)*frac);
            layerHtml += '<div style="width:'+seg.w+'%;height:100%;background:rgb('+r+','+g+','+b+');"></div>';
          });
          layerHtml += '</div>';
