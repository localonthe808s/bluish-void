              out += '<div style="display:flex;align-items:center;gap:6px;">';
              out += '<span style="font-size:.38rem;color:'+INK+';font-weight:700;min-width:62px;">'+(regionNames[r.name]||r.name)+'</span>';
              out += '<div style="flex:1;height:4px;background:rgba(43,34,244,.06);border-radius:2px;overflow:hidden;">';
              out += '<div style="width:'+pct+'%;height:100%;background:'+barCol+';border-radius:2px;"></div>';
              out += '</div>';
              out += '<span style="font-size:.38rem;color:'+INK_DIM+';font-weight:700;min-width:24px;text-align:right;">'+r.c+'</span>';
              out += '</div>';
