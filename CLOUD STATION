        rbLabel.style.webkitBackgroundClip = 'text';
        rbLabel.style.webkitTextFillColor = 'transparent';
        rbLabel.style.backgroundClip = 'text';
        var hStr = bestHour > 12 ? (bestHour-12)+'PM' : bestHour === 0 ? '12AM' : bestHour+'AM';
        if (rbDetail) rbDetail.textContent = 'Peak ~' + hStr + ' \u2022 Look ' + bestDir + ' \u2022 ' + bestScore + '%';
      } else if (bestScore >= 30) {
        // Moderate
        rbLabel.textContent = rbTypeInfo.label.toUpperCase() + ' POSSIBLE';
        rbLabel.style.color = '#cc8833';
        var hStr2 = bestHour > 12 ? (bestHour-12)+'PM' : bestHour === 0 ? '12AM' : bestHour+'AM';
        if (rbDetail) rbDetail.textContent = '~' + hStr2 + ' \u2022 ' + bestDir + ' \u2022 ' + bestScore + '%';
      } else if (bestScore >= 15) {
