                }
              }

              // ── Cb FEATURES: murus, cauda, velum, tuba ──
              var _cbFeat = (t.features || []).join(',');
              var _murCx = cx + cbSunSide*_cbW*0.35;
              var _murTopY = bY + 1;
              var _murBotY = bY + 9;
              var _murW = _cbW*0.55;
              // Murus (wall cloud) — dark blocky lowered region forward of
              // center. Tornado precursor. Required for cauda + tuba to make
              // physical sense (they hang from the murus, not bare base).
              if (_cbFeat.indexOf('murus') >= 0) {
                var _murP = 'M '+(_murCx-_murW*0.5).toFixed(1)+' '+_murTopY.toFixed(1);
                _murP += ' L '+(_murCx+_murW*0.5).toFixed(1)+' '+_murTopY.toFixed(1);
                for (var mux = 0; mux <= 8; mux++) {
                  var _muT = mux/8;
                  var _muX = _murCx + _murW*0.5 - _muT*_murW;
