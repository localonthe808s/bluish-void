  }

  function updateUnifiedPills(){
    var tab = hazardActiveTab;
    // Show only the active tab's pill
    ['fire','quake','tornado','flood'].forEach(function(p){
      var el = document.getElementById('hz-pill-' + p);
      if(el) el.style.display = (p === tab) ? '' : 'none';
    });

    // Fire pill
    var firePill = document.getElementById('hz-pill-fire');
    if(firePill){
      var allFires = window._activeFires || [];
      var satCount = allFires.filter(function(f){ return f.properties._country === 'SAT'; }).length;
      // "fires" = confirmed only (excludes SAT hotspots)
      var fires = allFires.filter(function(f){ return f.properties._country !== 'SAT'; });
      var rxCount = fires.filter(function(f){ var t = (f.properties.IncidentTypeCategory || f.properties.IncidentType || '').toString().toUpperCase(); return t.indexOf('RX') >= 0 || t.indexOf('PRESCRIBED') >= 0 || t.indexOf('USE') >= 0; }).length;
      var total = fires.length;
      var wf = total - rxCount;
      if(total > 0){
        // ── NIFC 10-year monthly avg fire counts (2014-2023 compiled) ──
        var monthlyAvgFires = [2800,2600,4200,5400,5800,7200,8500,9600,7800,6200,3800,2500];
        var now = new Date();
        var curMonth = now.getMonth();
        var ytdAvg = 0;
        for(var mi=0; mi<curMonth; mi++) ytdAvg += monthlyAvgFires[mi];
        ytdAvg += Math.round(monthlyAvgFires[curMonth] * (now.getDate() / new Date(now.getFullYear(), curMonth+1, 0).getDate()));
        var fireRatio = ytdAvg > 0 ? total / ytdAvg : 1;
        var ratioLabel, ratioCol;
        if(fireRatio > 2.0){ ratioLabel='WELL ABOVE'; ratioCol='#ef4444'; }
        else if(fireRatio > 1.3){ ratioLabel='ABOVE AVG'; ratioCol='#f97316'; }
        else if(fireRatio > 0.8){ ratioLabel='NEAR AVG'; ratioCol='#4ade80'; }
        else if(fireRatio > 0.5){ ratioLabel='BELOW AVG'; ratioCol='#60a5fa'; }
        else { ratioLabel='WELL BELOW'; ratioCol='#60a5fa'; }

        // Season phase
        var seasonPhases = ['SOUTHERN PRESCRIBED BURN SEASON','SOUTHERN PRESCRIBED BURN SEASON','SOUTHERN PRESCRIBED BURN SEASON','SPRING FIRE TRANSITION','SPRING FIRE TRANSITION','WESTERN FIRE SEASON ONSET','PEAK WESTERN FIRE SEASON','PEAK WESTERN FIRE SEASON','PEAK WESTERN FIRE SEASON','AUTUMN WIND-DRIVEN FIRE EVENTS','AUTUMN WIND-DRIVEN FIRE EVENTS','WINTER FIRE DORMANCY'];
        var seasonPhase = seasonPhases[curMonth];

        // Regional breakdown
        var reg = {SE:0,SP:0,SW:0,CA:0,GB:0,NW:0,NR:0,NE:0,AK:0};
        fires.forEach(function(f){
          var c = f.geometry && f.geometry.coordinates;
          if(!c) return;
          var fLon=c[0], fLat=c[1];
          if(fLat>58) reg.AK++;
          else if(fLat>42&&fLon<-115) reg.NW++;
          else if(fLat>42&&fLon>=-115&&fLon<-104) reg.NR++;
          else if(fLat>35&&fLat<=42&&fLon<-115) reg.GB++;
          else if(fLon<-115&&fLat<=42) reg.CA++;
          else if(fLat<=35&&fLon<-100) reg.SW++;
          else if(fLat<=37&&fLon>=-100&&fLon<-80) reg.SP++;
          else if(fLat<=37&&fLon>=-80) reg.SE++;
          else reg.NE++;
        });
        var topReg = Object.keys(reg).map(function(k){return{name:k,c:reg[k]};}).filter(function(r){return r.c>0;}).sort(function(a,b){return b.c-a.c;}).slice(0,3);

        // Palette aligned with site: ink blue on translucent paper
        var INK = '#2B22F4';
        var INK_DIM = 'rgba(43,34,244,.68)';
        var INK_MUTE = 'rgba(43,34,244,.45)';
        var INK_GHOST = 'rgba(43,34,244,.28)';
        var CHIP_BG = 'rgba(43,34,244,.05)';
        var CHIP_STROKE = 'rgba(43,34,244,.10)';
        var FIRE_STRONG = '#c2410c'; // deeper orange for contrast on light
        var FIRE = '#ea580c';

        // ── Fire count trend (vs ~yesterday via localStorage) ──
        var trendHtml = '';
        try {
          var now = Date.now();
          var snapRaw = localStorage.getItem('fireCountSnapshot');
          var snap = snapRaw ? JSON.parse(snapRaw) : null;
          var dayMs = 24 * 60 * 60 * 1000;
          if(snap && typeof snap.count === 'number' && snap.t){
            var ageHrs = (now - snap.t) / (60 * 60 * 1000);
            if(ageHrs >= 12 && ageHrs <= 60){
              var delta = total - snap.count;
              var lbl = ageHrs < 36 ? 'vs yesterday' : 'vs 2d ago';
              if(delta > 0) trendHtml = ' <span style="font-size:.42rem;color:#b91c1c;font-weight:700;" title="'+lbl+'">▲' + delta + '</span>';
              else if(delta < 0) trendHtml = ' <span style="font-size:.42rem;color:#047857;font-weight:700;" title="'+lbl+'">▼' + Math.abs(delta) + '</span>';
              else trendHtml = ' <span style="font-size:.42rem;color:'+INK_MUTE+';font-weight:700;" title="'+lbl+'">±0</span>';
            }
          }
          if(!snap || !snap.t || (now - snap.t) > dayMs){
            localStorage.setItem('fireCountSnapshot', JSON.stringify({count: total, t: now}));
          }
        } catch(e){}

        // Reusable section-header style
        function sectionHeader(label, accent){
          return '<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;">' +
            '<span style="width:3px;height:10px;background:'+(accent||INK)+';border-radius:2px;"></span>' +
            '<span style="font-size:.36rem;color:'+INK_MUTE+';font-weight:800;letter-spacing:.1em;">'+label+'</span>' +
          '</div>';
        }

        // ── Focus fires: Nearest + Largest tabs ──
        function renderFireRow(f, isLast){
          var acStr = f.acres >= 1000 ? (f.acres/1000).toFixed(1)+'K' : Math.round(f.acres).toLocaleString();
          var acCol = f.acres >= 50000 ? '#7f1d1d' : f.acres >= 10000 ? '#b91c1c' : f.acres >= 1000 ? '#ea580c' : '#a16207';
          var contPct = f.contained || 0;
          var contCol = contPct >= 80 ? '#047857' : contPct >= 50 ? '#a16207' : contPct >= 20 ? '#c2410c' : '#b91c1c';
          var out = '<div onclick="window.flyToFire('+f.lat+','+f.lon+')" style="padding:5px 0;cursor:pointer;'+(isLast ? '' : 'border-bottom:1px solid rgba(43,34,244,.06);')+'">';
