        if(pTrend!=null&&pTrend>1.5){sc+=1;facs.push('Rising pressure \u2014 clearing enhances colors');}
        if(vis!=null&&vis<8000){sc+=0.5;facs.push('Aerosols enhance warm scattering');}
        sc=Math.max(0,Math.min(10,Math.round(sc)));
        var sCol=sc>=8?'#f90':sc>=6?'#fa0':sc>=4?'#cc0':'#888';
        var sLbl=sc>=9?'EPIC':sc>=7?'EXCELLENT':sc>=5?'GOOD':sc>=3?'FAIR':'POOR';
        h+='<div style="margin:6px 0;"><span style="font-size:.7rem;font-weight:800;color:'+sCol+';">'+sc+'/10</span> <span style="font-weight:700;">'+sLbl+'</span>';
        if(mToSS>0)h+=' <span style="opacity:.5;">('+mToSS+' min)</span>';
        h+='</div>';
        if(mToSS>0){var gS=new Date(ss.getTime()-60*60000);h+='<div style="margin:3px 0;">'+K('Golden hour: ')+gS.toLocaleTimeString('en-US',{timeZone:LOCATION.tz,hour:'numeric',minute:'2-digit',hour12:true})+' \u2192 '+ss.toLocaleTimeString('en-US',{timeZone:LOCATION.tz,hour:'numeric',minute:'2-digit',hour12:true});if(mToSS<=60)h+=' <span style="color:#f90;font-weight:700;">\u2B24 ACTIVE</span>';h+='</div>';}
        facs.forEach(function(f){h+='<div style="margin:2px 0;opacity:.6;">\u2022 '+f+'</div>';});
      }
      // Sunrise golden hour
      else if (sr) {
        var mFromSR = Math.round((now - sr) / 60000);
        if (mFromSR > -10 && mFromSR < 75) {
          h += S('Sunrise Golden Hour');
          if (mFromSR < 0) h += '<div style="margin:4px 0;">Sun rises in ' + (-mFromSR) + ' minutes \u2014 golden hour imminent.</div>';
          else if (mFromSR < 60) h += '<div style="margin:4px 0;"><span style="color:#f90;font-weight:700;">\u2B24 Golden hour ACTIVE</span> \u2014 ' + (60-mFromSR) + ' min remaining.</div>';
          else h += '<div style="margin:4px 0;">Golden hour fading \u2014 sun climbing.</div>';
          if (cH != null && cH > 15 && cH < 70) h += '<div style="margin:3px 0;opacity:.7;">High clouds catching warm sunrise light \u2014 check GeoColor.</div>';
        }
      }
    }

    h += S('Data Source');
    h += '<a href="https://www.star.nesdis.noaa.gov/goes/index.php" target="_blank" rel="noopener" style="color:rgba(100,170,255,.8);text-decoration:underline;text-decoration-color:rgba(100,170,255,.3);text-underline-offset:2px;">NOAA/NESDIS STAR</a> GOES-R Series Advanced Baseline Imager (ABI). 16-band multispectral imagery from geostationary orbit at 35,786 km.';
