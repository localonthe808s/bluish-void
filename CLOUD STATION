  function getFcastLabel(fhrIdx){
    var fhrs = getActiveFhrs();
    
    // LIVE mode: show relative time
    if (fcastState.range === 'live'){
      var frameNum = parseInt(fhrs[fhrIdx], 10);
      if (frameNum === 0) return 'NOW';
      var minsAgo = frameNum * 2; // ~2 min per frame
      return '~' + minsAgo + ' MIN AGO';
    }
    
    var h = parseInt(fhrs[fhrIdx], 10);
    var cycleHour = parseInt(fcastState.cycle, 10);
    var now = new Date();
    var cycleDate = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate(), cycleHour));
    if (cycleDate > now) cycleDate.setUTCDate(cycleDate.getUTCDate() - 1);
    var targetUTC = new Date(cycleDate.getTime() + h * 3600000);
    var fullDays = ['SUNDAY','MONDAY','TUESDAY','WEDNESDAY','THURSDAY','FRIDAY','SATURDAY'];
    var dayName = fullDays[targetUTC.getDay()];
    var mon = targetUTC.getMonth() + 1;
    var date = targetUTC.getDate();
    var hr = targetUTC.getHours();
    var ampm = hr >= 12 ? 'PM' : 'AM';
    hr = hr % 12; if (hr === 0) hr = 12;
    var today = new Date();
    var isToday = targetUTC.toDateString() === today.toDateString();
    var tomorrow = new Date(today); tomorrow.setDate(tomorrow.getDate() + 1);
    var isTomorrow = targetUTC.toDateString() === tomorrow.toDateString();
    var prefix = isToday ? 'TODAY' : (isTomorrow ? 'TOMORROW' : dayName);
    return prefix + ' ' + mon + '/' + date + ' ' + hr + ampm + '  (+' + h + 'H)';
  }

  var lastGoodSrc = ''; // Last successfully loaded frame
  var loopGeneration = 0;
  var radarImgFront = true; // true = fcast-radar-img is front, false = fcast-radar-img-b is front

  function loadFcastRadar(){
    var fhrs = getActiveFhrs();
    var imgA = document.getElementById('fcast-radar-img');
    var imgB = document.getElementById('fcast-radar-img-b');
    var label = document.getElementById('fcast-radar-label');
    if (!fhrs || fhrs.length === 0){
      if (label) label.textContent = 'No data for range';
      return;
    }

    // Pick the back image to load into, then crossfade
    var front = radarImgFront ? imgA : imgB;
    var back = radarImgFront ? imgB : imgA;

    var url;
    if (fcastState.range === 'live'){
      var region = RIDGE_AREA_MAP[fcastState.area] || 'CONUS';
      var frameNum = fhrs[fcastState.idx] || '0';
      url = 'https://radar.weather.gov/ridge/standard/' + region + '_' + frameNum + '.gif?cb=' + Math.floor(Date.now()/60000);
      if (label){
        var n = parseInt(frameNum, 10);
        label.textContent = n === 0 ? 'NOW' : '~' + (n * 2) + ' MIN AGO';
      }
    } else {
      url = buildFcastUrl(fcastState.idx);
      if (label) label.textContent = getFcastLabel(fcastState.idx);
    }

    if (!back || !front) return;
    var loader = document.getElementById('fcast-loading');
    if (loader && !lastGoodSrc) loader.style.opacity = '1';

    // Copy filter style from current mode
    var filter = fcastState.range === 'live'
      ? 'invert(1) hue-rotate(180deg) contrast(1.1) saturate(1.4) brightness(0.95)'
      : 'invert(1) hue-rotate(180deg) contrast(1.2) saturate(1.5)';
    back.style.filter = filter;
    back.style.width = '100%';
    back.style.height = '100%';
    back.style.objectFit = (fcastState.range === 'live' && radarWideAreas.indexOf(fcastState.area) === -1) ? 'cover' : 'contain';
    back.style.objectPosition = 'center center';

    var retryCount = 0;
    back.onerror = function(){
      // Try previous cycle (up to 2 fallbacks)
      if (fcastState.range !== 'live' && retryCount < 2) {
        retryCount++;
        var prevCycle = fcastState.cycle;
        for (var r = 0; r < retryCount; r++) prevCycle = getPrevCycle(prevCycle, fcastState.model);
        var oldCycle = fcastState.cycle;
        fcastState.cycle = prevCycle;
        var fallbackUrl = buildFcastUrl(fcastState.idx);
        fcastState.cycle = oldCycle; // restore so state isn't permanently changed
        back.src = fallbackUrl;
        return;
      }
      // All retries exhausted
      if (lastGoodSrc && back.src !== lastGoodSrc) back.src = lastGoodSrc;
      else back.style.opacity = '0';
      if (loader) loader.style.opacity = '0';
    };
    // Timeout fallback — dismiss loader if image takes too long
    setTimeout(function(){ if (loader && loader.style.opacity !== '0') loader.style.opacity = '0'; }, 10000);
    back.onload = function(){
      // Crossfade: bring back to front, fade out old front
      back.style.zIndex = '2';
      back.style.opacity = '1';
      front.style.zIndex = '1';
      setTimeout(function(){ front.style.opacity = '0'; }, 350);
      radarImgFront = !radarImgFront;
      lastGoodSrc = back.src;
      if (loader) loader.style.opacity = '0';
      // If we used a fallback cycle, note it in the badge
      if (retryCount > 0) {
        var badge = document.getElementById('fcast-badge');
        if (badge) badge.textContent += ' (older run)';
      }
    };
    // Add transition to back image before loading
    back.style.transition = 'opacity .35s ease';
    back.style.opacity = '0';
    back.src = url;

    // Update frame indicator
    updateFrameIndicator();
  }

  var _frameDotCount = 0; // track dot count to avoid unnecessary rebuilds
  var _frameBarEl = null; // cached progress bar inner element

  function updateFrameIndicator(){
    var dotsEl = document.getElementById('fcast-frame-dots');
    if (!dotsEl) return;
    var fhrs = getActiveFhrs();
    var total = fhrs ? fhrs.length : 0;
    var current = fcastState.idx;

    // Progress bar for large frame counts
    if (total > 20) {
      var pct = total > 1 ? (current / (total - 1)) * 100 : 0;
      if (_frameDotCount !== -1 || !_frameBarEl) {
        dotsEl.innerHTML = '<div style="width:120px;height:3px;background:rgba(255,160,40,.2);border-radius:2px;overflow:hidden;"><div style="width:' + pct + '%;height:100%;background:rgba(255,160,40,.8);border-radius:2px;transition:width .2s;"></div></div>';
        _frameBarEl = dotsEl.querySelector('div > div');
        _frameDotCount = -1;
      } else {
        _frameBarEl.style.width = pct + '%';
      }
      return;
    }

    // Dots for small frame counts — only rebuild if count changed
    if (_frameDotCount !== total) {
      var html = '';
      for (var i = 0; i < total; i++) {
        html += '<div style="width:4px;height:4px;border-radius:2px;background:rgba(255,160,40,.25);transition:all .2s;"></div>';
      }
      dotsEl.innerHTML = html;
      _frameDotCount = total;
      _frameBarEl = null;
    }
    // Update active dot
    var dots = dotsEl.children;
    for (var j = 0; j < dots.length; j++) {
      var isActive = j === current;
      dots[j].style.width = isActive ? '8px' : '4px';
      dots[j].style.background = 'rgba(255,160,40,' + (isActive ? '.9' : '.25') + ')';
    }
  }

  function fcastRadarStep(dir){
    var fhrs = getActiveFhrs();
    fcastState.idx = Math.max(0, Math.min(fhrs.length - 1, fcastState.idx + dir));
    loadFcastRadar();
  }

  // Preload next frame in background
  var _fcastPreloadImg = null;
  function preloadNextFrame(){
    var fhrs = getActiveFhrs();
    if (!fhrs || fhrs.length === 0) return;
    var nextIdx = (fcastState.idx + 1) % fhrs.length;
    var url;
    if (fcastState.range === 'live'){
      var region = RIDGE_AREA_MAP[fcastState.area] || 'CONUS';
      var frameNum = fhrs[nextIdx] || '0';
      url = 'https://radar.weather.gov/ridge/standard/' + region + '_' + frameNum + '.gif?cb=' + Math.floor(Date.now()/60000);
    } else {
      var oldIdx = fcastState.idx;
      fcastState.idx = nextIdx;
      url = buildFcastUrl(nextIdx);
      fcastState.idx = oldIdx;
    }
    if (!_fcastPreloadImg) _fcastPreloadImg = new Image();
    _fcastPreloadImg.src = url;
  }

  function fcastRadarTogglePlay(){
    var btn = document.getElementById('fcast-radar-play-btn');
    if (fcastState.playing){
      if (fcastState.timer) clearInterval(fcastState.timer);
      fcastState.timer = null;
      fcastState.playing = false;
      if (btn) btn.textContent = '⏵';
    } else {
      fcastState.playing = true;
      if (btn) btn.textContent = '⏸';
      var interval = fcastState.range === 'live' ? 1200 : 500;
      fcastState.timer = setInterval(function(){
        var fhrs = getActiveFhrs();
        fcastState.idx++;
        if (fcastState.idx >= fhrs.length) fcastState.idx = 0;
        loadFcastRadar();
        preloadNextFrame();
      }, interval);
    }
  }

  // Keyboard controls for radar playback
  document.addEventListener('keydown', function(e){
    // Only handle when radar widget is active (not in clouds mode) and no input focused
    if (fcastState.range === 'clouds') return;
    if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable) return;
    var widget = document.getElementById('clouds-radar-widget');
    if (!widget) return;
    var rect = widget.getBoundingClientRect();
    // Only respond if widget is in the viewport
    if (rect.bottom < 0 || rect.top > window.innerHeight) return;
    if (e.key === 'ArrowRight') { e.preventDefault(); fcastRadarStep(1); }
    else if (e.key === 'ArrowLeft') { e.preventDefault(); fcastRadarStep(-1); }
    else if (e.key === ' ') { e.preventDefault(); fcastRadarTogglePlay(); }
  });

