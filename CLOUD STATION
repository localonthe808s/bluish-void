        h += '<div style="display:flex;align-items:center;gap:6px;margin:3px 0 4px;">'
          + '<div style="flex:1;height:5px;background:rgba(255,255,255,.04);border-radius:3px;position:relative;overflow:hidden;">'
          +   '<div style="position:absolute;left:'+range.start+'%;width:'+layer.pct+'%;height:100%;background:linear-gradient(90deg,'+layer.color+',rgba(255,255,255,.25));border-radius:3px;"></div>'
          + '</div>'
          + '<span style="font-size:7.5px;font-weight:800;color:'+layer.color+';opacity:.85;min-width:32px;text-align:right;">'+layer.pct+'%</span>'
          + '</div>';
        // Tiny axis labels — "center" and "surface" only on the first card so they set context
        if (li === 0) {
          h += '<div style="display:flex;justify-content:space-between;margin:-2px 38px 4px 0;font-size:6.5px;letter-spacing:.08em;color:rgba(255,255,255,.3);font-weight:700;text-transform:uppercase;">'
            + '<span>Center</span><span>Surface</span>'
            + '</div>';
        }
        // Stats chip row
        if (stats.length) {
          h += '<div style="display:flex;flex-wrap:wrap;gap:3px;margin:3px 0 4px;">';
          stats.forEach(function(s){
            h += '<span style="display:inline-flex;align-items:baseline;gap:3px;padding:2px 6px;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.06);border-radius:4px;font-size:7.5px;">'
              + '<span style="opacity:.4;font-weight:700;letter-spacing:.04em;">'+s.label+'</span>'
              + '<span style="font-weight:700;color:'+layer.color+';opacity:.9;">'+s.value+'</span>'
              + '</span>';
