      }

      // Full-circle interior cross-section
      for (var li=pi.layers.length-1; li>=0; li--) {
        var layer = pi.layers[li];
        var totalPct = 0; for(var k=0;k<=li;k++) totalPct+=pi.layers[k].pct;
        var r = svgR * totalPct/100;
        var ptn = _patternForLayer(layer);
