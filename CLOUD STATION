        } else if (body === 'saturn') {
          // Saturn: CSS body (14px matching others) + ring extending beyond
          planetsHtml += '<div style="width:14px;height:14px;flex-shrink:0;margin-right:5px;margin-left:1px;position:relative;display:flex;align-items:center;justify-content:center;">' +
            '<div style="width:14px;height:14px;border-radius:50%;background:radial-gradient(circle at 40% 35%,#f0dca0,#d4b060 50%,#b08830 85%,#8a6820);box-shadow:0 0 4px rgba(0,0,0,.3);position:relative;z-index:2;"></div>' +
            '<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:24px;height:6px;border-radius:50%;border:1.5px solid rgba(200,180,120,.5);background:transparent;z-index:1;pointer-events:none;"></div>' +
          '</div>';
        } else {
          planetsHtml += '<div class="today-tl-planet-indicator" style="background:' + pImgBg + ' center/160%;box-shadow:0 0 4px rgba(0,0,0,.3);"></div>';
        }
        planetsHtml += '<div class="today-tl-planet-bar">';
        
        if (w && w.segments && w.segments.length > 0){
