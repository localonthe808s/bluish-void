        var totalPct = 0; for(var k=0;k<=li;k++) totalPct+=pi.layers[k].pct;
        var innerPct = totalPct - layer.pct;
        var midR = svgR * (totalPct + innerPct) / 200;
        // Anchor on layer mid-radius arc, on RIGHT side, at closest point to label's y
