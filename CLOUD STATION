    // ── WATER VAPOR ───────────────────────────────────────────────────────────
    // Mid-level water vapor (6.19µm Band 8) — moisture fuel map for TC development
    if (which === 'wv') {
      if (on) {
        if (!_hurricaneLayerObjs.wv) {
