            }
          }

          // 1) Active meteor shower tonight (highest signal — happens rarely).
          // METEOR_SHOWERS uses {m,d} for peakStart/peakEnd/activeStart/activeEnd.
          // Compare via day-of-year to handle ranges that wrap year-end (Quadrantids).
          if (!spacePicked) try {
            if (typeof METEOR_SHOWERS !== 'undefined') {
