      var now=new Date();
      var dayLocal=new Date(now.getFullYear(),now.getMonth(),now.getDate(),12,0,0,0);
      var _t=_solarTerms(now);
      var _lr=LOCATION.lat*Math.PI/180;
      var _sn=solarNoonLocal(dayLocal,LOCATION.lat,LOCATION.lon);
      var _nm=now.getHours()*60+now.getMinutes()+now.getSeconds()/60;
      var _snm=_sn.getHours()*60+_sn.getMinutes()+_sn.getSeconds()/60;
      var _ha=(_nm-_snm)*15/60*Math.PI/180;
      var _si=Math.sin(_lr)*Math.sin(_t.decl)+Math.cos(_lr)*Math.cos(_t.decl)*Math.cos(_ha);
      var sa=Math.asin(Math.max(-1,Math.min(1,_si)))*180/Math.PI;
      var _e=function(id,a,v){var e=document.getElementById(id);if(e)e.setAttribute(a,v);};

