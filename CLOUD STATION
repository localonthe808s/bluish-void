          }
          
          // Build combined list: SPC outlook first if exists and no active tornado warning
          var hasTornadoWarning = features.some(function(f){
            var ev = (f.properties.event || '').toLowerCase();
            return ev.indexOf('tornado') >= 0 && ev.indexOf('warning') >= 0;
          });
          
          var allAlerts = [];
          if (spcAlert && !hasTornadoWarning){
            allAlerts.push(spcAlert);
          }
          features.forEach(function(f){ allAlerts.push(f); });
          
        // ── Build GROUPED condensed alert bar ──
        var groups = [];
        for (var i = 0; i < allAlerts.length; i++){
          var isSynthetic = allAlerts[i]._synthetic;
          var alert = allAlerts[i].properties;
          var event = alert.event || "Alert";
          var severity = (alert.severity || "").toLowerCase();
          var evLower = event.toLowerCase();
          var description = alert.description || "";
          var expires = alert.expires ? new Date(alert.expires) : null;
          var effective = alert.effective ? new Date(alert.effective) : null;
          var onset = alert.onset ? new Date(alert.onset) : effective;
          if (onset && expires && onset > expires) onset = effective || expires;
          
          // Determine category
          var cat = "statement";
          var icon = "ℹ️";
          if (evLower.indexOf("tornado") >= 0) { cat = "tornado"; icon = "🌪️"; }
          else if (evLower.indexOf("hurricane") >= 0 || evLower.indexOf("typhoon") >= 0) { cat = "warning"; icon = "🌀"; }
          else if (evLower.indexOf("tsunami") >= 0) { cat = "warning"; icon = "🌊"; }
          else if (evLower.indexOf("fire") >= 0 || evLower.indexOf("red flag") >= 0) { cat = "warning"; icon = "🔥"; }
          else if (evLower.indexOf("flash flood") >= 0) { cat = "warning"; icon = "🌊"; }
          else if (evLower.indexOf("warning") >= 0 || severity === "extreme" || severity === "severe") { cat = "warning"; icon = "⚠️"; }
          else if (evLower.indexOf("watch") >= 0 || severity === "moderate") { cat = "watch"; icon = "👁️"; }
          else if (evLower.indexOf("advisory") >= 0) { cat = "advisory"; icon = "⚠️"; }
          
          // Extract precip amounts
          var details = [];
          // Snow accumulation (range or single)
          var snowMatch = description.match(/(?:total\s+)?(?:snow\s+)?accumulations?\s+(?:of\s+)?(?:between\s+)?(\d+\.?\d*)\s*(?:to|and|-)\s*(\d+\.?\d*)\s*inch/i) ||
                         description.match(/(\d+\.?\d*)\s*(?:to|-)\s*(\d+\.?\d*)\s*inch(?:es)?\s*(?:of\s+)?(?:snow|accumulation|new snow)/i);
          if (snowMatch) details.push("❄️ " + snowMatch[1] + "–" + snowMatch[2] + '"');
          else {
            var singleSnow = description.match(/(?:up to|around|about|near)\s*(\d+\.?\d*)\s*inch(?:es)?\s*(?:of\s+)?(?:snow|accumulation)/i) ||
                            description.match(/(\d+\.?\d*)\s*inch(?:es)?\s*(?:of\s+)?(?:snow|new snow|accumulation)/i);
            if (singleSnow) details.push("❄️ " + singleSnow[1] + '"');
          }
          // Snow rate
          var snowRate = description.match(/(\d+\.?\d*)\s*(?:to\s*(\d+\.?\d*)\s*)?inch(?:es)?\s*(?:per|\/|an)\s*hour/i);
          if (snowRate) details.push("⏱ " + snowRate[1] + (snowRate[2] ? "–" + snowRate[2] : "") + '"/hr');
          // Rain accumulation
          var rainMatch = description.match(/(\d+\.?\d*)\s*(?:to|-)\s*(\d+\.?\d*)\s*inch(?:es)?\s*(?:of\s+)?rain/i);
          if (rainMatch) details.push("🌧️ " + rainMatch[1] + "–" + rainMatch[2] + '"');
          else {
            var singleRain = description.match(/(?:up to|around)\s*(\d+\.?\d*)\s*inch(?:es)?\s*(?:of\s+)?rain/i);
            if (singleRain) details.push("🌧️ " + singleRain[1] + '"');
          }
          // Ice accumulation
          var iceMatch = description.match(/ice\s+accumulations?\s+(?:of\s+)?(?:up to\s+)?(\d+\.?\d*)\s*(?:to|-)\s*(\d+\.?\d*)/i) ||
                        description.match(/(\d+\.?\d*)\s*(?:to|-)\s*(\d+\.?\d*)\s*(?:inch(?:es)?|tenths?\s+of\s+an?\s+inch)\s*(?:of\s+)?ice/i);
          if (iceMatch) details.push("🧊 " + iceMatch[1] + "–" + iceMatch[2] + '" ice');
          // Wind — combine sustained + gust into one clean metric
          var windStr = '';
          var windMatch = description.match(/wind[s]?\s+(?:gusting\s+)?(?:as\s+high\s+as\s+)?(?:up\s+to\s+)?(\d+)\s*(?:to|-)\s*(\d+)\s*mph/i) ||
                         description.match(/(\d+)\s*(?:to|-)\s*(\d+)\s*mph\s*wind/i);
          var singleWind = !windMatch && (description.match(/wind[s]?\s+(?:gusting\s+)?(?:as\s+high\s+as|up\s+to|around|near)\s+(\d+)\s*mph/i) ||
                          description.match(/sustained\s+winds?\s+(?:of\s+)?(?:up\s+to\s+)?(\d+)\s*mph/i));
          var gustMatch = description.match(/gust[s]?\s+(?:up\s+to|as\s+high\s+as|of|to|around|could\s+reach)\s+(\d+)\s*mph/i) ||
                         description.match(/(\d+)\s*mph\s*gust/i);
          if (windMatch) {
            windStr = windMatch[1] + '\u2013' + windMatch[2] + ' MPH';
            if (gustMatch && parseInt(gustMatch[1]) > parseInt(windMatch[2])) windStr += ' | G' + gustMatch[1];
          } else if (singleWind) {
            windStr = singleWind[1] + ' MPH';
            if (gustMatch) windStr += ' | G' + gustMatch[1];
          } else if (gustMatch) {
            windStr = 'G' + gustMatch[1] + ' MPH';
          }
          if (windStr) details.push('\ud83d\udca8 ' + windStr);
          // Flooding depth
          var floodDepth = description.match(/(\d+)\s*(?:to|-)\s*(\d+)\s*(?:ft|feet|foot)\s*(?:of\s+)?(?:inundation|water|flood|storm\s+surge)/i);
          if (floodDepth) details.push('\ud83c\udf0a ' + floodDepth[1] + '\u2013' + floodDepth[2] + ' ft');
          else {
            var singleFlood = description.match(/(?:up to|around)\s*(\d+)\s*(?:ft|feet|foot)\s*(?:of\s+)?(?:inundation|water|storm\s+surge)/i);
            if (singleFlood) details.push('\ud83c\udf0a ' + singleFlood[1] + ' ft');
          }
          // Visibility — only if room
          if (details.length < 2) {
            var visMatch2 = description.match(/near[\s-]*zero\s*visibility/i) || description.match(/whiteout/i);
            if (visMatch2) details.push('\ud83d\udc41 Near-zero vis');
            else {
              var visMatch = description.match(/visibility\s+(?:reduced\s+to\s+|below\s+|near\s+)?(?:one\s+quarter|1\/4)\s*mile/i);
              if (visMatch) details.push('\ud83d\udc41 \u00bc mi vis');
            }
          }
          // Cap at 2 key metrics for clean quick view
          if (details.length > 2) details = details.slice(0, 2);
          
          // Summary from description
          var summary = "";
          var _headlineSrc = "";
          if (description){
            var cleanDesc = description
              .replace(/\*\s*WHAT\.\.\./gi, '')
              .replace(/\*\s*WHERE\.\.\./gi, '')
              .replace(/\*\s*WHEN\.\.\./gi, '')
              .replace(/\*\s*IMPACTS\.\.\./gi, '')
              .replace(/\*\s*ADDITIONAL DETAILS\.\.\./gi, '')
              .replace(/^\s*[\*\-]\s*/gm, '')
              .trim();
            var firstSentence = cleanDesc.split(/\.(?:\s|$)/)[0];
            if (firstSentence && firstSentence.length > 10){
              _headlineSrc = firstSentence;
              summary = firstSentence + ".";
            }
          }
          
          // Time window
          function fmt12(d){
            if (!d || !isFinite(d.getTime())) return "--:--";
            var h = d.getHours(), m = d.getMinutes();
            var ampm = h >= 12 ? "PM" : "AM";
            var hh = h % 12; if (hh === 0) hh = 12;
            return hh + ":" + (m < 10 ? "0"+m : m) + " " + ampm;
          }
          var timeWindow = "";
          var now2 = new Date();
          if (onset && expires){
            var hasStarted = onset <= now2;
            var todayStr = fmtMonthDay(now2);
            var tomorrowStr = fmtMonthDay(new Date(now2.getTime() + 86400000));
            var expiresDay = fmtMonthDay(expires);
            if (hasStarted){
              if (expiresDay === todayStr) timeWindow = "Until " + fmt12(expires) + " today";
              else if (expiresDay === tomorrowStr) timeWindow = "Until " + fmt12(expires) + " tomorrow";
              else timeWindow = "Until " + expiresDay + " " + fmt12(expires);
            } else {
              var onsetDay = fmtMonthDay(onset);
              if (onsetDay === todayStr) timeWindow = "Today " + fmt12(onset) + " – " + fmt12(expires);
              else if (onsetDay === tomorrowStr) timeWindow = "Tomorrow " + fmt12(onset) + " – " + fmt12(expires);
              else timeWindow = onsetDay + " " + fmt12(onset) + " – " + fmt12(expires);
            }
          } else if (expires){
            var expiresDay = fmtMonthDay(expires);
            var todayStr = fmtMonthDay(now2);
            if (expiresDay === todayStr) timeWindow = "Until " + fmt12(expires) + " today";
            else timeWindow = "Until " + expiresDay + " " + fmt12(expires);
          }
          
          // Clean description for expanded view
          var cleanDescFull = description
            .replace(/\*\s*WHAT\.\.\./gi, 'WHAT: ')
            .replace(/\*\s*WHERE\.\.\./gi, 'WHERE: ')
            .replace(/\*\s*WHEN\.\.\./gi, 'WHEN: ')
            .replace(/\*\s*IMPACTS\.\.\./gi, 'IMPACTS: ')
            .replace(/\*\s*ADDITIONAL DETAILS\.\.\./gi, '')
            .replace(/^\s*[\*\-]\s*/gm, '')
            .trim();
          // Truncate for inline display
          if (cleanDescFull.length > 500) cleanDescFull = cleanDescFull.substring(0, 497) + '...';
          
          var instruction = alert.instruction || "";
          var areaDesc = alert.areaDesc || "";
          if (areaDesc.length > 200) areaDesc = areaDesc.substring(0, 197) + '...';
          
          groups.push({ event: event, cat: cat, icon: icon, details: details, summary: summary, _headlineSrc: _headlineSrc, timeWindow: timeWindow, idx: i, severity: severity, _expires: expires, _areaDesc: areaDesc, _instruction: instruction, _description: cleanDescFull });
          
          // Store alert geometry for radar overlay
          if (!isSynthetic && features[i] && features[i].geometry){
            alertGeometries.push({
              geometry: features[i].geometry,
              event: event,
              severity: severity,
              alertClass: cat
            });
          }
        }
        
        // Merge duplicate event types (e.g. multiple Special Weather Statements)
        var merged = [];
        var mergeMap = {};
        groups.forEach(function(g){
          // Only merge statements/advisories — never merge warnings/watches/tornado
          var evL = g.event.toLowerCase();
          if (evL.indexOf('statement') < 0 && evL.indexOf('advisory') < 0) { merged.push(g); return; }
          var key = g.event.toLowerCase().trim();
          if (mergeMap[key] !== undefined) {
            var target = merged[mergeMap[key]];
            // Keep the latest expiry
            if (g._expires && (!target._expires || g._expires > target._expires)) target._expires = g._expires;
            // Merge details
            g.details.forEach(function(d){ if (target.details.indexOf(d) < 0) target.details.push(d); });
            // Combine descriptions
            if (g._description && (target._description || '').indexOf(g._description) < 0) {
              target._description = (target._description || '') + '\n\n' + g._description;
            }
            // Build combined summary from both headlineSrcs
            var thisSrc = (g._headlineSrc || g.summary || '').replace(/^the combination of /i, '').replace(/\.$/, '').trim();
            var existingSrc = (target._headlineSrc || '');
            if (thisSrc && existingSrc.toLowerCase().indexOf(thisSrc.toLowerCase().substring(0, 20)) < 0) {
              target._headlineSrc = (existingSrc ? existingSrc + '. ' : '') + thisSrc;
            }
            target.summary = target._headlineSrc + '.';
            target._mergeCount = (target._mergeCount || 1) + 1;
            // Merge area desc
            if (g._areaDesc && (target._areaDesc || '').indexOf(g._areaDesc) < 0) {
              target._areaDesc = (target._areaDesc || '') + '; ' + g._areaDesc;
            }
            // Merge instructions
            if (g._instruction && (target._instruction || '').indexOf(g._instruction) < 0) {
              target._instruction = (target._instruction || '') + ' ' + g._instruction;
            }
          } else {
            mergeMap[key] = merged.length;
            merged.push(g);
          }
        });
        groups = merged;

        // Build unified alert panel HTML
        var sevColors = {
          tornado:  { sev:'rgba(180,60,255,1)', badge:'rgba(180,60,255,.2)' },
          warning:  { sev:'rgba(240,55,55,.95)', badge:'rgba(240,55,55,.15)' },
          watch:    { sev:'rgba(255,180,40,.95)', badge:'rgba(255,180,40,.15)' },
          advisory: { sev:'rgba(100,160,255,.95)', badge:'rgba(100,160,255,.15)' },
          statement:{ sev:'rgba(160,160,170,.9)', badge:'rgba(160,160,170,.1)' }
        };
        
        if (!groups.length){
          alertsEl.innerHTML = '';
        } else {
          var MAX_VISIBLE = 3;
          var hasMore = groups.length > MAX_VISIBLE;
          var html = '<div class="alert-panel">';
          
          groups.forEach(function(g, gi){
            if (gi > 0) html += '<div class="alert-line-sep"' + (gi >= MAX_VISIBLE ? ' style="display:none;" data-alert-overflow' : '') + '></div>';
            var sc = sevColors[g.cat] || sevColors.statement;
            
            html += '<div class="alert-line" data-alert-index="' + g.idx + '"' + (gi >= MAX_VISIBLE ? ' style="display:none;" data-alert-overflow' : '') + ' onclick="this.classList.toggle(\'expanded\')">';
            
            // Top row: event name + severity badge + metrics + countdown + chevron
            // For statements with summaries, show summary as headline with compact type badge
            var isStatement = g.event.toLowerCase().indexOf('statement') >= 0 || g.event.toLowerCase().indexOf('advisory') >= 0;
            var hasUsableSummary = isStatement && g.summary && g.summary.length > 15;

            html += '<div class="alert-line-top">';
            if (hasUsableSummary) {
              // Clean short headline — no badge, just the summary
              var raw = (g._headlineSrc || g.summary || '').replace(/^the combination of /i, '').replace(/^a /i, '').replace(/\.\.\.$/, '').replace(/\.$/, '').trim();
              // Cut at a natural break (comma, semicolon, "and", "with") that fits
              var cuts = [];
              raw.replace(/[,;]/g, function(m, i){ cuts.push(i); });
              raw.replace(/\s+(?:and|with|through|including|resulting)\s+/gi, function(m, i){ cuts.push(i); });
              cuts.sort(function(a,b){ return a - b; });
              var shortHead = raw;
              for (var ci = 0; ci < cuts.length; ci++) {
                if (cuts[ci] >= 35 && cuts[ci] <= 70) { shortHead = raw.substring(0, cuts[ci]).trim(); break; }
              }
              if (shortHead.length > 70) shortHead = raw.substring(0, 67).replace(/\s+\S*$/, '');
              shortHead = shortHead.charAt(0).toUpperCase() + shortHead.slice(1);
              html += '<span class="alert-line-event ' + g.cat + '">' + shortHead + '</span>';
            } else {
              html += '<span class="alert-line-event ' + g.cat + '">' + g.event + '</span>';
            }
            if (g.severity === 'extreme') html += '<span class="alert-line-sev" style="background:' + sc.badge + ';color:' + sc.sev + ';">EXTREME</span>';
            else if (g.severity === 'severe') html += '<span class="alert-line-sev" style="background:' + sc.badge + ';color:' + sc.sev + ';">SEVERE</span>';

