        // height. Aurora is on the magnetic-north horizon at mid latitudes;
        // becomes overhead as user latitude approaches the oval.
        var lookCompass = function(yourLat, threshold) {
          if (yourLat < threshold) return ''; // not visible — skip
          // Elevation: roughly 0–10° at threshold, up to 70° well within oval
          var elevDeg = Math.min(80, Math.max(5, (yourLat - threshold) * 8));
          var size = 100;
          var cx = size/2, cy = size/2 + 10; // shifted down so elev arc fits up top
          var rRose = 28;
          var s = '<svg width="'+size+'" height="'+size+'" viewBox="0 0 '+size+' '+size+'" style="display:block;margin:4px auto;">';
          // Sky dome arc (horizon to zenith on the north side)
          s += '<path d="M '+(cx-rRose-2)+' '+cy+' A '+(rRose+2)+' '+(rRose+2)+' 0 0 1 '+(cx+rRose+2)+' '+cy+'" fill="none" stroke="rgba(43,34,244,.18)" stroke-width="1" stroke-dasharray="2 2"/>';
          // Mark elevation angle on the arc (where to look up to)
          // 0° = horizon (left/right), 90° = zenith (top of arc)
          var elevRad = elevDeg * Math.PI / 180;
          // Point along arc at given elevation, on north side (top of arc)
          var ex = cx;  // straight up from center for due north
          var ey = cy - (rRose+2);  // top of arc
          // For elevation < 90° looking N, we travel along the arc from
          // horizon (left or right of cx) toward top. Simplification:
          // place the marker at top of arc (looking N) and indicate
          // elevation via the arc length and a numeric label.
          // Compass rose ring
          s += '<circle cx="'+cx+'" cy="'+cy+'" r="'+rRose+'" fill="rgba(255,255,255,.6)" stroke="rgba(43,34,244,.25)" stroke-width="1"/>';
          // Cardinal labels
          s += '<text x="'+cx+'" y="'+(cy-rRose-4)+'" text-anchor="middle" font-size="9" font-weight="900" fill="#cc4422">N</text>';
          s += '<text x="'+cx+'" y="'+(cy+rRose+10)+'" text-anchor="middle" font-size="8" font-weight="700" fill="rgba(43,34,244,.5)">S</text>';
          s += '<text x="'+(cx-rRose-4)+'" y="'+(cy+3)+'" text-anchor="end" font-size="8" font-weight="700" fill="rgba(43,34,244,.5)">W</text>';
          s += '<text x="'+(cx+rRose+4)+'" y="'+(cy+3)+'" text-anchor="start" font-size="8" font-weight="700" fill="rgba(43,34,244,.5)">E</text>';
          // Tick marks every 45°
          for (var ang = 0; ang < 360; ang += 45) {
            var ar = ang * Math.PI / 180;
            var tx1 = cx + Math.sin(ar) * (rRose - 3);
            var ty1 = cy - Math.cos(ar) * (rRose - 3);
            var tx2 = cx + Math.sin(ar) * rRose;
            var ty2 = cy - Math.cos(ar) * rRose;
            s += '<line x1="'+tx1.toFixed(1)+'" y1="'+ty1.toFixed(1)+'" x2="'+tx2.toFixed(1)+'" y2="'+ty2.toFixed(1)+'" stroke="rgba(43,34,244,.3)" stroke-width="0.8"/>';
          }
          // Look-direction arrow (red arrow pointing N)
          s += '<g stroke="#cc4422" stroke-width="2.5" fill="#cc4422">';
          s += '<line x1="'+cx+'" y1="'+cy+'" x2="'+cx+'" y2="'+(cy-rRose+5)+'" stroke-linecap="round"/>';
          s += '<polygon points="'+cx+','+(cy-rRose+1)+' '+(cx-4)+','+(cy-rRose+8)+' '+(cx+4)+','+(cy-rRose+8)+'"/>';
          s += '</g>';
          // Elevation indicator — small arc from horizon (E side) up to
          // elevation angle, on the right side of the compass
          var arcCx = cx + rRose + 8;
          var arcCy = cy + 4;
          var arcR = 12;
          var arcStartX = arcCx;
          var arcStartY = arcCy - arcR;
          var arcEndAngle = (90 - elevDeg) * Math.PI / 180;
          var arcEndX = arcCx + arcR * Math.cos(arcEndAngle);
          var arcEndY = arcCy - arcR * Math.sin(arcEndAngle);
          // Skipping the arc ind since it crowds — use just text
          s += '<text x="'+(cx+rRose+6)+'" y="'+(cy-2)+'" font-size="9" font-weight="700" fill="#cc4422">↑'+Math.round(elevDeg)+'°</text>';
          s += '<text x="'+(cx+rRose+6)+'" y="'+(cy+8)+'" font-size="7" font-weight="600" fill="rgba(43,34,244,.5)">elev</text>';
          s += '</svg>';
