  var SLIDER = 'https://slider.cira.colostate.edu/data/json/';
  var _currentTab = 'goes';
  var _eventsLoaded = false;
  var _archiveRendered = false;
  var _allPosts = [];
  var _decodeEl = document.createElement('textarea');
  function decodeHTML(s){ _decodeEl.innerHTML = s; return _decodeEl.value; }

  function _ciraError(msg){
    var title = document.getElementById('cira-lod-title');
    var loading = document.getElementById('cira-lod-loading');
    if (title) title.textContent = msg;
    if (loading) loading.style.display = 'none';
    var archList = document.getElementById('cira-archive-list');
    if (archList) archList.innerHTML = '<div style="font-family:system-ui,sans-serif;font-size:.65rem;color:rgba(234,88,12,.7);padding:20px;text-align:center;grid-column:1/-1;">' + msg + '</div>';
  }

  // ── Tab switcher (exposed globally so onclick can reach it) ──
  window.switchCiraTab = function(tab) {
    _currentTab = tab;
    // Restore GOES satellite view when switching back to LIVE from radar
    if(tab==='goes' && typeof switchFcastRange === 'function' && typeof fcastState !== 'undefined' && fcastState.range !== 'clouds') switchFcastRange('clouds');
    // Update top-right attribution label
    var srcLink = document.getElementById('fcast-source-link');
    if(srcLink){
      if(tab==='goes'){
        srcLink.textContent='NESDIS/STAR GOES-19 | NORTHEAST • GEOCOLOR';
        srcLink.href='https://www.star.nesdis.noaa.gov/goes/index.php';
      } else if(tab==='events'){
        srcLink.textContent="RAMMB/CIRA · SATLIB ↗";
        srcLink.href='https://satlib.cira.colostate.edu';
      } else {
        srcLink.textContent='RAMMB/CIRA · SATLIB ↗';
        srcLink.href='https://satlib.cira.colostate.edu';
      }
    }
    ['goes','events','archive','radar'].forEach(function(t){
      var pane = document.getElementById('cira-pane-'+t);
      var btn  = document.querySelector('.cira-tab[data-tab="'+t+'"]');
      if(pane) { pane.style.display = (t===tab && t!=='goes') ? (t==='archive' ? 'block' : 'flex') : 'none'; }
      // Reset archive inline player back to grid when leaving archive tab
      if(t==='archive' && t!==tab){
        var archPlayer=document.getElementById('cira-arch-player');
        var archGrid=document.getElementById('cira-archive-list');
        var archVid=document.getElementById('cira-arch-video');
        if(archVid){archVid.pause();archVid.src='';}
        if(archPlayer)archPlayer.style.display='none';
        if(archGrid)archGrid.style.display='grid';
        if(btn) btn.textContent='ARCHIVE';
      }
      if(btn)  {
        btn.style.color      = t===tab ? '#fff' : 'rgba(255,255,255,.7)';
        btn.style.background = t===tab ? 'rgba(255,255,255,.18)' : 'none';
        btn.style.border     = t===tab ? '1px solid rgba(255,255,255,.35)' : '1px solid transparent';
        btn.style.boxShadow  = t===tab ? 'inset 0 1px 0 rgba(255,255,255,.15)' : 'none';
      }
    });
    // If clicking ARCHIVE while player is open, go back to grid
    if(tab==='archive'){
      var archPlayer=document.getElementById('cira-arch-player');
      if(archPlayer && archPlayer.style.display==='flex'){ ciraArchBack(); return; }
    }
    // Lazy-load archive + thumbnails when first visited
    if(tab==='archive' && !_archiveRendered && _allPosts.length) {
      _archiveRendered = true;
      renderArchive(_allPosts);
      fetchAndInjectThumbs(_allPosts);
    }
    // Hide radar panels + insight pill behind events/archive overlays
    var radarPanelsHidden = (tab === 'events' || tab === 'archive');
    var lp = document.getElementById('fcast-left-panel');
    var rp = document.getElementById('fcast-right-panel');
    var pb = document.getElementById('fcast-playback-bar');
    var ic = document.getElementById('fcast-img-container');
    var ciPill = document.getElementById('cloud-intel-pill');
    if (lp) lp.style.visibility = radarPanelsHidden ? 'hidden' : '';
    if (rp) rp.style.visibility = radarPanelsHidden ? 'hidden' : '';
    if (pb) pb.style.visibility = radarPanelsHidden ? 'hidden' : '';
    if (ic) ic.style.visibility = radarPanelsHidden ? 'hidden' : '';
    if (ciPill) ciPill.style.visibility = radarPanelsHidden ? 'hidden' : '';
  };

  function parseGoesTs(ts){
    var s=String(ts);
    if(s.length<12)return s;
    return s.slice(0,4)+'-'+s.slice(4,6)+'-'+s.slice(6,8)+' '+s.slice(8,10)+':'+s.slice(10,12)+'z';
  }

  function minutesAgo(ts){
    var s=String(ts);
    if(s.length<12)return '';
    var d=new Date(Date.UTC(+s.slice(0,4),+s.slice(4,6)-1,+s.slice(6,8),+s.slice(8,10),+s.slice(10,12)));
    var m=Math.round((Date.now()-d)/60000);
    if(m<2)return 'live';
    if(m<60)return m+'m ago';
    return Math.round(m/60)+'h ago';
  }

  function statusColor(ts){
    var s=String(ts);
    if(s.length<12)return 'rgba(255,255,255,.3)';
    var d=new Date(Date.UTC(+s.slice(0,4),+s.slice(4,6)-1,+s.slice(6,8),+s.slice(8,10),+s.slice(10,12)));
    var m=(Date.now()-d)/60000;
    if(m<15)return '#4ade80';   // green  — fresh
    if(m<45)return '#facc15';   // yellow — aging
    return '#f87171';            // red    — stale
  }

  function extractMedia(post){
    var c=(post.content&&post.content.rendered)||'';
    var mp4=c.match(/https:\/\/[^\s"<>]+\.mp4/);
    var img=c.match(/https:\/\/[^\s"<>]+\.(?:jpg|jpeg|png|webp)/i);
    var thumb=img?img[0]:null;
    // Get thumbnail from _embedded featured media
    try{
      var fm=post._embedded&&post._embedded['wp:featuredmedia'];
      if(fm&&fm[0]){
        var sz=(fm[0].media_details&&fm[0].media_details.sizes)||{};
        thumb=(sz.medium&&sz.medium.source_url)||(sz.large&&sz.large.source_url)||
              (sz.thumbnail&&sz.thumbnail.source_url)||(sz.full&&sz.full.source_url)||fm[0].source_url||thumb;
      }
    }catch(e){}
    // Extract description from content
    var desc = '';
    var descMatch = c.match(/<p[^>]*class="[^"]*video_description[^"]*"[^>]*>([\s\S]*?)<\/p>/i);
    if (descMatch) desc = decodeHTML(descMatch[1].replace(/<[^>]+>/g,'').trim());
    // Extract source/instrument from content
    var srcMatch = c.match(/Daily loop from:[^<]*<a[^>]*>([^<]+)<\/a>/i);
    var instrument = srcMatch ? decodeHTML(srcMatch[1].trim()) : '';
    // Extract topic + author from embedded terms
    var topic = '', author = '';
    try {
      var terms = (post._embedded && post._embedded['wp:term']) || [];
      terms.forEach(function(group){
        if (!group) return;
        group.forEach(function(t){
          if (t.taxonomy === 'lod_topics' && !topic) topic = t.name;
          if (t.taxonomy === 'author' && !author) author = t.name;
        });
      });
    } catch(e){}
    // Human-readable date
    var dateStr = post.date ? post.date.slice(0,10) : '';
    var datePretty = '';
    if (post.date) {
      var d = new Date(post.date);
      var months = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      datePretty = months[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
    }
    return{
      mp4:mp4?mp4[0]:null,
      img:thumb,
      mediaId:post.featured_media||0,
      title:decodeHTML((post.title&&post.title.rendered)?post.title.rendered:''),
      date:dateStr,
      datePretty:datePretty,
      link:post.link||'https://satlib.cira.colostate.edu',
      description:desc,
      instrument:instrument || topic,
      author:author
    };
  }

  // Fetch all thumbnails in one batched request, inject into rendered cards
  function fetchAndInjectThumbs(posts){
    var ids=posts.map(function(p){return p.featured_media||0;}).filter(Boolean);
    if(!ids.length)return;
    var thumbUrl=SATLIB+'media?include='+ids.join(',')+'&_fields=id,source_url,media_details&per_page='+ids.length;
    console.log('[CIRA] fetching thumbs:',thumbUrl,'ids:',ids);
    fetch(thumbUrl)
      .then(function(r){console.log('[CIRA] thumb response:',r.status,r.ok);return r.json();})
      .then(function(items){
        console.log('[CIRA] thumb items received:',items.length,items[0]);
        var map={};
        items.forEach(function(m){
          var sz=(m.media_details&&m.media_details.sizes)||{};
          map[m.id]=(sz.medium&&sz.medium.source_url)||(sz.large&&sz.large.source_url)||
                    (sz.thumbnail&&sz.thumbnail.source_url)||(sz.full&&sz.full.source_url)||m.source_url||'';
        });
        console.log('[CIRA] thumb map:',map);
        window._ciraThumbMap=map;
        injectThumbs();
      }).catch(function(e){console.error('[CIRA thumbs FAILED]',e);});
  }

  function injectThumbs(){
    var map=window._ciraThumbMap;
    if(!map)return;
    document.querySelectorAll('.cira-arch-card').forEach(function(card){
      var mid=parseInt(card.dataset.mediaid||0);
      var url=mid&&map[mid];
      if(!url)return;
      var thumb=card.querySelector('.cira-arch-thumb');
      if(!thumb)return;
      // Remove any existing img first
      var existing=thumb.querySelector('img');
      if(existing)existing.remove();
      var fb=thumb.querySelector('.cira-thumb-fallback');
      if(fb)fb.style.display='none';
      var img=document.createElement('img');
      img.src=url;
      img.referrerPolicy='no-referrer';
      img.style.cssText='position:absolute;inset:0;width:100%;height:100%;object-fit:cover;display:block;z-index:1;';
      img.onerror=function(){img.remove();if(fb)fb.style.display='flex';};
      thumb.insertBefore(img,thumb.firstChild);
    });
  }

  function loadLOD(m){
    var vid=document.getElementById('cira-lod-video');
    var imgEl=document.getElementById('cira-lod-img');
    var loading=document.getElementById('cira-lod-loading');
    var titleEl=document.getElementById('cira-lod-title');
    var dateEl=document.getElementById('cira-lod-date-badge');
    var srcEl=document.getElementById('cira-lod-source');
    var linkEl=document.getElementById('cira-lod-link');
    if(!vid)return;
    if(titleEl)titleEl.textContent=m.title;
    if(dateEl)dateEl.textContent=m.date;
    if(linkEl)linkEl.href=m.link;
    var srcParts = [m.instrument, m.datePretty || m.date, m.author ? 'by ' + m.author : '', 'CIRA/RAMMB'].filter(Boolean);
    if(srcEl)srcEl.textContent=srcParts.join(' · ');
    // Show description if available
    var descEl = document.getElementById('cira-lod-desc');
    if(descEl) descEl.textContent = m.description || '';
    // Also update the top-right header link to point directly to this post
    var topLink=document.getElementById('fcast-source-link');
    if(topLink && m.link){ topLink.href=m.link; }
    if(loading)loading.style.display='flex';
    if(m.mp4){
      imgEl.style.display='none';
      vid.style.display='block';
      vid.src=m.mp4; vid.load();
      vid.oncanplay=function(){if(loading)loading.style.display='none';};
      vid.onerror=function(){if(loading)loading.style.display='none';if(m.img){vid.style.display='none';imgEl.src=m.img;imgEl.style.display='block';}};
    }else if(m.img){
      vid.style.display='none';
      imgEl.src=m.img; imgEl.style.display='block';
      imgEl.onload=function(){if(loading)loading.style.display='none';};
      imgEl.onerror=function(){if(loading)loading.style.display='none';};
    }else{
      if(loading)loading.style.display='none';
    }
  }

