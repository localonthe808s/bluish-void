  display:inline-block;width:6px;height:6px;border-radius:50%;margin-left:4px;vertical-align:middle;
  animation:sh-pulse 1.5s ease infinite;
}
/* Clickable retry rows in dropdown */
.source-health-drop .sh-row.sh-clickable{cursor:pointer;border-radius:4px;padding:3px 4px;margin:0 -4px;transition:background .15s ease;}
.source-health-drop .sh-row.sh-clickable:hover{background:rgba(249,115,22,.12);}
.source-health-drop .sh-row.sh-clickable:active{background:rgba(249,115,22,.2);}
/* Clickable inline retry items */
.sh-inline .sh-item.sh-clickable{cursor:pointer;border-radius:3px;padding:1px 4px;margin:-1px 6px -1px -4px;transition:background .15s ease;}
.sh-inline .sh-item.sh-clickable:hover{background:rgba(249,115,22,.12);}
.sh-inline .sh-item.sh-clickable:active{background:rgba(249,115,22,.2);}
/* Hazard has many sources — use small dropdown */
.source-health-drop{
  position:absolute;top:calc(100% + 6px);left:0;z-index:9000;
  background:rgba(8,8,22,.94);backdrop-filter:blur(20px) saturate(140%);-webkit-backdrop-filter:blur(20px) saturate(140%);
  border:1px solid rgba(255,255,255,.08);border-radius:10px;
  padding:8px 10px;min-width:220px;max-width:320px;
  box-shadow:0 12px 48px rgba(0,0,0,.6);
  font-family:system-ui,sans-serif;
  opacity:0;transform:translateY(-4px);transition:opacity .2s ease,transform .2s ease;pointer-events:none;
  max-height:60vh;overflow-y:auto;scrollbar-width:thin;scrollbar-color:rgba(255,255,255,.12) transparent;
}
.source-health-drop.open{opacity:1;transform:translateY(0);pointer-events:auto;}
.source-health-drop .sh-row{
  display:flex;align-items:center;gap:6px;padding:3px 0;
  font-size:.42rem;font-weight:600;color:rgba(255,255,255,.7);letter-spacing:.02em;
}
.source-health-drop .sh-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}
.source-health-drop .sh-dot.ok{background:#4ade80;}
.source-health-drop .sh-dot.retry{background:#f97316;animation:sh-pulse 1.5s ease infinite;}
.source-health-drop .sh-dot.dead{background:#ef4444;}
.source-health-drop .sh-name{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.source-health-drop .sh-ago{color:rgba(255,255,255,.35);font-size:.38rem;white-space:nowrap;}
.source-health-drop .sh-retry{color:#f97316;font-size:.38rem;white-space:nowrap;}
.source-health-drop .sh-summary{
  margin-top:4px;padding-top:4px;border-top:1px solid rgba(255,255,255,.06);
  font-size:.38rem;font-weight:700;color:rgba(255,255,255,.35);letter-spacing:.06em;
}


