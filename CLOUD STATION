  // ── FORECAST POINTS (intensity-colored dots) ──
  function _fetchStormForecastPts(baseUrl, layerId, q, name) {
    monitoredFetch('nhc-fpts-' + layerId, baseUrl + layerId + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || !_hurricaneMap) return;
        var pts = gj.features.filter(function(f) {
          return f.geometry && f.geometry.type === 'Point';
        }).sort(function(a, b) {
          var ta = (a.properties || {}).TAU || (a.properties || {}).FHOUR || 0;
          var tb = (b.properties || {}).TAU || (b.properties || {}).FHOUR || 0;
          return ta - tb;
        });
        if (pts.length === 0) return;

        // Connector line behind dots
        var lineCoords = pts.map(function(f) {
          return [f.geometry.coordinates[1], f.geometry.coordinates[0]];
        });
        var connector = L.polyline(lineCoords, {
          color: 'rgba(255,255,255,0.35)', weight: 1.5, opacity: 1,
          dashArray: '4 4', lineCap: 'round', pane: 'hz-track'
        });
        connector.addTo(_hurricaneMap);
        _hurricaneLayerObjs.trackLines.push(connector);

        // Intensity dot at each forecast position
        pts.forEach(function(feat) {
          var p = feat.properties || {};
          var coords = feat.geometry.coordinates;
          var fLat = coords[1], fLon = coords[0];
          var tau = p.TAU || p.FHOUR || p.FCSTHR || 0;
          var fWind = parseInt(p.MAXWIND || p.INTENSITY || p.WINDMAX || 0);
          var fPres = p.MSLP || p.MINPRES || p.GUST || '—';
          var fColor = hurricaneIntensityColor(fWind);
          var fLabel = hurricaneCategoryLabel(fWind);
          var fCat = fWind < 34 ? 'TD' : fWind < 64 ? 'TS' : fWind < 83 ? 'C1' : fWind < 96 ? 'C2' : fWind < 113 ? 'C3' : fWind < 137 ? 'C4' : 'C5';
          var dotR = tau === 0 ? 0 : (tau <= 48 ? 7 : tau <= 96 ? 6 : 5);
          if (dotR === 0) return;

          var dotHtml = '<div style="position:relative;width:' + (dotR*2) + 'px;height:' + (dotR*2) + 'px;">' +
            '<div style="position:absolute;inset:0;border-radius:50%;background:' + fColor + ';opacity:0.25;"></div>' +
            '<div style="position:absolute;inset:2px;border-radius:50%;background:' + fColor + ';border:1.5px solid rgba(0,0,0,0.5);"></div>' +
            '<div style="position:absolute;bottom:' + (dotR*2+2) + 'px;left:50%;transform:translateX(-50%);white-space:nowrap;pointer-events:none;">' +
            '<span style="font-family:system-ui;font-size:.32rem;font-weight:700;color:' + fColor + ';text-shadow:0 0 6px #000;letter-spacing:.04em;">' + fCat + '</span>' +
            '</div>' +
            '<div style="position:absolute;top:' + (dotR*2+2) + 'px;left:50%;transform:translateX(-50%);white-space:nowrap;pointer-events:none;">' +
            '<span style="font-family:system-ui;font-size:.28rem;font-weight:600;color:rgba(255,255,255,.4);text-shadow:0 0 5px #000;">' + tau + 'h</span>' +
            '</div></div>';

          var dotIcon = L.divIcon({ className: '', html: dotHtml, iconSize: [dotR*2, dotR*2], iconAnchor: [dotR, dotR] });
          var tLabel = '+' + tau + 'h';
          var fWindMph = Math.round(fWind * 1.15);
          var validTime = '';
          if (p.VALIDTIME || p.validtime) {
            try { var vd = new Date(p.VALIDTIME || p.validtime); if (!isNaN(vd)) validTime = vd.toLocaleString('en-US', {weekday:'short', month:'short', day:'numeric', hour:'numeric', timeZoneName:'short'}); } catch(e){}
          }
          var dot = L.marker([fLat, fLon], { icon: dotIcon, zIndexOffset: 500, pane: 'hz-track' });
          dot.bindTooltip(
            '<div class="hz-tooltip">' +
            '<div class="hz-card-head"><span>' + name + ' — ' + tLabel + '</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Category</span><span class="hz-val" style="color:' + fColor + ';">' + fLabel + '</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Forecast winds</span><span class="hz-val">' + fWindMph + ' mph (' + fWind + ' kt)</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Pressure</span><span class="hz-val">' + fPres + ' mb</span></div>' +
            (validTime ? '<div class="hz-card-row"><span class="hz-label">Valid</span><span class="hz-val">' + validTime + '</span></div>' : '') +
            '<div class="hz-card-footer">NHC Official Forecast · mapservices.weather.noaa.gov</div></div>',
            { sticky: true, className: 'hz-tooltip', opacity: 1 }
          );
          dot.addTo(_hurricaneMap);
          _hurricaneLayerObjs.trackLines.push(dot);
        });
      }).catch(function(){});
  }

  // ── WATCH / WARNING ZONES ──
  function _fetchStormWatchWarn(baseUrl, layerId, q, name) {
    monitoredFetch('nhc-ww-' + layerId, baseUrl + layerId + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
        gj.features.forEach(function(feat) {
          var p = feat.properties || {};
          var sig = (p.TCWW || p.PRODTYPE || p.SIGNIF || '').toUpperCase();
          // Style by watch/warning type
          var isWarning = sig.indexOf('WARN') >= 0 || sig.indexOf('HWR') >= 0 || sig.indexOf('TWR') >= 0;
          var isHurricane = sig.indexOf('HUR') >= 0 || sig.indexOf('HWR') >= 0 || sig.indexOf('HWA') >= 0;
          var wwColor = isWarning ? (isHurricane ? '#ef4444' : '#f97316') : (isHurricane ? '#ff6b9d' : '#fbbf24');
          var wwFill  = isWarning ? (isHurricane ? 'rgba(239,68,68,0.2)' : 'rgba(249,115,22,0.15)') : (isHurricane ? 'rgba(255,107,157,0.12)' : 'rgba(251,191,36,0.1)');
          var wwLabel = isWarning ? (isHurricane ? 'HURRICANE WARNING' : 'TROPICAL STORM WARNING') : (isHurricane ? 'HURRICANE WATCH' : 'TROPICAL STORM WATCH');

          var layer = L.geoJSON(feat, {
            style: { color: wwColor, weight: 3, fillColor: wwFill, fillOpacity: 1, opacity: 0.85 },
            pane: 'hz-track'
          });
          layer.bindTooltip(
            '<div class="hz-tooltip">' +
            '<div class="hz-card-head"><span style="color:' + wwColor + ';">' + wwLabel + '</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Storm</span><span class="hz-val">' + name + '</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Type</span><span class="hz-val" style="color:' + wwColor + ';">' + (isWarning ? 'WARNING — Take action' : 'WATCH — Be prepared') + '</span></div>' +
            '<div class="hz-card-footer">NHC Official Advisory</div></div>',
            { sticky: true, className: 'hz-tooltip', opacity: 1 }
          );
          layer.addTo(_hurricaneMap);
          _hurricaneLayerObjs.conePolygons.push(layer);
        });
      }).catch(function(){});
  }

  // ── PAST TRACK (historical positions + line) ──
  function _fetchStormPastTrack(baseUrl, ptsLayerId, lineLayerId, q, name) {
    // Past track line
    monitoredFetch('nhc-pastline-' + lineLayerId, baseUrl + lineLayerId + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || !_hurricaneMap) return;
        gj.features.forEach(function(feat) {
          if (!feat.geometry) return;
          var line = L.geoJSON(feat, {
            style: { color: 'rgba(255,255,255,0.28)', weight: 1.5, opacity: 1, dashArray: '3 5', lineCap: 'round' },
            pane: 'hz-track'
          });
          line.addTo(_hurricaneMap);
          _hurricaneLayerObjs.trackLines.push(line);
        });
      }).catch(function(){});

    // Past position points
    monitoredFetch('nhc-pastpts-' + ptsLayerId, baseUrl + ptsLayerId + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || !_hurricaneMap) return;
        gj.features.forEach(function(feat) {
          if (!feat.geometry || feat.geometry.type !== 'Point') return;
          var p = feat.properties || {};
          var pWind = parseInt(p.MAXWIND || p.INTENSITY || p.maxwind || 0);
          var pColor = hurricaneIntensityColor(pWind);
          var coords = feat.geometry.coordinates;
          var dtStr = p.ADVDATE || p.DTG || p.STORMDAT || '';
          var pastDot = L.circleMarker([coords[1], coords[0]], {
            radius: 3, color: 'rgba(0,0,0,0.5)', weight: 1,
            fillColor: pColor, fillOpacity: 0.6, pane: 'hz-track'
          });
          if (dtStr || pWind) {
            var pWindMph = Math.round(pWind * 1.15);
            var timeAgo = '';
            if (dtStr) {
              try {
                var pDate = new Date(dtStr);
                if (!isNaN(pDate)) {
                  var hoursAgo = Math.round((Date.now() - pDate.getTime()) / 3600000);
                  timeAgo = hoursAgo > 0 ? ' (' + hoursAgo + 'h ago)' : '';
                }
              } catch(e){}
            }
            pastDot.bindTooltip(
              '<div class="hz-tooltip">' +
              '<div class="hz-card-head"><span>' + name + ' — Past Position</span></div>' +
              (dtStr ? '<div class="hz-card-row"><span class="hz-label">Time</span><span class="hz-val">' + dtStr + timeAgo + '</span></div>' : '') +
              '<div class="hz-card-row"><span class="hz-label">Winds</span><span class="hz-val" style="color:' + pColor + ';">' + pWindMph + ' mph (' + pWind + ' kt)</span></div>' +
              '<div class="hz-card-row"><span class="hz-label">Type</span><span class="hz-val" style="color:' + pColor + ';">' + hurricaneCategoryLabel(pWind) + '</span></div>' +
              '<div class="hz-card-row"><span class="hz-label">Position</span><span class="hz-val">' + coords[1].toFixed(1) + '°N, ' + Math.abs(coords[0]).toFixed(1) + '°W</span></div>' +
              '<div class="hz-card-footer">NHC Best Track</div></div>',
              { sticky: true, className: 'hz-tooltip', opacity: 1 }
            );
          }
          pastDot.addTo(_hurricaneMap);
          _hurricaneLayerObjs.trackLines.push(pastDot);
        });
      }).catch(function(){});
  }

  // ── FORECAST WIND RADII (34/50/64 kt wind field polygons) ──
  function _fetchStormWindRadii(baseUrl, layerId, q, name) {
    monitoredFetch('nhc-windradii-' + layerId, baseUrl + layerId + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
        // Sort so larger (34kt) radii render beneath smaller (64kt)
        var sorted = gj.features.slice().sort(function(a, b) {
          var wa = parseInt((a.properties || {}).RADII || (a.properties || {}).WINDFORCE || 34);
          var wb = parseInt((b.properties || {}).RADII || (b.properties || {}).WINDFORCE || 34);
          return wa - wb;
        });
        sorted.forEach(function(feat) {
          if (!feat.geometry) return;
          var p = feat.properties || {};
          var radii = parseInt(p.RADII || p.WINDFORCE || p.RADWIND || 34);
          var radiiColor, radiiLabel;
          if (radii >= 64) { radiiColor = 'rgba(239,68,68,0.35)'; radiiLabel = '64-kt (Hurricane Force)'; }
          else if (radii >= 50) { radiiColor = 'rgba(249,115,22,0.3)'; radiiLabel = '50-kt (Storm Force)'; }
          else { radiiColor = 'rgba(251,191,36,0.2)'; radiiLabel = '34-kt (Tropical Storm Force)'; }

          // Extract quadrant radii for detailed tooltip
          var neR = parseInt(p.NE || p.RAD1 || 0);
          var seR = parseInt(p.SE || p.RAD2 || 0);
          var swR = parseInt(p.SW || p.RAD3 || 0);
          var nwR = parseInt(p.NW || p.RAD4 || 0);
          var quadrantInfo = '';
          if (neR || seR || swR || nwR) {
            quadrantInfo = '<div class="hz-card-row"><span class="hz-label">NE / SE / SW / NW</span><span class="hz-val">' + neR + ' / ' + seR + ' / ' + swR + ' / ' + nwR + ' nm</span></div>';
            // Flag asymmetry — the dangerous semicircle
            var maxQ = Math.max(neR, seR, swR, nwR);
            var minQ = Math.min(neR || 999, seR || 999, swR || 999, nwR || 999);
            if (maxQ > 0 && minQ < 999 && maxQ > minQ * 1.5) {
              var dangerSide = maxQ === neR ? 'NE' : maxQ === seR ? 'SE' : maxQ === swR ? 'SW' : 'NW';
              quadrantInfo += '<div style="font-size:.38rem;color:rgba(255,255,255,.35);margin-top:2px;font-style:italic;">Strongest winds ' + dangerSide + ' quadrant (right-front)</div>';
            }
          }

          var layer = L.geoJSON(feat, {
            style: {
              color: radiiColor.replace(/[\d.]+\)$/, '0.7)'),
              weight: 1, fillColor: radiiColor, fillOpacity: 1,
              dashArray: radii >= 64 ? '' : '4 3'
            },
            pane: 'hz-track'
          });
          layer.bindTooltip(
            '<div class="hz-tooltip">' +
            '<div class="hz-card-head"><span>' + name + ' Wind Field</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Radii</span><span class="hz-val" style="color:' + radiiColor.replace(/[\d.]+\)$/, '1)') + ';">' + radiiLabel + '</span></div>' +
            quadrantInfo +
            '<div class="hz-card-footer">NHC Forecast Wind Radii · mapservices.weather.noaa.gov</div></div>',
            { sticky: true, className: 'hz-tooltip', opacity: 1 }
          );
          layer.addTo(_hurricaneMap);
          _hurricaneLayerObjs.conePolygons.push(layer);
        });
      }).catch(function(){});
  }

  // ── STORM SURGE INUNDATION OVERLAY (raster from NHC MapServer) ──────────────
  // NHC publishes P-Surge inundation rasters per storm slot when surge watches/warnings are active
  // ── FORECAST WIND FIELD — wind radii at future tau positions ────────────────
  // Layer +13 (Advisory Wind Field) contains wind radii polygons at each forecast hour,
  // showing how the wind field expands/contracts as the storm evolves. This is critical
  // for professionals assessing when tropical storm and hurricane force winds arrive.
  // ── ARRIVAL TIME OF TROPICAL STORM FORCE WINDS ──────────────────────────────
  // Layers +15 (earliest reasonable) and +16 (most likely) show contours of when
  // TS-force winds (34kt+) are expected to arrive. This is the single most actionable
  // product for emergency managers — it answers "when do I need to be done preparing?"
  function _fetchWindArrivalTime(baseUrl, earlyLyrId, likelyLyrId, q, name) {
    // Fetch "most likely" arrival time contours
    monitoredFetch('nhc-arrival-' + likelyLyrId, baseUrl + likelyLyrId + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
        gj.features.forEach(function(feat) {
          if (!feat.geometry) return;
          var p = feat.properties || {};
          // Arrival time fields vary: STARTTIME, ARRTIME, LABEL, etc.
          var label = p.LABEL || p.STARTTIME || p.ARRTIME || '';
          var hours = parseInt(p.HOURS || p.TAU || 0);

          // Color by urgency — sooner = more urgent
          var arrColor, arrFill;
          if (hours <= 12) { arrColor = 'rgba(239,68,68,.7)'; arrFill = 'rgba(239,68,68,.12)'; }
          else if (hours <= 24) { arrColor = 'rgba(249,115,22,.6)'; arrFill = 'rgba(249,115,22,.08)'; }
          else if (hours <= 36) { arrColor = 'rgba(251,191,36,.5)'; arrFill = 'rgba(251,191,36,.06)'; }
          else if (hours <= 48) { arrColor = 'rgba(103,232,249,.4)'; arrFill = 'rgba(103,232,249,.04)'; }
          else { arrColor = 'rgba(139,92,246,.3)'; arrFill = 'rgba(139,92,246,.03)'; }

          var layer = L.geoJSON(feat, {
            style: { color: arrColor, weight: 1.5, fillColor: arrFill, fillOpacity: 1, dashArray: '5 3' },
            pane: 'hz-track'
          });
          layer.bindTooltip(
            '<div class="hz-tooltip">' +
            '<div class="hz-card-head"><span style="color:' + arrColor + ';">TS Wind Arrival — ' + name + '</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Arrival</span><span class="hz-val">' + (label || ('Within ' + hours + 'h')) + '</span></div>' +
            (hours > 0 ? '<div class="hz-card-row"><span class="hz-label">Urgency</span><span class="hz-val" style="color:' + arrColor + ';">' + (hours <= 12 ? 'IMMINENT — shelter now' : hours <= 24 ? 'URGENT — final preparations' : hours <= 36 ? 'PREPARE — secure property' : hours <= 48 ? 'PLAN — review supplies & routes' : 'MONITOR — stay informed') + '</span></div>' : '') +
            '<div class="hz-card-footer">Most likely arrival of 34-kt (TS force) winds · NHC</div></div>',
            { sticky: true, className: 'hz-tooltip', opacity: 1 }
          );
          layer.addTo(_hurricaneMap);
          _hurricaneLayerObjs.conePolygons.push(layer);
        });
      }).catch(function(){});

    // Also fetch "earliest reasonable" — thinner, more transparent
    monitoredFetch('nhc-arrival-early-' + earlyLyrId, baseUrl + earlyLyrId + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
        gj.features.forEach(function(feat) {
          if (!feat.geometry) return;
          var p = feat.properties || {};
          var hours = parseInt(p.HOURS || p.TAU || 0);
          var layer = L.geoJSON(feat, {
            style: { color: 'rgba(255,255,255,.15)', weight: 0.8, fillColor: 'rgba(255,255,255,.02)', fillOpacity: 1, dashArray: '3 4' },
            pane: 'hz-track'
          });
          layer.bindTooltip(
            '<div class="hz-tooltip">' +
            '<div class="hz-card-head"><span>Earliest Possible TS Winds — ' + name + '</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Could arrive</span><span class="hz-val">' + (hours > 0 ? 'As early as ' + hours + 'h' : 'Unknown') + '</span></div>' +
            '<div style="font-size:.38rem;color:rgba(255,255,255,.4);margin-top:3px;">Worst-case timing assuming faster/closer track. Plan for this, hope for the most-likely contour.</div>' +
            '<div class="hz-card-footer">Earliest reasonable arrival · NHC</div></div>',
            { sticky: true, className: 'hz-tooltip', opacity: 1 }
          );
          layer.addTo(_hurricaneMap);
          _hurricaneLayerObjs.conePolygons.push(layer);
        });
      }).catch(function(){});
  }

  // ── CUMULATIVE WIND SWATH (past wind exposure) ─────────────────────────────
  // Layer +9 shows everywhere the storm has already produced TS/hurricane-force winds.
  // Essential for post-landfall: shows the damage footprint, not just the track.
  function _fetchCumulativeWindSwath(baseUrl, layerId, q, name) {
    monitoredFetch('nhc-windswath-' + layerId, baseUrl + layerId + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
        // Sort so larger (34kt) swath renders beneath smaller (64kt)
        var sorted = gj.features.slice().sort(function(a, b) {
          var wa = parseInt((a.properties || {}).RADII || (a.properties || {}).WINDFORCE || 34);
          var wb = parseInt((b.properties || {}).RADII || (b.properties || {}).WINDFORCE || 34);
          return wa - wb;
        });
        sorted.forEach(function(feat) {
          if (!feat.geometry) return;
          var p = feat.properties || {};
          var radii = parseInt(p.RADII || p.WINDFORCE || p.SWATH || 34);
          var swathColor, swathLabel;
          if (radii >= 64) { swathColor = 'rgba(239,68,68,0.18)'; swathLabel = 'Hurricane-force winds experienced'; }
          else if (radii >= 50) { swathColor = 'rgba(249,115,22,0.12)'; swathLabel = 'Storm-force winds experienced'; }
          else { swathColor = 'rgba(251,191,36,0.08)'; swathLabel = 'TS-force winds experienced'; }

          var layer = L.geoJSON(feat, {
            style: {
              color: swathColor.replace(/[\d.]+\)$/, '0.4)'),
              weight: 0.5, fillColor: swathColor, fillOpacity: 1
            },
            pane: 'hz-track'
          });
          layer.bindTooltip(
            '<div class="hz-tooltip">' +
            '<div class="hz-card-head"><span>' + name + ' — Wind History Swath</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Exposure</span><span class="hz-val">' + swathLabel + '</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Wind threshold</span><span class="hz-val">' + radii + ' kt (' + Math.round(radii * 1.15) + ' mph)</span></div>' +
            '<div class="hz-card-footer">Cumulative wind swath — areas already impacted</div></div>',
            { sticky: true, className: 'hz-tooltip', opacity: 1 }
          );
          layer.addTo(_hurricaneMap);
          _hurricaneLayerObjs.conePolygons.push(layer);
        });
      }).catch(function(){});
  }

  function _fetchForecastWindField(baseUrl, layerId, q, name) {
    monitoredFetch('nhc-windfield-' + layerId, baseUrl + layerId + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
        // Group by tau and sort so earlier tau renders first (beneath later)
        var byTau = {};
        gj.features.forEach(function(feat) {
          if (!feat.geometry) return;
          var p = feat.properties || {};
          var tau = parseInt(p.TAU || p.FHOUR || p.FCSTHR || 0);
          if (tau <= 0) return; // Current position radii handled by _fetchStormWindRadii
          if (!byTau[tau]) byTau[tau] = [];
          byTau[tau].push(feat);
        });

        var taus = Object.keys(byTau).map(Number).sort(function(a,b){return a-b;});
        taus.forEach(function(tau) {
          var feats = byTau[tau];
          // Opacity fades with time — nearby forecast hours are more certain
          var fadeOpacity = tau <= 24 ? 0.5 : tau <= 48 ? 0.35 : tau <= 72 ? 0.2 : 0.12;

          feats.forEach(function(feat) {
            var p = feat.properties || {};
            var radii = parseInt(p.RADII || p.WINDFORCE || p.RADWIND || 34);

            // Only show 34kt (TS force) and 64kt (hurricane force) at future positions
            // 50kt is too much visual clutter for forecast hours
            if (radii !== 34 && radii < 64) return;

            var radiiColor, radiiLabel;
            if (radii >= 64) { radiiColor = 'rgba(239,68,68,' + (fadeOpacity * 0.6) + ')'; radiiLabel = '64-kt Hurricane Force'; }
            else { radiiColor = 'rgba(251,191,36,' + (fadeOpacity * 0.4) + ')'; radiiLabel = '34-kt TS Force'; }

            var layer = L.geoJSON(feat, {
              style: {
                color: radiiColor.replace(/[\d.]+\)$/, (fadeOpacity * 0.8) + ')'),
                weight: 0.5, fillColor: radiiColor, fillOpacity: 1,
                dashArray: '3 3'
              },
              pane: 'hz-track'
            });
            layer.bindTooltip(
              '<div class="hz-tooltip">' +
              '<div class="hz-card-head"><span>' + name + ' Wind Field — +' + tau + 'h</span></div>' +
              '<div class="hz-card-row"><span class="hz-label">Radii</span><span class="hz-val">' + radiiLabel + '</span></div>' +
              '<div class="hz-card-row"><span class="hz-label">Forecast hour</span><span class="hz-val">+' + tau + 'h</span></div>' +
              '<div class="hz-card-footer">NHC Advisory Wind Field · Forecast radii at +' + tau + 'h</div></div>',
              { sticky: true, className: 'hz-tooltip', opacity: 1 }
            );
            layer.addTo(_hurricaneMap);
            _hurricaneLayerObjs.conePolygons.push(layer);
          });
        });
      }).catch(function(){});
  }

  function _fetchStormSurgeInundation(baseUrl, layerId, bin, name) {
    if (!_hurricaneMap) return;
    monitoredFetch('nhc-surge-' + bin, baseUrl + layerId + '?f=json')
      .then(function(r){ return r.json(); })
      .then(function(info) {
        if (!info || !info.extent || !info.extent.xmin) return;
        var ext = info.extent;
        if (Math.abs(ext.xmax - ext.xmin) < 0.01) return;

        var bounds = [[ext.ymin, ext.xmin], [ext.ymax, ext.xmax]];
        var surgeUrl = baseUrl + 'export?bbox=' + ext.xmin + ',' + ext.ymin + ',' + ext.xmax + ',' + ext.ymax +
          '&layers=show:' + layerId + '&size=1024,768&format=png32&transparent=true&f=image&bboxSR=4326&imageSR=4326';

        var surgeOverlay = L.imageOverlay(surgeUrl, bounds, {
          opacity: 0.7, pane: 'hz-track', interactive: false
        });
        surgeOverlay.addTo(_hurricaneMap);
        _hurricaneLayerObjs.conePolygons.push(surgeOverlay);

        // Surge legend
        if (!document.getElementById('hz-surge-legend')) {
          var ld = document.createElement('div');
          ld.id = 'hz-surge-legend';
          ld.style.cssText = 'padding:8px 13px;border-top:1px solid rgba(239,68,68,.15);';
          ld.innerHTML =
            '<div style="font-size:.5rem;font-weight:900;color:#ef4444;letter-spacing:.08em;margin-bottom:5px;">⚠ STORM SURGE — ' + name + '</div>' +
            '<div style="display:flex;flex-direction:column;gap:2px;">' +
            '<div style="display:flex;align-items:center;gap:5px;"><span style="display:inline-block;width:16px;height:8px;background:#7f1d1d;border-radius:2px;"></span><span style="font-size:.42rem;color:rgba(255,255,255,.7);">9+ ft — Catastrophic</span></div>' +
            '<div style="display:flex;align-items:center;gap:5px;"><span style="display:inline-block;width:16px;height:8px;background:#ef4444;border-radius:2px;"></span><span style="font-size:.42rem;color:rgba(255,255,255,.7);">6–9 ft — Life-threatening</span></div>' +
            '<div style="display:flex;align-items:center;gap:5px;"><span style="display:inline-block;width:16px;height:8px;background:#f97316;border-radius:2px;"></span><span style="font-size:.42rem;color:rgba(255,255,255,.7);">3–6 ft — Dangerous</span></div>' +
            '<div style="display:flex;align-items:center;gap:5px;"><span style="display:inline-block;width:16px;height:8px;background:#ffffcc;border-radius:2px;"></span><span style="font-size:.42rem;color:rgba(255,255,255,.7);">1–3 ft — Moderate</span></div>' +
            '</div>' +
            '<div style="margin-top:3px;font-size:.32rem;color:rgba(255,255,255,.25);line-height:1.4;">Above ground level · Follow evacuation orders</div>';
          var dynSlot = document.getElementById('hz-leg-dynamic');
          if (dynSlot) dynSlot.appendChild(ld);
          else { var mc = document.getElementById('hazard-hurricane-container'); if (mc) mc.appendChild(ld); }
        }
        console.log('Storm surge inundation loaded for', name);
      }).catch(function(){});
  }

  // ══════════════════════════════════════════════════════════════════════════════
  // PROFESSIONAL HURRICANE INTELLIGENCE — Rainfall, Tornado, Recon, Wind Probs
  // ══════════════════════════════════════════════════════════════════════════════

  // ── 1. WIND SPEED PROBABILITY CONTOURS (34/50/64 kt) ──────────────────────
  // NHC publishes cumulative wind speed probabilities as GIS layers
  // Source: mapservices.weather.noaa.gov tropical cyclone wind speed probabilities
  var _windProbLayers = [];
  function _fetchWindProbability(name) {
    // Clean previous
    _windProbLayers.forEach(function(l){ try{ _hurricaneMap.removeLayer(l); }catch(e){} });
    _windProbLayers = [];
    if (!_hurricaneMap) return;

    var wsBase = 'https://mapservices.weather.noaa.gov/tropical/rest/services/tropical/NHC_tropical_weather/MapServer/';
    // Layers 0-3 are the TC wind speed probability layers (basin-wide):
    // 0 = Initial condition, 1 = 34kt cumulative, 2 = 50kt cumulative, 3 = 64kt cumulative
    var probLayers = [
      { id: 1, label: '34-kt (TS Force)', threshold: 34, color: '#fbbf24', minOpacity: 0.06 },
      { id: 2, label: '50-kt (Storm Force)', threshold: 50, color: '#f97316', minOpacity: 0.05 },
      { id: 3, label: '64-kt (Hurricane Force)', threshold: 64, color: '#ef4444', minOpacity: 0.04 }
    ];

    probLayers.forEach(function(pl) {
      var url = wsBase + pl.id + '/query?where=1%3D1&outFields=*&f=geojson&outSR=4326';
      monitoredFetch('nhc-windprob-' + pl.id, url)
        .then(function(r){ return r.json(); })
        .then(function(gj) {
          if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
          gj.features.forEach(function(feat) {
            if (!feat.geometry) return;
            var p = feat.properties || {};
            // Probability percentage — field names vary: PERCENTAGE, PROB, CUM_PROB
            var pct = parseFloat(p.PERCENTAGE || p.PROB || p.CUM_PROB || p.CUMPROB || 0);
            if (pct < 10) return; // Skip negligible probabilities

            // Opacity scales with probability
            var opacity = Math.max(pl.minOpacity, Math.min(0.35, pct / 200));
            var layer = L.geoJSON(feat, {
              style: {
                color: pl.color, weight: 0.5, opacity: 0.4,
                fillColor: pl.color, fillOpacity: opacity
              },
              pane: 'hz-track'
            });
            layer.bindTooltip(
              '<div class="hz-tooltip">' +
              '<div class="hz-card-head"><span style="color:' + pl.color + ';">Wind Probability — ' + pl.label + '</span></div>' +
              '<div class="hz-card-row"><span class="hz-label">Probability</span><span class="hz-val" style="color:' + pl.color + ';">' + pct.toFixed(0) + '%</span></div>' +
              '<div class="hz-card-row"><span class="hz-label">Threshold</span><span class="hz-val">' + pl.threshold + ' kt (' + Math.round(pl.threshold * 1.15) + ' mph)</span></div>' +
              '<div class="hz-card-footer">Cumulative probability through 120h · NHC Wind Speed Probabilities</div></div>',
              { sticky: true, className: 'hz-tooltip', opacity: 1 }
            );
            layer.addTo(_hurricaneMap);
            _windProbLayers.push(layer);
          });
        }).catch(function(){});
    });
  }

  // ── 2. WPC EXCESSIVE RAINFALL OUTLOOK ──────────────────────────────────────
  // Weather Prediction Center issues Excessive Rainfall Outlooks (ERO) for Days 1-3
  // These directly address the #1 TC killer: inland flooding from torrential rain
  var _qpfLayers = [];
  function _fetchWPCExcessiveRainfall(name) {
    _qpfLayers.forEach(function(l){ try{ _hurricaneMap.removeLayer(l); }catch(e){} });
    _qpfLayers = [];
    if (!_hurricaneMap) return;

    // WPC ERO GIS service — Excessive Rainfall Outlook
    var eroUrl = 'https://mapservices.weather.noaa.gov/vector/rest/services/outlooks/wpc_qpf/MapServer/';
    // Layer 1 = Day 1 Excessive Rainfall, Layer 5 = Day 2, Layer 9 = Day 3
    var days = [
      { id: 1, label: 'Day 1' },
      { id: 5, label: 'Day 2' },
      { id: 9, label: 'Day 3' }
    ];
    var q = '?where=1%3D1&outFields=*&f=geojson&outSR=4326';

    // ERO risk levels and colors
    var eroColors = {
      'MRGL': { color: '#2dd4bf', label: 'Marginal', desc: 'Low chance of excessive rainfall' },
      'SLGT': { color: '#fbbf24', label: 'Slight', desc: 'Isolated flash flooding possible' },
      'MDT':  { color: '#f97316', label: 'Moderate', desc: 'Scattered flash flooding likely' },
      'HIGH': { color: '#ef4444', label: 'High', desc: 'Numerous instances of flash flooding' }
    };

    days.forEach(function(day) {
      monitoredFetch('wpc-ero-' + day.id, eroUrl + day.id + '/query' + q)
        .then(function(r){ return r.json(); })
        .then(function(gj) {
          if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
          gj.features.forEach(function(feat) {
            if (!feat.geometry) return;
            var p = feat.properties || {};
            var cat = (p.OUTLOOK || p.CAT || p.CATEGORY || p.IDPCAT || '').toUpperCase().trim();
            // Try to match to ERO category
            var ero = null;
            Object.keys(eroColors).forEach(function(k) {
              if (cat.indexOf(k) >= 0) ero = eroColors[k];
            });
            if (!ero) {
              // Try to infer from label/description
              var label = (p.LABEL || p.NAME || cat || '').toUpperCase();
              if (label.indexOf('HIGH') >= 0) ero = eroColors['HIGH'];
              else if (label.indexOf('MODERATE') >= 0 || label.indexOf('MDT') >= 0) ero = eroColors['MDT'];
              else if (label.indexOf('SLIGHT') >= 0 || label.indexOf('SLGT') >= 0) ero = eroColors['SLGT'];
              else if (label.indexOf('MARGINAL') >= 0 || label.indexOf('MRGL') >= 0) ero = eroColors['MRGL'];
              else ero = { color: '#a3a3a3', label: cat || 'Unknown', desc: '' };
            }

            var layer = L.geoJSON(feat, {
              style: {
                color: ero.color, weight: 1.5, opacity: 0.6,
                fillColor: ero.color, fillOpacity: 0.15,
                dashArray: '6 3'
              },
              pane: 'hz-track'
            });
            layer.bindTooltip(
              '<div class="hz-tooltip">' +
              '<div class="hz-card-head"><span style="color:' + ero.color + ';">Excessive Rainfall — ' + day.label + '</span></div>' +
              '<div class="hz-card-row"><span class="hz-label">Risk</span><span class="hz-val" style="color:' + ero.color + ';font-weight:800;">' + ero.label + '</span></div>' +
              (ero.desc ? '<div class="hz-card-row"><span class="hz-label">Meaning</span><span class="hz-val">' + ero.desc + '</span></div>' : '') +
              (name ? '<div class="hz-card-row"><span class="hz-label">Associated TC</span><span class="hz-val">' + name + '</span></div>' : '') +
              '<div style="font-size:.36rem;color:rgba(255,255,255,.3);margin-top:3px;line-height:1.4;">Flooding is the #1 killer in tropical cyclones. Rainfall often extends 300+ miles from storm center.</div>' +
              '<div class="hz-card-footer">WPC Excessive Rainfall Outlook · weather.gov</div></div>',
              { sticky: true, className: 'hz-tooltip', opacity: 1 }
            );
            layer.addTo(_hurricaneMap);
            _qpfLayers.push(layer);
          });
        }).catch(function(e){ console.warn('WPC ERO fetch failed:', e.message); });
    });
  }

  // ── 3. SPC TORNADO OUTLOOK PROBABILITIES ───────────────────────────────────
  // Landfalling hurricanes spawn tornadoes in the right-front quadrant.
  // SPC Day 1/2 tornado probability contours show where this risk is elevated.
  var _tornadoLayers = [];
  function _fetchSPCTornadoOutlook(name) {
    _tornadoLayers.forEach(function(l){ try{ _hurricaneMap.removeLayer(l); }catch(e){} });
    _tornadoLayers = [];
    if (!_hurricaneMap) return;

    // SPC Day 1 probabilistic tornado outlook
    var spcUrl = 'https://www.spc.noaa.gov/products/outlook/day1otlk_torn.nolyr.geojson';
    monitoredFetch('spc-tornado-d1', spcUrl)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
        gj.features.forEach(function(feat) {
          if (!feat.geometry) return;
          var p = feat.properties || {};
          var pct = parseFloat(p.LABEL || p.LABEL2 || p.DN || 0);
          var isSig = (p.LABEL || '').toString().indexOf('SIGN') >= 0 || (p.LABEL || '').toString().indexOf('sig') >= 0;

          // SPC tornado probability coloring
          var torColor, torLabel;
          if (pct >= 30 || isSig) { torColor = '#dc2626'; torLabel = pct + '% — Significant tornado risk'; }
          else if (pct >= 15) { torColor = '#f97316'; torLabel = pct + '% — Enhanced tornado risk'; }
          else if (pct >= 10) { torColor = '#fbbf24'; torLabel = pct + '% — Moderate tornado risk'; }
          else if (pct >= 5) { torColor = '#a3e635'; torLabel = pct + '% — Slight tornado risk'; }
          else if (pct >= 2) { torColor = '#2dd4bf'; torLabel = pct + '% — Marginal tornado risk'; }
          else { torColor = '#94a3b8'; torLabel = (pct || '?') + '% probability'; }

          var layer = L.geoJSON(feat, {
            style: {
              color: torColor, weight: 2, opacity: 0.6,
              fillColor: torColor, fillOpacity: 0.12
            },
            pane: 'hz-track'
          });
          layer.bindTooltip(
            '<div class="hz-tooltip">' +
            '<div class="hz-card-head"><span style="color:' + torColor + ';">Tornado Outlook — Day 1</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Probability</span><span class="hz-val" style="color:' + torColor + ';">' + torLabel + '</span></div>' +
            (name ? '<div class="hz-card-row"><span class="hz-label">TC influence</span><span class="hz-val">' + name + ' outer bands</span></div>' : '') +
            '<div style="font-size:.36rem;color:rgba(255,255,255,.3);margin-top:3px;line-height:1.4;">TC tornadoes typically form in the right-front quadrant rainbands. They can develop rapidly with minimal warning time.</div>' +
            '<div class="hz-card-footer">SPC Day 1 Probabilistic Tornado Outlook · spc.noaa.gov</div></div>',
            { sticky: true, className: 'hz-tooltip', opacity: 1 }
          );
          layer.addTo(_hurricaneMap);
          _tornadoLayers.push(layer);
        });
      }).catch(function(e){ console.warn('SPC tornado fetch failed:', e.message); });
  }

  // ── 4. HURRICANE HUNTER RECON DATA ─────────────────────────────────────────
  // NOAA/USAF Hurricane Hunters transmit real-time vortex data messages (VDMs)
  // and high-density observations (HDOBs). These contain actual measured eye
  // pressures and flight-level winds — the ground truth for intensification.
  var _reconLayers = [];
  function _fetchReconData(name) {
    _reconLayers.forEach(function(l){ try{ _hurricaneMap.removeLayer(l); }catch(e){} });
    _reconLayers = [];
    if (!_hurricaneMap) return;

    // NHC publishes recon data as a JSON feed
    var reconUrl = 'https://www.nhc.noaa.gov/recon/ReconData.json';
    monitoredFetch('nhc-recon', reconUrl, { timeout: 8000 })
      .then(function(r) {
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      })
      .then(function(data) {
        if (!data || !_hurricaneMap) return;
        // Data structure varies — could be array of missions or object with missions key
        var missions = Array.isArray(data) ? data : (data.missions || data.Missions || data.features || []);
        if (missions.length === 0) {
          // Try alternate format — HDOB observations
          if (data.observations || data.hdobs) {
            missions = data.observations || data.hdobs;
          }
        }

        missions.forEach(function(mission) {
          var lat = parseFloat(mission.lat || mission.latitude || (mission.geometry && mission.geometry.coordinates ? mission.geometry.coordinates[1] : 0));
          var lon = parseFloat(mission.lon || mission.longitude || (mission.geometry && mission.geometry.coordinates ? mission.geometry.coordinates[0] : 0));
          if (!lat || !lon || isNaN(lat) || isNaN(lon)) return;

          var mslp = parseFloat(mission.mslp || mission.minPressure || mission.extrapolated_sfcP || 0);
          var flWind = parseFloat(mission.flightLevelWind || mission.maxFlWind || mission.maxSfcWind || 0);
          var sfcWind = parseFloat(mission.maxSfcWind || mission.peakSfc || 0);
          var aircraft = mission.aircraft || mission.callSign || mission.plane || 'N/A';
          var time = mission.time || mission.obsTime || mission.date || '';

          var marker = L.circleMarker([lat, lon], {
            radius: 5, fillColor: '#c084fc', color: '#a855f7',
            weight: 1.5, fillOpacity: 0.7, pane: 'hz-track'
          });
          var tip = '<div class="hz-tooltip">' +
            '<div class="hz-card-head"><span style="color:#c084fc;">Recon Observation</span></div>';
          if (aircraft && aircraft !== 'N/A') tip += '<div class="hz-card-row"><span class="hz-label">Aircraft</span><span class="hz-val">' + aircraft + '</span></div>';
          if (time) tip += '<div class="hz-card-row"><span class="hz-label">Time</span><span class="hz-val">' + time + '</span></div>';
          if (mslp > 0) tip += '<div class="hz-card-row"><span class="hz-label">Extrapolated MSLP</span><span class="hz-val" style="color:#f472b6;">' + mslp.toFixed(0) + ' mb</span></div>';
          if (flWind > 0) tip += '<div class="hz-card-row"><span class="hz-label">Flight-level wind</span><span class="hz-val">' + flWind.toFixed(0) + ' kt</span></div>';
          if (sfcWind > 0) tip += '<div class="hz-card-row"><span class="hz-label">Surface wind</span><span class="hz-val" style="color:' + hurricaneIntensityColor(sfcWind) + ';">' + sfcWind.toFixed(0) + ' kt (' + Math.round(sfcWind * 1.15) + ' mph)</span></div>';
          tip += '<div class="hz-card-footer">NOAA/USAF Hurricane Hunter · In-situ measurement</div></div>';

          marker.bindTooltip(tip, { sticky: true, className: 'hz-tooltip', opacity: 1 });
          marker.addTo(_hurricaneMap);
          _reconLayers.push(marker);
        });
        if (_reconLayers.length > 0) console.info('Recon: Loaded', _reconLayers.length, 'observations');
      }).catch(function(e){
        // Recon data only available during active missions — silent fail is expected
        console.debug('Recon data not available:', e.message);
      });
  }

  // ── 5. SHIPS/LGEM INTENSITY MODEL GUIDANCE (from ATCF a-deck) ─────────────
  // Extracts intensity forecasts from the same a-deck data used for track models.
  // Shows whether models expect strengthening or weakening over the next 5 days.
  // This is injected into the storm detail popup.
  function _buildIntensityGuidanceSVG(models, name) {
    // models = parsed ATCF data from _parseATCFaDeck — { TECH: [{tau,lat,lon,wind},...] }
    if (!models || Object.keys(models).length < 2) return '';

    // Priority models for intensity — different from track models
    var intensityModels = ['OFCL','HWRF','HMON','HAFS','HFSA','HFSB','AVNO','AEMN','SHIP','LGEM','DSHP','ICON','UKX','CMC','NVGM','TVCA'];
    var modelData = [];
    intensityModels.forEach(function(tech) {
      if (!models[tech] || models[tech].length < 2) return;
      var def = _ATCF_MODELS[tech] || { name: tech, color: 'rgba(255,255,255,.4)' };
      // Only include if we haven't already included this display name
      if (modelData.some(function(m){ return m.name === def.name; })) return;
      modelData.push({
        name: def.name, color: def.color,
        points: models[tech].map(function(p){ return { tau: p.tau, wind: p.wind }; })
      });
    });

    if (modelData.length < 2) return '';

    // SVG dimensions
    var w = 280, h = 90, pad = { l: 30, r: 10, t: 10, b: 18 };
    var plotW = w - pad.l - pad.r;
    var plotH = h - pad.t - pad.b;

    // Find global tau/wind ranges
    var maxTau = 0, maxWind = 0, minWind = 999;
    modelData.forEach(function(m) {
      m.points.forEach(function(p) {
        if (p.tau > maxTau) maxTau = p.tau;
        if (p.wind > maxWind) maxWind = p.wind;
        if (p.wind > 0 && p.wind < minWind) minWind = p.wind;
      });
    });
    if (maxTau === 0 || maxWind === 0) return '';
    maxWind = Math.max(maxWind, 80);
    minWind = Math.max(0, minWind - 10);

    var scaleX = function(tau) { return pad.l + (tau / maxTau) * plotW; };
    var scaleY = function(wind) { return pad.t + plotH - ((wind - minWind) / (maxWind - minWind)) * plotH; };

    var svg = '<svg width="' + w + '" height="' + h + '" viewBox="0 0 ' + w + ' ' + h + '" xmlns="http://www.w3.org/2000/svg" style="display:block;width:100%;">';

    // SS thresholds
    var thresholds = [
      { kt: 34, label: 'TS', color: 'rgba(251,191,36,.15)' },
      { kt: 64, label: 'C1', color: 'rgba(249,115,22,.12)' },
      { kt: 96, label: 'C3', color: 'rgba(239,68,68,.1)' },
      { kt: 137, label: 'C5', color: 'rgba(139,92,246,.1)' }
    ];
    thresholds.forEach(function(t) {
      if (t.kt >= minWind && t.kt <= maxWind) {
        var y = scaleY(t.kt);
        svg += '<line x1="' + pad.l + '" y1="' + y + '" x2="' + (w - pad.r) + '" y2="' + y + '" stroke="rgba(255,255,255,.08)" stroke-width="0.5" stroke-dasharray="2 2"/>';
        svg += '<text x="' + (pad.l - 3) + '" y="' + (y + 2) + '" text-anchor="end" fill="rgba(255,255,255,.2)" font-size="4" font-family="system-ui">' + t.label + '</text>';
      }
    });

    // Tau axis labels
    for (var t = 0; t <= maxTau; t += 24) {
      var tx = scaleX(t);
      svg += '<text x="' + tx + '" y="' + (h - 2) + '" text-anchor="middle" fill="rgba(255,255,255,.2)" font-size="4" font-family="system-ui">+' + t + 'h</text>';
    }

    // Model intensity lines
    modelData.forEach(function(m) {
      var d = '';
      m.points.forEach(function(p, i) {
        if (p.wind <= 0) return;
        var cmd = d === '' ? 'M' : 'L';
        d += cmd + scaleX(p.tau).toFixed(1) + ',' + scaleY(p.wind).toFixed(1) + ' ';
      });
      if (d) {
        var isOfficial = m.name === 'NHC';
        svg += '<path d="' + d.trim() + '" fill="none" stroke="' + m.color + '" stroke-width="' + (isOfficial ? '1.5' : '1') + '" opacity="' + (isOfficial ? '.8' : '.5') + '" stroke-dasharray="' + (isOfficial ? '' : '3 2') + '"/>';
      }
    });

    svg += '</svg>';
    return svg;
  }

  // ── 6. INVEST / DISTURBANCE DETAIL ─────────────────────────────────────────
  // Enhanced information for pre-TC disturbances from the GTWO product
  // Adds formation probability context and environmental analysis
  function _getInvestDetail(disturbance) {
    if (!disturbance) return null;
    var formProb2 = parseFloat(disturbance.prob2day || disturbance.twoDay || 0);
    var formProb7 = parseFloat(disturbance.prob7day || disturbance.sevenDay || 0);

    var urgency, urgColor, envFactors = [];

    if (formProb7 >= 70) {
      urgency = 'HIGH — likely to develop';
      urgColor = '#ef4444';
    } else if (formProb7 >= 40) {
      urgency = 'MEDIUM — possible development';
      urgColor = '#f97316';
    } else if (formProb7 >= 20) {
      urgency = 'LOW — development unlikely';
      urgColor = '#fbbf24';
    } else {
      urgency = 'MINIMAL';
      urgColor = 'rgba(255,255,255,.4)';
    }

    // Environmental factors assessment based on position
    var lat = parseFloat(disturbance.lat || 0);
    var lon = parseFloat(disturbance.lon || 0);
    var month = new Date().getMonth() + 1;

    if (lat >= 8 && lat <= 20 && lon >= -60 && lon <= -15) envFactors.push('MDR position — warm SSTs');
    if (lat >= 15 && lat <= 30 && lon >= -90 && lon <= -75) envFactors.push('Western Caribbean — low shear corridor');
    if (lat >= 22 && lat <= 32 && lon >= -98 && lon <= -80) envFactors.push('Gulf of Mexico — warm loop current');
    if (month >= 8 && month <= 10) envFactors.push('Peak season — favorable large-scale pattern');
    if (month >= 6 && month <= 7) envFactors.push('Early season — SAL dust may inhibit');
    if (lat > 30) envFactors.push('High latitude — increasing shear likely');

    return {
      formProb2: formProb2, formProb7: formProb7,
      urgency: urgency, urgColor: urgColor,
      envFactors: envFactors
    };
  }

  // ── MODEL TRACKS — real ATCF a-deck data with synthetic fallback ────────────
  // Primary: fetch real model tracks from NHC ATCF a-deck files (ftp.nhc.noaa.gov)
  // Fallback: if FTP unavailable, generate synthetic spread from NHC cone
  var _spaghettiLayers = [];

  // ATCF model color/name map — the models professionals track
  var _ATCF_MODELS = {
    'AVNO': { name: 'GFS',    color: '#ef4444', full: 'NCEP Global Forecast System' },
    'GFSO': { name: 'GFS',    color: '#ef4444', full: 'NCEP GFS (Older version)' },
    'AEMN': { name: 'ECMWF',  color: '#3b82f6', full: 'European Centre (Ensemble Mean)' },
    'EMXI': { name: 'ECMWF',  color: '#3b82f6', full: 'ECMWF Interpolated' },
    'HWRF': { name: 'HWRF',   color: '#22c55e', full: 'Hurricane Weather Research & Forecasting' },
    'HMON': { name: 'HMON',   color: '#f97316', full: 'Hurricanes in a Multi-scale Ocean-coupled Non-hydrostatic' },
    'HAFS': { name: 'HAFS-A', color: '#06b6d4', full: 'Hurricane Analysis & Forecast System' },
    'HFSA': { name: 'HAFS-A', color: '#06b6d4', full: 'HAFS-A (Storm-following nest)' },
    'HFSB': { name: 'HAFS-B', color: '#0ea5e9', full: 'HAFS-B (Basin-scale domain)' },
    'UKX':  { name: 'UKMET',  color: '#a855f7', full: 'UK Met Office Global' },
    'UKXI': { name: 'UKMET',  color: '#a855f7', full: 'UKMET Interpolated' },
    'CMC':  { name: 'CMC',    color: '#8b5cf6', full: 'Canadian Meteorological Centre' },
    'CMCI': { name: 'CMC',    color: '#8b5cf6', full: 'CMC Interpolated' },
    'NVGM': { name: 'NAVGEM', color: '#eab308', full: 'Navy Global Environmental Model' },
    'NGXI': { name: 'NAVGEM', color: '#eab308', full: 'NAVGEM Interpolated' },
    'COTC': { name: 'OFCL',   color: '#c4b5fd', full: 'NHC Official (prev cycle for verification)' },
    'OFCL': { name: 'NHC',    color: '#c4b5fd', full: 'NHC Official Forecast' },
    'TVCA': { name: 'Consensus', color: '#ffffff', full: 'TVCA Multi-model Consensus' },
    'ICON': { name: 'ICON',   color: '#f472b6', full: 'DWD ICON Global (Germany)' }
  };

  function _buildSpaghettiTracks(stormBin, name, color) {
    if (!_hurricaneMap) return;
    _spaghettiLayers.forEach(function(l){ try{ _hurricaneMap.removeLayer(l); }catch(e){} });
    _spaghettiLayers = [];

    // Derive ATCF ID from bin (AT1 → al01, EP3 → ep03)
    var atcfId = '';
    if (stormBin) {
      var b = stormBin.substring(0, 2).toLowerCase();
      var n = parseInt(stormBin.substring(2));
      if (b === 'at') b = 'al';
      atcfId = b + (n < 10 ? '0' : '') + n + new Date().getFullYear();
    }

    if (!atcfId) { _buildSyntheticSpaghetti(stormBin, name, color); return; }

    // Check cache first — avoid re-fetching on every 10-min refresh if data hasn't changed
    var cacheKey = '_atcfCache_' + atcfId;
    var cached = window[cacheKey];
    if (cached && cached.ts && (Date.now() - cached.ts < 600000) && cached.data) {
      _renderRealModelTracks(cached.data, name);
      console.info('ATCF: Using cached model tracks for', name);
      return;
    }

    // ── Multi-source fetch chain with retry ──
    // Source 1: NHC FTP plain text
    // Source 2: NHC FTP gzip (if plain 404s, some storms only have .gz)
    // Source 3: Retry Source 1 after 2s delay (transient failures)
    // Fallback: Synthetic spread

    var sources = [
      { url: 'https://ftp.nhc.noaa.gov/atcf/aid_public/a' + atcfId + '.dat', label: 'FTP plain', delay: 0 },
      { url: 'https://ftp.nhc.noaa.gov/atcf/aid_public/a' + atcfId + '.dat', label: 'FTP retry', delay: 2500 },
    ];

    var attemptIdx = 0;
    function tryNextSource() {
      if (attemptIdx >= sources.length) {
        console.warn('ATCF: All sources exhausted for', atcfId, '— using synthetic');
        _buildSyntheticSpaghetti(stormBin, name, color);
        return;
      }
      var src = sources[attemptIdx];
      attemptIdx++;

      var doFetch = function() {
        monitoredFetch('atcf-' + src.label.replace(/\s/g,'') + '-' + atcfId, src.url, { timeout: 10000 })
          .then(function(r) {
            if (!r.ok) throw new Error('HTTP ' + r.status);
            return r.text();
          })
          .then(function(text) {
            if (!text || text.length < 50) throw new Error('Empty response');
            var parsed = _parseATCFaDeck(text, atcfId);
            if (parsed && Object.keys(parsed).length >= 2) {
              // Cache successful result
              window[cacheKey] = { ts: Date.now(), data: parsed };
              _renderRealModelTracks(parsed, name);
              console.info('ATCF: Loaded real model tracks for', name, 'via', src.label, '—', Object.keys(parsed).length, 'models');
            } else {
              console.warn('ATCF:', src.label, '— insufficient models for', name, '(' + Object.keys(parsed||{}).length + '), trying next');
              tryNextSource();
            }
          })
          .catch(function(e) {
            console.warn('ATCF:', src.label, 'failed for', atcfId, ':', e.message);
            tryNextSource();
          });
      };

      if (src.delay > 0) {
        setTimeout(doFetch, src.delay);
      } else {
        doFetch();
      }
    }

    tryNextSource();
  }

  // ── Parse ATCF a-deck fixed-width format ──
  // Format: BASIN,CY,YYYYMMDDHH,TECHNUM/MIN,TECH,TAU,LAT(N/S),LON(E/W),VMAX,MSLP,...
  // Example: AL,09,2024100618,,AVNO,  0, 183N,  857W,  50, 1001,...
  function _parseATCFaDeck(text, stormId) {
    var models = {};
    var lines = text.split('\n');
    // Find the latest advisory DTG (most recent date-time group)
    var latestDTG = '';
    lines.forEach(function(line) {
      var parts = line.split(',');
      if (parts.length < 9) return;
      var dtg = (parts[2] || '').trim();
      if (dtg > latestDTG) latestDTG = dtg;
    });

    // Only parse lines from the latest advisory cycle
    lines.forEach(function(line) {
      var parts = line.split(',');
      if (parts.length < 9) return;

      var dtg = (parts[2] || '').trim();
      if (dtg !== latestDTG) return; // Only latest cycle

      var tech = (parts[4] || '').trim().toUpperCase();
      var tau = parseInt((parts[5] || '').trim());
      var latStr = (parts[6] || '').trim();
      var lonStr = (parts[7] || '').trim();
      var vmax = parseInt((parts[8] || '').trim());

      // Skip non-track models (statistical, probability, etc.)
      if (!_ATCF_MODELS[tech] && tech !== 'OFCL' && tech !== 'TVCA') return;
      if (isNaN(tau) || tau < 0 || tau > 168) return;

      // Parse lat/lon — format: 183N = 18.3°N, 857W = 85.7°W
      var lat = parseFloat(latStr.replace(/[NS]/i, '')) / 10;
      var lon = parseFloat(lonStr.replace(/[EW]/i, '')) / 10;
      if (latStr.toUpperCase().indexOf('S') >= 0) lat = -lat;
      if (lonStr.toUpperCase().indexOf('W') >= 0) lon = -lon;

      if (isNaN(lat) || isNaN(lon) || lat === 0 || lon === 0) return;

      if (!models[tech]) models[tech] = [];
      models[tech].push({ tau: tau, lat: lat, lon: lon, wind: vmax || 0 });
    });

    // Sort each model's points by tau
    Object.keys(models).forEach(function(tech) {
      models[tech].sort(function(a, b) { return a.tau - b.tau; });
    });

    return models;
  }

  // ── Render real ATCF model tracks on the map ──
  function _renderRealModelTracks(models, name) {
    var renderedModels = [];

    // Prioritize key models — render in order so important ones are on top
    var priority = ['OFCL','TVCA','AVNO','GFSO','AEMN','EMXI','HWRF','HMON','HAFS','HFSA','HFSB','UKX','UKXI','CMC','CMCI','NVGM','NGXI','ICON'];
    var rendered = {};

    priority.forEach(function(tech) {
      if (!models[tech] || models[tech].length < 2) return;
      var def = _ATCF_MODELS[tech] || { name: tech, color: 'rgba(255,255,255,.4)', full: tech };

      // Skip if we already rendered this model name (e.g., AVNO and GFSO are both "GFS")
      if (rendered[def.name] && tech !== 'OFCL' && tech !== 'TVCA') return;
      rendered[def.name] = true;

      var coords = models[tech].map(function(p) { return [p.lat, p.lon]; });

      // NHC official track gets a solid, thicker line; others dashed
      var isOfficial = tech === 'OFCL';
      var isConsensus = tech === 'TVCA';
      var lineStyle = {
        color: def.color,
        weight: isOfficial ? 2.5 : isConsensus ? 2 : 1.5,
        opacity: isOfficial ? 0.8 : isConsensus ? 0.7 : 0.55,
        dashArray: isOfficial ? '' : isConsensus ? '6 3' : '4 3',
        lineCap: 'round', lineJoin: 'round', pane: 'hz-track'
      };

      var line = L.polyline(coords, lineStyle);

      // Tooltip with model details
      var lastPt = models[tech][models[tech].length - 1];
      var maxTau = lastPt.tau;
      var endWind = lastPt.wind;
      line.bindTooltip(
        '<div class="hz-tooltip">' +
        '<div class="hz-card-head"><span style="color:' + def.color + ';">' + def.name + '</span></div>' +
        '<div class="hz-card-row"><span class="hz-label">Model</span><span class="hz-val">' + def.full + '</span></div>' +
        '<div class="hz-card-row"><span class="hz-label">Storm</span><span class="hz-val">' + name + '</span></div>' +
        '<div class="hz-card-row"><span class="hz-label">Forecast range</span><span class="hz-val">0–' + maxTau + 'h</span></div>' +
        (endWind > 0 ? '<div class="hz-card-row"><span class="hz-label">Winds at +' + maxTau + 'h</span><span class="hz-val" style="color:' + hurricaneIntensityColor(endWind) + ';">' + Math.round(endWind * 1.15) + ' mph (' + endWind + ' kt)</span></div>' : '') +
        '<div class="hz-card-footer">ATCF a-deck · ftp.nhc.noaa.gov · Real model output</div></div>',
        { sticky: true, className: 'hz-tooltip', opacity: 1 }
      );

      line.addTo(_hurricaneMap);
      _spaghettiLayers.push(line);
      renderedModels.push({ tech: tech, name: def.name, color: def.color, full: def.full });
    });

    // Build legend from actually-rendered models
    _buildModelTrackLegend(renderedModels, false);
  }

  // ── Build model track legend (shared by real and synthetic) ──
  function _buildModelTrackLegend(modelList, isSynthetic) {
    var existing = document.getElementById('hz-spaghetti-legend');
    if (existing) existing.remove();
    if (modelList.length === 0) return;

    var lg = document.createElement('div');
    lg.id = 'hz-spaghetti-legend';
    lg.style.cssText = 'padding:8px 13px;border-top:1px solid rgba(255,255,255,.06);';

    // Source badge — green checkmark for real data, orange warning for synthetic
    var sourceBadge = isSynthetic
      ? '<span style="display:inline-block;padding:1px 5px;border-radius:3px;background:rgba(249,115,22,.15);border:1px solid rgba(249,115,22,.3);color:#f97316;font-size:.32rem;font-weight:800;letter-spacing:.04em;margin-left:6px;">SYNTHETIC</span>'
      : '<span style="display:inline-block;padding:1px 5px;border-radius:3px;background:rgba(74,222,128,.12);border:1px solid rgba(74,222,128,.25);color:#4ade80;font-size:.32rem;font-weight:800;letter-spacing:.04em;margin-left:6px;">LIVE ATCF</span>';

    var lh = '<div style="font-size:.48rem;font-weight:900;color:rgba(255,255,255,.5);letter-spacing:.08em;margin-bottom:4px;display:flex;align-items:center;">' +
      (isSynthetic ? 'MODEL SPREAD' : 'MODEL TRACKS') + ' (' + modelList.length + ')' + sourceBadge + '</div>';
    lh += '<div style="display:flex;flex-wrap:wrap;gap:2px 10px;">';
    modelList.forEach(function(m) {
      var dashStyle = m.name === 'NHC' ? 'solid' : 'dashed';
      lh += '<div style="display:flex;align-items:center;gap:4px;" title="' + (m.full || m.name) + '"><span style="display:inline-block;width:14px;height:0;border-top:1.5px ' + dashStyle + ' ' + m.color + ';"></span><span style="font-size:.38rem;color:rgba(255,255,255,.55);">' + m.name + '</span></div>';
    });
    lh += '</div>';
    if (isSynthetic) {
      lh += '<div style="margin-top:3px;font-size:.3rem;color:rgba(249,115,22,.4);line-height:1.4;">Spread derived from NHC cone error radii · Not real model output · ATCF source unavailable</div>';
    } else {
      lh += '<div style="margin-top:3px;font-size:.3rem;color:rgba(74,222,128,.3);">ATCF a-deck · ftp.nhc.noaa.gov · Real numerical weather prediction output</div>';
    }
    lg.innerHTML = lh;
    var dynSlot = document.getElementById('hz-leg-dynamic');
    if (dynSlot) dynSlot.appendChild(lg);
    else { var mc2 = document.getElementById('hazard-hurricane-container'); if (mc2) mc2.appendChild(lg); }
  }

  // ── Synthetic fallback — used when ATCF data is unavailable ──
  function _buildSyntheticSpaghetti(stormBin, name, color) {
    if (!_hurricaneMap) return;
    var baseUrl = 'https://mapservices.weather.noaa.gov/tropical/rest/services/tropical/NHC_tropical_weather/MapServer/';
    var q = '?where=1%3D1&outFields=*&f=geojson&outSR=4326';
    var base = _NHC_STORM_LAYER_MAP[stormBin];
    if (base == null) return;

    monitoredFetch('spaghetti-pts-' + stormBin, baseUrl + (base + 2) + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(ptsGj) {
        if (!ptsGj.features || ptsGj.features.length < 2) return;

        var pts = ptsGj.features.filter(function(f){ return f.geometry && f.geometry.type === 'Point'; })
          .sort(function(a,b){ return (a.properties.tau||0)-(b.properties.tau||0); });
        if (pts.length < 2) return;

        var coneErrorNm = { 0:0, 12:25, 24:40, 36:55, 48:70, 60:90, 72:110, 96:155, 120:200 };

        var syntheticDefs = [
          { name: 'Track A', color: '#ef4444', bias: 0.6 },
          { name: 'Track B', color: '#3b82f6', bias: -0.3 },
          { name: 'Track C', color: '#22c55e', bias: 0.1 },
          { name: 'Track D', color: '#f97316', bias: -0.5 },
          { name: 'Track E', color: '#a855f7', bias: 0.4 },
          { name: 'Track F', color: '#06b6d4', bias: -0.7 },
          { name: 'Track G', color: '#eab308', bias: 0.8 }
        ];

        var seed = pts.length * 7 + parseInt((pts[0].properties.advisnum || '1').replace(/\D/g,'') || '42');
        function sRand() { seed = (seed * 16807) % 2147483647; return (seed - 1) / 2147483646; }

        syntheticDefs.forEach(function(model) {
          var trackCoords = [];
          pts.forEach(function(pt) {
            var tau = pt.properties.tau || pt.properties.fcstprd || 0;
            var lat = pt.geometry.coordinates[1];
            var lon = pt.geometry.coordinates[0];
            var taus = Object.keys(coneErrorNm).map(Number).sort(function(a,b){return a-b;});
            var err = 0;
            for (var i = 0; i < taus.length - 1; i++) {
              if (tau >= taus[i] && tau <= taus[i+1]) {
                var frac = (tau - taus[i]) / (taus[i+1] - taus[i]);
                err = coneErrorNm[taus[i]] + frac * (coneErrorNm[taus[i+1]] - coneErrorNm[taus[i]]);
                break;
              }
            }
            if (tau > taus[taus.length-1]) err = coneErrorNm[taus[taus.length-1]];
            var errDeg = err / 60;
            var spread = errDeg * 0.5;
            var angle = (model.bias + (sRand() - 0.5) * 0.8) * Math.PI;
            var tFrac = Math.min(1, tau / 120);
            trackCoords.push([lat + Math.sin(angle) * spread * tFrac, lon + Math.cos(angle) * spread * tFrac]);
          });

          if (trackCoords.length < 2) return;
          var line = L.polyline(trackCoords, {
            color: model.color, weight: 1.5, opacity: 0.5,
            dashArray: '4 3', lineCap: 'round', lineJoin: 'round', pane: 'hz-track'
          });
          line.bindTooltip(
            '<div class="hz-tooltip"><div class="hz-card-head"><span style="color:' + model.color + ';">' + model.name + '</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Storm</span><span class="hz-val">' + name + '</span></div>' +
            '<div class="hz-card-footer">Synthetic spread · ATCF data unavailable</div></div>',
            { sticky: true, className: 'hz-tooltip', opacity: 1 }
          );
          line.addTo(_hurricaneMap);
          _spaghettiLayers.push(line);
        });

        _buildModelTrackLegend(syntheticDefs.map(function(m){ return { name: m.name, color: m.color, full: 'Synthetic' }; }), true);
      }).catch(function(e){ console.warn('Synthetic spaghetti failed:', e); });
  }

  // ── RI PROBABILITY ASSESSMENT (called during storm plotting) ────────────────
  function _assessRIProbability(storm) {
    var windKt = parseInt(storm.intensity || storm.maxWinds || 0);
    var pressure = parseInt(storm.minimumPressure || storm.minPressure || 1013);
    var classification = (storm.classification || '').toUpperCase();

    var isTropical = classification.indexOf('EX') < 0 && classification.indexOf('PT') < 0 &&
                     classification.indexOf('LO') < 0 && classification.indexOf('DB') < 0;
    if (!isTropical) return { prob: 0, label: '', color: '', factors: [] };

    var riScore = 0, riFactors = [];

    // Intensity range (RI most common TS → Cat 2)
    if (windKt >= 34 && windKt < 100) {
      riScore += 15;
      if (windKt >= 50 && windKt < 80) { riScore += 10; riFactors.push('Optimal intensity range'); }
    }

    // Pressure
    if (pressure < 1000 && pressure > 940) {
      riScore += 10;
      if (pressure < 980) { riScore += 10; riFactors.push('Low central pressure'); }
    }

    // Season timing
    var month = new Date().getMonth() + 1;
    if (month >= 8 && month <= 10) { riScore += 15; riFactors.push('Peak RI season'); }
    else if (month >= 6 && month <= 11) riScore += 5;

    // Location (MDR warm water)
    var lat = parseFloat(storm.centerLocLatitude || storm.lat || 0);
    var lon = parseFloat(storm.centerLocLongitude || storm.lon || 0);
    if (lat >= 10 && lat <= 25 && lon <= -15 && lon >= -85) {
      riScore += 15; riFactors.push('Over warm MDR waters');
      if (lat >= 15 && lat <= 30 && lon >= -100 && lon <= -60) {
        riScore += 10; riFactors.push('Caribbean/Gulf warm pool');
      }
    }

    riScore = Math.min(100, Math.max(0, riScore));
    var riLabel = '', riColor = '';
    if (riScore >= 60) { riLabel = 'HIGH'; riColor = '#ef4444'; }
    else if (riScore >= 40) { riLabel = 'MODERATE'; riColor = '#f97316'; }
    else if (riScore >= 20) { riLabel = 'LOW'; riColor = '#fbbf24'; }

    return { prob: riScore, label: riLabel, color: riColor, factors: riFactors };
  }

  // ══════════════════════════════════════════════════════════════════════════════
  // TIER 2 — TCHP (Tropical Cyclone Heat Potential) OVERLAY
  // ══════════════════════════════════════════════════════════════════════════════
  // Fetches SST from Open-Meteo Marine API at a grid of points across the Atlantic/EPAC.
  // Approximates TCHP from SST using the empirical relationship:
  //   TCHP ≈ ρ × Cp × h × (SST − 26) where h ≈ mixed layer depth (approx from SST)
  //   Simplified: TCHP(kJ/cm²) ≈ 20 × (SST − 26)² for SST > 26°C (Leipper & Volgenau proxy)
  // This is a satellite-derived approximation; real TCHP uses subsurface profiles.
  // Values: <20 = marginal, 20-60 = supportive, 60-90 = favorable RI, >90 = extreme fuel
  function _fetchTCHP() {
    if (!_hurricaneMap) return;
    _hurricaneLayerObjs.tchpMarkers.forEach(function(m){ try{ _hurricaneMap.removeLayer(m); }catch(e){} });
    _hurricaneLayerObjs.tchpMarkers = [];

    // Grid: 5° spacing across tropical Atlantic + Gulf + Caribbean + EPAC
    var gridPts = [];
    for (var lat = 5; lat <= 35; lat += 4) {
      for (var lon = -140; lon <= -10; lon += 5) {
        // Only ocean (rough check: skip obvious land)
        if (lat >= 25 && lon >= -100 && lon <= -80) continue; // US interior
        if (lat >= 15 && lat <= 25 && lon >= -100 && lon <= -83) continue; // Mexico/CenAm land
        if (lat >= 5 && lat <= 12 && lon >= -82 && lon <= -68) continue; // S. America/Colombia
        gridPts.push([lat, lon]);
      }
    }

    // Batch: Open-Meteo supports one lat/lon per call, but we can batch up to ~50 points
    // by comma-separating. Do it in chunks.
    var chunkSize = 40;
    var chunks = [];
    for (var c = 0; c < gridPts.length; c += chunkSize) {
      chunks.push(gridPts.slice(c, c + chunkSize));
    }

    chunks.forEach(function(chunk) {
      var lats = chunk.map(function(p){ return p[0]; }).join(',');
      var lons = chunk.map(function(p){ return p[1]; }).join(',');
      var url = 'https://api.open-meteo.com/v1/marine?latitude=' + lats + '&longitude=' + lons +
        '&current=sea_surface_temperature&timezone=auto';

      monitoredFetch('tchp-grid', url)
        .then(function(r){ return r.json(); })
        .then(function(data) {
          if (!_hurricaneMap || !_hurricaneLayers.tchp) return;
          // Response is array when multiple coords
          var results = Array.isArray(data) ? data : [data];
          results.forEach(function(pt, idx) {
            if (!pt || !pt.current) return;
            var sst = pt.current.sea_surface_temperature;
            if (sst == null || sst < 20) return; // Skip cold/land returns
            var ptLat = chunk[idx][0], ptLon = chunk[idx][1];

            // Approximate TCHP from SST using Leipper-Volgenau proxy
            var tchp = 0;
            if (sst > 26) {
              // Empirical: TCHP ≈ k × (SST - 26)^1.5 where k ≈ 15 (calibrated to AOML climatology)
              tchp = Math.round(15 * Math.pow(sst - 26, 1.5));
            }

            // Color by TCHP value
            var fillColor, fillOpacity, radius, label;
            if (tchp >= 90)      { fillColor = '#9333ea'; fillOpacity = 0.65; radius = 12; label = 'Extreme fuel (RI likely)'; }
            else if (tchp >= 60) { fillColor = '#ef4444'; fillOpacity = 0.55; radius = 10; label = 'Favorable for RI'; }
            else if (tchp >= 40) { fillColor = '#f97316'; fillOpacity = 0.45; radius = 9;  label = 'Supportive of intensification'; }
            else if (tchp >= 20) { fillColor = '#fbbf24'; fillOpacity = 0.35; radius = 8;  label = 'Marginal support'; }
            else                 { fillColor = '#67e8f9'; fillOpacity = 0.2;  radius = 6;  label = 'Insufficient heat content'; }

            var marker = L.circleMarker([ptLat, ptLon], {
              radius: radius, color: 'rgba(0,0,0,0.3)', weight: 0.5,
              fillColor: fillColor, fillOpacity: fillOpacity, pane: 'hz-sst'
            });
            var sstF = (sst * 9/5 + 32).toFixed(1);
            var aboveThresh = sst > 26 ? (sst - 26).toFixed(1) : 0;
            marker.bindTooltip(
              '<div class="hz-tooltip">' +
              '<div class="hz-card-head"><span>Ocean Heat Content</span></div>' +
              '<div class="hz-card-row"><span class="hz-label">SST</span><span class="hz-val">' + sst.toFixed(1) + '°C (' + sstF + '°F)</span></div>' +
              (sst > 26 ? '<div class="hz-card-row"><span class="hz-label">Above 26°C threshold</span><span class="hz-val" style="color:' + fillColor + ';">+' + aboveThresh + '°C</span></div>' : '<div class="hz-card-row"><span class="hz-label">26°C threshold</span><span class="hz-val" style="color:rgba(255,255,255,.35);">Below minimum for TC support</span></div>') +
              '<div class="hz-card-row"><span class="hz-label">TCHP (est.)</span><span class="hz-val" style="color:' + fillColor + ';">' + tchp + ' kJ/cm²</span></div>' +
              '<div class="hz-card-row"><span class="hz-label">Assessment</span><span class="hz-val">' + label + '</span></div>' +
              '<div class="hz-card-footer">Open-Meteo Marine SST · Leipper-Volgenau TCHP proxy</div></div>',
              { sticky: true, className: 'hz-tooltip', opacity: 1 }
            );
            marker.addTo(_hurricaneMap);
            _hurricaneLayerObjs.tchpMarkers.push(marker);
          });

          // Add TCHP legend (once)
          if (!document.getElementById('hz-tchp-legend')) {
            var container = document.getElementById('hz-leg-dynamic') || document.getElementById('hazard-hurricane-container') || document.getElementById('hurricane-map');
            if (container) {
              var leg = document.createElement('div');
              leg.id = 'hz-tchp-legend';
              leg.style.cssText = 'padding:8px 13px;border-top:1px solid rgba(255,255,255,.06);';
              leg.innerHTML =
                '<div style="font-size:.42rem;font-weight:900;letter-spacing:.1em;color:rgba(255,255,255,.4);margin-bottom:4px;">OCEAN HEAT (TCHP)</div>' +
                '<div style="display:flex;flex-wrap:wrap;gap:2px 8px;">' +
                '<div style="display:flex;align-items:center;gap:3px;"><span style="width:8px;height:8px;border-radius:50%;background:#9333ea;display:inline-block;"></span><span style="font-size:.4rem;color:rgba(255,255,255,.6);">90+</span></div>' +
                '<div style="display:flex;align-items:center;gap:3px;"><span style="width:8px;height:8px;border-radius:50%;background:#ef4444;display:inline-block;"></span><span style="font-size:.4rem;color:rgba(255,255,255,.6);">60–90</span></div>' +
                '<div style="display:flex;align-items:center;gap:3px;"><span style="width:8px;height:8px;border-radius:50%;background:#f97316;display:inline-block;"></span><span style="font-size:.4rem;color:rgba(255,255,255,.6);">40–60</span></div>' +
                '<div style="display:flex;align-items:center;gap:3px;"><span style="width:8px;height:8px;border-radius:50%;background:#fbbf24;display:inline-block;"></span><span style="font-size:.4rem;color:rgba(255,255,255,.6);">20–40</span></div>' +
                '<div style="display:flex;align-items:center;gap:3px;"><span style="width:8px;height:8px;border-radius:50%;background:#67e8f9;display:inline-block;"></span><span style="font-size:.4rem;color:rgba(255,255,255,.6);"><20</span></div>' +
                '</div>' +
                '<div style="margin-top:3px;font-size:.3rem;color:rgba(255,255,255,.2);">kJ/cm² · 26°C isotherm depth · Open-Meteo</div>';
              container.appendChild(leg);
            }
          }
        }).catch(function(e){ console.warn('TCHP fetch error:', e); });
    });
  }

  // ══════════════════════════════════════════════════════════════════════════════
  // TIER 2 — WIND HISTORY SPARKLINE (Intensity over lifetime)
  // ══════════════════════════════════════════════════════════════════════════════
  // Fetches past track points and forecast points from NHC MapServer,
  // builds a mini SVG intensity chart showing wind speed progression.
  // Returns an SVG string for embedding in the storm detail popup.
  function _buildWindHistorySVG(stormBin, callback) {
    if (!stormBin || !_NHC_STORM_LAYER_MAP[stormBin]) { callback(''); return; }
    var base = _NHC_STORM_LAYER_MAP[stormBin];
    var baseUrl = 'https://mapservices.weather.noaa.gov/tropical/rest/services/tropical/NHC_tropical_weather/MapServer/';
    var q = '?where=1%3D1&outFields=*&f=geojson&outSR=4326';
    var pastPtsLyr = base + 7;
    var fcstPtsLyr = base + 2;

    var allPts = [];

    // Fetch past points
    var p1 = monitoredFetch('wh-past-' + stormBin, baseUrl + pastPtsLyr + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features) return;
        gj.features.forEach(function(f) {
          var p = f.properties || {};
          var w = parseInt(p.MAXWIND || p.INTENSITY || p.maxwind || 0);
          var dt = p.ADVDATE || p.DTG || p.STORMDAT || '';
          allPts.push({ wind: w, tau: null, date: dt, type: 'past' });
        });
      }).catch(function(){});

    // Fetch forecast points
    var p2 = monitoredFetch('wh-fcst-' + stormBin, baseUrl + fcstPtsLyr + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features) return;
        gj.features.forEach(function(f) {
          var p = f.properties || {};
          var w = parseInt(p.MAXWIND || p.INTENSITY || p.WINDMAX || 0);
          var tau = parseInt(p.TAU || p.FHOUR || p.FCSTHR || 0);
          allPts.push({ wind: w, tau: tau, date: '', type: 'forecast' });
        });
      }).catch(function(){});

    Promise.all([p1, p2]).then(function() {
      if (allPts.length < 2) { callback(''); return; }

      // Sort: past points first (by date or order), then forecast by tau
      var past = allPts.filter(function(p){ return p.type === 'past'; });
      var fcst = allPts.filter(function(p){ return p.type === 'forecast'; }).sort(function(a,b){ return (a.tau||0) - (b.tau||0); });
      var ordered = past.concat(fcst);

      // Build SVG sparkline
      var W = 260, H = 72, padL = 2, padR = 2, padT = 6, padB = 14;
      var n = ordered.length;
      var maxW = 0;
      ordered.forEach(function(p){ if (p.wind > maxW) maxW = p.wind; });
      maxW = Math.max(maxW, 80); // Minimum scale to Cat 1

      var xStep = (W - padL - padR) / Math.max(1, n - 1);

      // Saffir-Simpson threshold lines
      var thresholds = [
        { kt: 34, label: 'TS', color: '#67e8f9' },
        { kt: 64, label: 'Cat1', color: '#fde68a' },
        { kt: 96, label: 'C3', color: '#f97316' },
        { kt: 137, label: 'C5', color: '#9333ea' }
      ];

      var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ' + W + ' ' + H + '" style="width:100%;height:auto;display:block;margin:4px 0;">';

      // Threshold lines
      thresholds.forEach(function(t) {
        if (t.kt > maxW * 1.1) return;
        var y = padT + (1 - t.kt / (maxW * 1.15)) * (H - padT - padB);
        svg += '<line x1="' + padL + '" y1="' + y + '" x2="' + (W - padR) + '" y2="' + y + '" stroke="rgba(255,255,255,.1)" stroke-width="0.5" stroke-dasharray="2 2"/>';
        svg += '<text x="' + (W - padR - 1) + '" y="' + (y - 2) + '" fill="rgba(255,255,255,.25)" font-size="5" font-family="system-ui" text-anchor="end">' + t.label + '</text>';
      });

      // Build path
      var pathPast = '', pathFcst = '';
      var pastEnd = past.length;
      var pts = [];
      ordered.forEach(function(p, i) {
        var x = padL + i * xStep;
        var y = padT + (1 - p.wind / (maxW * 1.15)) * (H - padT - padB);
        pts.push({ x: x, y: y, wind: p.wind, type: p.type, i: i });
      });

      // Past track line
      var pastPts = pts.filter(function(p){ return p.i < pastEnd; });
      if (pastPts.length > 0) {
        pathPast = 'M' + pastPts.map(function(p){ return p.x.toFixed(1) + ',' + p.y.toFixed(1); }).join('L');
        svg += '<path d="' + pathPast + '" fill="none" stroke="rgba(255,255,255,.65)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>';
      }

      // Forecast line (dashed)
      var fcstPts = pts.filter(function(p){ return p.i >= pastEnd - 1; }); // overlap at transition
      if (fcstPts.length > 1) {
        pathFcst = 'M' + fcstPts.map(function(p){ return p.x.toFixed(1) + ',' + p.y.toFixed(1); }).join('L');
        svg += '<path d="' + pathFcst + '" fill="none" stroke="rgba(139,92,246,.6)" stroke-width="1.5" stroke-dasharray="3 2" stroke-linecap="round"/>';
      }

      // Transition marker (now → forecast)
      if (pastEnd > 0 && pastEnd < pts.length) {
        var tPt = pts[pastEnd - 1];
        svg += '<circle cx="' + tPt.x.toFixed(1) + '" cy="' + tPt.y.toFixed(1) + '" r="3" fill="#c4b5fd" stroke="rgba(0,0,0,.5)" stroke-width="0.5"/>';
        svg += '<text x="' + tPt.x.toFixed(1) + '" y="' + (H - 2) + '" fill="rgba(196,181,253,.6)" font-size="5" font-family="system-ui" text-anchor="middle">NOW</text>';
      }

      // Color dots at key positions
      pts.forEach(function(p, i) {
        if (i % Math.max(1, Math.floor(n / 10)) === 0 || i === n - 1 || i === pastEnd - 1) {
          var c = hurricaneIntensityColor(p.wind);
          svg += '<circle cx="' + p.x.toFixed(1) + '" cy="' + p.y.toFixed(1) + '" r="2" fill="' + c + '" stroke="rgba(0,0,0,.4)" stroke-width="0.4"/>';
        }
      });

      // Labels: start and end winds
      if (pts.length > 0) {
        var first = pts[0], last = pts[pts.length - 1];
        svg += '<text x="' + first.x + '" y="' + (H - 2) + '" fill="rgba(255,255,255,.4)" font-size="5" font-family="system-ui" text-anchor="start">' + first.wind + 'kt</text>';
        svg += '<text x="' + last.x + '" y="' + (H - 2) + '" fill="rgba(139,92,246,.5)" font-size="5" font-family="system-ui" text-anchor="end">' + last.wind + 'kt</text>';
      }

      svg += '</svg>';
      var peakWind = 0;
      ordered.forEach(function(p){ if (p.wind > peakWind) peakWind = p.wind; });
      callback(svg, { peakWind: peakWind, totalPts: ordered.length, pastCount: past.length, fcstCount: fcst.length });
    });
  }

  // ══════════════════════════════════════════════════════════════════════════════
  // TIER 2 — CLOSEST APPROACH CALCULATOR
  // ══════════════════════════════════════════════════════════════════════════════
  // Given forecast track points and the user's location, computes the closest
  // point of approach (CPA) with distance and estimated arrival time.
  function _computeClosestApproach(stormBin, currentLat, currentLon, callback) {
    if (!stormBin || !_NHC_STORM_LAYER_MAP[stormBin]) { callback(null); return; }
    var base = _NHC_STORM_LAYER_MAP[stormBin];
    var baseUrl = 'https://mapservices.weather.noaa.gov/tropical/rest/services/tropical/NHC_tropical_weather/MapServer/';
    var q = '?where=1%3D1&outFields=*&f=geojson&outSR=4326';
    var fcstPtsLyr = base + 2;

    var userLat = LOCATION ? LOCATION.lat : 40.7;
    var userLon = LOCATION ? LOCATION.lon : -74.0;

    monitoredFetch('cpa-fcst-' + stormBin, baseUrl + fcstPtsLyr + '/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0) { callback(null); return; }

        // Include current position (tau=0) if available, plus all forecast points
        var pts = gj.features.filter(function(f){ return f.geometry && f.geometry.type === 'Point'; })
          .map(function(f) {
            var p = f.properties || {};
            return {
              lat: f.geometry.coordinates[1],
              lon: f.geometry.coordinates[0],
              tau: parseInt(p.TAU || p.FHOUR || p.FCSTHR || 0),
              wind: parseInt(p.MAXWIND || p.INTENSITY || 0)
            };
          }).sort(function(a,b){ return a.tau - b.tau; });

        // Also compute from current storm position
        pts.unshift({ lat: currentLat, lon: currentLon, tau: 0, wind: 0 });

        // Find CPA
        var minDist = Infinity, cpaPoint = null;
        pts.forEach(function(pt) {
          var d = haversineMi(userLat, userLon, pt.lat, pt.lon);
          if (d < minDist) {
            minDist = d;
            cpaPoint = pt;
          }
        });

        if (!cpaPoint) { callback(null); return; }

        // Bearing from user to CPA
        var dLon = (cpaPoint.lon - userLon) * Math.PI / 180;
        var lat1 = userLat * Math.PI / 180, lat2 = cpaPoint.lat * Math.PI / 180;
        var y = Math.sin(dLon) * Math.cos(lat2);
        var x = Math.cos(lat1) * Math.sin(lat2) - Math.sin(lat1) * Math.cos(lat2) * Math.cos(dLon);
        var brng = ((Math.atan2(y, x) * 180 / Math.PI) + 360) % 360;
        var dirs16 = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
        var compass = dirs16[Math.round(brng / 22.5) % 16];

        // ETA text
        var etaText = '';
        if (cpaPoint.tau === 0) etaText = 'Currently closest';
        else if (cpaPoint.tau <= 12) etaText = 'Within ~' + cpaPoint.tau + ' hours';
        else etaText = 'In approximately ' + cpaPoint.tau + ' hours';

        // Threat assessment
        var threat = '';
        var threatColor = 'rgba(255,255,255,.5)';
        if (minDist < 60) { threat = 'DIRECT THREAT — Take immediate protective action'; threatColor = '#ef4444'; }
        else if (minDist < 120) { threat = 'HIGH RISK — Prepare for tropical storm+ conditions'; threatColor = '#f97316'; }
        else if (minDist < 250) { threat = 'MODERATE RISK — Monitor closely, review plans'; threatColor = '#fbbf24'; }
        else if (minDist < 500) { threat = 'Outer bands possible — Stay informed'; threatColor = '#67e8f9'; }
        else { threat = 'Low direct risk at current forecast'; threatColor = 'rgba(255,255,255,.4)'; }

        callback({
          distance: Math.round(minDist),
          direction: compass,
          bearing: Math.round(brng),
          tau: cpaPoint.tau,
          etaText: etaText,
          wind: cpaPoint.wind,
          threat: threat,
          threatColor: threatColor
        });
      }).catch(function(){ callback(null); });
  }

  // ══════════════════════════════════════════════════════════════════════════════
  // TIER 2 — WIRE CPA + WIND HISTORY INTO STORM DETAIL POPUP
  // ══════════════════════════════════════════════════════════════════════════════
  // These are async (they fetch NHC data), so we inject them into the popup DOM
  // after the popup opens rather than building into the initial HTML.
  function _enrichStormPopup(stormBin, lat, lon, stormName) {
    if (!stormBin) return;

    // Wind History Sparkline — inject into popup
    _buildWindHistorySVG(stormBin, function(svg, meta) {
      if (!svg) return;
      var target = document.getElementById('hz-wind-history-' + stormBin);
      if (target) {
        var metaText = '';
        if (meta && meta.peakWind) {
          metaText = ' · Peak: ' + Math.round(meta.peakWind * 1.15) + ' mph (' + meta.peakWind + ' kt)';
        }
        if (meta && meta.totalPts) {
          metaText += ' · ' + meta.totalPts + ' data points';
        }
        target.innerHTML =
          '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;">' +
          '<span style="font-size:.42rem;font-weight:900;letter-spacing:.1em;color:rgba(255,255,255,.4);">INTENSITY TIMELINE</span>' +
          (meta && meta.pastCount && meta.fcstCount ? '<span style="font-size:.34rem;color:rgba(255,255,255,.2);">' + meta.pastCount + ' obs + ' + meta.fcstCount + ' fcst</span>' : '') +
          '</div>' +
          svg +
          '<div style="font-size:.34rem;color:rgba(255,255,255,.2);margin-top:1px;">Solid white = observed · Dashed purple = NHC forecast' + metaText + '</div>';
      }
    });

    // Intensity Guidance — use cached ATCF data to build multi-model intensity chart
    (function() {
      var atcfId = '';
      if (stormBin) {
        var b = stormBin.substring(0, 2).toLowerCase();
        var n = parseInt(stormBin.substring(2));
        if (b === 'at') b = 'al';
        atcfId = b + (n < 10 ? '0' : '') + n + new Date().getFullYear();
      }
      var cacheKey = '_atcfCache_' + atcfId;
      var cached = window[cacheKey];
      if (cached && cached.data) {
        var igSvg = _buildIntensityGuidanceSVG(cached.data, stormName || stormBin);
        if (igSvg) {
          var igTarget = document.getElementById('hz-intensity-guidance-' + stormBin);
          if (igTarget) {
            var modelNames = [];
            Object.keys(cached.data).forEach(function(tech) {
              var def = _ATCF_MODELS[tech];
              if (def && modelNames.indexOf(def.name) < 0) modelNames.push(def.name);
            });
            igTarget.innerHTML =
              '<div style="font-size:.36rem;color:rgba(255,255,255,.25);margin-bottom:3px;">' + modelNames.length + ' models · Wind speed forecast through 120h</div>' +
              igSvg +
              '<div style="display:flex;flex-wrap:wrap;gap:1px 8px;margin-top:3px;">' +
              modelNames.slice(0, 8).map(function(mn) {
                var mc = '#fff';
