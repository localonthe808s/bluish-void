    _updateWidget: function(widgetId) {
      var w = SH.widgets[widgetId]; if (!w || !w.liveTagId) return;
      var tag = document.getElementById(w.liveTagId); if (!tag) return;
      var ok = 0, total = 0, anyRetry = false;
      w.sourceIds.forEach(function(sid) {
        var s = SH.sources[sid]; if (!s) return; total++;
        if (s.status === 'ok') ok++;
        if (s.status === 'retry') anyRetry = true;
      });
      if (total === 0) return;
      var health = ok === total ? 'ok' : (ok === 0 ? 'offline' : 'degraded');
      tag.setAttribute('data-health', health);
