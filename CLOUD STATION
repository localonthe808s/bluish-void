          smokeHtml += '<span style="width:7px;height:7px;border-radius:50%;background:'+(sevCol[sev]||'#047857')+';flex-shrink:0;box-shadow:0 0 8px '+(sevCol[sev]||'#047857')+'40;"></span>';
          smokeHtml += '<span style="font-size:.42rem;color:'+(sevCol[sev]||'#047857')+';font-weight:700;">'+(sevLabel[sev]||'No smoke data')+'</span>';
          if(sev !== 'none'){
            if(si.probableSource) smokeHtml += '<span style="font-size:.36rem;color:'+INK_DIM+';"> from '+si.probableSource+'</span>';
            if(si.transportWindDir) smokeHtml += '<span style="font-size:.36rem;color:'+INK_MUTE+';"> · wind '+si.transportWindDir+'</span>';
          }
          if(si.dispersionRating && sev === 'none'){
            smokeHtml += '<span style="font-size:.36rem;color:'+INK_MUTE+';"> · dispersion: '+si.dispersionRating+'</span>';
