          if(m >= 6.5) return '#991b1b';
          if(m >= 5.5) return '#b91c1c';
          if(m >= 4.5) return '#c2410c';
          if(m >= 3.5) return '#a16207';
          if(m >= 2.5) return '#4d7c0f';
          if(m >= 1.5) return '#047857';
          return '#0369a1';
        }

        // Magnitude tiers — each bucket is exclusive (M7 only goes in qM7)
        var qM0=0,qM1=0,qM2=0,qM3=0,qM4=0,qM5=0,qM6=0,qM7=0,qM8=0,qM9=0,qMaxMag=0;
        qFeats.forEach(function(q){
          var m = q.properties.mag || 0;
          if(m > qMaxMag) qMaxMag = m;
          if(m >= 9) qM9++;
          else if(m >= 8) qM8++;
          else if(m >= 7) qM7++;
          else if(m >= 6) qM6++;
          else if(m >= 5) qM5++;
          else if(m >= 4) qM4++;
          else if(m >= 3) qM3++;
          else if(m >= 2) qM2++;
          else if(m >= 1) qM1++;
          else qM0++;
        });

        // USGS daily avg: ~55 detected/day by NEIC
        var dailyAvg = 55;
        var qRatio = dailyAvg > 0 ? qCount / dailyAvg : 1;
        var qRatioLabel, qRatioCol;
        if(qRatio > 2.5){qRatioLabel='WELL ABOVE';qRatioCol='#b91c1c';}
        else if(qRatio > 1.5){qRatioLabel='ABOVE NORMAL';qRatioCol='#c2410c';}
        else if(qRatio > 0.7){qRatioLabel='NORMAL';qRatioCol='#047857';}
        else{qRatioLabel='BELOW NORMAL';qRatioCol=INK;}

        // Regional breakdown
        var zoneCount = {AK:0,CA:0,HI:0,PNW:0,CentUS:0,PacRim:0,Other:0};
        qFeats.forEach(function(q){
          var c = q.geometry&&q.geometry.coordinates; if(!c) return;
          var qlat=c[1],qlon=c[0];
          if(qlat>54 && qlon>=-170 && qlon<-130) zoneCount.AK++;
          else if(qlat>32 && qlat<42 && qlon>-125 && qlon<-114) zoneCount.CA++;
          else if(qlat>18 && qlat<22 && qlon>-162 && qlon<-154) zoneCount.HI++;
          else if(qlat>42 && qlon>-125 && qlon<-116) zoneCount.PNW++;
          else if(qlat>30 && qlat<50 && qlon>-110 && qlon<-90) zoneCount.CentUS++;
          else if(qlon<-60 || qlon>100) zoneCount.PacRim++;
          else zoneCount.Other++;
        });
        var zLabels = {AK:'Alaska',CA:'California',HI:'Hawaii',PNW:'Pacific NW',CentUS:'Central US',PacRim:'Pacific Rim',Other:'Other'};
        var topZ = Object.keys(zoneCount).map(function(k){return {name:k,c:zoneCount[k]};}).filter(function(r){return r.c>0;}).sort(function(a,b){return b.c-a.c;}).slice(0,4);

        // Felt quakes
        var feltCount = qFeats.filter(function(q){ return q.properties.felt && q.properties.felt > 0; }).length;
        // Deepest quake
        var maxDepth = 0;
        qFeats.forEach(function(q){ var d = q.geometry && q.geometry.coordinates && q.geometry.coordinates[2]; if(d && d > maxDepth) maxDepth = d; });

        // Parse helper — condense place name
        function shortPlace(place){
          if(!place) return 'Unknown';
          var sp = place;
          if(place.indexOf(' of ') > -1) sp = place.split(' of ')[1] || place;
          var parts = sp.split(', ');
          if(parts.length >= 2) sp = parts[0] + ', ' + parts[1].substring(0,2).toUpperCase();
          return sp;
        }
        function timeAgo(t){
          if(!t) return '';
          var mins = Math.floor((Date.now() - t) / 60000);
          if(mins < 60) return mins + 'm';
          if(mins < 1440) return Math.floor(mins/60) + 'h';
          return Math.floor(mins/1440) + 'd';
        }

        // Distance calc for nearest
        var uLat = LOCATION && LOCATION.lat, uLon = LOCATION && LOCATION.lon;

        // Build NEAREST earthquakes (within 500mi, sorted by distance)
        var nearestQuakes = [];
        if(uLat != null && uLon != null){
          qFeats.forEach(function(q){
            var c = q.geometry && q.geometry.coordinates;
            if(!c) return;
            var dLat = c[1] - uLat, dLon = (c[0] - uLon) * Math.cos(uLat * Math.PI / 180);
            var dist = Math.sqrt(dLat * dLat + dLon * dLon) * 69;
            if(dist > 500) return;
            var bearing = Math.atan2(c[0] - uLon, c[1] - uLat) * 180 / Math.PI;
            if(bearing < 0) bearing += 360;
            var dirs = ['N','NE','E','SE','S','SW','W','NW'];
            var dir = dirs[Math.round(bearing / 45) % 8];
            nearestQuakes.push({
              mag: q.properties.mag || 0,
              place: shortPlace(q.properties.place),
              time: timeAgo(q.properties.time),
              lat: c[1], lon: c[0], depth: c[2],
              meta: Math.round(dist) + 'mi ' + dir
            });
          });
          nearestQuakes.sort(function(a,b){ return parseInt(a.meta) - parseInt(b.meta); });
        }

        // Build STRONGEST (top 4 by magnitude)
        var strongestQuakes = qFeats.slice().sort(function(a,b){
          return (b.properties.mag || 0) - (a.properties.mag || 0);
        }).slice(0,4).map(function(q){
          var c = q.geometry && q.geometry.coordinates;
          return {
            mag: q.properties.mag || 0,
            place: shortPlace(q.properties.place),
            time: timeAgo(q.properties.time),
            lat: c ? c[1] : 0, lon: c ? c[0] : 0, depth: c ? c[2] : 0,
            meta: timeAgo(q.properties.time) + ' ago'
          };
        });

        // Render a quake row
        function renderQuakeRow(q, isLast){
          var mCol = magColorInk(q.mag);
          var out = '<div onclick="window.flyToQuake('+q.lat+','+q.lon+','+q.mag+')" style="padding:3px 0;cursor:pointer;'+(isLast ? '' : 'border-bottom:1px solid rgba(43,34,244,.06);')+'">';
          out += '<div style="display:flex;align-items:baseline;gap:4px;">';
          out += '<span style="font-size:.56rem;color:'+mCol+';font-weight:800;flex-shrink:0;">M'+q.mag.toFixed(1)+'</span>';
          out += '<span style="font-size:.46rem;color:'+INK+';font-weight:700;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">'+q.place+'</span>';
          out += '<span style="font-size:.40rem;color:'+INK_MUTE+';font-weight:700;flex-shrink:0;">'+q.time+'</span>';
          out += '</div>';
          out += '<div style="display:flex;align-items:center;gap:6px;margin-top:1px;">';
          out += '<span style="font-size:.40rem;color:'+INK_MUTE+';font-weight:700;flex-shrink:0;min-width:68px;">'+q.meta+'</span>';
          out += '<span style="font-size:.38rem;color:'+INK_GHOST+';flex:1;">depth '+Math.round(q.depth||0)+' km</span>';
          out += '</div></div>';
          return out;
        }

        var hasNearest = nearestQuakes.length > 0;
        var defaultTab = hasNearest ? 'near' : 'strong';
        var focusHtml = '<div style="margin-top:14px;">';
        focusHtml += '<div style="display:flex;align-items:center;gap:12px;margin-bottom:6px;">';
        focusHtml += '<span style="width:3px;height:12px;background:'+QUAKE_STRONG+';border-radius:2px;"></span>';
        focusHtml += '<span onclick="window._switchQuakeFocusTab(\'near\')" id="quake-focus-tab-near" style="font-size:.44rem;font-weight:800;letter-spacing:.1em;cursor:pointer;padding:2px 0;border-bottom:1.5px solid '+(defaultTab==='near'?QUAKE_STRONG:'transparent')+';color:'+(defaultTab==='near'?QUAKE_STRONG:INK_MUTE)+';">NEAREST</span>';
        focusHtml += '<span onclick="window._switchQuakeFocusTab(\'strong\')" id="quake-focus-tab-strong" style="font-size:.44rem;font-weight:800;letter-spacing:.1em;cursor:pointer;padding:2px 0;border-bottom:1.5px solid '+(defaultTab==='strong'?QUAKE_STRONG:'transparent')+';color:'+(defaultTab==='strong'?QUAKE_STRONG:INK_MUTE)+';">STRONGEST</span>';
        focusHtml += '</div>';

        focusHtml += '<div id="quake-focus-panel-near" style="display:'+(defaultTab==='near'?'block':'none')+';padding:10px 12px;background:rgba(30,64,175,.04);border:1px solid rgba(30,64,175,.12);border-radius:12px;">';
        if(hasNearest){
          nearestQuakes.slice(0,4).forEach(function(q,i){ focusHtml += renderQuakeRow(q, i === Math.min(3,nearestQuakes.length-1)); });
          if(nearestQuakes.length > 4) focusHtml += '<div style="font-size:.40rem;color:'+INK_MUTE+';margin-top:4px;font-weight:600;">+' + (nearestQuakes.length - 4) + ' more within 500mi</div>';
        } else {
          focusHtml += '<div style="font-size:.44rem;color:'+INK_MUTE+';font-weight:600;text-align:center;padding:6px 0;">No earthquakes within 500mi</div>';
        }
        focusHtml += '</div>';

        focusHtml += '<div id="quake-focus-panel-strong" style="display:'+(defaultTab==='strong'?'block':'none')+';padding:10px 12px;background:rgba(30,64,175,.04);border:1px solid rgba(30,64,175,.12);border-radius:12px;">';
        strongestQuakes.forEach(function(q,i){ focusHtml += renderQuakeRow(q, i === strongestQuakes.length-1); });
        focusHtml += '</div>';
        focusHtml += '</div>';

        window._switchQuakeFocusTab = function(tab){
          ['near','strong'].forEach(function(t){
            var tabEl = document.getElementById('quake-focus-tab-'+t);
            var panelEl = document.getElementById('quake-focus-panel-'+t);
            if(tabEl){
              tabEl.style.borderBottom = '1.5px solid ' + (t === tab ? '#1e40af' : 'transparent');
              tabEl.style.color = t === tab ? '#1e40af' : 'rgba(43,34,244,.45)';
            }
            if(panelEl) panelEl.style.display = t === tab ? 'block' : 'none';
          });
        };

        if(qHead) qHead.innerHTML =
          '<div style="font-size:.95rem;font-weight:800;color:'+QUAKE_STRONG+';line-height:1.1;letter-spacing:-.01em;">' + qCount.toLocaleString() + ' EARTHQUAKES</div>' +
          '<div style="font-size:.56rem;color:'+INK_DIM+';margin-top:4px;font-weight:600;">Past 24h · strongest M' + qMaxMag.toFixed(1) + '</div>' +
          // Stat chips row
          '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:12px;">' +
            '<div style="padding:8px 12px;background:'+CHIP_BG+';border-radius:12px;border:1px solid '+CHIP_STROKE+';">' +
              '<div style="font-size:.38rem;color:'+INK_MUTE+';font-weight:800;letter-spacing:.06em;white-space:nowrap;">VS DAILY AVG</div>' +
              '<div style="font-size:.62rem;color:' + qRatioCol + ';font-weight:800;margin-top:3px;line-height:1;">' + (qRatio*100).toFixed(0) + '%</div>' +
              '<div style="font-size:.34rem;color:'+qRatioCol+';font-weight:700;margin-top:2px;opacity:.85;">' + qRatioLabel + '</div>' +
            '</div>' +
            '<div style="padding:8px 12px;background:'+CHIP_BG+';border-radius:12px;border:1px solid '+CHIP_STROKE+';">' +
              '<div style="font-size:.38rem;color:'+INK_MUTE+';font-weight:800;letter-spacing:.06em;white-space:nowrap;">FELT / DEPTH</div>' +
              '<div style="font-size:.46rem;color:'+INK+';font-weight:700;margin-top:4px;line-height:1.2;">' + feltCount + ' felt</div>' +
              '<div style="font-size:.38rem;color:'+INK_DIM+';font-weight:600;margin-top:1px;">' + Math.round(maxDepth) + 'km max depth</div>' +
            '</div>' +
          '</div>' +
          // Magnitude distribution
          '<div style="margin-top:14px;">' +
            qSectionHeader('MAGNITUDE DISTRIBUTION', INK) +
            (function(){
              var tiers = [
                {label:'M9', count:qM9, col:magColor(9.5)},
                {label:'M8', count:qM8, col:magColor(8.5)},
                {label:'M7', count:qM7, col:magColor(7.5)},
                {label:'M6', count:qM6, col:magColor(6.5)},
                {label:'M5', count:qM5, col:magColor(5.5)},
                {label:'M4', count:qM4, col:magColor(4.5)},
                {label:'M3', count:qM3, col:magColor(3.5)},
                {label:'M2', count:qM2, col:magColor(2.5)},
                {label:'M1', count:qM1, col:magColor(1.5)},
                {label:'M0', count:qM0, col:magColor(0.5)}
              ];
              var maxT = Math.max.apply(null, tiers.map(function(t){return t.count;}));
              var active = tiers.filter(function(t){return t.count>0;});
              var out = '<div style="display:flex;flex-direction:column;gap:4px;">';
              active.forEach(function(t){
                var pct = maxT > 0 ? (t.count / maxT * 100) : 0;
                out += '<div style="display:flex;align-items:center;gap:8px;">';
                out += '<span style="font-size:.44rem;color:'+INK+';font-weight:800;min-width:36px;">'+t.label+'</span>';
                out += '<div style="flex:1;height:5px;background:rgba(43,34,244,.06);border-radius:2px;overflow:hidden;">';
                out += '<div style="width:'+pct+'%;height:100%;background:'+t.col+';border-radius:2px;"></div>';
                out += '</div>';
                out += '<span style="font-size:.44rem;color:'+INK_DIM+';font-weight:700;min-width:30px;text-align:right;">'+t.count+'</span>';
                out += '</div>';
              });
              out += '</div>';
              return out;
            })() +
          '</div>' +
          // Regional activity
          (topZ.length > 0 ? (function(){
            var maxC = topZ[0].c;
            var out = '<div style="margin-top:14px;">';
            out += qSectionHeader('REGIONAL ACTIVITY', INK);
            out += '<div style="display:flex;flex-direction:column;gap:5px;">';
            topZ.forEach(function(r){
              var pct = maxC > 0 ? (r.c / maxC * 100) : 0;
              out += '<div style="display:flex;align-items:center;gap:8px;">';
              out += '<span style="font-size:.44rem;color:'+INK+';font-weight:700;min-width:84px;">'+zLabels[r.name]+'</span>';
              out += '<div style="flex:1;height:5px;background:rgba(43,34,244,.06);border-radius:2px;overflow:hidden;">';
              out += '<div style="width:'+pct+'%;height:100%;background:'+QUAKE_STRONG+';border-radius:2px;"></div>';
              out += '</div>';
              out += '<span style="font-size:.44rem;color:'+INK_DIM+';font-weight:700;min-width:28px;text-align:right;">'+r.c+'</span>';
              out += '</div>';
            });
            out += '</div></div>';
            return out;
          })() : '') +
          focusHtml +
          // ── Map legend ──
          '<div style="margin-top:14px;">' +
            qSectionHeader('MAP LEGEND', INK) +
            '<div style="padding:8px 10px;background:rgba(255,255,255,.88);border-radius:12px;border:1px solid rgba(43,34,244,.08);">' +
              '<div style="display:flex;flex-wrap:wrap;align-items:center;gap:5px 9px;font-size:.42rem;color:#555;font-weight:600;">' +
                '<span style="display:flex;align-items:center;gap:3px;"><span style="width:6px;height:6px;border-radius:50%;background:#4ade80;"></span>&lt;M2</span>' +
                '<span style="display:flex;align-items:center;gap:3px;"><span style="width:7px;height:7px;border-radius:50%;background:#84cc16;"></span>M2+</span>' +
                '<span style="display:flex;align-items:center;gap:3px;"><span style="width:8px;height:8px;border-radius:50%;background:#eab308;"></span>M3+</span>' +
                '<span style="display:flex;align-items:center;gap:3px;"><span style="width:10px;height:10px;border-radius:50%;background:#f97316;"></span>M4+</span>' +
                '<span style="display:flex;align-items:center;gap:3px;"><span style="width:12px;height:12px;border-radius:50%;background:#ef4444;"></span>M5+</span>' +
                '<span style="display:flex;align-items:center;gap:3px;"><span style="width:14px;height:14px;border-radius:50%;background:#dc2626;"></span>M6+</span>' +
                '<span style="display:flex;align-items:center;gap:3px;"><span style="width:15px;height:15px;border-radius:50%;background:#7f1d1d;"></span>M7+</span>' +
              '</div>' +
            '</div>' +
          '</div>';
      } else {
        if(qHead) qHead.innerHTML = '<div style="font-size:.9rem;font-weight:800;color:#1e40af;line-height:1.1;">EARTHQUAKES</div><div style="font-size:.42rem;color:rgba(43,34,244,.68);margin-top:3px;">Loading...</div>';
      }
    }

    // Tornado pill — updated directly by loadTornadoReports

    // Flood pill — the left-side control panel is the pill; hz-pill-flood is empty/hidden
  }

  // ═══════════════════════════════════════════════════════════
  //  NWS ALERTS TAB — All active watches, warnings, advisories
  //  Source: api.weather.gov/alerts/active
  //  Plotted as colored polygons on the shared hazard map
  // ═══════════════════════════════════════════════════════════
  window._alertLayerGroup = null;
  window._hazardAlerts = [];
  var alertFilters = { warning: true, watch: true, advisory: true };

  function initAlertsData(){
    if(!hazardMap) return;
    window._alertLayerGroup = L.layerGroup();
    loadNWSAlerts();
    setInterval(function(){ if(hazardActiveTab === 'alerts') loadNWSAlerts(); }, 3 * 60 * 1000);
  }

  function classifyAlertSeverity(event){
    var e = (event || '').toLowerCase();
    if(e.indexOf('warning') >= 0) return 'warning';
    if(e.indexOf('watch') >= 0) return 'watch';
    if(e.indexOf('advisory') >= 0 || e.indexOf('statement') >= 0 || e.indexOf('outlook') >= 0) return 'advisory';
    return 'advisory';
  }

  function alertColor(severity){
    if(severity === 'warning') return { fill: '#ef4444', stroke: '#dc2626', opacity: 0.25 };
    if(severity === 'watch') return { fill: '#f97316', stroke: '#ea580c', opacity: 0.18 };
    return { fill: '#eab308', stroke: '#ca8a04', opacity: 0.12 };
  }

  function loadNWSAlerts(){
    // Skip if alerts were just fetched (3-min interval can overlap with manual calls)
    if(!shouldRefetch('nws-alerts', 2.5 * 60 * 1000)) return;

    var pill = document.getElementById('alerts-status-pill');
    // Get alerts for the visible area — use state-level for broader coverage
    var bounds = hazardMap.getBounds();
    var lat = LOCATION.lat, lon = LOCATION.lon;

    // Fetch regional alerts (wider area)
    var url = 'https://api.weather.gov/alerts/active?point=' + lat.toFixed(4) + ',' + lon.toFixed(4);
    // Also fetch state-wide for the map view
    var stateUrl = 'https://api.weather.gov/alerts/active?area=' + (window._userState || 'NY');

    var allAlerts = [];
    var fetched = 0;

    function processAlerts(data){
      if(!data || !data.features) return;
      data.features.forEach(function(f){
        var props = f.properties || {};
        var geom = f.geometry;
        // Some alerts don't have geometry — skip
        allAlerts.push({
          event: props.event || 'Alert',
          headline: props.headline || '',
          description: props.description || '',
          severity: classifyAlertSeverity(props.event),
          geometry: geom,
          areaDesc: props.areaDesc || '',
          onset: props.onset,
          expires: props.expires,
          senderName: props.senderName || 'NWS'
        });
      });
    }

    function finishAlerts(){
      // Deduplicate: same event type + same expiration = same alert issued for overlapping NWS zones
      // Keep the one with the longest description for best detail
      var seen = {};
      var unique = [];
      allAlerts.forEach(function(a){
        var key = a.event + '|' + (a.expires || '');
        if(!seen[key]){
          seen[key] = true;
          a._mergeCount = 1;
          unique.push(a);
        } else {
          // Merge: keep longer description, combine area descriptions
          for(var ui=0;ui<unique.length;ui++){
            var uKey = unique[ui].event + '|' + (unique[ui].expires || '');
            if(uKey === key){
              unique[ui]._mergeCount = (unique[ui]._mergeCount||1) + 1;
              if((a.description||'').length > (unique[ui].description||'').length){
                unique[ui].description = a.description;
                unique[ui].headline = a.headline;
              }
              // Merge geometry if both have it
              if(a.geometry && unique[ui].geometry){
                if(!unique[ui]._mergedGeometries) unique[ui]._mergedGeometries = [unique[ui].geometry];
                unique[ui]._mergedGeometries.push(a.geometry);
              }
              break;
            }
          }
        }
      });

      window._hazardAlerts = unique;

      // Clear old layers
      if(window._alertLayerGroup) window._alertLayerGroup.clearLayers();

      var warnCount = 0, watchCount = 0, advCount = 0;

      unique.forEach(function(alert){
        if(alert.severity === 'warning') warnCount++;
        else if(alert.severity === 'watch') watchCount++;
        else advCount++;

        // Only plot alerts with geometry
        if(!alert.geometry) return;

        var colors = alertColor(alert.severity);
        // Render all merged geometries if available
        var geos = alert._mergedGeometries || [alert.geometry];
        try {
          geos.forEach(function(geo){
          var layer = L.geoJSON(geo, {
            style: {
              fillColor: colors.fill,
              fillOpacity: colors.opacity,
              color: colors.stroke,
              weight: 2,
              opacity: 0.7
            }
          });
          layer.bindPopup(
            '<div class="hz-card-head"><div class="hz-accent" style="background:' + colors.stroke + ';"></div><span style="color:' + colors.stroke + ';">' + alert.event.toUpperCase() + '</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Area</span><span class="hz-val" style="max-width:180px;text-align:right;font-size:9px;">' + alert.areaDesc + '</span></div>' +
            '<div style="margin-top:6px;font-size:9px;color:rgba(255,255,255,.6);max-height:120px;overflow-y:auto;line-height:1.4;">' + (alert.headline || alert.description.substring(0,300)) + '</div>' +
            '<div class="hz-card-footer">NWS · ' + (alert.senderName || 'National Weather Service') + '</div>',
            { maxWidth: 320, className: 'hz-popup' }
          );
          window._alertLayerGroup.addLayer(layer);
          }); // end geos.forEach
        } catch(e){ /* geometry parse error */ }
      });

      // Update pill
      if(pill){
        var total = unique.length;
        if(total === 0){
          pill.textContent = '⚠️ NO ACTIVE ALERTS';
          pill.style.color = '#4ade80';
        } else {
          var parts = [];
          if(warnCount) parts.push(warnCount + ' ⛔');
          if(watchCount) parts.push(watchCount + ' ⚠️');
          if(advCount) parts.push(advCount + ' 📋');
          pill.textContent = '⚠️ ' + total + ' ALERTS · ' + parts.join(' ');
          pill.style.color = warnCount > 0 ? '#ef4444' : watchCount > 0 ? '#f97316' : '#eab308';
        }
      }

      updateHazardBadges(); try{updateUnifiedPills();}catch(e){}
    }

    // Fetch point alerts
    fetchWithTimeout(url, null, 10000)
      .then(function(r){ return r.json(); })
      .then(function(data){
        processAlerts(data);
        fetched++;
        if(fetched >= 2) finishAlerts();
      })
      .catch(function(){ fetched++; if(fetched >= 2) finishAlerts(); });

    // Fetch state alerts for broader map view
    fetchWithTimeout(stateUrl, null, 12000)
      .then(function(r){ return r.json(); })
      .then(function(data){
        processAlerts(data);
        fetched++;
        if(fetched >= 2) finishAlerts();
      })
      .catch(function(){ fetched++; if(fetched >= 2) finishAlerts(); });
  }

  function toggleAlertFilter(type){
    alertFilters[type] = !alertFilters[type];
    var btn = document.getElementById('alert-filter-' + type);
    if(btn) btn.style.opacity = alertFilters[type] ? '1' : '.35';
    // Re-render alert layers
    if(!window._alertLayerGroup) return;
    window._alertLayerGroup.clearLayers();
    (window._hazardAlerts || []).forEach(function(alert){
      if(!alertFilters[alert.severity]) return;
      if(!alert.geometry) return;
      var colors = alertColor(alert.severity);
      try {
        var layer = L.geoJSON(alert.geometry, {
          style: { fillColor: colors.fill, fillOpacity: colors.opacity, color: colors.stroke, weight: 2, opacity: 0.7 }
        });
        layer.bindPopup(
          '<div style="font-weight:700;font-size:.6rem;color:' + colors.stroke + ';">' + alert.event + '</div>' +
          '<div style="font-size:.45rem;color:#999;margin:2px 0;">' + alert.areaDesc + '</div>' +
          '<div style="font-size:.42rem;color:#ccc;max-height:120px;overflow-y:auto;">' + (alert.headline || alert.description.substring(0,300)) + '</div>',
          { maxWidth: 320, className: 'fire-popup' }
        );
        window._alertLayerGroup.addLayer(layer);
      } catch(e){}
    });
  }

  // ═══════════════════════════════════════════════════════════
  //  FLOOD TAB — NWS AHPS River Gauges (National)
  //  Source: idpgis.ncep.noaa.gov AHPS MapServer
  //  Layer 0: Observed · 1-14: Forecast 24h-336h · 15: Full period
  //  + USGS IV as supplemental for nearby detail
  //  + WPC Significant River Flood Outlook polygons
  // ═══════════════════════════════════════════════════════════
  window._floodLayerGroup = null;
  window._floodGauges = [];
  window._floodGaugesAboveNormal = 0;
  window._floodStats = { total:0, major:0, moderate:0, minor:0, action:0, normal:0, noData:0 };
  var floodScope = 'conus';
  var floodForecastHour = 'obs'; // obs, 24, 48, 72, 96, full
  var AHPS_BASE = 'https://idpgis.ncep.noaa.gov/arcgis/rest/services/NWS_Observations/ahps_riv_gauges/MapServer';
  var AHPS_LAYERS = { obs:0, '24':1, '48':2, '72':3, '96':4, '144':6, '192':8, '336':14, full:15 };
  var SIG_FLOOD_OUTLOOK = 'https://idpgis.ncep.noaa.gov/arcgis/rest/services/NWS_Forecasts_Guidance_Warnings/sig_riv_fld_outlk/MapServer/0/query';

  function initFloodData(){
    if(!hazardMap) return;
    window._floodLayerGroup = L.layerGroup().addTo(hazardMap);
    loadFloodGaugesAHPS('obs');
    loadSigRiverFloodOutlook();
    setTimeout(function(){ switchHazardOutlook('flood','d1'); }, 200);
    setInterval(function(){ if(hazardActiveTab === 'flood') loadFloodGaugesAHPS(floodForecastHour); }, 10 * 60 * 1000);
  }

  function switchFloodScope(scope){
    floodScope = scope;
    var btns = ['nearby','region','state','conus'];
    btns.forEach(function(s){
      var btn = document.getElementById('flood-scope-' + s);
      if(!btn) return;
      var isActive = s === scope;
      btn.style.borderColor = isActive ? 'rgba(43,34,244,.40)' : 'rgba(43,34,244,.10)';
      btn.style.background = isActive ? 'rgba(43,34,244,.12)' : 'rgba(43,34,244,.04)';
      btn.style.color = isActive ? '#2B22F4' : 'rgba(43,34,244,.55)';
    });
    loadFloodGaugesAHPS(floodForecastHour);
    // Show insight bubble
    if(floodScopeInsights[scope]) showFloodInsight('flood-scope-insight', floodScopeInsights[scope]);
    // Zoom map to appropriate extent
    if(hazardMap){
      if(scope === 'conus') hazardMap.flyTo([39.0, -98.0], 4, {duration:0.8});
      else if(scope === 'region') hazardMap.flyTo([LOCATION.lat, LOCATION.lon], 5, {duration:0.8});
      else if(scope === 'state') hazardMap.flyTo([39.0, -98.0], 4, {duration:0.8});
      else hazardMap.flyTo([LOCATION.lat, LOCATION.lon], 7, {duration:0.8});
    }
  }

  window.switchFloodForecast = function(hr){
    floodForecastHour = hr;
    // Update toggle buttons — ink light theme
    document.querySelectorAll('.flood-fcst-btn').forEach(function(b){
      var isActive = b.getAttribute('data-fhr') === hr;
      b.style.borderColor = isActive ? 'rgba(8,145,178,.40)' : 'rgba(43,34,244,.10)';
      b.style.background = isActive ? 'rgba(8,145,178,.12)' : 'rgba(43,34,244,.04)';
      b.style.color = isActive ? '#0e7490' : 'rgba(43,34,244,.55)';
    });
    loadFloodGaugesAHPS(hr);
    if(floodFcstInsights[hr]) showFloodInsight('flood-fcst-insight', floodFcstInsights[hr]);
  };

  function ahpsStatusColor(status){
    status = (status || '').toLowerCase().replace(/\s+/g,'_');
    if(status === 'major') return { color:'#9333ea', label:'MAJOR FLOOD', priority:5, bg:'rgba(147,51,234,.15)' };
    if(status === 'moderate') return { color:'#ef4444', label:'MODERATE FLOOD', priority:4, bg:'rgba(239,68,68,.12)' };
    if(status === 'minor') return { color:'#f97316', label:'MINOR FLOOD', priority:3, bg:'rgba(249,115,22,.1)' };
    if(status === 'action') return { color:'#eab308', label:'ACTION STAGE', priority:2, bg:'rgba(234,179,8,.1)' };
    if(status === 'no_flooding' || status === 'not_defined' || status === 'obs_not_current' || status === 'out_of_service' || status === 'low_threshold') return { color:'#22c55e', label:'NORMAL', priority:1, bg:'rgba(34,197,94,.06)' };
    return { color:'#64748b', label:'NO DATA', priority:0, bg:'rgba(100,116,139,.06)' };
  }

  function loadFloodGaugesAHPS(forecastHr){
    // Skip redundant refetch if same params were just loaded (10-min interval overlap)
    var floodCacheKey = 'flood-' + floodScope + '-' + forecastHr;
    if(!shouldRefetch(floodCacheKey, 8 * 60 * 1000) && !window._prefetchedFlood) return;

    // ── Use boot-prefetched flood GeoJSON if available (initial obs load only) ──
    if (window._prefetchedFlood && forecastHr === 'obs' && floodScope === 'nearby') {
      var gj = window._prefetchedFlood;
      window._prefetchedFlood = null; // free memory
      // Convert GeoJSON features → ArcGIS format for renderFloodGauges
      var converted = (gj.features || []).map(function(f){
        var p = f.properties || {};
        var coords = f.geometry && f.geometry.coordinates;
        return {
          attributes: {
            gaugelid: p.gaugelid || p.nws_lid || p.lid || '',
            location: p.location || p.name || '',
            waterbody: p.waterbody || '',
            status: p.status || p.flood_status || '',
            observed: p.observed || p.obs_value || null,
            units: p.units || 'ft',
            action: p.action || null,
            flood: p.flood || null,
            moderate: p.moderate || null,
            major: p.major || null,
            obstime: p.obstime || p.obs_time || null,
            url: p.url || null
          },
          geometry: coords ? { x: coords[0], y: coords[1] } : null
        };
      }).filter(function(f){ return f.geometry; });
      if (converted.length > 0) {
        SH.ok('ahps');
        renderFloodGauges(converted, forecastHr);
        return;
      }
      // Fall through to normal fetch if conversion yielded nothing
    }

    var layerId = AHPS_LAYERS[forecastHr] != null ? AHPS_LAYERS[forecastHr] : 0;
    var lat = LOCATION.lat, lon = LOCATION.lon;
    var baseUrl = AHPS_BASE + '/' + layerId + '/query?outFields=gaugelid,location,waterbody,status,observed,units,action,flood,moderate,major,obstime,url&outSR=4326&f=json';

    if(floodScope === 'conus'){
      // Sequential waterfall: fetch one quadrant at a time, render progressively
      // This avoids 4 simultaneous 20s-timeout fetches competing for connections
      var quads = [
        { name:'NW', bbox:'-130,38,-95,52' },
        { name:'NE', bbox:'-95,38,-65,52' },
        { name:'SW', bbox:'-130,24,-95,38' },
        { name:'SE', bbox:'-95,24,-65,38' }
      ];
      var allFeatures = [];
      var quadIdx = 0;

      function fetchNextQuad(){
        if(quadIdx >= quads.length){
          console.log('AHPS CONUS: loaded ' + allFeatures.length + ' gauges from 4 quadrants');
          SH.ok('ahps');
          renderFloodGauges(allFeatures, forecastHr);
          return;
        }
        var q = quads[quadIdx];
        quadIdx++;
        var qurl = baseUrl + '&geometry=' + q.bbox + '&geometryType=esriGeometryEnvelope&spatialRel=esriSpatialRelIntersects&inSR=4326&where=1%3D1&resultRecordCount=3000';
        fetchWithTimeout(qurl, null, 20000)
          .then(function(r){ return r.json(); })
          .then(function(data){
            if(data && data.features){
              allFeatures = allFeatures.concat(data.features);
              // Progressive render: show what we have so far
              renderFloodGauges(allFeatures, forecastHr);
            }
          })
          .catch(function(e){ console.warn('AHPS quad ' + q.name + ' failed:', e); })
          .finally(fetchNextQuad);
      }
      fetchNextQuad();
      return;
    }

    // Non-CONUS scopes: single query
    var geomParam = '';
    if(floodScope === 'state'){
      geomParam = '&where=status+IN+(%27major%27,%27moderate%27,%27minor%27,%27action%27)';
    } else if(floodScope === 'region'){
      var rdelta = 7.0;
      geomParam = '&geometry=' + (lon-rdelta).toFixed(2) + ',' + (lat-rdelta).toFixed(2) + ',' + (lon+rdelta).toFixed(2) + ',' + (lat+rdelta).toFixed(2) + '&geometryType=esriGeometryEnvelope&spatialRel=esriSpatialRelIntersects&inSR=4326&where=1%3D1';
    } else {
      var delta = 3.0;
      geomParam = '&geometry=' + (lon-delta).toFixed(2) + ',' + (lat-delta).toFixed(2) + ',' + (lon+delta).toFixed(2) + ',' + (lat+delta).toFixed(2) + '&geometryType=esriGeometryEnvelope&spatialRel=esriSpatialRelIntersects&inSR=4326&where=1%3D1';
    }

    var url = baseUrl + geomParam + '&resultRecordCount=3000';

    fetchWithTimeout(url, null, 20000)
      .then(function(r){ return r.json(); })
      .then(function(data){
        if(!data || !data.features) return;
        SH.ok('ahps');
        renderFloodGauges(data.features, forecastHr);
      })
      .catch(function(e){
        SH.fail('ahps', function(){ loadFloodGaugesAHPS(forecastHr); });
        console.warn('AHPS fetch failed, falling back to USGS IV:', e);
        loadFloodGaugesUSGS();
      });
  }

  function renderFloodGauges(features, forecastHr){
    if(window._floodLayerGroup) window._floodLayerGroup.clearLayers();
    window._floodGauges = [];
    var stats = { total:0, major:0, moderate:0, minor:0, action:0, normal:0, noData:0 };

    // Parse all features first
    var parsed = [];
    features.forEach(function(f){
      var a = f.attributes || {};
      var g = f.geometry;
      if(!g) return;
      var sLat = g.y, sLon = g.x;
      if(isNaN(sLat) || isNaN(sLon)) return;

      var status = ahpsStatusColor(a.status);
      stats.total++;
      if(status.priority >= 5) stats.major++;
      else if(status.priority === 4) stats.moderate++;
      else if(status.priority === 3) stats.minor++;
      else if(status.priority === 2) stats.action++;
      else if(status.priority === 1) stats.normal++;
      else stats.noData++;

      parsed.push({ lat:sLat, lon:sLon, a:a, status:status });
    });

    // Decide rendering mode
    var useGrid = (floodScope === 'conus' || floodScope === 'region') && parsed.length > 200;

    if(useGrid){
      // ═══ GRID POLYGON MODE ═══
      console.log('Rendering GRID mode: ' + parsed.length + ' gauges, scope=' + floodScope);
      // Group gauges into geographic grid cells and render colored rectangles
      var gridSize = floodScope === 'conus' ? 1.0 : 0.5; // degrees per cell
      var cells = {};

      parsed.forEach(function(p){
        var cellLat = Math.floor(p.lat / gridSize) * gridSize;
        var cellLon = Math.floor(p.lon / gridSize) * gridSize;
        var key = cellLat + ',' + cellLon;
        if(!cells[key]) cells[key] = { lat:cellLat, lon:cellLon, gauges:[], maxPriority:0, totalPriority:0, count:0 };
        cells[key].gauges.push(p);
        cells[key].count++;
        if(p.status.priority > cells[key].maxPriority) cells[key].maxPriority = p.status.priority;
        cells[key].totalPriority += p.status.priority;
      });

      Object.keys(cells).forEach(function(key){
        var cell = cells[key];
        var avgPri = cell.totalPriority / cell.count;
        var maxPri = cell.maxPriority;

        // Color based on worst gauge in cell
        var fillColor, fillOpacity, borderColor;
        if(maxPri >= 5){ fillColor = '#9333ea'; fillOpacity = 0.45; borderColor = 'rgba(147,51,234,.6)'; }
        else if(maxPri >= 4){ fillColor = '#ef4444'; fillOpacity = 0.4; borderColor = 'rgba(239,68,68,.5)'; }
        else if(maxPri >= 3){ fillColor = '#f97316'; fillOpacity = 0.35; borderColor = 'rgba(249,115,22,.4)'; }
        else if(maxPri >= 2){ fillColor = '#eab308'; fillOpacity = 0.3; borderColor = 'rgba(234,179,8,.35)'; }
        else if(maxPri >= 1){ fillColor = '#22c55e'; fillOpacity = 0.15; borderColor = 'rgba(34,197,94,.15)'; }
        else { fillColor = '#64748b'; fillOpacity = 0.08; borderColor = 'rgba(100,116,139,.1)'; }

        // Boost opacity if multiple gauges are elevated
        var elevatedCount = cell.gauges.filter(function(g){ return g.status.priority >= 2; }).length;
        if(elevatedCount >= 3) fillOpacity = Math.min(fillOpacity + 0.15, 0.7);

        var rect = L.rectangle(
          [[cell.lat, cell.lon], [cell.lat + gridSize, cell.lon + gridSize]],
          { fillColor: fillColor, fillOpacity: fillOpacity, color: borderColor, weight: 0.5, interactive: true }
        );

        // Tooltip for grid cell
        var statusCounts = { major:0, moderate:0, minor:0, action:0, normal:0 };
        cell.gauges.forEach(function(g){
          if(g.status.priority >= 5) statusCounts.major++;
          else if(g.status.priority === 4) statusCounts.moderate++;
          else if(g.status.priority === 3) statusCounts.minor++;
          else if(g.status.priority === 2) statusCounts.action++;
          else statusCounts.normal++;
        });

        var ttLines = '<div style="font-weight:800;font-size:10px;margin-bottom:3px;">' + cell.count + ' GAUGES IN AREA</div>';
        if(statusCounts.major) ttLines += '<div style="color:#9333ea;">⬤ ' + statusCounts.major + ' Major Flood</div>';
        if(statusCounts.moderate) ttLines += '<div style="color:#ef4444;">⬤ ' + statusCounts.moderate + ' Moderate</div>';
        if(statusCounts.minor) ttLines += '<div style="color:#f97316;">⬤ ' + statusCounts.minor + ' Minor</div>';
        if(statusCounts.action) ttLines += '<div style="color:#eab308;">⬤ ' + statusCounts.action + ' Action</div>';
        ttLines += '<div style="color:#22c55e;opacity:.7;">⬤ ' + statusCounts.normal + ' Normal</div>';
        ttLines += '<div style="margin-top:3px;font-size:8px;opacity:.5;">Zoom in or use Local scope for individual gauges</div>';

        rect.bindPopup(ttLines, { className:'hz-popup', maxWidth:260 });

        // Click grid cell → zoom into it
        rect.on('click', function(){
          if(hazardMap) hazardMap.flyTo([cell.lat + gridSize/2, cell.lon + gridSize/2], 8, {duration:0.5});
          floodScope = 'nearby';
          switchFloodScope('nearby');
        });

        window._floodLayerGroup.addLayer(rect);
      });

      // Still overlay individual markers for elevated gauges (action+) on top of grid
      parsed.forEach(function(p){
        if(p.status.priority < 2) return; // skip normal
        var r = p.status.priority >= 5 ? 6 : p.status.priority >= 4 ? 5 : p.status.priority >= 3 ? 4 : 3;
        if(floodScope === 'conus') r = Math.max(2, Math.round(r * 0.6));
        var m = L.circleMarker([p.lat, p.lon], {
          radius: r, fillColor: p.status.color, fillOpacity: 0.9,
          color: p.status.color, weight: 0, opacity: 0
        });
        var observed = p.a.observed != null ? parseFloat(p.a.observed) : null;
        var ttip = '<div class="hz-card-head"><div class="hz-accent" style="background:' + p.status.color + ';"></div><span style="color:' + p.status.color + ';">' + p.status.label + '</span></div>' +
          '<div class="hz-card-row"><span class="hz-label">Station</span><span class="hz-val">' + (p.a.location||'Unknown') + '</span></div>' +
          (p.a.waterbody ? '<div class="hz-card-row"><span class="hz-label">River</span><span class="hz-val">' + p.a.waterbody + '</span></div>' : '') +
          (observed != null ? '<div class="hz-card-row"><span class="hz-label">Stage</span><span class="hz-val" style="color:' + p.status.color + ';">' + observed.toFixed(2) + ' ' + (p.a.units||'ft') + '</span></div>' : '');
        m.bindPopup(ttip, { className:'hz-popup', maxWidth:280 });
        if(p.a.url || p.a.gaugelid){
          m.on('click', function(){ window.open(p.a.url || ('https://water.noaa.gov/gauges/' + p.a.gaugelid.toLowerCase()), '_blank'); });
        }
        window._floodLayerGroup.addLayer(m);
      });

    } else {
      // ═══ DOT MARKER MODE (Local / small result sets) ═══
      parsed.forEach(function(p){
        var a = p.a;
        var status = p.status;
        var observed = a.observed != null ? parseFloat(a.observed) : null;
        var units = a.units || 'ft';
        var location = a.location || 'Unknown';
        var waterbody = a.waterbody || '';
        var gaugeId = a.gaugelid || '';

        var stageInfo = '';
        if(observed != null){
          if(a.major && observed >= parseFloat(a.major)) stageInfo = ' · ≥ Major (' + a.major + ')';
          else if(a.moderate && observed >= parseFloat(a.moderate)) stageInfo = ' · ≥ Moderate (' + a.moderate + ')';
          else if(a.flood && observed >= parseFloat(a.flood)) stageInfo = ' · ≥ Flood (' + a.flood + ')';
          else if(a.action && observed >= parseFloat(a.action)) stageInfo = ' · ≥ Action (' + a.action + ')';
          else if(a.flood) stageInfo = ' · Flood stage: ' + a.flood;
        }

        var timeStr = '';
        if(a.obstime){ try { timeStr = new Date(a.obstime).toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'}); } catch(e){} }

        var radius = status.priority >= 5 ? 9 : status.priority >= 4 ? 7 : status.priority >= 3 ? 6 : status.priority >= 2 ? 5 : 4;
        if(floodScope === 'region') radius = Math.max(3, Math.round(radius * 0.7));
        var marker = L.circleMarker([p.lat, p.lon], {
          radius: radius, fillColor: status.color,
          fillOpacity: status.priority >= 3 ? 0.9 : 0.7,
          color: status.color, weight: 0, opacity: 0
        });

        if(status.priority >= 5) marker.setStyle({ className: 'flood-pulse' });

        var ttip = '<div class="hz-card-head"><div class="hz-accent" style="background:' + status.color + ';"></div><span style="color:' + status.color + ';">' + status.label + '</span></div>' +
          '<div class="hz-card-row"><span class="hz-label">Station</span><span class="hz-val" style="max-width:150px;text-align:right;">' + location + '</span></div>' +
          (waterbody ? '<div class="hz-card-row"><span class="hz-label">River</span><span class="hz-val">' + waterbody + '</span></div>' : '') +
          (observed != null ? '<div class="hz-card-row"><span class="hz-label">Stage</span><span class="hz-val" style="color:' + status.color + ';">' + observed.toFixed(2) + ' ' + units + '</span></div>' : '') +
          (a.action ? '<div class="hz-card-row"><span class="hz-label">Thresholds</span><span class="hz-val" style="font-size:8.5px;">Act: ' + a.action + ' · Fld: ' + (a.flood||'--') + ' · Maj: ' + (a.major||'--') + '</span></div>' : '') +
          (forecastHr !== 'obs' ? '<div class="hz-card-row"><span class="hz-label">Forecast</span><span class="hz-val" style="color:#22d3ee;">' + (forecastHr === 'full' ? 'Full period' : forecastHr + 'h') + '</span></div>' : '') +
          '<div class="hz-card-footer">' + (timeStr ? timeStr + ' · ' : '') + 'NWS AHPS' + (gaugeId ? ' · ' + gaugeId : '') + '</div>';

        marker.bindPopup(ttip, { className: 'hz-popup', maxWidth: 280 });

        if(a.url || gaugeId){
          marker.on('click', function(){
            var hydrUrl = a.url || ('https://water.noaa.gov/gauges/' + gaugeId.toLowerCase());
            window.open(hydrUrl, '_blank');
          });
          marker.setStyle({ cursor: 'pointer' });
        }

        window._floodLayerGroup.addLayer(marker);
        window._floodGauges.push({
          lat: p.lat, lon: p.lon, gage: observed, name: location, waterbody: waterbody,
          status: status, gaugeId: gaugeId, action: a.action ? parseFloat(a.action) : null,
          flood: a.flood ? parseFloat(a.flood) : null, moderate: a.moderate ? parseFloat(a.moderate) : null,
          major: a.major ? parseFloat(a.major) : null
        });
      });
    }

    window._floodStats = stats;
    window._floodGaugesAboveNormal = stats.major + stats.moderate + stats.minor;
    // Ensure layer group is on the map
    if(hazardMap && window._floodLayerGroup && !hazardMap.hasLayer(window._floodLayerGroup)){
      window._floodLayerGroup.addTo(hazardMap);
    }
    updateHazardBadges(); try{updateUnifiedPills();}catch(e){}
    try { updateHazardInsight(); } catch(e){}
  }

  // Fallback: original USGS IV endpoint (used if AHPS is down)
  function loadFloodGaugesUSGS(){
    var lat = LOCATION.lat, lon = LOCATION.lon;
    var delta = 1.5;
    var url = 'https://waterservices.usgs.gov/nwis/iv/?format=json&bBox=' +
      (lon - delta).toFixed(3) + ',' + (lat - delta).toFixed(3) + ',' +
      (lon + delta).toFixed(3) + ',' + (lat + delta).toFixed(3) +
      '&parameterCd=00065&siteType=ST&siteStatus=active';

    fetchWithTimeout(url, null, 20000)
      .then(function(r){ return r.json(); })
      .then(function(data){
        if(!data || !data.value || !data.value.timeSeries) return;
        var series = data.value.timeSeries;
        if(window._floodLayerGroup) window._floodLayerGroup.clearLayers();
        window._floodGauges = [];
        var aboveNormal = 0, totalGauges = 0;

        for(var i = 0; i < series.length; i++){
          var ts = series[i];
          var site = ts.sourceInfo;
          if(!site || !site.geoLocation || !site.geoLocation.geogLocation) continue;
          var geo = site.geoLocation.geogLocation;
          var sLat = parseFloat(geo.latitude), sLon = parseFloat(geo.longitude);
          if(isNaN(sLat) || isNaN(sLon)) continue;
          var vals = ts.values && ts.values[0] && ts.values[0].value;
          if(!vals || vals.length === 0) continue;
          var latest = vals[vals.length - 1];
          var gageHt = parseFloat(latest.value);
          if(isNaN(gageHt) || gageHt < 0) continue;
          var siteName = site.siteName || 'Unknown';
          totalGauges++;

          var status;
          if(gageHt > 20) { status = { color: '#ef4444', label: 'ELEVATED', priority: 4 }; aboveNormal++; }
          else if(gageHt > 12) { status = { color: '#f97316', label: 'ABOVE NORMAL', priority: 3 }; aboveNormal++; }
          else if(gageHt > 8) { status = { color: '#eab308', label: 'NEAR NORMAL', priority: 2 }; }
          else { status = { color: '#22c55e', label: 'NORMAL', priority: 1 }; }

          var marker = L.circleMarker([sLat, sLon], {
            radius: gageHt > 15 ? 7 : gageHt > 8 ? 5 : 4,
