        var goldenHourPreview = function(highC, midC, lowC) {
          var W = 308, H = 100;
          highC = highC || 0; midC = midC || 0; lowC = lowC || 0;
          // Sunset gradient — deep purple zenith → pink → orange horizon
          var bgGrad = 'linear-gradient(180deg, #2a1c4a 0%, #4a2855 25%, #8a3855 50%, #d87838 78%, #c85828 88%, #4a1810 100%)';
          var s = '<svg width="100%" viewBox="0 0 '+W+' '+H+'" preserveAspectRatio="xMidYMax meet" style="display:block;border-radius:10px;background:'+bgGrad+';box-shadow:inset 0 0 0 1px rgba(43,34,244,.08);margin:6px 0 8px;">';

          // Sun on the horizon — visible only when low cover doesn't
          // completely block the western horizon (lowC < 60).
          var sunCx = W - 60;
          var sunCy = 80;
          if (lowC < 60) {
            // Halo glow
            s += '<defs><radialGradient id="ghSunGlow" cx="50%" cy="50%" r="50%">' +
              '<stop offset="0%" stop-color="rgba(255,220,150,0.85)"/>' +
              '<stop offset="40%" stop-color="rgba(255,180,100,0.40)"/>' +
              '<stop offset="100%" stop-color="rgba(255,140,80,0)"/>' +
            '</radialGradient></defs>';
            s += '<circle cx="'+sunCx+'" cy="'+sunCy+'" r="34" fill="url(#ghSunGlow)"/>';
            // Sun disc
            s += '<circle cx="'+sunCx+'" cy="'+sunCy+'" r="9" fill="rgba(255,220,160,0.95)" filter="blur(0.4px)"/>';
            s += '<circle cx="'+sunCx+'" cy="'+sunCy+'" r="6" fill="rgba(255,240,200,1)"/>';
          }

          // ── HIGH cirrus / cirrostratus ──
          // At sunset, ice crystals scatter pinks/magentas — characteristic
          // of high cirrus catching sun from below.
          var hType = pickHighType(highC);
          if (hType === 'cirrostratus') {
            var csA = Math.min(0.65, 0.35 + (highC-60)/150);
            s += '<defs><linearGradient id="ghCs" x1="0" y1="0" x2="0" y2="1">' +
              '<stop offset="0%" stop-color="rgba(255,180,200,0)"/>' +
              '<stop offset="50%" stop-color="rgba(255,180,200,'+csA.toFixed(2)+')"/>' +
              '<stop offset="100%" stop-color="rgba(255,150,180,0)"/>' +
            '</linearGradient></defs>';
            s += '<rect x="0" y="2" width="'+W+'" height="28" fill="url(#ghCs)"/>';
          } else if (hType === 'cirrus' || hType === 'cirrus-thin') {
            var nFib = hType === 'cirrus' ? 6 : 3;
            var fibAlpha = hType === 'cirrus' ? 0.85 : 0.55;
            for (var fi = 0; fi < nFib; fi++) {
              var fy = 8 + fi*4;
              var fx1 = 20 + fi*10;
              var fx2 = fx1 + 90 + fi*15;
              // Magenta-pink fibers — sunset-lit cirrus
              s += '<path d="M '+fx1+' '+fy+' Q '+((fx1+fx2)/2)+' '+(fy-2)+' '+fx2+' '+fy+'" stroke="rgba(255,180,210,'+fibAlpha+')" stroke-width="1.2" fill="none" stroke-linecap="round"/>';
            }
          }

          // ── MID altocumulus / altostratus ──
          var mType = pickMidType(midC);
          if (mType === 'altostratus') {
            // Soft-fade gradient veil with golden-hour palette (purple
            // top → warm peach middle → fade). Same structure as the GH
            // widget's golden-hour altostratus rendering — fades at top
            // and bottom so the sheet bleeds into the sunset gradient
            // instead of having a hard rectangular edge.
            var asCovFacG = Math.max(0.55, Math.min(1.0, 0.55 + (midC-50)/55*0.45));
            var asGidG = 'ghAs-'+Math.round(midC);
            s += '<defs><linearGradient id="'+asGidG+'" x1="0" y1="0" x2="0" y2="1">' +
              '<stop offset="0%"  stop-color="rgb(110,80,110)"  stop-opacity="0"/>' +
              '<stop offset="22%" stop-color="rgb(130,95,110)"  stop-opacity="'+(0.55*asCovFacG).toFixed(2)+'"/>' +
              '<stop offset="55%" stop-color="rgb(180,128,112)" stop-opacity="'+(0.78*asCovFacG).toFixed(2)+'"/>' +
              '<stop offset="82%" stop-color="rgb(210,142,118)" stop-opacity="'+(0.55*asCovFacG).toFixed(2)+'"/>' +
              '<stop offset="100%" stop-color="rgb(225,155,122)" stop-opacity="0"/>' +
            '</linearGradient></defs>';
            s += '<rect x="0" y="0" width="'+W+'" height="80" fill="url(#'+asGidG+')"/>';
            // Density mottles
            for (var asGi = 0; asGi < 5; asGi++) {
              var amgx = (asGi+0.5)*W/5 + (asGi*7 % 30 - 15);
              var amgy = 18 + (asGi*5) % 28;
              var amgrx = 26 + (asGi*11) % 16;
              s += '<ellipse cx="'+amgx.toFixed(1)+'" cy="'+amgy+'" rx="'+amgrx+'" ry="5" fill="rgba(80,55,90,0.16)" filter="blur(2px)"/>';
            }
            // Faint warm sun bleed where the partly-hidden sun is
            if (midC < 85) {
              var wsB = (1 - midC/100) * 0.50;
              s += '<defs><radialGradient id="'+asGidG+'-sun" cx="'+((sunCx/W)*100).toFixed(0)+'%" cy="'+((sunCy/H)*100).toFixed(0)+'%" r="22%">' +
                '<stop offset="0%"  stop-color="rgba(255,200,140,'+wsB.toFixed(2)+')"/>' +
                '<stop offset="50%" stop-color="rgba(255,170,110,'+(wsB*0.30).toFixed(2)+')"/>' +
                '<stop offset="100%" stop-color="rgba(255,140,90,0)"/>' +
              '</radialGradient></defs>';
              s += '<rect x="0" y="0" width="'+W+'" height="'+H+'" fill="url(#'+asGidG+'-sun)" filter="blur(0.5px)"/>';
            }
          } else if (mType === 'altocumulus' || mType === 'altocumulus-thin') {
            // The IDEAL SUNSET CANVAS — altocumulus puffs with cream tops
            // and pink-magenta undersides catching warm light from below.
            var acAlpha = mType === 'altocumulus' ? 0.95 : 0.65;
            var nCells = mType === 'altocumulus' ? 14 : 6;
            for (var aci = 0; aci < nCells; aci++) {
              var ax = 12 + (aci % 7) * (W-30)/7 + (Math.floor(aci/7) * 12);
              var ay = 28 + Math.floor(aci/7) * 9;
              // Cream/peach top
              s += '<ellipse cx="'+ax+'" cy="'+ay+'" rx="7" ry="3" fill="rgba(255,235,200,'+acAlpha+')" filter="blur(0.3px)"/>';
              // Pink-magenta underside catching horizon glow
              s += '<ellipse cx="'+ax+'" cy="'+(ay+1.5)+'" rx="6" ry="1.5" fill="rgba(255,170,180,'+(acAlpha*0.85)+')" filter="blur(0.3px)"/>';
            }
          }

          // ── LOW layer ──
          var lType = pickLowType(lowC, prVal || 0);
          if (lType === 'nimbostratus') {
            // Storm at sunset — mostly dark with rain
            s += '<rect x="0" y="50" width="'+W+'" height="32" fill="rgba(40,25,40,0.92)"/>';
            for (var rni = 0; rni < 18; rni++) {
              var rx = 8 + rni*16;
              var ry = 78 + (rni%3);
              s += '<line x1="'+rx+'" y1="'+ry+'" x2="'+(rx+2)+'" y2="'+(ry+8)+'" stroke="rgba(140,100,120,0.6)" stroke-width="0.8" stroke-linecap="round"/>';
            }
          } else if (lType === 'stratus') {
            // Dark band silhouetted against the sunset
            s += '<rect x="0" y="60" width="'+W+'" height="20" fill="rgba(40,25,45,0.92)"/>';
          } else if (lType === 'stratocumulus') {
            // Dark rolls with golden lit tops
            for (var sci = 0; sci < 5; sci++) {
              var scx = 30 + sci * (W-60)/4;
              var scy = 70;
              // Dark body
              s += '<ellipse cx="'+scx+'" cy="'+scy+'" rx="32" ry="9" fill="rgba(50,30,45,0.85)" filter="blur(0.3px)"/>';
              // Golden lit top edge (sun-side)
              s += '<ellipse cx="'+scx+'" cy="'+(scy-5)+'" rx="28" ry="2" fill="rgba(255,180,120,0.75)" filter="blur(0.5px)"/>';
            }
          } else if (lType === 'cumulus') {
            // Backlit cumulus — dark bodies with bright orange/pink rims
            for (var cui = 0; cui < 4; cui++) {
              var cux = 35 + cui * (W-70)/3;
              // Bright rim (drawn first, behind)
              s += '<path d="'+puffPath(cux, 76, 22, 14, 4)+'" fill="rgba(255,200,140,0.85)" filter="blur(0.6px)"/>';
              // Dark interior
              s += '<path d="'+puffPath(cux, 77, 19, 12, 4)+'" fill="rgba(50,28,45,0.92)"/>';
              // Pink underside catch
              s += '<ellipse cx="'+cux+'" cy="76" rx="14" ry="2" fill="rgba(255,150,160,0.55)" filter="blur(0.4px)"/>';
            }
          } else if (lType === 'cumulus-fair') {
            if (lowC >= 4) {
              var nFair = lowC >= 8 ? 2 : 1;
              for (var cuf = 0; cuf < nFair; cuf++) {
                var fcx = nFair === 1 ? W/2 : 80 + cuf*(W-160);
                // Bright rim
                s += '<path d="'+puffPath(fcx, 78, 14, 7, 3)+'" fill="rgba(255,200,140,0.78)" filter="blur(0.5px)"/>';
                // Cream body lit by sun
                s += '<path d="'+puffPath(fcx, 78, 12, 6, 3)+'" fill="rgba(255,225,180,0.92)"/>';
              }
            }
          }

          // Horizon line
          s += '<line x1="0" y1="83" x2="'+W+'" y2="83" stroke="rgba(20,8,12,0.45)" stroke-width="0.8"/>';

          s += '</svg>';
          return s;
        };

        // layerIcon — small thumbnail showing dominant cloud type at a
        // single layer. Used inline next to each HIGH/MID/LOW row.
        var layerIcon = function(layer, cover, prVal) {
          var W = 44, H = 22;
          var type = layer === 'high' ? pickHighType(cover) : layer === 'mid' ? pickMidType(cover) : pickLowType(cover, prVal || 0);
          var s = '<svg width="'+W+'" height="'+H+'" viewBox="0 0 '+W+' '+H+'" style="display:inline-block;vertical-align:middle;margin-right:6px;background:rgba(43,34,244,.04);border-radius:4px;">';
          if (!type) {
            s += '<text x="'+(W/2)+'" y="'+(H/2+3)+'" text-anchor="middle" font-size="8" fill="rgba(43,34,244,.3)">—</text>';
          } else if (type === 'cirrostratus') {
            s += '<rect x="2" y="6" width="'+(W-4)+'" height="6" fill="rgba(140,150,200,0.55)" rx="2"/>';
          } else if (type === 'cirrus' || type === 'cirrus-thin') {
            for (var ci = 0; ci < 3; ci++) {
              s += '<path d="M '+(4+ci*2)+' '+(7+ci*3)+' Q '+(W/2)+' '+(5+ci*3)+' '+(W-4-ci*2)+' '+(7+ci*3)+'" stroke="rgba(140,150,200,0.7)" stroke-width="0.8" fill="none" stroke-linecap="round"/>';
            }
          } else if (type === 'altostratus') {
            s += '<rect x="2" y="7" width="'+(W-4)+'" height="9" fill="rgba(200,180,140,0.65)" rx="2"/>';
          } else if (type === 'altocumulus' || type === 'altocumulus-thin') {
            for (var ai = 0; ai < 5; ai++) {
              s += '<ellipse cx="'+(5+ai*8)+'" cy="11" rx="3" ry="1.5" fill="rgba(220,190,140,0.85)"/>';
            }
          } else if (type === 'nimbostratus') {
            s += '<rect x="2" y="4" width="'+(W-4)+'" height="10" fill="rgba(80,80,100,0.78)" rx="2"/>';
            for (var nri = 0; nri < 4; nri++) s += '<line x1="'+(6+nri*9)+'" y1="14" x2="'+(7+nri*9)+'" y2="20" stroke="rgba(140,140,170,0.7)" stroke-width="1"/>';
          } else if (type === 'stratus') {
            s += '<rect x="2" y="9" width="'+(W-4)+'" height="6" fill="rgba(160,165,180,0.78)" rx="2"/>';
          } else if (type === 'stratocumulus') {
            for (var li = 0; li < 3; li++) s += '<ellipse cx="'+(8+li*14)+'" cy="13" rx="6" ry="3" fill="rgba(170,170,185,0.85)"/>';
          } else if (type === 'cumulus' || type === 'cumulus-fair') {
            for (var cmi = 0; cmi < 2; cmi++) s += '<path d="'+puffPath(11+cmi*22, 18, 8, 7, 3)+'" fill="rgba(255,255,255,0.92)" stroke="rgba(120,130,160,0.18)" stroke-width="0.4"/>';
          }
          s += '</svg>';
          return s;
        };

        // ── SKY PREVIEW ──
        // Rendered before the layer breakdown so users see what the sky
        // actually looks like before reading the per-layer numbers.
        var prVal = (window._wxCurrent && window._wxCurrent.precip != null) ? window._wxCurrent.precip : 0;
        if (typeof totalCloud === 'number' && totalCloud > 0) {
          h += FS('Sky Right Now', '#5a78c8');
          h += skyPreview(highCloud || 0, midCloud || 0, lowCloud || 0, prVal);
        }

        // ── LAYER BREAKDOWN with bars ──
        if (lowCloud !== null || midCloud !== null || highCloud !== null) {
          h += FS('Cloud Layers', '#8899bb');

          if (highCloud !== null) {
            var hcDesc = highCloud > 70 ? 'Dense cirrostratus' : highCloud > 40 ? 'Cirrus / cirrostratus' : highCloud > 15 ? 'Scattered cirrus' : highCloud > 0 ? 'Thin wisps' : 'Clear';
            h += '<div style="margin:6px 0;"><div style="display:flex;justify-content:space-between;align-items:center;font-size:9px;margin-bottom:3px;">';
            h += '<span style="color:#8899dd;font-weight:700;display:inline-flex;align-items:center;">'+layerIcon('high', highCloud, prVal)+'HIGH <span style="opacity:.5;margin-left:4px;">>20,000ft</span></span>';
            h += '<span style="color:#8899dd;font-weight:700;">'+highCloud+'%'+trendArrow(highTrend)+'</span></div>';
            h += bar2(highCloud, '#8899dd', 5);
            h += '<div style="font-size:9px;color:rgba(43,34,244,.55);margin-top:2px;">'+hcDesc+(highCloud>30?' \u00b7 Ice crystals scatter pastel pinks/magentas at sunset':'')+'</div></div>';
          }

          if (midCloud !== null) {
            var mcDesc = midCloud > 70 ? 'Dense altostratus' : midCloud > 40 ? 'Altocumulus / altostratus' : midCloud > 15 ? 'Scattered altocumulus' : midCloud > 0 ? 'Thin patches' : 'Clear';
            h += '<div style="margin:6px 0;"><div style="display:flex;justify-content:space-between;align-items:center;font-size:9px;margin-bottom:3px;">';
            h += '<span style="color:#ddb870;font-weight:700;display:inline-flex;align-items:center;">'+layerIcon('mid', midCloud, prVal)+'MID <span style="opacity:.5;margin-left:4px;">6,500\u201320,000ft</span></span>';
            h += '<span style="color:#ddb870;font-weight:700;">'+midCloud+'%'+trendArrow(midTrend)+'</span></div>';
            h += bar2(midCloud, '#ddb870', 5);
            var midSunset = midCloud >= 30 && midCloud <= 70 ? ' \u00b7 \ud83c\udf05 IDEAL SUNSET CANVAS \u2014 catches golden light beautifully' : midCloud > 70 ? ' \u00b7 May block some light but dramatic when backlit' : '';
            h += '<div style="font-size:9px;color:rgba(43,34,244,.55);margin-top:2px;">'+mcDesc+midSunset+'</div></div>';
          }

          if (lowCloud !== null) {
            var lcDesc = lowCloud > 70 ? 'Dense stratus / stratocumulus' : lowCloud > 40 ? 'Broken stratocumulus' : lowCloud > 15 ? 'Scattered cumulus' : lowCloud > 0 ? 'Fair weather cumulus' : 'Clear';
            h += '<div style="margin:6px 0;"><div style="display:flex;justify-content:space-between;align-items:center;font-size:9px;margin-bottom:3px;">';
            h += '<span style="color:#99a;font-weight:700;display:inline-flex;align-items:center;">'+layerIcon('low', lowCloud, prVal)+'LOW <span style="opacity:.5;margin-left:4px;"><6,500ft</span></span>';
            h += '<span style="color:#99a;font-weight:700;">'+lowCloud+'%'+trendArrow(lowTrend)+'</span></div>';
            h += bar2(lowCloud, '#99a', 5);
            var lowSunset = lowCloud > 50 ? ' \u00b7 \u274c Blocks western horizon \u2014 sun may not reach higher clouds' : lowCloud > 20 ? ' \u00b7 \u26a0\ufe0f Gaps may create crepuscular rays' : '';
            h += '<div style="font-size:9px;color:rgba(43,34,244,.55);margin-top:2px;">'+lcDesc+lowSunset+'</div></div>';
          }
        }

        // ── WIND PROFILE & SHEAR ──
        // Pull current-hour winds at surface + cloud-bearing pressure
        // levels (700/500/300 hPa). Vertical shear between the surface
        // and 300 hPa is a reliable proxy for atmospheric instability —
        // strong shear can spawn deep convection (Cb), weak shear favors
        // stratiform layers (St/As/Ns).
        var wpIdx = 0;
        if (hourly && hourly.time) {
          var nowDtW = new Date();
          for (var wpi = 0; wpi < hourly.time.length; wpi++) {
            var hdtW = new Date(hourly.time[wpi]);
            if (hdtW.getDate() === nowDtW.getDate() && hdtW.getHours() === nowDtW.getHours()) {
              wpIdx = wpi; break;
            }
          }
        }
        var sfcSpd = (hourly && hourly.wind_speed_10m && hourly.wind_speed_10m[wpIdx] != null) ? hourly.wind_speed_10m[wpIdx] : null;
        var sfcDir = (hourly && hourly.wind_direction_10m && hourly.wind_direction_10m[wpIdx] != null) ? hourly.wind_direction_10m[wpIdx] : null;
        var w700  = (hourly && hourly.windspeed_700hPa  && hourly.windspeed_700hPa[wpIdx]  != null) ? hourly.windspeed_700hPa[wpIdx]  : null;
        var wd700 = (hourly && hourly.winddirection_700hPa && hourly.winddirection_700hPa[wpIdx] != null) ? hourly.winddirection_700hPa[wpIdx] : null;
        var w500  = (hourly && hourly.windspeed_500hPa  && hourly.windspeed_500hPa[wpIdx]  != null) ? hourly.windspeed_500hPa[wpIdx]  : null;
        var wd500 = (hourly && hourly.winddirection_500hPa && hourly.winddirection_500hPa[wpIdx] != null) ? hourly.winddirection_500hPa[wpIdx] : null;
        var w300  = (hourly && hourly.windspeed_300hPa  && hourly.windspeed_300hPa[wpIdx]  != null) ? hourly.windspeed_300hPa[wpIdx]  : null;
        var wd300 = (hourly && hourly.winddirection_300hPa && hourly.winddirection_300hPa[wpIdx] != null) ? hourly.winddirection_300hPa[wpIdx] : null;

        var hasAnyWind = sfcSpd != null || w700 != null || w500 != null || w300 != null;
        if (hasAnyWind) {
          h += FS('Wind Profile', '#88a8c8');
          // Wind speed scale: max for the visualization is 100 mph (jet
          // streams routinely exceed this, but bar saturates).
          var WIND_MAX = 100;
          var spdColFor = function(s){
            return s > 60 ? '#cc4422' : s > 30 ? '#cc8800' : s > 15 ? '#88a8c8' : '#88aaff';
          };
          var spdLabelFor = function(s){
            return s > 80 ? 'Jet stream' : s > 50 ? 'Strong' : s > 25 ? 'Moderate' : s > 10 ? 'Light' : 'Calm';
          };
          // Compass direction text from FROM-direction degrees
          var dirText = function(d){
            if (d == null) return '';
            var dirs = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
            return dirs[Math.round(d/22.5) % 16];
          };
          // Render a single altitude row: arrow + label + bar + value
          var renderWindRow = function(label, alt, layerCol, spd, dir) {
            if (spd == null) return '';
            var pct = Math.min(100, spd / WIND_MAX * 100);
            var sCol = spdColFor(spd);
            // Arrow rotation: meteorological wind direction is FROM, but
            // we want the arrow to point in the flow direction (TO), so
            // rotate by (dir + 180) % 360 (SVG rotates clockwise from N).
            var arrowRot = ((dir == null ? 0 : dir) + 180) % 360;
            var html = '<div style="display:flex;align-items:center;gap:8px;font-size:10px;margin:3px 0;">';
            // Direction arrow (SVG)
            html += '<svg width="22" height="22" viewBox="0 0 22 22" style="flex-shrink:0;background:rgba(43,34,244,.04);border-radius:50%;">';
            html += '<g transform="rotate('+arrowRot.toFixed(1)+' 11 11)">';
            html += '<line x1="11" y1="5" x2="11" y2="17" stroke="'+sCol+'" stroke-width="2" stroke-linecap="round"/>';
            html += '<polygon points="11,3 7,9 15,9" fill="'+sCol+'"/>';
            html += '</g></svg>';
            // Label + altitude
            html += '<div style="min-width:70px;line-height:1.1;">'+
              '<div style="font-weight:700;color:'+layerCol+';font-size:9.5px;letter-spacing:.04em;">'+label+'</div>'+
              '<div style="font-size:8px;color:rgba(43,34,244,.45);font-weight:600;">'+alt+'</div>'+
            '</div>';
            // Speed bar
            html += '<div style="flex:1;height:7px;background:rgba(43,34,244,.05);border-radius:4px;overflow:hidden;">';
            html += '<div style="height:100%;width:'+pct.toFixed(0)+'%;background:'+sCol+';border-radius:4px;"></div>';
            html += '</div>';
            // Speed + dir text
            html += '<div style="min-width:62px;text-align:right;font-weight:700;color:'+sCol+';">'+Math.round(spd)+' <span style="font-size:8px;font-weight:600;opacity:.7;">mph '+dirText(dir)+'</span></div>';
            html += '</div>';
            return html;
          };

          if (w300 != null) h += renderWindRow('HIGH',  '300 mb · ~30,000 ft', '#8899dd', w300, wd300);
          if (w500 != null) h += renderWindRow('UPPER', '500 mb · ~18,000 ft', '#aa99cc', w500, wd500);
          if (w700 != null) h += renderWindRow('MID',   '700 mb · ~10,000 ft', '#ddb870', w700, wd700);
          if (sfcSpd != null) h += renderWindRow('SURFACE', '10 m · ground',    '#99a',    sfcSpd, sfcDir);

          // Vertical shear interpretation
          if (sfcSpd != null && (w300 != null || w500 != null)) {
            // Use the highest-altitude available wind for the shear calc
            var topSpd = w300 != null ? w300 : w500;
            var topAlt = w300 != null ? '300 mb' : '500 mb';
            var shear = Math.abs(topSpd - sfcSpd);
            var shearLabel, shearDesc, shearCol;
            if (shear > 60) {
              shearLabel = 'Severe shear';
              shearDesc = 'Strong vertical wind change — favors organized convection (Cb), supercells, possible severe weather.';
              shearCol = '#cc3333';
            } else if (shear > 30) {
              shearLabel = 'Strong shear';
              shearDesc = 'Active atmosphere — towering cumulus and storms can organize. Cloud layers move at very different speeds.';
              shearCol = '#cc8800';
            } else if (shear > 15) {
              shearLabel = 'Moderate shear';
              shearDesc = 'Typical mid-latitude pattern. Layers drift independently — fair-weather Cu / mid stratiform.';
              shearCol = '#88a8c8';
            } else {
              shearLabel = 'Weak shear';
              shearDesc = 'Stable column — favors smooth stratiform layers (St / As) or stagnant fog. Low storm potential.';
              shearCol = '#1a8a4a';
            }
