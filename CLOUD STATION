                  ' L '+(_tubaCurveX+_tubaBotHalfW).toFixed(1)+' '+_tubaBotY.toFixed(1)+
                  ' Q '+(_tubaCurveX+_tubaTopHalfW*0.4).toFixed(1)+' '+((_tubaTopY+_tubaBotY)/2).toFixed(1)+
                  ' '+(_tubaTopX+_tubaTopHalfW).toFixed(1)+' '+_tubaTopY.toFixed(1)+' Z';
