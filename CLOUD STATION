    /* ========== MOBILE HAZARDS — map on top, dashboard below pattern ========== */
    /* Same shape as the radar widget: tab bar pinned top, map takes a
       fixed top portion, overview dashboard cards flow below in normal
       block flow (not absolutely-positioned overlay). */
    #hazard-widget {
      grid-column: 1 / -1 !important;
    }
    #hazard-widget .widget-body {
      min-height: 0 !important;
      height: auto !important;
      display: flex !important;
      flex-direction: column !important;
      overflow: visible !important;
    }
    /* Tab bar — let the 7 hazard tabs scroll horizontally instead of
       cramming all into a single row width. Each tab gets its real
       readable label width back. Pin to top via flex order:1. */
    #hazard-tab-bar {
      position: relative !important;
      overflow-x: auto !important;
      flex-wrap: nowrap !important;
      scrollbar-width: none !important;
      -ms-overflow-style: none !important;
      order: 1 !important;
      flex: 0 0 auto !important;
    }
    #hazard-tab-bar::-webkit-scrollbar { display: none !important; }
    #hazard-tab-bar .geo-tab {
      flex: 0 0 auto !important;
      white-space: nowrap !important;
    }
    /* Map — pop out of absolute fill, take a fixed mobile height as a
       block sibling. Order:2 places it below the tab bar. 45vh leaves
       enough room below for the stat dashboard to be visible without
       scrolling past a giant map. */
    #hazard-map {
      position: relative !important;
      top: auto !important; left: auto !important;
      right: auto !important; bottom: auto !important;
      width: 100% !important;
      height: 45vh !important;
      flex: 0 0 auto !important;
      order: 2 !important;
    }
    /* Overview dashboard — pop out of absolute overlay (top:34px;left:0;
       right:0;bottom:0) so it flows BELOW the map as a block sibling.
       Single-column cards, full width, scannable. */
    #hazard-overview-dashboard {
      position: relative !important;
      top: auto !important; left: auto !important;
      right: auto !important; bottom: auto !important;
      width: 100% !important;
      height: auto !important;
      flex: 0 0 auto !important;
      order: 3 !important;
    }
    #hazard-overview-dashboard > div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
      grid-template-rows: auto !important;
    }
    #hazard-overview-dashboard .hz-dash-card {
      min-height: 64px !important;
    }
    /* Per-hazard status pills (Fire / Quake / Tornado / Flood / Lightning
       / Hurricane) — same treatment as the overview dashboard. They were
       absolutely positioned at top:56px;left:10px overlaying the map.
       Pop them out so the active pill flows below the map as a block,
       seamlessly connected to the map's bottom edge (no gap). */
    #hazard-status-pill {
      position: relative !important;
      top: auto !important; left: auto !important;
      right: auto !important; bottom: auto !important;
      max-width: 100% !important;
      width: 100% !important;
      display: block !important;
      flex: 0 0 auto !important;
      order: 4 !important;
      padding: 0 !important;
      margin: 0 !important;
      min-height: 60px !important;
      box-sizing: border-box !important;
      overflow: hidden !important;
    }
    /* Inner pill: square top corners (so it visually merges with the
       map's bottom edge), keep rounded bottom corners. */
    #hazard-status-pill .hz-pill {
      max-width: 100% !important;
      width: 100% !important;
      box-sizing: border-box !important;
      overflow-wrap: anywhere !important;
      margin: 0 !important;
      border-top-left-radius: 0 !important;
      border-top-right-radius: 0 !important;
    }
    /* Stop bars / charts inside the pill from bleeding past the right
       edge — they had hardcoded widths in the desktop layout. */
    #hazard-status-pill .hz-pill * {
      max-width: 100% !important;
      box-sizing: border-box !important;
    }
    /* Widget body min-height: enough for tab bar + 45vh map + ~30vh
       of dashboard. Let it grow if dashboard needs more vertical space. */
    #hazard-widget .widget-body {
      min-height: auto !important;
      height: auto !important;
    }
    /* OVERVIEW tab active — the dashboard IS the content. Hide the
       map (it's just empty/black at the OVERVIEW level since no
       hazard layer is selected) and the per-hazard pill so the
       overview cards take the full widget area. */
    #hazard-widget.hz-overview-active #hazard-map,
    #hazard-widget.hz-overview-active #hazard-status-pill,
    #hazard-widget.hz-overview-active #hazard-scroll-guard {
      display: none !important;
    }
    /* The "INTERACT WITH MAP" guard on mobile — make sure it's tappable
       full-screen so users can actually clear it on touch. */
    #hazard-scroll-guard {
      touch-action: manipulation !important;
    }

    /* ========== MOBILE CIRA RADAR: full-bleed image + buttons below ========== */
    /* Convert the radar widget body into a flex column so the radar
       image (#fcast-img-container) takes a fixed top portion and the
       side panels (left = time/area, right = forecast models) stack
       below as full-width rows. The panels were originally absolute-
       positioned to overlay the image; flatten them onto the widget
       body's flex flow on mobile only. */
    #radar-widget-body {
      aspect-ratio: auto !important;
      display: flex !important;
      flex-direction: column !important;
      min-height: 0 !important;
    }
    /* Square radar/satellite box on mobile — height:100vw makes the
       container exactly 1:1, matching the natural aspect of CIRA
       full-disk GOES imagery and most square radar mosaics. Image
       fills the full width and is just as tall. */
    #fcast-img-container {
      position: relative !important;
      top: auto !important; left: auto !important;
      right: auto !important; bottom: auto !important;
      width: 100% !important;
      height: 100vw !important;
      flex: 0 0 auto !important;
      order: 2 !important;  /* below tab bar, above panels */
    }
    #fcast-goes-layer {
      position: relative !important;
      top: auto !important; left: auto !important;
      right: auto !important; bottom: auto !important;
      width: 100% !important;
      height: 100vw !important;
      flex: 0 0 auto !important;
      order: 2 !important;
    }
    #fcast-left-panel {
      position: relative !important;
      top: auto !important; left: auto !important;
      right: auto !important; bottom: auto !important;
      width: 100% !important;
      max-width: 100% !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      -webkit-mask-image: none !important;
      mask-image: none !important;
      align-items: stretch !important;
      flex: 0 0 auto !important;
      order: 4 !important;
      padding: 8px 10px !important;
    }
    #fcast-right-panel {
      position: relative !important;
      top: auto !important; left: auto !important;
      right: auto !important; bottom: auto !important;
      width: 100% !important;
      max-width: 100% !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      -webkit-mask-image: none !important;
      mask-image: none !important;
      align-items: stretch !important;
      flex: 0 0 auto !important;
      order: 5 !important;
      padding: 8px 10px !important;
    }
    #fcast-area-selector {
      max-width: 100% !important;
      width: 100% !important;
    }
    /* CIRA tab bar — pinned at top via order:1. Square the bottom
       corners on mobile so the orange rectangle butts cleanly against
       whatever pane sits below it (was border-radius:0 0 14px 14px
       inline, which left visible gray gaps either side of the curve). */
    #cira-tab-bar {
      order: 1 !important;
      position: relative !important;
      flex: 0 0 auto !important;
      border-radius: 0 !important;
    }
    /* Playback bar — order:3 puts it directly under the radar image
       (image is order:2) and ABOVE the button panels (left=4, right=5).
       Padding gives it breathing room from the image and the buttons. */
    #fcast-playback-bar {
      position: relative !important;
      top: auto !important; bottom: auto !important;
      left: auto !important; right: auto !important;
      width: 100% !important;
      opacity: 1 !important;
      pointer-events: auto !important;
      flex: 0 0 auto !important;
      order: 3 !important;
      padding: 6px 8px !important;
    }
    #fcast-playback-bar > div {
      border-radius: 14px !important;
    }
    /* Radar image: contain (full image visible, letterbox top/bottom)
       so the NATIONAL WEATHER SERVICE header + dBZ legend at the
       bottom aren't cropped on the sides. */
    #fcast-radar-img,
    #fcast-radar-img-b {
      object-fit: contain !important;
    }

    /* TODAY'S HIGHLIGHT (cira-pane-events) and ARCHIVE (cira-pane-archive)
       — pop out of absolute fill on mobile so they take a fixed
       reasonable height instead of inheriting the full square widget
       height (was making the widget ~100vw tall on phones). */
    #cira-pane-events {
      position: relative !important;
      inset: auto !important;
      top: auto !important; left: auto !important;
      right: auto !important; bottom: auto !important;
      width: 100% !important;
      height: 56vw !important;        /* ~16:9, framed */
      max-height: 60vh !important;
      flex: 0 0 auto !important;
      order: 2 !important;
    }
    #cira-pane-archive {
      position: relative !important;
      inset: auto !important;
      top: auto !important; left: auto !important;
      right: auto !important; bottom: auto !important;
      width: 100% !important;
      height: auto !important;
      max-height: 70vh !important;
      flex: 0 0 auto !important;
      order: 2 !important;
      padding-top: 0 !important;
      padding-bottom: 14px !important;
      padding-left: 8px !important;
      padding-right: 8px !important;
      margin: 0 !important;
    }
    /* Inside the events player keep video/img at object-fit:contain so
       the satellite frame isn't cropped at the edges */
    #cira-pane-events #cira-lod-video,
    #cira-pane-events #cira-lod-img {
      object-fit: contain !important;
      background: #000 !important;
    }
    /* When ARCHIVE is active, hide EVERYTHING in the widget body
       except the archive pane and the tab bar. Otherwise the
       playback scrubber / left-time panel / right-band panel / fcast
       image all stay reserved in the flex column and create huge
       empty bands above the archive grid. */
    #radar-widget-body[data-cira-tab="archive"] > *:not(#cira-pane-archive):not(#cira-tab-bar) {
      display: none !important;
    }
    /* Pop the archive pane out of absolute fill on mobile so it
       flows in the flex column directly after the tab bar — that's
       what kills the grey strip between the orange tab bar and the
       first row of thumbnails. Padding-top is 0 so the first row
       starts FLUSH with the bottom of the tab bar; left/right/bottom
       padding gives the cards a normal gutter. */
    #radar-widget-body[data-cira-tab="archive"] #cira-pane-archive {
      position: relative !important;
      top: auto !important; left: auto !important;
      right: auto !important; bottom: auto !important;
      order: 2 !important;
      padding-top: 0 !important;
      padding-bottom: 14px !important;
      padding-left: 8px !important;
      padding-right: 8px !important;
      margin: 0 !important;
      flex: 1 1 auto !important;
