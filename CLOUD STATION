      if(aqi <= 50){ intel.healthGuidance = 'Good — air quality satisfactory'; intel.activityGuidance = 'All outdoor activities safe'; }
      else if(aqi <= 100){ intel.healthGuidance = 'Moderate — acceptable for most'; intel.activityGuidance = 'Unusually sensitive people should consider reducing prolonged outdoor exertion'; }
      else if(aqi <= 150){ intel.healthGuidance = 'Unhealthy for Sensitive Groups'; intel.activityGuidance = 'Active children/adults and people with respiratory disease should limit prolonged outdoor exertion'; }
