  // Custom Leaflet layer for ArcGIS MapServer export endpoints
  var ArcGISExportLayer = L.Layer.extend({
    initialize: function(url, options){
      this._url = url;
      this._layers = options.layers || '';
      this._renderingRule = options.renderingRule || null;
      this._opacity = options.opacity || 0.6;
      this._imgEl = null;
      this._isImage = !!options.isImageServer;
    },
    onAdd: function(map){
      this._map = map;
      this._imgEl = L.DomUtil.create('img', 'arcgis-export-overlay');
      this._imgEl.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;opacity:'+this._opacity+';z-index:250;';
      map.getPane('overlayPane').appendChild(this._imgEl);
      var self = this;
      this._debouncedUpdate = function(){ clearTimeout(self._updateTimer); self._updateTimer = setTimeout(function(){ self._update(); }, 250); };
      map.on('moveend zoomend resize', this._debouncedUpdate, this);
      this._update();
    },
    onRemove: function(map){
      if(this._imgEl && this._imgEl.parentNode) this._imgEl.parentNode.removeChild(this._imgEl);
      map.off('moveend zoomend resize', this._debouncedUpdate, this);
      clearTimeout(this._updateTimer);
    },
    _update: function(){
      if(!this._map) return;
      var bounds = this._map.getBounds();
      var size = this._map.getSize();
      var bbox = bounds.getWest()+','+bounds.getSouth()+','+bounds.getEast()+','+bounds.getNorth();
      var w = Math.min(size.x, 2048);
      var h = Math.min(size.y, 2048);
      var url;
      if(this._isImage){
        url = this._url + '/exportImage?bbox='+bbox+'&bboxSR=4326&imageSR=4326&size='+w+','+h+'&format=png32&transparent=true&f=image';
        if(this._renderingRule) url += '&renderingRule='+encodeURIComponent(JSON.stringify(this._renderingRule));
      } else {
        url = this._url + '/export?bbox='+bbox+'&bboxSR=4326&imageSR=4326&size='+w+','+h+'&dpi=96&format=png32&transparent=true&f=image';
        if(this._layers) url += '&layers=show:'+this._layers;
      }
      this._imgEl.src = url;
      // Position image to match map bounds
      var topLeft = this._map.latLngToLayerPoint(bounds.getNorthWest());
      var bottomRight = this._map.latLngToLayerPoint(bounds.getSouthEast());
      L.DomUtil.setPosition(this._imgEl, topLeft);
      this._imgEl.style.width = (bottomRight.x - topLeft.x) + 'px';
      this._imgEl.style.height = (bottomRight.y - topLeft.y) + 'px';
    }
  });

