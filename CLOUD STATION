          var valid = p.valid || '';
          var expire = p.expire || '';
          var outlookColor = hazType === 'fire' ? '#f97316' : hazType === 'tornado' ? '#76ff03' : '#eab308';

          // ── Fire weather: decode SPC risk categories ──
          var riskName = '', riskColor = '', riskDesc = '', riskIcon = '';
          if (hazType === 'fire') {
            if (dn >= 10) { riskName = 'EXTREMELY CRITICAL'; riskColor = '#9333ea'; riskIcon = ''; riskDesc = 'Life-threatening fire weather conditions. Rapid fire spread, extreme rates of spread, and long-range spotting expected. Any fires that develop will be nearly impossible to control. Evacuations likely.'; }
            else if (dn >= 8) { riskName = 'CRITICAL'; riskColor = '#ef4444'; riskIcon = ''; riskDesc = 'Critical fire weather conditions expected. Low relative humidity, strong winds, and dry fuels will support rapid fire growth and extreme fire behavior. New fire starts will spread quickly and be difficult to suppress.'; }
            else if (dn >= 5) { riskName = 'ELEVATED'; riskColor = '#f97316'; riskIcon = ''; riskDesc = 'Elevated fire weather conditions. Warm temperatures, low humidity, and moderate winds will support fire spread. Outdoor burning is strongly discouraged. Fire starts can grow if not quickly suppressed.'; }
            else if (dn >= 2) { riskName = 'NON-CRITICAL'; riskColor = '#eab308'; riskIcon = ''; riskDesc = 'General fire weather area. Conditions are not expected to reach critical thresholds, but dry conditions may support limited fire activity.'; }
            else { riskName = 'GENERAL'; riskColor = '#888'; riskIcon = ''; riskDesc = 'General fire weather area identified by SPC.'; }

            // Detect sub-types from idp_source
            var subTypes = [];
            if (src.indexOf('dryltg') >= 0 || src.indexOf('dry_ltg') >= 0) subTypes.push({ name: 'DRY LIGHTNING', icon: '', desc: 'Thunderstorms producing lightning with little or no rain. Primary wildfire ignition source \u2014 multiple simultaneous fire starts possible.' });
            if (src.indexOf('wind') >= 0) subTypes.push({ name: 'CRITICAL WIND', icon: '', desc: 'Sustained winds or gusts meeting critical fire weather thresholds. Drives rapid fire spread and long-range spotting.' });
            if (src.indexOf('rh') >= 0 || src.indexOf('humidity') >= 0) subTypes.push({ name: 'LOW HUMIDITY', icon: '', desc: 'Relative humidity dropping below critical thresholds (typically <15%). Fine fuels become extremely flammable.' });

            outlookColor = riskColor;
          } else if (hazType === 'tornado') {
            var label = (p.LABEL || p.label || '').toString();
            if (dn >= 30 || label.indexOf('High') >= 0) { riskName = 'HIGH RISK'; riskColor = '#9333ea'; riskDesc = 'A high risk for severe thunderstorms with tornadoes, very large hail, and damaging winds. Significant severe weather outbreak expected. This is a rare outlook category \u2014 prepare immediately.'; }
            else if (dn >= 20 || label.indexOf('MDT') >= 0) { riskName = 'MODERATE RISK'; riskColor = '#ef4444'; riskDesc = 'Widespread severe thunderstorms expected with tornadoes (some strong), large hail, and damaging wind gusts. Significant severe weather event likely.'; }
            else if (dn >= 10 || label.indexOf('ENH') >= 0) { riskName = 'ENHANCED RISK'; riskColor = '#f97316'; riskDesc = 'Numerous severe thunderstorms possible with a few intense storms. Threats include tornadoes, large hail, and damaging winds.'; }
            else if (dn >= 5 || label.indexOf('SLGT') >= 0) { riskName = 'SLIGHT RISK'; riskColor = '#eab308'; riskDesc = 'Scattered severe thunderstorms possible. Isolated tornadoes, hail to 1.5 inches, and wind gusts to 70 mph.'; }
            else if (dn >= 3 || label.indexOf('MRGL') >= 0) { riskName = 'MARGINAL RISK'; riskColor = '#84cc16'; riskDesc = 'Isolated to scattered severe thunderstorms possible, generally limited in duration or intensity.'; }
            else { riskName = 'THUNDERSTORM'; riskColor = '#60a5fa'; riskDesc = 'General thunderstorm activity expected.'; }
