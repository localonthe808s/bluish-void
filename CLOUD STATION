            if (startPct < 0) startPct = 0;
            if (endPct < 0) endPct = 0;
            if (endPct > 100) endPct = 100;
            
            var widthPct = endPct - startPct;
            if (widthPct < 0.5) widthPct = 0.5;
            
            var visClass = seg.belowTreeline ? "dashed" : "solid";
            planetsHtml += '<div class="today-tl-planet-vis ' + visClass + '" style="left:' + startPct + '%;width:' + widthPct + '%;background:' + color + ';color:' + color + ';"></div>';
          }
        }
        
        planetsHtml += '</div></div>';
      }
      
      tlPlanetTracks.innerHTML = planetsHtml;
      // Attach click handlers directly to each planet row
      var pRows = tlPlanetTracks.querySelectorAll('.today-tl-planet-row');
      pRows.forEach(function(row) {
        row.addEventListener('click', function(e) {
          e.stopPropagation();
          var planetKey = row.dataset.planet;
          var col = decodeURIComponent(row.dataset.color || '#aaa');
          if (planetKey) showPlanetInsight(planetKey, col, e);
        });
      });
    }

    // ── PRESSURE TENDENCY BAR ──
    var pressureTrack = document.getElementById('today-tl-pressure-track');
    var pressureVal = document.getElementById('today-tl-pressure-val');
    if (pressureTrack && hourly && hourly.pressure_msl && hourly.time) {
      // Build hourly pressure data with 3hr tendency at each point
      var pHours = [];
      for (var pi = 0; pi < hourly.time.length; pi++) {
        var pTime = new Date(hourly.time[pi]);
        var pVal = hourly.pressure_msl[pi];
        if (typeof pVal !== 'number') continue;
        var pPct = pctForTime(pTime);
        if (pPct < 0 || pPct > 100) continue;
        var prev = (pi >= 3 && typeof hourly.pressure_msl[pi-3] === 'number') ? hourly.pressure_msl[pi-3] : null;
        var chg = prev !== null ? pVal - prev : 0;
        pHours.push({ pct: pPct, val: pVal, chg: chg, time: pTime });
      }

      if (pHours.length > 2) {
        var nowMs = Date.now();
        var curIdx = 0;
        for (var ni = 0; ni < pHours.length - 1; ni++) {
          if (pHours[ni].time.getTime() <= nowMs && pHours[ni+1].time.getTime() > nowMs) { curIdx = ni; break; }
        }
        var curP = pHours[curIdx].val;
        var curChg = pHours[curIdx].chg;

        var trendLabel, trendIcon;
        if (curChg > 3) { trendLabel = 'RISING FAST'; trendIcon = '\u2B06'; }
        else if (curChg > 1) { trendLabel = 'RISING'; trendIcon = '\u2197'; }
        else if (curChg > 0.3) { trendLabel = 'RISING SLOWLY'; trendIcon = '\u2197'; }
        else if (curChg < -3) { trendLabel = 'FALLING FAST'; trendIcon = '\u2B07'; }
        else if (curChg < -1) { trendLabel = 'FALLING'; trendIcon = '\u2198'; }
        else if (curChg < -0.3) { trendLabel = 'FALLING SLOWLY'; trendIcon = '\u2198'; }
        else { trendLabel = 'STEADY'; trendIcon = '\u2192'; }

        // Update label
        if (pressureVal) pressureVal.textContent = curP.toFixed(0) + ' mb ' + trendIcon + ' ' + trendLabel;

        // Build segments using bar-segment class
        var segsHtml = '';
        for (var bi = 0; bi < pHours.length - 1; bi++) {
          var segW = pHours[bi+1].pct - pHours[bi].pct;
          if (segW <= 0) continue;
          var c = pHours[bi].chg;
          var segColor;
          if (c > 2) segColor = 'rgba(68,136,255,.7)';
          else if (c > 0.5) segColor = 'rgba(68,136,255,.4)';
          else if (c > 0.1) segColor = 'rgba(100,187,204,.25)';
          else if (c < -2) segColor = 'rgba(255,102,68,.7)';
          else if (c < -0.5) segColor = 'rgba(255,153,0,.4)';
          else if (c < -0.1) segColor = 'rgba(255,170,0,.25)';
          else segColor = 'rgba(255,255,255,.06)';
          segsHtml += '<div class="today-tl-bar-segment" style="width:' + segW + '%;background:' + segColor + ';"></div>';
        }
        pressureTrack.innerHTML = segsHtml;

        // Click handler — comprehensive weather insight popup
        var barRow = pressureTrack.parentElement;
        barRow.style.cursor = 'pointer';
        barRow.onclick = function() {
          // Toggle the modern modal — _openInsightModal de-dupes its
          // own popup id, but explicit close on re-click matches the
          // other today-timeline popups.
          if (document.getElementById('planet-insight-popup')) {
            if (typeof window._closePlanetPopup === 'function') window._closePlanetPopup();
            return;
          }

          var wx = window._wxCurrent || {};
          var gL = function(l,v){return '<div class="hz-card-row"><span class="hz-label">'+l+'</span><span class="hz-val">'+v+'</span></div>';};
          var FS = function(t,c){return '<div style="font-weight:800;font-size:9.5px;color:'+(c||'#3344cc')+';text-transform:uppercase;letter-spacing:.04em;margin-top:12px;margin-bottom:6px;padding-bottom:4px;border-bottom:1px solid rgba(43,34,244,.10);">'+t+'</div>';};

          // Determine pressure regime
          var p = wx.pressure;
          var regime = '';
          var regimeColor = '';
          if (p > 1030) { regime = 'Strong High Pressure'; regimeColor = '#4af'; }
          else if (p > 1020) { regime = 'High Pressure'; regimeColor = '#6cc'; }
          else if (p > 1013) { regime = 'Near Average'; regimeColor = 'rgba(255,255,255,.6)'; }
          else if (p > 1005) { regime = 'Low Pressure'; regimeColor = '#f90'; }
          else if (p > 995) { regime = 'Deep Low'; regimeColor = '#f66'; }
          else { regime = 'Very Deep Low'; regimeColor = '#f44'; }

          // Build analysis text based on all available data
          var analysis = [];

          // Pressure trajectory
          var pt3 = wx.pressureTrend;
          var pt6 = wx.pressureTrend6hr;
          if (pt3 !== null && pt6 !== null) {
            if (pt3 < -1 && pt6 < -2) analysis.push('Pressure is in a <b>sustained fall</b> (' + pt6.toFixed(1) + ' mb over 6hr). This signals an approaching low-pressure system or frontal boundary. Expect deteriorating conditions.');
            else if (pt3 < -0.5) analysis.push('Pressure is <b>falling</b> (' + pt3.toFixed(1) + ' mb/3hr). Conditions may worsen \u2014 increasing clouds, wind, and precipitation possible in the next 6\u201312 hours.');
            else if (pt3 > 1 && pt6 > 2) analysis.push('Pressure is in a <b>sustained rise</b> (+' + pt6.toFixed(1) + ' mb over 6hr). A high-pressure system is building in. Expect clearing skies and improving conditions.');
            else if (pt3 > 0.5) analysis.push('Pressure is <b>rising</b> (+' + pt3.toFixed(1) + ' mb/3hr). Conditions improving \u2014 clouds should thin and winds relax.');
            else analysis.push('Pressure is <b>steady</b> (' + (pt3 > 0 ? '+' : '') + pt3.toFixed(1) + ' mb/3hr). Current conditions are likely to persist for the next several hours.');
          }

          // Frontal context
          if (wx.frontalSignature) {
            var fs = wx.frontalSignature;
            if (fs === 'cold_front_passage') analysis.push('\ud83c\udf00 A <b>cold front has just passed.</b> The pressure rise, wind shift, and temperature drop confirm post-frontal air is moving in. Skies should clear within hours.');
            else if (fs === 'cold_front_approaching') analysis.push('\ud83c\udf00 A <b>cold front is approaching.</b> The falling pressure and warming pattern indicate the warm sector is overhead. Watch for a sharp wind shift and gusty conditions when the front arrives.');
            else if (fs === 'warm_front_passage') analysis.push('\ud83c\udf00 A <b>warm front has passed.</b> Warmer, more humid air is now in place. If instability develops, thunderstorms are possible in this warm sector.');
            else if (fs === 'warm_front_approaching') analysis.push('\ud83c\udf00 A <b>warm front is approaching.</b> Expect increasing clouds and possible light precipitation as warm air overrides the cooler surface air ahead.');
          }

          // Wind + instability context
          if (wx.cape != null && wx.cape > 500) {
            analysis.push('\u26a1 <b>CAPE is ' + Math.round(wx.cape) + ' J/kg</b> \u2014 the atmosphere has energy for convection.' + (wx.cape > 1500 ? ' Severe thunderstorms possible if a trigger mechanism (front, outflow, terrain) initiates lift.' : ' Scattered showers or thunderstorms may develop with sufficient forcing.'));
          }

          // Wind shear
          if (wx.wind300spd != null && wx.wind != null) {
            var shear = Math.abs(wx.wind300spd - wx.wind);
            if (shear > 70) analysis.push('\ud83d\udca8 <b>Strong wind shear</b> (' + Math.round(shear) + ' mph difference sfc\u2192300mb). If storms develop, supercell potential is elevated.');
            else if (shear > 40) analysis.push('\ud83d\udca8 <b>Moderate wind shear</b> present (' + Math.round(shear) + ' mph sfc\u2192300mb). Storm organization possible if convection initiates.');
          }

          // Temperature + dewpoint comfort
          if (wx.temp != null && wx.dewpoint != null) {
            var spread = wx.temp - wx.dewpoint;
            if (spread < 3) analysis.push('\ud83c\udf2b\ufe0f Temperature-dewpoint spread is only ' + spread + '\u00b0F \u2014 air is near saturation. Fog, mist, or low clouds are likely, especially overnight.');
            else if (wx.dewpoint > 65) analysis.push('\ud83d\udca7 Dewpoint is ' + wx.dewpoint + '\u00b0F \u2014 <b>very humid</b>. This moisture feeds storm potential and makes conditions feel oppressive.');
          }

          // Cloud evolution
          if (wx.cloudLow != null && wx.cloudMid != null && wx.cloudHigh != null) {
            var total = Math.max(wx.cloudLow, wx.cloudMid, wx.cloudHigh);
            var lt = wx.cloudLowTrend, mt = wx.cloudMidTrend, ht = wx.cloudHighTrend;
            if (ht > 20 && (lt === null || lt < 10)) analysis.push('\u2601\ufe0f High clouds are <b>increasing</b> (+' + ht + '% in 3hr). This often precedes an approaching warm front or moisture plume arriving aloft.');
            if (lt != null && lt < -20) analysis.push('\u2600\ufe0f Low clouds are <b>clearing</b> (' + lt + '% in 3hr). Surface heating or post-frontal drying is eroding the cloud deck.');
          }

          // Visibility
          if (wx.visibility != null && wx.visibility < 5000) {
            analysis.push('\ud83d\udc41\ufe0f Visibility is reduced to ' + (wx.visibility/1000).toFixed(1) + ' km. ' + (wx.visibility < 1000 ? 'Dense fog or heavy precipitation is severely limiting sight distance.' : 'Haze, mist, or light precipitation is limiting visibility.'));
          }

          // Modal shell (_openInsightModal) supplies hero with title +
          // subtitle + liveStats. Skip the legacy hz-card-head and the
