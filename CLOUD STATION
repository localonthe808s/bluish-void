                if (_et && !isNaN(_et.getTime())) { expire = _et.getUTCFullYear().toString()+String(_et.getUTCMonth()+1).padStart(2,'0')+String(_et.getUTCDate()).padStart(2,'0')+String(_et.getUTCHours()).padStart(2,'0')+String(_et.getUTCMinutes()).padStart(2,'0'); p.EXPIRE = expire; }
              }
