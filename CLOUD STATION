  // ── TIMELINE DAY NAVIGATION ──
  window._tlDayOffset = 0; // 0=today, -1=yesterday, +1=tomorrow, etc.
  window._tlBaseDay = 1;   // With past_days=1, today is index 1 in daily arrays

  function tlUpdateDateLabel() {
    var el = document.getElementById('tl-nav-date');
    var prevLabel = document.getElementById('tl-nav-prev-label');
    var nextLabel = document.getElementById('tl-nav-next-label');
    if (!el) return;

    var days = ['SUN','MON','TUE','WED','THU','FRI','SAT'];
    var months = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
    var fmtDay = function(date) {
      return days[date.getDay()] + ' | ' + months[date.getMonth()] + ' ' + date.getDate();
    };

    // Current day
    var d = new Date();
    d.setDate(d.getDate() + window._tlDayOffset);
    var s = fmtDay(d);
    if (window._tlDayOffset === 0) s = 'TODAY · ' + s;
    el.textContent = s;

    // Previous day arrow label
    var prevDay = new Date();
    prevDay.setDate(prevDay.getDate() + window._tlDayOffset - 1);
    if (prevLabel) prevLabel.textContent = fmtDay(prevDay);

    // Next day arrow label
    var nextDay = new Date();
    nextDay.setDate(nextDay.getDate() + window._tlDayOffset + 1);
    if (nextLabel) nextLabel.textContent = fmtDay(nextDay);

    // Style arrows based on availability
    var prev = document.getElementById('tl-nav-prev');
    var next = document.getElementById('tl-nav-next');
    if (prev) prev.style.opacity = window._tlDayOffset <= -1 ? '.35' : '1';
    if (next) {
      var h = window._hourlyData;
      var maxDays = h ? Math.floor(h.time.length / 24) - window._tlBaseDay - 1 : 8;
      next.style.opacity = window._tlDayOffset >= maxDays ? '.35' : '1';
    }
  }

  function tlSliceDay(offset) {
    var h = window._hourlyData, d = window._dailyData;
    if (!h || !d) return null;

    var dayIdx = window._tlBaseDay + offset; // daily array index
    if (dayIdx < 0 || dayIdx >= (d.sunrise ? d.sunrise.length : 0)) return null;

    // Use daily.time (YYYY-MM-DD) for reliable day matching
    var targetDateStr = d.time ? d.time[dayIdx] : null;
    var targetDate;
    if (targetDateStr) {
      // Parse YYYY-MM-DD as local date
      var parts = targetDateStr.split('-');
      targetDate = new Date(parseInt(parts[0]), parseInt(parts[1])-1, parseInt(parts[2]), 0, 0, 0);
    } else {
      targetDate = new Date(d.sunrise[dayIdx]);
      targetDate = new Date(targetDate.getFullYear(), targetDate.getMonth(), targetDate.getDate(), 0, 0, 0);
    }
    var dayStart = targetDate;
    var dayEnd = new Date(dayStart.getTime() + 24 * 3600000);

    // Find hourly indices for this day by matching the date string prefix
    var startI = -1, endI = -1;
    for (var i = 0; i < h.time.length; i++) {
      var t = new Date(h.time[i]).getTime();
      if (t >= dayStart.getTime() && startI === -1) startI = i;
      if (t < dayEnd.getTime()) endI = i;
    }
    if (startI === -1) return null;
    endI = Math.min(endI + 1, h.time.length);

    // Slice all hourly arrays
    var sliced = {};
    for (var key in h) {
      if (Array.isArray(h[key])) {
        sliced[key] = h[key].slice(startI, endI);
      } else {
        sliced[key] = h[key];
      }
    }

    // Build single-day daily arrays
    var slicedDaily = {};
    for (var dk in d) {
      if (Array.isArray(d[dk])) {
        slicedDaily[dk] = [d[dk][dayIdx]];
      } else {
        slicedDaily[dk] = d[dk];
      }
    }

    // Find nearest index for this day
    var now = new Date();
    var ni = 0, minD = Infinity;
    for (var j = 0; j < sliced.time.length; j++) {
      var diff = Math.abs(now - new Date(sliced.time[j]));
      if (diff < minD) { minD = diff; ni = j; }
    }

    return { hourly: sliced, daily: slicedDaily, nearestIndex: ni };
  }

  window.tlNavDay = function(delta) {
    var newOffset = window._tlDayOffset + delta;
    if (newOffset < -1) return; // can't go before yesterday
    var h = window._hourlyData, d = window._dailyData;
    if (!h || !d) return;
    var maxDays = Math.floor(h.time.length / 24) - window._tlBaseDay - 1;
    if (newOffset > maxDays) return;

    window._tlDayOffset = newOffset;
    tlRenderForOffset();
  };

  function tlRenderForOffset() {
    var data = tlSliceDay(window._tlDayOffset);
    if (!data) return;

    tlUpdateDateLabel();

    // Hide/show NOW markers based on viewing today
    var isToday = window._tlDayOffset === 0;
    var nowMarker1 = document.getElementById('today-tl-now-marker');
    var nowMarker2 = document.getElementById('tl-now');
    if (nowMarker1) nowMarker1.style.display = isToday ? '' : 'none';
    if (nowMarker2) nowMarker2.style.display = isToday ? '' : 'none';

    try { renderTimeline(data.hourly, data.daily, data.nearestIndex); } catch(e) {}
    try {
      if (window._kpDataCache) {
        renderTodayTimeline(data.hourly, data.daily, data.nearestIndex, window._kpDataCache);
      }
    } catch(e) {}
  }

  // Initial date label
  tlUpdateDateLabel();

  // Architectural split — fast tick vs slow tick:
  // - Fast tick (60s): NOW marker + clock-time displays only. Always cheap.
  // - Slow tick (every 5 min OR on weather data refresh): full re-render via
  //   tlRenderForOffset() which rebuilds GH widget, scores, DOM cards.
  // Render gating inside renderTodayTimeline still short-circuits the cloud
  // SVG rebuild even when the slow tick fires, so steady-state cost stays low.
