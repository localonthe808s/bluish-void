            (function(){
              var nc = setInterval(function(){
                if (window._moonPreload && window._moonPreload.loaded) {
                  clearInterval(nc);
                  var dot = document.getElementById('nightsky-moon-dot');
                  if (dot) dot.style.background = "url('" + window._moonPreload.url + "') center/150%";
                } else if (window._moonPreload && window._moonPreload.failed) { clearInterval(nc); }
              }, 300);
