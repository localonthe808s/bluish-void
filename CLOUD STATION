          +     '<circle cx="7" cy="7" r="6.4" fill="url(#ptn-'+_ptnKey+')"/>'
          +     '<circle cx="7" cy="7" r="6.4" fill="none" stroke="rgba(255,255,255,.22)" stroke-width=".5"/>'
          +   '</svg>'
          +   '<div style="font-size:9px;font-weight:700;color:'+layer.color+';">'+layer.name+' <span style="opacity:.5;font-weight:400;">\u2014 '+layer.label+'</span></div>'
          + '</div>';
        // Radial-depth bar: track is the full planet radius (center → surface),
