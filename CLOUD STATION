  function _fetchNHCCurrentStorms() {
    // NHC CurrentStorms.json — official live active storm summary
    var url = 'https://www.nhc.noaa.gov/CurrentStorms.json';
    monitoredFetch('nhc-storms', url, { headers: { 'Accept': 'application/json' } })
      .then(function(r){ return r.json(); })
      .then(function(data) {
        _clearHurricaneStorms();
        var storms = data.activeStorms || [];
        window._nhcActiveStorms = storms;

        // Update badge and season pill
        var badge = document.getElementById('hazard-badge-hurricane');
        var countEl = document.getElementById('hz-active-storms-count');
        var seasonEl = document.getElementById('hz-season-label');
        var now = new Date();
        var month = now.getMonth() + 1;
        var inSeason = month >= 6 && month <= 11;

        if (badge) {
          if (storms.length > 0) {
            badge.textContent = storms.length;
            badge.style.display = 'inline-flex';
            // Check if any storm is a major hurricane (Cat 3+ = 96kt+)
            var hasMajor = storms.some(function(s){ return parseInt(s.intensity || 0) >= 96; });
            var hasHurricane = storms.some(function(s){ return parseInt(s.intensity || 0) >= 64; });
            badge.setAttribute('data-urgency', hasMajor ? 'critical' : hasHurricane ? 'elevated' : storms.length >= 3 ? 'elevated' : 'moderate');
            // Pulse animation for major hurricanes
            if (hasMajor) {
              badge.style.animation = 'badge-pulse-critical 1.5s ease-in-out infinite';
            } else {
              badge.style.animation = '';
            }
          } else {
            badge.textContent = '';
            badge.style.display = 'none';
            badge.style.animation = '';
          }
        }
        if (countEl) countEl.textContent = 'Active storms: ' + storms.length;
        if (seasonEl) {
          if (storms.length > 0) {
            seasonEl.textContent = storms.length + ' ACTIVE SYSTEM' + (storms.length > 1 ? 'S' : '');
            seasonEl.style.color = '#f97316';
          } else if (inSeason) {
            seasonEl.textContent = 'SEASON ACTIVE · QUIET';
            seasonEl.style.color = '#4ade80';
          } else {
            seasonEl.textContent = 'OFF SEASON';
            seasonEl.style.color = 'rgba(255,255,255,.4)';
          }
        }

        // Plot each storm
        storms.forEach(function(storm) {
          _plotNHCStorm(storm);
        });

        // Always build the season summary (handles both active & quiet states)
        _showNoStormsMessage();

        // Build spaghetti model tracks for each active storm
        storms.forEach(function(storm) {
          var bin = _resolveStormBin(storm);
          if (bin) _buildSpaghettiTracks(bin, (storm.name || 'Unnamed').toUpperCase(), hurricaneIntensityColor(parseInt(storm.intensity || 0)));
        });

        // If storms are active, also show their names in the active count
        if (storms.length > 0 && countEl) {
          var names = storms.map(function(s){ return (s.name || 'Unnamed'); }).join(', ');
          countEl.textContent = names;
        }

        // ── STORM SWITCHER PANEL — clickable pills for each active system ──
        _buildStormSwitcher(storms);

        // ── AUTO-ZOOM to fit all active storms with padding ──
        if (storms.length > 0 && _hurricaneMap) {
          var stormBounds = [];
          storms.forEach(function(s) {
            var sLat = parseFloat(s.centerLocLatitude || s.lat);
            var sLon = parseFloat(s.centerLocLongitude || s.lon);
            if (!isNaN(sLat) && !isNaN(sLon)) stormBounds.push([sLat, sLon]);
          });
          if (stormBounds.length > 0) {
            // If single storm, zoom to it with context; if multiple, fit all
            if (stormBounds.length === 1) {
              _hurricaneMap.flyTo(stormBounds[0], 6, { duration: 1.2 });
            } else {
              var bounds = L.latLngBounds(stormBounds);
              // Pad generously so tracks/cones aren't clipped
              _hurricaneMap.flyToBounds(bounds.pad(0.5), { duration: 1.2, maxZoom: 6 });
            }
          }
        }

        // Update data freshness indicator
        var pillEl = document.getElementById('hz-hurricane-season-pill');
        if (pillEl) {
          var freshEl = document.getElementById('hz-data-fresh');
          if (!freshEl) {
            freshEl = document.createElement('div');
            freshEl.id = 'hz-data-fresh';
            freshEl.style.cssText = 'font-size:.44rem;color:rgba(255,255,255,.2);margin-top:4px;padding-top:4px;border-top:1px solid rgba(255,255,255,.06);';
            pillEl.appendChild(freshEl);
          }
          freshEl.textContent = 'NHC data · ' + new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
        }
      })
      .catch(function(e) {
        console.warn('NHC CurrentStorms fetch failed:', e);
        _fetchNHCGISFallback();
      });
  }

