  function _showNoStormsMessage() {
    var now = new Date();
    var month = now.getMonth() + 1;
    var day = now.getDate();
    var year = now.getFullYear();
    var inSeason = month >= 6 && month <= 11;
    var nextSeasonYear = month >= 12 ? year + 1 : year;
    var seasonStart = 'June 1, ' + nextSeasonYear;

    var seasonEl = document.getElementById('hz-season-label');
    var countEl = document.getElementById('hz-active-storms-count');
    var summaryEl = document.getElementById('hz-season-summary');

    if (seasonEl) {
      if (inSeason) {
        seasonEl.textContent = 'NO ACTIVE SYSTEMS';
        seasonEl.style.color = '#047857';
      } else {
        seasonEl.textContent = 'OFF SEASON';
        seasonEl.style.color = 'rgba(43,34,244,.55)';
      }
    }

    // Countdown to next season or peak
    var countdownText = '';
    if (!inSeason) {
      var targetDate = new Date(nextSeasonYear, 5, 1); // June 1
      var daysUntil = Math.ceil((targetDate - now) / 86400000);
      countdownText = daysUntil + ' days until ' + seasonStart;
    } else if (month < 8 || (month === 8 && day < 20)) {
      // Before peak
      var peakDate = new Date(year, 7, 20); // Aug 20
      var daysToPeak = Math.ceil((peakDate - now) / 86400000);
      countdownText = daysToPeak + ' days to peak season (Aug 20)';
    } else if (month <= 10 && (month < 10 || day <= 10)) {
      countdownText = 'Peak season active (Aug 20 – Oct 10)';
    } else {
      var endDate = new Date(year, 10, 30); // Nov 30
      var daysLeft = Math.ceil((endDate - now) / 86400000);
      countdownText = daysLeft + ' days remain in season';
    }
    if (countEl) countEl.textContent = countdownText;

    // Build season summary panel
    if (!summaryEl) return;
    summaryEl.style.display = '';

    // Determine which season to show: current if in-season, last completed otherwise
    var recapYear = inSeason ? year : (month < 6 ? year - 1 : year);
    var recapData = _HURR_RECENT_SEASONS[recapYear] || _HURR_RECENT_SEASONS[recapYear - 1];
    var recapLabel = recapData ? recapYear : '';

    // Season progress bar (what % of climatological season are we through)
    var seasonProgressPct = 0;
    if (inSeason) {
      var seasonStartDate = new Date(year, 5, 1);
      var seasonEndDate = new Date(year, 10, 30);
      seasonProgressPct = Math.min(100, Math.max(0, Math.round(((now - seasonStartDate) / (seasonEndDate - seasonStartDate)) * 100)));
    }

    // Monthly activity indicator
    var monthActivity = _HURR_CLIMO.monthlyPct[month] || 0;
    var activityLabel = monthActivity >= 20 ? 'HIGH' : monthActivity >= 10 ? 'MODERATE' : monthActivity >= 5 ? 'LOW' : 'MINIMAL';
    var activityColor = monthActivity >= 20 ? '#b91c1c' : monthActivity >= 10 ? '#c2410c' : monthActivity >= 5 ? '#a16207' : 'rgba(43,34,244,.45)';

    var R = function(label, val, color) {
      return '<div style="display:flex;justify-content:space-between;align-items:center;padding:3px 0;">' +
        '<span style="font-size:.52rem;color:rgba(43,34,244,.55);font-weight:600;">' + label + '</span>' +
        '<span style="font-size:.52rem;font-weight:800;color:' + (color || '#2B22F4') + ';">' + val + '</span></div>';
    };

    var html = '';

    // Climatological activity for current month
    if (inSeason) {
      html += '<div style="display:flex;align-items:center;gap:6px;margin-bottom:5px;"><span style="width:3px;height:10px;background:#7e22ce;border-radius:2px;"></span><span style="font-size:.38rem;color:rgba(43,34,244,.45);font-weight:800;letter-spacing:.1em;">CURRENT MONTH</span></div>';
      html += R('Activity level', activityLabel, activityColor);
      html += R('Season share', monthActivity + '% of avg', activityColor);
      html += '<div style="margin:5px 0 3px;height:5px;background:rgba(43,34,244,.08);border-radius:3px;overflow:hidden;">' +
        '<div style="width:' + seasonProgressPct + '%;height:100%;background:linear-gradient(90deg,#7e22ce,#a855f7);border-radius:3px;"></div></div>' +
        '<div style="font-size:.42rem;color:rgba(43,34,244,.45);text-align:right;font-weight:600;">' + seasonProgressPct + '% through season</div>';
    }

    // 30-year averages
    html += '<div style="display:flex;align-items:center;gap:6px;margin:10px 0 5px;"><span style="width:3px;height:10px;background:#2B22F4;border-radius:2px;"></span><span style="font-size:.38rem;color:rgba(43,34,244,.45);font-weight:800;letter-spacing:.1em;">CLIMATOLOGY (1991–2020)</span></div>';
    html += R('Named storms', _HURR_CLIMO.avgNamed + ' avg');
    html += R('Hurricanes', _HURR_CLIMO.avgHurricanes + ' avg');
    html += R('Major (Cat 3+)', _HURR_CLIMO.avgMajor + ' avg', '#c2410c');
    html += R('Peak period', _HURR_CLIMO.peakStart + ' – ' + _HURR_CLIMO.peakEnd);
    html += R('MDR SST threshold', '≥ 26°C (79°F)');

    // Last/current season recap
    if (recapData) {
      var aboveBelow = function(actual, avg) {
        var pct = Math.round(((actual - avg) / avg) * 100);
        if (pct > 10) return '<span style="color:#b91c1c;">▲ +' + pct + '%</span>';
        if (pct < -10) return '<span style="color:#047857;">▼ ' + pct + '%</span>';
        return '<span style="color:rgba(43,34,244,.55);">≈ near avg</span>';
      };
      html += '<div style="display:flex;align-items:center;gap:6px;margin:10px 0 5px;"><span style="width:3px;height:10px;background:#7e22ce;border-radius:2px;"></span><span style="font-size:.38rem;color:rgba(43,34,244,.45);font-weight:800;letter-spacing:.1em;">' + recapLabel + ' SEASON' + (inSeason ? ' (SO FAR)' : ' RECAP') + '</span></div>';
      html += R('Named storms', recapData.named + ' ' + aboveBelow(recapData.named, _HURR_CLIMO.avgNamed));
      html += R('Hurricanes', recapData.hurricanes + ' ' + aboveBelow(recapData.hurricanes, _HURR_CLIMO.avgHurricanes));
      html += R('Major', recapData.major + ' ' + aboveBelow(recapData.major, _HURR_CLIMO.avgMajor), '#c2410c');
      if (recapData.strongest) html += R('Strongest', recapData.strongest, '#6d28d9');
      if (recapData.landfalls != null) html += R('US landfalls', recapData.landfalls);
      if (recapData.notable) {
        html += '<div style="margin-top:4px;font-size:.42rem;color:rgba(43,34,244,.55);line-height:1.5;font-weight:500;"><span style="color:#2B22F4;font-weight:800;">Named storms:</span> ' + recapData.notable + '</div>';
