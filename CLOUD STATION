          var svg = '<div style="position:relative;margin:4px 0 22px;">';
          // The bar itself
          svg += '<div style="position:relative;height:12px;border-radius:6px;background:linear-gradient(90deg,#3344cc 0%,#5566cc 25%,#cc8800 50%,#1a8a4a 75%,#0a6633 100%);">';
