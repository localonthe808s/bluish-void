          svg += '<div style="display:flex;justify-content:space-between;font-size:8px;font-weight:700;color:rgba(43,34,244,.5);">' +
            '<span>250 SLOW</span><span>500</span><span style="color:#ff9900;">800+ FAST</span>' +
          '</div>';
          return svg;
        };

        // forecastSparkline — bar chart of upcoming Kp values, colored by
        // intensity. Compact alternative to the gL() Range/Peak/Storm rows.
        var forecastSparkline = function(data) {
          if (!data || data.length < 2) return '';
          var nowT = Date.now();
          var bars = [];
          for (var fi = 0; fi < data.length; fi++) {
            var dt = data[fi].t && typeof data[fi].t.getTime === 'function' ? data[fi].t.getTime() : null;
            if (dt == null) continue;
