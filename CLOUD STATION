  function initQuakeData(){
    if (!hazardMap) return;

    // Legend is now integrated into the main earthquake pill (see updateUnifiedPills)

    // Load USGS earthquake data
    loadQuakeData();
    setInterval(function(){ if(hazardActiveTab === 'quake') loadQuakeData(); }, 5 * 60 * 1000);
