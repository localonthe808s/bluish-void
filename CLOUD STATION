                var _nsPannus = isNight ? 'rgba(15,16,30,0.75)'
                              : isGoldenHour ? 'rgba(40,28,58,0.72)'
                              : 'rgba(60,65,82,0.70)';
                var nFrag=5+Math.round(precipIntensity*4);
                for(var fi=0;fi<nFrag;fi++){
                  var fx=xOff+R()*pW;
                  var fy=btY+1+R()*10;
                  var fw=8+R()*22;
                  var fh=2+R()*3;
                  var frEl=document.createElementNS(ns,'ellipse');
                  frEl.setAttribute('cx',fx.toFixed(1));frEl.setAttribute('cy',fy.toFixed(1));
                  frEl.setAttribute('rx',fw.toFixed(1));frEl.setAttribute('ry',fh.toFixed(1));
                  frEl.setAttribute('fill',_nsPannus);
                  frEl.setAttribute('filter','url(#cuFeather)');
                  g.appendChild(frEl);
                }
                // Curtain-shaped virga — wide-at-top, tapers downward bezier
                var _nsVirga = isNight ? 'rgba(35,38,60,0.32)'
                             : isGoldenHour ? 'rgba(70,55,90,0.32)'
                             : 'rgba(95,100,118,0.32)';
                var nVirga=3+Math.round(precipIntensity*4);
                for(var vi=0;vi<nVirga;vi++){
                  var vx=xOff+10+R()*(pW-20);
                  var vw=15+R()*18;
                  var vh=14+R()*14;
                  var vTopY=btY+1;
                  var vBotY=btY+vh;
                  var vd='M '+(vx-vw*0.5).toFixed(1)+' '+vTopY.toFixed(1)+
                         ' Q '+vx.toFixed(1)+' '+(vTopY+vh*0.3).toFixed(1)+
                         ' '+(vx-vw*0.30).toFixed(1)+' '+vBotY.toFixed(1)+
                         ' L '+(vx+vw*0.30).toFixed(1)+' '+vBotY.toFixed(1)+
                         ' Q '+vx.toFixed(1)+' '+(vTopY+vh*0.3).toFixed(1)+
                         ' '+(vx+vw*0.5).toFixed(1)+' '+vTopY.toFixed(1)+' Z';
                  var vrE=document.createElementNS(ns,'path');
                  vrE.setAttribute('d',vd);
                  vrE.setAttribute('fill',_nsVirga);
                  vrE.setAttribute('filter','url(#cuFeather)');
                  g.appendChild(vrE);
                }
                // Heavy rain shafts at higher coverage (90%+) — kept from previous
                if(t.cover>=90&&!isSnow){
                  var nShafts=2+Math.round((t.cover-85)/6);
                  for(var si=0;si<nShafts;si++){
                    var sx=xOff+((si+0.5)/nShafts)*pW+(R()-0.5)*40;
                    var sw=35+R()*25;
                    var sShaftH=128-btY+5;
                    var shE=document.createElementNS(ns,'rect');
                    shE.setAttribute('x',(sx-sw/2).toFixed(1));shE.setAttribute('y',btY.toFixed(1));
                    shE.setAttribute('width',sw.toFixed(1));shE.setAttribute('height',sShaftH.toFixed(1));
                    shE.setAttribute('fill','rgba(40,32,62,0.42)');
                    shE.setAttribute('filter','url(#cuFeather)');
                    shE.setAttribute('rx',(sw/4).toFixed(1));
                    g.appendChild(shE);
                  }
                }
                // Per-line precipitation — fires at ALL coverages so light/
                // moderate Ns has visible rain (was invisible <90%).
                var _nsPrecipBot = 130;
                if (isSnow) {
                  // Snow particle field — many small grains + a few larger streaked flakes
                  var nFlakes=80;
                  for(var sf=0;sf<nFlakes;sf++){
                    var sfx=xOff+R()*pW;
                    var sfy=btY+2+R()*(_nsPrecipBot-btY-4);
                    var isLargeFlake=R()<0.10;
                    var sfr=isLargeFlake?(1.0+R()*0.6):(0.3+R()*0.5);
                    var sAlpha=isLargeFlake?(0.55+R()*0.25):(0.30+R()*0.30);
                    if (isLargeFlake) {
                      var _snLine = document.createElementNS(ns,'line');
                      _snLine.setAttribute('x1',sfx.toFixed(1));
                      _snLine.setAttribute('y1',sfy.toFixed(1));
                      _snLine.setAttribute('x2',sfx.toFixed(1));
                      _snLine.setAttribute('y2',(sfy+sfr*1.5).toFixed(1));
                      _snLine.setAttribute('stroke','rgba(220,215,228,'+(sAlpha*0.5).toFixed(2)+')');
                      _snLine.setAttribute('stroke-width',(sfr*0.6).toFixed(2));
                      _snLine.setAttribute('stroke-linecap','round');
                      g.appendChild(_snLine);
                    }
                    var _snDot = document.createElementNS(ns,'circle');
                    _snDot.setAttribute('cx',sfx.toFixed(1));
                    _snDot.setAttribute('cy',sfy.toFixed(1));
                    _snDot.setAttribute('r',sfr.toFixed(2));
                    _snDot.setAttribute('fill',isLargeFlake?'rgba(225,220,232,'+sAlpha.toFixed(2)+')':'rgba(215,212,225,'+sAlpha.toFixed(2)+')');
                    g.appendChild(_snDot);
                  }
                } else {
                  // Rain streaks — diagonal, intensity scales with coverage
                  var nRain=Math.round(30+precipIntensity*40);
                  var rainSlant=2.5;
                  for(var rn=0;rn<nRain;rn++){
                    var rxR=xOff+R()*pW;
                    var ryR=btY+2+R()*(_nsPrecipBot-btY-6);
                    var rL=6+R()*12;
                    var rOp=0.30+R()*0.30;
                    var rW2=0.5+R()*0.4;
                    var _rnL = document.createElementNS(ns,'line');
                    _rnL.setAttribute('x1',rxR.toFixed(1));
                    _rnL.setAttribute('y1',ryR.toFixed(1));
                    _rnL.setAttribute('x2',(rxR+rainSlant).toFixed(1));
                    _rnL.setAttribute('y2',(ryR+rL).toFixed(1));
                    _rnL.setAttribute('stroke','rgba(170,165,195,'+rOp.toFixed(2)+')');
                    _rnL.setAttribute('stroke-width',rW2.toFixed(2));
                    _rnL.setAttribute('stroke-linecap','round');
                    g.appendChild(_rnL);
                  }
                }
              } else {
                // ───────── STRATUS v3 — variant dispatch (E solid mass / G layered depth / H fractus lenses) ─────────
                // Replaces old stacked-rect approach. Single continuous wavy silhouette,
                // bright defined sunset-lit base, internal density via horizontal bands
                // (NEVER dots/beads). Time-of-day adaptation preserved via col('low',a,t).
                if(covFac<1) renderSheetSunGlow(g,tY,btY,0.08);
                var isFractus=t.species==='fractus'||t.cover<50;
                var hasMultiLayer=!isFractus&&cM>25&&t.cover>=60;
                var stKey='-st-'+seed+'-'+Math.round(t.cover);

                if(isFractus){
                  // ─── v3 H — lens-shaped pieces on faint base veil ───
                  var stHveil=document.createElementNS(ns,'rect');
                  stHveil.setAttribute('x',(xOff-5).toString());stHveil.setAttribute('y',(btY-7).toFixed(1));
                  stHveil.setAttribute('width',(pW+10).toString());stHveil.setAttribute('height','9');
                  stHveil.setAttribute('fill',col('low',bA*0.32,0.40));
                  stHveil.setAttribute('filter','url(#ghCloudHaze)');
                  g.appendChild(stHveil);
                  var stHnP=4;
                  for(var lpi=0;lpi<stHnP;lpi++){
                    var lpcx=xOff+(lpi+0.45+(R()-0.5)*0.3)*pW/stHnP;
                    var lpcy=btY-14+(R()-0.5)*4;
                    var lensW=28+R()*22;
                    var lensH=5+R()*3;
                    var ld='M '+(lpcx-lensW)+' '+lpcy;
                    for(var lj=0;lj<=12;lj++){var ltt=lj/12;var lpx=lpcx-lensW+ltt*lensW*2;var larc=Math.sin(ltt*Math.PI);var lpy=lpcy-lensH*larc-(R()-0.5)*1.2;ld+=' L'+lpx.toFixed(1)+' '+lpy.toFixed(1);}
                    for(var lj2=12;lj2>=0;lj2--){var ltt2=lj2/12;var lpx2=lpcx-lensW+ltt2*lensW*2;var larc2=Math.sin(ltt2*Math.PI);var lpy2=lpcy+lensH*larc2*0.5+(R()-0.5)*1.2;ld+=' L'+lpx2.toFixed(1)+' '+lpy2.toFixed(1);}
                    ld+=' Z';
                    var stHgid=panelPrefix+stKey+'-Hg-'+lpi;
                    var stHdef=document.createElementNS(ns,'defs');
                    stHdef.innerHTML='<linearGradient id="'+stHgid+'" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="'+col('low',0.4,0.10)+'"/><stop offset="50%" stop-color="'+col('low',1,0.30)+'"/><stop offset="100%" stop-color="'+col('low',1,0.65)+'"/></linearGradient>';
                    g.appendChild(stHdef);
                    var lensHalo=document.createElementNS(ns,'path');
                    lensHalo.setAttribute('d',ld);lensHalo.setAttribute('fill',col('low',bA*0.30,0.05));
                    lensHalo.setAttribute('filter','url(#ghCloudHaze)');lensHalo.setAttribute('transform','translate(0 -1)');
                    g.appendChild(lensHalo);
                    var lensBody=document.createElementNS(ns,'path');
                    lensBody.setAttribute('d',ld);lensBody.setAttribute('fill','url(#'+stHgid+')');
                    lensBody.setAttribute('opacity','0.92');lensBody.setAttribute('filter','url(#ghCloudSoft)');
                    g.appendChild(lensBody);
                    var lensUnder=document.createElementNS(ns,'ellipse');
                    lensUnder.setAttribute('cx',lpcx.toFixed(1));lensUnder.setAttribute('cy',(lpcy+lensH*0.4).toFixed(1));
                    lensUnder.setAttribute('rx',(lensW*0.92).toFixed(1));lensUnder.setAttribute('ry','2');
                    lensUnder.setAttribute('fill',col('low',bA*0.55,0.85));
                    lensUnder.setAttribute('filter','url(#ghPrecipSoft)');
                    g.appendChild(lensUnder);
                  }
                  var stHbase=document.createElementNS(ns,'rect');
                  stHbase.setAttribute('x',(xOff-5).toString());stHbase.setAttribute('y',(btY-1).toFixed(1));
                  stHbase.setAttribute('width',(pW+10).toString());stHbase.setAttribute('height','2.5');
                  stHbase.setAttribute('fill',col('low',bA*0.72,0.82));
                  g.appendChild(stHbase);
                } else if(hasMultiLayer){
                  // ─── v3 G — two overlapping masses (paler back + bolder defined front) ───
                  var dBack='M '+(xOff-3)+' '+(btY-10);
                  for(var bi=0;bi<=14;bi++){var btt=bi/14;var bpx=(xOff-3)+btt*(pW+6);var bTopY=btY-32-Math.sin(btt*Math.PI*1.2)*4-(R()-0.5)*3;dBack+=' L'+bpx.toFixed(1)+' '+bTopY.toFixed(1);}
                  dBack+=' L'+(xOff+pW+3)+' '+(btY-9);
                  for(var bi2=14;bi2>=0;bi2--){var btt2=bi2/14;var bpx2=(xOff-3)+btt2*(pW+6);var bby=btY-8+(R()-0.5)*1.2;dBack+=' L'+bpx2.toFixed(1)+' '+bby.toFixed(1);}
                  dBack+=' Z';
                  var dFront='M '+(xOff-3)+' '+(btY+3);
                  for(var fri=0;fri<=12;fri++){var ftt=fri/12;var fpx=(xOff-3)+ftt*(pW+6);var fpy=btY+(R()-0.5)*1.5;dFront+=' L'+fpx.toFixed(1)+' '+fpy.toFixed(1);}
                  dFront+=' L'+(xOff+pW+3)+' '+(btY-22);
                  for(var fri2=12;fri2>=0;fri2--){var ftt2=fri2/12;var fpx2=(xOff-3)+ftt2*(pW+6);var fTopY=btY-22-Math.sin(ftt2*Math.PI*1.5+1.2)*5-(R()-0.5)*3;dFront+=' L'+fpx2.toFixed(1)+' '+fTopY.toFixed(1);}
                  dFront+=' Z';
                  var stGdef=document.createElementNS(ns,'defs');
                  var stGbgid=panelPrefix+stKey+'-Gb';
                  var stGfgid=panelPrefix+stKey+'-Gf';
                  stGdef.innerHTML='<linearGradient id="'+stGbgid+'" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="'+col('low',0,0.08)+'"/><stop offset="40%" stop-color="'+col('low',0.55,0.18)+'"/><stop offset="100%" stop-color="'+col('low',0.7,0.55)+'"/></linearGradient><linearGradient id="'+stGfgid+'" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="'+col('low',0.4,0.05)+'"/><stop offset="40%" stop-color="'+col('low',1,0.20)+'"/><stop offset="80%" stop-color="'+col('low',1,0.55)+'"/><stop offset="100%" stop-color="'+col('low',1,0.85)+'"/></linearGradient>';
                  g.appendChild(stGdef);
                  var stGback=document.createElementNS(ns,'path');
                  stGback.setAttribute('d',dBack);stGback.setAttribute('fill','url(#'+stGbgid+')');
                  stGback.setAttribute('opacity',(bA*0.85).toFixed(2));stGback.setAttribute('filter','url(#ghCloudSoft)');
                  g.appendChild(stGback);
                  var stGfHalo=document.createElementNS(ns,'path');
                  stGfHalo.setAttribute('d',dFront);stGfHalo.setAttribute('fill',col('low',bA*0.32,0.05));
                  stGfHalo.setAttribute('filter','url(#ghCloudHaze)');stGfHalo.setAttribute('transform','translate(0 -2)');
                  g.appendChild(stGfHalo);
                  var stGfront=document.createElementNS(ns,'path');
                  stGfront.setAttribute('d',dFront);stGfront.setAttribute('fill','url(#'+stGfgid+')');
                  stGfront.setAttribute('opacity',(bA*0.96).toFixed(2));stGfront.setAttribute('filter','url(#ghCloudSoft)');
                  g.appendChild(stGfront);
                  var stGbase=document.createElementNS(ns,'rect');
                  stGbase.setAttribute('x',(xOff-5).toString());stGbase.setAttribute('y',(btY-1.4).toFixed(1));
                  stGbase.setAttribute('width',(pW+10).toString());stGbase.setAttribute('height','2.8');
                  stGbase.setAttribute('fill',col('low',bA*0.78,0.85));
                  stGbase.setAttribute('filter','url(#ghPrecipSoft)');
                  g.appendChild(stGbase);
                } else {
                  // ─── v3 E — single continuous wavy mass + horizontal density bands (default) ───
                  var massThk=30;
                  var dE='M '+(xOff-3)+' '+(btY+4);
                  for(var ei=0;ei<=8;ei++){var ett=ei/8;var epx=(xOff-3)+ett*(pW+6);var epy=btY+(R()-0.5)*1.5;dE+=' L'+epx.toFixed(1)+' '+epy.toFixed(1);}
                  dE+=' L'+(xOff+pW+3)+' '+(btY-massThk);
                  for(var ei2=0;ei2<=14;ei2++){var ett2=ei2/14;var epx2=(xOff+pW+3)-ett2*(pW+6);var eTopY=btY-(massThk-2)-Math.sin(ett2*Math.PI*1.3)*5-(R()-0.5)*4;dE+=' L'+epx2.toFixed(1)+' '+eTopY.toFixed(1);}
                  dE+=' Z';
                  var stEgid=panelPrefix+stKey+'-Eg';
                  var stEdef=document.createElementNS(ns,'defs');
                  stEdef.innerHTML='<linearGradient id="'+stEgid+'" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="'+col('low',0,0.05)+'"/><stop offset="20%" stop-color="'+col('low',0.85,0.10)+'"/><stop offset="60%" stop-color="'+col('low',1,0.30)+'"/><stop offset="92%" stop-color="'+col('low',1,0.65)+'"/><stop offset="100%" stop-color="'+col('low',1,0.85)+'"/></linearGradient>';
                  g.appendChild(stEdef);
                  var stEhalo=document.createElementNS(ns,'path');
                  stEhalo.setAttribute('d',dE);stEhalo.setAttribute('fill',col('low',bA*0.30,0.05));
                  stEhalo.setAttribute('filter','url(#ghCloudHaze)');stEhalo.setAttribute('transform','translate(0 -2)');
                  g.appendChild(stEhalo);
                  var stEbody=document.createElementNS(ns,'path');
                  stEbody.setAttribute('d',dE);stEbody.setAttribute('fill','url(#'+stEgid+')');
                  stEbody.setAttribute('opacity',(bA*0.95).toFixed(2));stEbody.setAttribute('filter','url(#ghCloudSoft)');
                  g.appendChild(stEbody);
                  for(var dbi=0;dbi<4;dbi++){
                    var dby=btY-22+dbi*5;
                    var stEband=document.createElementNS(ns,'rect');
                    stEband.setAttribute('x',(xOff-5).toString());stEband.setAttribute('y',dby.toFixed(1));
                    stEband.setAttribute('width',(pW+10).toString());stEband.setAttribute('height','2');
                    stEband.setAttribute('fill',col('low',0.13+dbi*0.04,0.05));
                    stEband.setAttribute('filter','url(#ghCloudHaze)');
                    g.appendChild(stEband);
                  }
                  var stEbase=document.createElementNS(ns,'rect');
                  stEbase.setAttribute('x',(xOff-5).toString());stEbase.setAttribute('y',(btY-1.5).toFixed(1));
                  stEbase.setAttribute('width',(pW+10).toString());stEbase.setAttribute('height','3');
                  stEbase.setAttribute('fill',col('low',bA*0.72,0.85));
                  stEbase.setAttribute('filter','url(#ghPrecipSoft)');
                  g.appendChild(stEbase);
                  var stEbase2=document.createElementNS(ns,'rect');
                  stEbase2.setAttribute('x',(xOff-5).toString());stEbase2.setAttribute('y',(btY-0.4).toFixed(1));
                  stEbase2.setAttribute('width',(pW+10).toString());stEbase2.setAttribute('height','1.4');
                  stEbase2.setAttribute('fill',col('low',bA*0.65,0.95));
                  g.appendChild(stEbase2);
                }
              }
            }
            svgEl.insertBefore(g,refEl);
          });

          // ══ LAYER 3.5: SURFACE FOG ══
          // Fog is classified as a separate genus (layer:'surface') and was not
          // rendered before — the low/deep pass filtered it out. Surface fog
          // sits at the bottom of the panel as a soft graduated layer, density
          // scaled by species (thin / moderate / dense) and palette adapted to
          // lighting state.
          types.forEach(function(t){
            if (t.layer !== 'surface' || t.genus !== 'Fog') return;
            var fG = makeG('fog');
            var _fogTopY = 95;
            var _fogBotY = 130;
            var _fogDensity = t.species==='dense' ? 1.0 : (t.species==='moderate' ? 0.75 : 0.50);
            var _fogStops;
            if (isNight) {
              _fogStops =
                '<stop offset="0%"  stop-color="rgb(28,30,52)"  stop-opacity="0"/>'+
                '<stop offset="35%" stop-color="rgb(38,42,68)"  stop-opacity="'+(0.55*_fogDensity).toFixed(2)+'"/>'+
                '<stop offset="80%" stop-color="rgb(48,52,78)"  stop-opacity="'+(0.85*_fogDensity).toFixed(2)+'"/>'+
                '<stop offset="100%" stop-color="rgb(58,62,88)" stop-opacity="'+(0.95*_fogDensity).toFixed(2)+'"/>';
            } else if (isGoldenHour) {
              _fogStops =
                '<stop offset="0%"  stop-color="rgb(170,120,130)" stop-opacity="0"/>'+
                '<stop offset="35%" stop-color="rgb(200,145,138)" stop-opacity="'+(0.55*_fogDensity).toFixed(2)+'"/>'+
                '<stop offset="80%" stop-color="rgb(225,165,142)" stop-opacity="'+(0.85*_fogDensity).toFixed(2)+'"/>'+
                '<stop offset="100%" stop-color="rgb(240,180,150)" stop-opacity="'+(0.95*_fogDensity).toFixed(2)+'"/>';
            } else {
              _fogStops =
                '<stop offset="0%"  stop-color="rgb(190,195,210)" stop-opacity="0"/>'+
                '<stop offset="35%" stop-color="rgb(208,212,222)" stop-opacity="'+(0.55*_fogDensity).toFixed(2)+'"/>'+
                '<stop offset="80%" stop-color="rgb(220,224,232)" stop-opacity="'+(0.85*_fogDensity).toFixed(2)+'"/>'+
                '<stop offset="100%" stop-color="rgb(228,232,240)" stop-opacity="'+(0.95*_fogDensity).toFixed(2)+'"/>';
            }
            var _fogGid = panelPrefix+'-fog-'+seed;
            var _fogDef = document.createElementNS(ns,'defs');
            _fogDef.innerHTML = '<linearGradient id="'+_fogGid+'" x1="0" y1="0" x2="0" y2="1">'+_fogStops+'</linearGradient>';
            fG.appendChild(_fogDef);
            // Main fog layer
            var _fogR = document.createElementNS(ns,'rect');
            _fogR.setAttribute('x',(xOff-10).toString());
            _fogR.setAttribute('y',_fogTopY.toString());
            _fogR.setAttribute('width',(pW+20).toString());
            _fogR.setAttribute('height',(_fogBotY-_fogTopY).toString());
            _fogR.setAttribute('fill','url(#'+_fogGid+')');
            _fogR.setAttribute('filter','url(#cuFluff)');
            fG.appendChild(_fogR);
            // Vertical wisp tendrils — give the fog atmospheric texture, more
            // numerous and taller for denser fog.
            var _fogWispCol = isNight ? 'rgba(50,55,82,0.30)'
                            : isGoldenHour ? 'rgba(190,140,135,0.32)'
                            : 'rgba(200,208,220,0.30)';
            var nFogWisps = Math.round(8 + _fogDensity*10);
            for (var fw = 0; fw < nFogWisps; fw++) {
              var fwX = xOff + R()*pW;
              var fwH = 6 + R()*14;
              var fwW = 4 + R()*6;
              var _fwE = document.createElementNS(ns,'ellipse');
              _fwE.setAttribute('cx',fwX.toFixed(1));
              _fwE.setAttribute('cy',(_fogTopY + 5 + R()*15).toFixed(1));
              _fwE.setAttribute('rx',fwW.toFixed(1));
              _fwE.setAttribute('ry',fwH.toFixed(1));
              _fwE.setAttribute('fill',_fogWispCol);
              _fwE.setAttribute('filter','url(#cuHalo)');
              fG.appendChild(_fwE);
            }
            // Sun-side warm bleed at golden hour — fog catches horizon light
            if (isGoldenHour) {
              var _fogSunGid = panelPrefix+'-fog-sun-'+seed;
              var _fogSunDef = document.createElementNS(ns,'defs');
              _fogSunDef.innerHTML =
                '<linearGradient id="'+_fogSunGid+'" x1="0" y1="0" x2="1" y2="0">'+
                  '<stop offset="0%" stop-color="rgb(255,200,160)" stop-opacity="0"/>'+
                  '<stop offset="55%" stop-color="rgb(255,200,160)" stop-opacity="'+(0.18*_fogDensity).toFixed(2)+'"/>'+
                  '<stop offset="100%" stop-color="rgb(255,220,180)" stop-opacity="'+(0.28*_fogDensity).toFixed(2)+'"/>'+
                '</linearGradient>';
              fG.appendChild(_fogSunDef);
              var _fogSun = document.createElementNS(ns,'rect');
              _fogSun.setAttribute('x',(xOff-5).toString());
              _fogSun.setAttribute('y',(_fogTopY+8).toString());
              _fogSun.setAttribute('width',(pW+10).toString());
              _fogSun.setAttribute('height','12');
              _fogSun.setAttribute('fill','url(#'+_fogSunGid+')');
              _fogSun.setAttribute('filter','url(#cuFeather)');
              fG.appendChild(_fogSun);
            }
            svgEl.insertBefore(fG,refEl);
          });

          // ══ LAYER 4: PRECIPITATION (on top of clouds) ══
          if(pr>0.05||snow>0){
            var pG=makeG('precip');
            var pI=Math.min(1,(pr+snow)/2.5);
            // Blizzard detection: heavy snow + low vis + high winds
            var isBlizzard = snow > 0.5 && vis < 5000;
            var nP=Math.round(isBlizzard ? 80+pI*80 : 20+pI*55);

            if(snow>0){
              // Snowfall — density scales with intensity
              for(var i=0;i<nP;i++){
                var sx=xOff+R()*pW,sy=5+R()*120;
                var sr=0.5+R()*2.0*Math.min(1.5,snow/1.2);
