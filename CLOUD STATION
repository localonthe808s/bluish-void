          var h = '';

          // Pressure scale visualization — horizontal bar 985–1040 mb
          // with colored zones (low/normal/high) and a marker on
          // current pressure. Replaces the inline numeric + regime
          // header that was previously rendered as text.
          if (p != null) {
            var pMin = 985, pMax = 1040;
            var pPct = Math.max(0, Math.min(100, ((p - pMin) / (pMax - pMin)) * 100));
            h += '<div style="position:relative;padding-top:20px;margin:6px 0 2px;">';
            // Floating callout above the marker
            h += '<div style="position:absolute;left:'+pPct.toFixed(2)+'%;top:0;transform:translateX(-50%);font-size:11px;font-weight:900;color:rgba(43,34,244,.95);background:rgba(255,255,255,.92);padding:2px 8px;border-radius:10px;box-shadow:0 2px 6px rgba(43,34,244,.18),0 0 0 1px rgba(43,34,244,.08);white-space:nowrap;">'+p.toFixed(1)+' mb</div>';
            // Bar with low/normal/high zones
            h += '<div style="position:relative;height:14px;border-radius:7px;background:linear-gradient(90deg, #f44 0%, #f66 18%, #f90 32%, #cccccc 50%, #6cc 70%, #4af 100%);box-shadow:inset 0 1px 2px rgba(0,0,0,.15);">';
            // Marker
            h += '<div style="position:absolute;left:'+pPct.toFixed(2)+'%;top:-3px;bottom:-3px;width:3px;background:rgba(43,34,244,.95);border-radius:2px;box-shadow:0 0 0 2px rgba(255,255,255,.85);transform:translateX(-50%);"></div>';
            h += '</div>';
            // Scale labels
            h += '<div style="display:flex;justify-content:space-between;font-size:8px;font-weight:700;color:rgba(43,34,244,.5);letter-spacing:.04em;margin-top:4px;">'+
              '<span style="color:#cc4422;">985 LOW</span>'+
              '<span>1000</span>'+
              '<span>1013 AVG</span>'+
              '<span>1025</span>'+
              '<span style="color:#3388cc;">1040 HIGH</span>'+
            '</div>';
            h += '</div>';
          }

          // ── PRESSURE TENDENCY (visualized) ──
          h += FS('Pressure Tendency');

          // 24-hour pressure sparkline — pulls hourly.pressure_msl
          // centered on now (12 hours back, 12 hours forward) so the
          // user can see where pressure has been and where it's heading.
          var hourlyP = window._wxHourly || window._lastHourly;
          if (hourlyP && hourlyP.time && hourlyP.pressure_msl) {
            var nowDtP = new Date();
            var nowIdxP = -1;
            for (var pi3 = 0; pi3 < hourlyP.time.length; pi3++) {
              var hdtP = new Date(hourlyP.time[pi3]);
              if (hdtP.getDate() === nowDtP.getDate() && hdtP.getHours() === nowDtP.getHours()) {
                nowIdxP = pi3; break;
              }
            }
            if (nowIdxP >= 0) {
              var startP = Math.max(0, nowIdxP - 12);
              var endP   = Math.min(hourlyP.time.length, nowIdxP + 13);
              var pVals = [];
              for (var pj = startP; pj < endP; pj++) {
                var pv = hourlyP.pressure_msl[pj];
                if (typeof pv === 'number') pVals.push({i:pj, p:pv, t:new Date(hourlyP.time[pj])});
              }
              if (pVals.length > 4) {
                var pMinV = Math.min.apply(null, pVals.map(function(x){return x.p;}));
                var pMaxV = Math.max.apply(null, pVals.map(function(x){return x.p;}));
                var pRange = Math.max(2, pMaxV - pMinV);
                var spkW = 308, spkH = 50;
                var s = '<svg width="100%" viewBox="0 0 '+spkW+' '+spkH+'" preserveAspectRatio="none" style="display:block;background:rgba(43,34,244,.04);border-radius:6px;margin:4px 0 6px;">';
                // Center horizontal line (avg)
                s += '<line x1="0" y1="'+(spkH/2)+'" x2="'+spkW+'" y2="'+(spkH/2)+'" stroke="rgba(43,34,244,0.10)" stroke-width="0.6" stroke-dasharray="2 3"/>';
                // Path of pressure values
                var pts = pVals.map(function(d, idx){
                  var x = (idx / (pVals.length-1)) * spkW;
                  var y = spkH - 6 - ((d.p - pMinV) / pRange) * (spkH - 12);
                  return {x:x, y:y, d:d};
                });
                // Area under curve
                var areaPath = 'M '+pts[0].x+' '+spkH+' L '+pts[0].x+' '+pts[0].y;
                pts.forEach(function(p){ areaPath += ' L '+p.x.toFixed(1)+' '+p.y.toFixed(1); });
                areaPath += ' L '+pts[pts.length-1].x+' '+spkH+' Z';
                s += '<path d="'+areaPath+'" fill="rgba(100,140,220,0.18)"/>';
                // Line
                var linePath = 'M '+pts[0].x.toFixed(1)+' '+pts[0].y.toFixed(1);
                for (var lpi = 1; lpi < pts.length; lpi++) linePath += ' L '+pts[lpi].x.toFixed(1)+' '+pts[lpi].y.toFixed(1);
                s += '<path d="'+linePath+'" fill="none" stroke="#3366cc" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>';
                // "Now" marker
                var nowPt = null;
                for (var nj = 0; nj < pts.length; nj++) if (pts[nj].d.i === nowIdxP) { nowPt = pts[nj]; break; }
                if (nowPt) {
                  s += '<line x1="'+nowPt.x.toFixed(1)+'" y1="2" x2="'+nowPt.x.toFixed(1)+'" y2="'+(spkH-2)+'" stroke="rgba(43,34,244,0.45)" stroke-width="1" stroke-dasharray="2 2"/>';
                  s += '<circle cx="'+nowPt.x.toFixed(1)+'" cy="'+nowPt.y.toFixed(1)+'" r="3.5" fill="#fff" stroke="#3366cc" stroke-width="2"/>';
                }
                // Min/max labels
                s += '<text x="4" y="9" font-size="7" font-weight="700" fill="rgba(43,34,244,.5)" style="fill:rgba(43,34,244,.5);">'+pMaxV.toFixed(1)+'</text>';
                s += '<text x="4" y="'+(spkH-3)+'" font-size="7" font-weight="700" fill="rgba(43,34,244,.5)" style="fill:rgba(43,34,244,.5);">'+pMinV.toFixed(1)+'</text>';
                // Time labels
                s += '<text x="'+(spkW-2)+'" y="'+(spkH-3)+'" text-anchor="end" font-size="7" font-weight="700" fill="rgba(43,34,244,.4)" style="fill:rgba(43,34,244,.4);">+12h</text>';
                s += '<text x="2" y="'+(spkH-3)+'" font-size="7" font-weight="700" fill="rgba(43,34,244,.4)" style="fill:rgba(43,34,244,.4);">-12h</text>';
                s += '</svg>';
                h += s;
                h += '<div style="font-size:9px;text-align:center;color:rgba(43,34,244,.55);margin:-4px 0 4px;font-weight:600;">24-hour pressure trace · now is centered</div>';
              }
            }
          }

          // Tendency rows with arrows (replaces the gL text rows)
          var tendencyRow = function(label, val, unit) {
            if (val == null) return '';
            var arrow, col, mag;
            var absV = Math.abs(val);
            if (val > 1.5) { arrow = '\u2191'; col = '#1a8a4a'; mag = 'rising'; }
            else if (val > 0.5) { arrow = '\u2197'; col = '#5a9a4a'; mag = 'rising'; }
            else if (val > -0.5) { arrow = '\u2192'; col = 'rgba(43,34,244,0.55)'; mag = 'steady'; }
            else if (val > -1.5) { arrow = '\u2198'; col = '#cc8822'; mag = 'falling'; }
            else { arrow = '\u2193'; col = '#cc4422'; mag = 'falling'; }
            // Bar shows magnitude (cap at 5 mb)
            var pct = Math.min(100, absV / 5 * 100);
            var dir = val > 0 ? 'right' : 'left';
            return '<div style="display:flex;align-items:center;gap:8px;margin:4px 0;font-size:10px;">'+
              '<div style="font-size:18px;font-weight:900;color:'+col+';line-height:1;width:24px;text-align:center;">'+arrow+'</div>'+
              '<div style="min-width:64px;font-weight:700;color:rgba(43,34,244,.55);letter-spacing:.04em;font-size:9px;">'+label+'</div>'+
              '<div style="flex:1;position:relative;height:6px;background:rgba(43,34,244,.05);border-radius:3px;">'+
                '<div style="position:absolute;'+(val>=0?'left:50%':'right:50%')+';top:0;height:100%;width:'+(pct/2).toFixed(0)+'%;background:'+col+';border-radius:3px;'+(val<0?'border-radius:3px 0 0 3px;':'border-radius:0 3px 3px 0;')+'"></div>'+
                '<div style="position:absolute;left:50%;top:-2px;bottom:-2px;width:1px;background:rgba(43,34,244,0.20);"></div>'+
              '</div>'+
              '<div style="min-width:60px;text-align:right;font-weight:700;color:'+col+';">'+(val>0?'+':'')+val.toFixed(absV<1?2:1)+' '+unit+'</div>'+
            '</div>';
          };
          h += tendencyRow('1HR', wx.pressureTrend1hr, 'mb');
          h += tendencyRow('3HR', wx.pressureTrend, 'mb');
          h += tendencyRow('6HR', wx.pressureTrend6hr, 'mb');

          // ── CURRENT CONDITIONS (visualized) ──
          h += FS('Current Conditions');

          // Temperature + dewpoint dual-marker scale. The spread between
          // them indicates moisture: small spread (<5°F) = saturated /
          // fog likely; big spread = dry air. Range -10°F to 100°F.
          if (wx.temp != null && wx.dewpoint != null) {
            var tdMin = -10, tdMax = 100;
            var tPct = Math.max(0, Math.min(100, ((wx.temp - tdMin) / (tdMax - tdMin)) * 100));
            var dPct = Math.max(0, Math.min(100, ((wx.dewpoint - tdMin) / (tdMax - tdMin)) * 100));
            var spread = wx.temp - wx.dewpoint;
            var spreadCol = spread < 4 ? '#1a8a4a' : spread < 10 ? '#88a8c8' : '#cc8822';
            var spreadLab = spread < 4 ? 'Saturated · fog likely' : spread < 10 ? 'Humid' : spread < 25 ? 'Comfortable' : 'Dry';
            h += '<div style="margin:4px 0 8px;">';
            h += '<div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">'+
              '<span style="font-size:9px;font-weight:700;color:rgba(43,34,244,.55);letter-spacing:.04em;">TEMP \u00b7 DEWPOINT</span>'+
              '<span style="font-size:9px;font-weight:700;color:'+spreadCol+';">spread '+spread+'\u00b0F \u00b7 '+spreadLab+'</span>'+
            '</div>';
            h += '<div style="position:relative;height:10px;border-radius:5px;background:linear-gradient(90deg,#3366cc 0%,#66aaee 25%,#66cc88 50%,#cccc66 70%,#dd8844 90%,#dd4444 100%);">';
            // Spread highlight (between dew and temp)
            h += '<div style="position:absolute;left:'+Math.min(tPct,dPct)+'%;width:'+Math.abs(tPct-dPct)+'%;top:-2px;height:14px;background:rgba(255,255,255,0.25);border-radius:3px;"></div>';
            // Dewpoint marker
            h += '<div style="position:absolute;left:'+dPct.toFixed(2)+'%;top:-3px;bottom:-3px;width:3px;background:#3344cc;border-radius:2px;box-shadow:0 0 0 1.5px #fff;transform:translateX(-50%);"></div>';
            h += '<div style="position:absolute;left:'+dPct.toFixed(2)+'%;top:14px;transform:translateX(-50%);font-size:9px;font-weight:700;color:#3344cc;white-space:nowrap;">'+wx.dewpoint+'\u00b0 dew</div>';
            // Temp marker
            h += '<div style="position:absolute;left:'+tPct.toFixed(2)+'%;top:-3px;bottom:-3px;width:3px;background:#cc4422;border-radius:2px;box-shadow:0 0 0 1.5px #fff;transform:translateX(-50%);"></div>';
            h += '<div style="position:absolute;left:'+tPct.toFixed(2)+'%;top:14px;transform:translateX(-50%);font-size:9px;font-weight:700;color:#cc4422;white-space:nowrap;">'+wx.temp+'\u00b0 temp</div>';
            h += '</div>';
            h += '<div style="display:flex;justify-content:space-between;font-size:8px;font-weight:700;color:rgba(43,34,244,.4);margin-top:30px;"><span>-10\u00b0</span><span>32\u00b0</span><span>70\u00b0</span><span>100\u00b0F</span></div>';
            h += '</div>';
          }

          // Wind compass + speed gauge (combined widget)
          if (wx.wind != null) {
            var windDir = wx.windDir != null ? wx.windDir : 0;
            var windSpd = wx.wind;
            var windGust = (wx.gust && wx.gust > wx.wind + 5) ? wx.gust : null;
            var compassNames = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
            var compassLabel = wx.windDir != null ? compassNames[Math.round(wx.windDir/22.5) % 16] : '';
            var spdCol = windSpd > 30 ? '#cc4422' : windSpd > 15 ? '#cc8822' : windSpd > 8 ? '#88a8c8' : '#88aaff';
            // Compass arrow rotates by (windDir + 180) so it points in flow direction
            var arrowRot = ((windDir == null ? 0 : windDir) + 180) % 360;
            h += '<div style="display:flex;align-items:center;gap:10px;margin:6px 0;">';
            // Compass SVG
            h += '<svg width="42" height="42" viewBox="0 0 42 42" style="flex-shrink:0;">';
            h += '<circle cx="21" cy="21" r="19" fill="rgba(43,34,244,.04)" stroke="rgba(43,34,244,.18)" stroke-width="1"/>';
            h += '<text x="21" y="8" text-anchor="middle" font-size="7" font-weight="900" fill="#cc4422" style="fill:#cc4422;">N</text>';
            h += '<text x="21" y="40" text-anchor="middle" font-size="7" font-weight="700" fill="rgba(43,34,244,.4)" style="fill:rgba(43,34,244,.4);">S</text>';
            h += '<g transform="rotate('+arrowRot.toFixed(1)+' 21 21)">';
            h += '<line x1="21" y1="14" x2="21" y2="28" stroke="'+spdCol+'" stroke-width="2.5" stroke-linecap="round"/>';
            h += '<polygon points="21,12 18,17 24,17" fill="'+spdCol+'"/>';
            h += '</g></svg>';
            // Label + value
            h += '<div style="flex:1;">';
            h += '<div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:3px;">'+
              '<span style="font-size:9px;font-weight:700;color:rgba(43,34,244,.55);letter-spacing:.04em;">WIND</span>'+
              '<span style="font-size:11px;font-weight:900;color:'+spdCol+';">'+Math.round(windSpd)+' mph '+(compassLabel?'<span style="font-size:9px;font-weight:700;opacity:.7;">'+compassLabel+'</span>':'')+(windGust?' <span style="font-size:9px;color:#cc4422;">G'+Math.round(windGust)+'</span>':'')+'</span>'+
            '</div>';
            // Speed bar
            var spdPct = Math.min(100, windSpd/50*100);
            h += '<div style="height:6px;background:rgba(43,34,244,.05);border-radius:3px;overflow:hidden;">';
            h += '<div style="height:100%;width:'+spdPct.toFixed(0)+'%;background:'+spdCol+';border-radius:3px;"></div>';
            h += '</div>';
            h += '</div></div>';
          }

          // Humidity ring + visibility bar (compact two-up row)
          if (wx.rh != null || wx.visibility != null) {
            h += '<div style="display:flex;gap:10px;margin:6px 0;">';
            // Humidity ring
            if (wx.rh != null) {
              var rhPct = wx.rh / 100;
              var rhCol = wx.rh > 80 ? '#3366cc' : wx.rh > 50 ? '#66aaee' : wx.rh > 25 ? '#88a8c8' : '#cc8822';
              var ringR = 16, ringC = 2 * Math.PI * ringR;
              var ringFill = ringC * rhPct;
              h += '<div style="display:flex;align-items:center;gap:8px;flex:1;">';
              h += '<svg width="42" height="42" viewBox="0 0 42 42" style="flex-shrink:0;">';
              h += '<circle cx="21" cy="21" r="'+ringR+'" fill="none" stroke="rgba(43,34,244,.08)" stroke-width="4"/>';
              h += '<circle cx="21" cy="21" r="'+ringR+'" fill="none" stroke="'+rhCol+'" stroke-width="4" stroke-dasharray="'+ringFill.toFixed(1)+' '+ringC.toFixed(1)+'" stroke-linecap="round" transform="rotate(-90 21 21)"/>';
              h += '<text x="21" y="24" text-anchor="middle" font-size="11" font-weight="900" fill="'+rhCol+'" style="fill:'+rhCol+';">'+wx.rh+'</text>';
              h += '</svg>';
              h += '<div><div style="font-size:9px;font-weight:700;color:rgba(43,34,244,.55);letter-spacing:.04em;">HUMIDITY</div><div style="font-size:10px;font-weight:700;color:'+rhCol+';">'+(wx.rh>80?'Saturated':wx.rh>60?'Humid':wx.rh>30?'Comfortable':'Dry')+'</div></div>';
              h += '</div>';
            }
            // Visibility bar
            if (wx.visibility != null) {
              var visKm = wx.visibility / 1000;
              var visPct = Math.min(100, visKm / 16 * 100);
              var visCol = visKm < 1 ? '#cc4422' : visKm < 5 ? '#cc8822' : visKm < 10 ? '#cccccc' : '#1a8a4a';
              var visLab = visKm < 1 ? 'Fog' : visKm < 5 ? 'Hazy' : visKm < 10 ? 'Light haze' : 'Clear';
              h += '<div style="flex:1;">';
              h += '<div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:3px;">'+
                '<span style="font-size:9px;font-weight:700;color:rgba(43,34,244,.55);letter-spacing:.04em;">VISIBILITY</span>'+
                '<span style="font-size:10px;font-weight:700;color:'+visCol+';">'+visKm.toFixed(1)+' km \u00b7 '+visLab+'</span>'+
              '</div>';
              h += '<div style="height:6px;background:linear-gradient(90deg,#cc4422 0%,#cc8822 30%,#cccccc 60%,#1a8a4a 100%);border-radius:3px;position:relative;">';
              h += '<div style="position:absolute;left:'+visPct.toFixed(0)+'%;top:-2px;bottom:-2px;width:2px;background:#fff;border-radius:1px;box-shadow:0 0 0 1px '+visCol+';transform:translateX(-50%);"></div>';
              h += '</div>';
              h += '<div style="display:flex;justify-content:space-between;font-size:7.5px;color:rgba(43,34,244,.4);font-weight:700;margin-top:2px;"><span>0</span><span>5</span><span>10</span><span>16+ km</span></div>';
              h += '</div>';
            }
            h += '</div>';
          }

          // Cloud cover (compact)
          if (wx.cloudCover != null) {
            var ccCol = wx.cloudCover > 75 ? '#cc4422' : wx.cloudCover > 40 ? '#cc8822' : wx.cloudCover > 15 ? '#88a8c8' : '#1a8a4a';
            h += gL('Cloud cover', '<span style="color:'+ccCol+';">'+wx.cloudCover+'%</span>');
          }
          // Tendency text rows (kept as-is for trend indicators we already
          // visualized via sparkline + tendency row arrows above)
          if (wx.tempTrend3hr != null) h += gL('Temp trend (3hr)', (wx.tempTrend3hr > 0 ? '+' : '') + wx.tempTrend3hr + '\u00b0F');
          if (wx.dewpointTrend3hr != null) h += gL('Dewpoint trend (3hr)', (wx.dewpointTrend3hr > 0 ? '+' : '') + wx.dewpointTrend3hr + '\u00b0F');

          // Analysis
          if (analysis.length > 0) {
            h += FS('Weather Analysis', regimeColor);
            h += '<div style="font-size:11px;color:rgba(43,34,244,.7);line-height:1.55;">';
            analysis.forEach(function(a) { h += '<div style="margin-bottom:6px;">' + a + '</div>'; });
            h += '</div>';
          }

          // ── INFO: Understanding Pressure (overview) ──
          h += FS('Understanding Pressure');
          h += '<div style="font-size:11px;color:rgba(43,34,244,.65);line-height:1.55;">';
          h += 'Atmospheric pressure is the weight of the air column above you. <b>High pressure</b> (>1020 mb) means sinking air \u2014 which suppresses clouds and brings clear, stable weather. <b>Low pressure</b> (<1010 mb) means rising air \u2014 which creates clouds, precipitation, and wind as air flows inward and upward.';
          h += '<br><br>The <b>rate of change</b> matters more than the absolute value. A rapid fall (>3 mb/3hr) often precedes significant weather. A steady barometer means conditions will persist. Old mariners\u2019 rule: "Long foretold, long last; short notice, soon past."';
          h += '</div>';

          // ── INFO: Pressure Regimes (level-card list, current highlighted) ──
          h += FS('Pressure Regimes');
          var pRegimes = [
            { lo: 1030, label:'Strong High',  c:'#3388cc', desc:'Sinking air \u00b7 clear cool stable \u00b7 fair-weather Cu only' },
            { lo: 1020, hi: 1030, label:'High',          c:'#6cc',     desc:'Suppressed clouds \u00b7 dry stable air \u00b7 light winds' },
            { lo: 1013, hi: 1020, label:'Near Average',  c:'#88a8c8',  desc:'Standard sea-level pressure (1013.25 mb) \u00b7 mixed conditions' },
            { lo: 1005, hi: 1013, label:'Low',           c:'#cc8822',  desc:'Rising air \u00b7 building clouds \u00b7 possible precipitation' },
            { lo: 995,  hi: 1005, label:'Deep Low',      c:'#cc4422',  desc:'Active storm system \u00b7 winds, rain, possible severe weather' },
            { hi: 995,             label:'Extreme Low',   c:'#990033',  desc:'Major storm / hurricane \u00b7 destructive winds, heavy precip' }
          ];
          h += '<div style="display:flex;flex-direction:column;gap:3px;margin:4px 0;">';
          pRegimes.forEach(function(rg) {
            var active = (rg.lo == null || (p != null && p >= rg.lo)) && (rg.hi == null || (p != null && p < rg.hi));
            var rangeStr = rg.lo != null && rg.hi != null ? rg.lo+'\u2013'+rg.hi+' mb'
                         : rg.lo != null ? '>'+rg.lo+' mb'
                         : '<'+rg.hi+' mb';
            h += '<div style="display:flex;align-items:center;gap:8px;padding:5px 8px;background:'+(active?rg.c+'22':'rgba(43,34,244,.03)')+';border-radius:5px;border-left:3px solid '+rg.c+';opacity:'+(active?'1':'0.65')+';">'+
              '<div style="font-weight:900;font-size:10.5px;color:'+rg.c+';min-width:88px;">'+rg.label+'</div>'+
              '<div style="font-size:9px;font-weight:700;color:'+(active?rg.c:'rgba(43,34,244,.55)')+';min-width:74px;">'+rangeStr+'</div>'+
              '<div style="font-size:9.5px;color:rgba(43,34,244,.7);line-height:1.3;flex:1;">'+rg.desc+'</div>'+
            '</div>';
          });
          h += '</div>';

          // ── INFO: Reading the Tendency (rate-of-change interpretation) ──
          h += FS('Reading the Tendency');
          var tendencyRefs = [
            { rate:'\u22653 mb / 3hr', dir:'fall', col:'#cc3322', desc:'Rapid fall \u00b7 active low approaching \u00b7 squalls likely' },
            { rate:'1.5\u20133 mb / 3hr', dir:'fall', col:'#cc8822', desc:'Significant fall \u00b7 deteriorating weather in 6\u201312 h' },
            { rate:'0.5\u20131.5 mb / 3hr', dir:'fall', col:'#cca65c', desc:'Slow fall \u00b7 increasing clouds, gradual change' },
            { rate:'\u00b10.5 mb / 3hr', dir:'steady', col:'rgba(43,34,244,.55)', desc:'Steady \u00b7 current conditions persist for hours' },
            { rate:'0.5\u20131.5 mb / 3hr', dir:'rise', col:'#5a9a4a', desc:'Slow rise \u00b7 conditions improving' },
            { rate:'1.5\u20133 mb / 3hr', dir:'rise', col:'#338855', desc:'Strong rise \u00b7 high-pressure system building in' },
            { rate:'\u22653 mb / 3hr', dir:'rise', col:'#1a7a4a', desc:'Rapid rise \u00b7 cold front cleared, drying air' }
          ];
          h += '<div style="display:flex;flex-direction:column;gap:2px;margin:4px 0;font-size:10px;">';
          tendencyRefs.forEach(function(tr) {
            var arrow = tr.dir === 'fall' ? '\u2193' : tr.dir === 'rise' ? '\u2191' : '\u2192';
            h += '<div style="display:flex;align-items:center;gap:8px;padding:4px 8px;background:rgba(43,34,244,.02);border-radius:4px;">'+
              '<div style="font-size:14px;font-weight:900;color:'+tr.col+';width:18px;text-align:center;">'+arrow+'</div>'+
              '<div style="min-width:96px;font-size:9px;font-weight:700;color:'+tr.col+';">'+tr.rate+'</div>'+
              '<div style="font-size:9.5px;color:rgba(43,34,244,.65);line-height:1.3;flex:1;">'+tr.desc+'</div>'+
            '</div>';
          });
          h += '</div>';

          // ── INFO: Buys Ballot's Law (wind direction from pressure) ──
          h += FS("Buys Ballot's Law");
          h += '<div style="display:flex;align-items:center;gap:10px;margin:4px 0;">';
          // Mini SVG: pressure low + high with circulation arrows
