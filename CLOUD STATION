  /* ─── RADAR button — circular scope ─── */
  @keyframes radarSweep {
    0% { transform:rotate(0deg); }
    100% { transform:rotate(360deg); }
  }
  /* Storm drifts slowly NE like a real system */
  @keyframes stormDrift {
    0%   { top:58%; left:38%; }
    50%  { top:44%; left:52%; }
    100% { top:58%; left:38%; }
  }
  /* Subtle internal pulsing - storm intensifies/weakens */
  @keyframes stormPulse {
    0%, 100% { opacity:.85; transform:scale(1); }
    30%  { opacity:.95; transform:scale(1.04); }
    70%  { opacity:.8;  transform:scale(.97); }
  }
  #fcast-range-radar {
    position:relative !important;
    width:110px; height:110px;
    border:2px solid rgba(0,255,80,.3) !important;
    border-radius:50% !important;
    color:rgba(0,255,80,.95) !important;
    text-shadow:0 0 12px rgba(0,255,80,.6), 0 0 24px rgba(0,255,80,.2);
    background:radial-gradient(circle, rgba(0,22,0,.88) 0%, rgba(0,8,0,.96) 100%) !important;
    box-shadow:0 0 24px rgba(0,255,80,.12), 0 0 48px rgba(0,255,80,.05), inset 0 0 40px rgba(0,255,80,.04) !important;
    overflow:hidden !important;
    z-index:1;
    display:flex; align-items:center; justify-content:center;
    padding:0 !important;
  }
  /* Range rings */
  #fcast-range-radar .radar-rings {
    position:absolute; inset:0;
    pointer-events:none;
  }
  #fcast-range-radar .radar-rings::before {
    content:'';
    position:absolute;
    top:50%; left:50%;
    width:33%; height:33%;
    transform:translate(-50%,-50%);
    border:1px solid rgba(0,255,80,.1);
    border-radius:50%;
  }
  #fcast-range-radar .radar-rings::after {
    content:'';
    position:absolute;
    top:50%; left:50%;
    width:66%; height:66%;
    transform:translate(-50%,-50%);
    border:1px solid rgba(0,255,80,.08);
    border-radius:50%;
  }
  #fcast-range-radar .radar-ring-outer {
    position:absolute;
    top:50%; left:50%;
    width:92%; height:92%;
    transform:translate(-50%,-50%);
    border:1px solid rgba(0,255,80,.06);
    border-radius:50%;
    pointer-events:none;
  }
  /* Crosshairs */
  #fcast-range-radar .radar-cross {
    position:absolute; inset:0;
    pointer-events:none;
  }
  #fcast-range-radar .radar-cross::before {
    content:'';
    position:absolute;
    top:50%; left:10%; right:10%;
    height:1px;
    background:rgba(0,255,80,.06);
    transform:translateY(-50%);
  }
  #fcast-range-radar .radar-cross::after {
    content:'';
    position:absolute;
    left:50%; top:10%; bottom:10%;
    width:1px;
    background:rgba(0,255,80,.06);
    transform:translateX(-50%);
  }
  /* Sweep beam — slower rotation */
  #fcast-range-radar .radar-beam {
    position:absolute;
    width:100%; height:100%;
    top:0; left:0;
    animation: radarSweep 4.5s linear infinite;
    pointer-events:none;
  }
  #fcast-range-radar .radar-beam::before {
    content:'';
    position:absolute;
    width:100%; height:100%;
    background:conic-gradient(
      from 0deg at 50% 50%,
      transparent 0deg,
      transparent 315deg,
      rgba(0,255,80,.02) 330deg,
      rgba(0,255,80,.05) 340deg,
      rgba(0,255,80,.1) 348deg,
      rgba(0,255,80,.2) 354deg,
      rgba(0,255,80,.35) 358deg,
      rgba(0,255,80,.45) 359.5deg,
      transparent 360deg
    );
    border-radius:50%;
  }
  #fcast-range-radar .radar-beam::after {
    content:'';
    position:absolute;
    top:50%; left:50%;
    width:46%; height:1px;
    background:linear-gradient(90deg, rgba(0,255,80,.5), rgba(0,255,80,.1));
    transform-origin:left center;
    transform:translateY(-50%);
  }
  /* Storm system — single container drifting slowly NE */
  #fcast-range-radar .storm-system {
    position:absolute;
    width:70px; height:60px;
    top:58%; left:38%;
    animation: stormDrift 30s ease-in-out infinite;
    pointer-events:none;
  }
  /* Outer green shield — widespread light rain */
  #fcast-range-radar .storm-outer {
    position:absolute;
    width:100%; height:100%;
    top:0; left:0;
    background:
      radial-gradient(ellipse 100% 90% at 48% 52%, rgba(0,190,0,.45) 0%, rgba(0,160,0,.25) 40%, rgba(0,130,0,.1) 65%, transparent 85%);
    border-radius:40% 55% 45% 60%;
    filter:blur(2px);
    animation: stormPulse 8s ease-in-out infinite;
    pointer-events:none;
  }
  /* Mid yellow/orange band — moderate rain */
  #fcast-range-radar .storm-mid {
    position:absolute;
    width:62%; height:58%;
    top:18%; left:20%;
    background:
      radial-gradient(ellipse 100% 90% at 50% 50%, rgba(255,210,0,.55) 0%, rgba(255,160,0,.35) 50%, transparent 80%);
    border-radius:45% 55% 50% 45%;
    filter:blur(1.5px);
    animation: stormPulse 6.5s ease-in-out infinite 1s;
    pointer-events:none;
  }
  /* Inner red/magenta core — heavy rain/hail */
  #fcast-range-radar .storm-core {
    position:absolute;
    width:32%; height:30%;
    top:28%; left:30%;
    background:
      radial-gradient(ellipse 80% 90% at 50% 50%, rgba(200,0,60,.6) 0%, rgba(255,0,0,.5) 40%, rgba(255,80,0,.25) 70%, transparent 100%);
    border-radius:50% 40% 55% 45%;
    filter:blur(1px);
    animation: stormPulse 5s ease-in-out infinite 0.5s;
    pointer-events:none;
  }
  /* Secondary cell — trailing convection */
  #fcast-range-radar .storm-cell2 {
    position:absolute;
    width:35%; height:32%;
    top:55%; left:-10%;
    background:
      radial-gradient(ellipse 90% 80% at 50% 50%, rgba(0,200,0,.4) 0%, rgba(0,160,0,.2) 50%, transparent 75%);
    border-radius:50% 45% 55% 50%;
    filter:blur(1.5px);
    animation: stormPulse 7s ease-in-out infinite 2s;
    pointer-events:none;
  }
  /* Anvil/outflow — wispy leading edge */
  #fcast-range-radar .storm-anvil {
    position:absolute;
    width:40%; height:25%;
    top:-5%; left:50%;
    background:
      radial-gradient(ellipse 100% 80% at 40% 60%, rgba(0,150,0,.25) 0%, rgba(0,120,0,.1) 50%, transparent 80%);
    border-radius:60% 40% 50% 50%;
    filter:blur(2px);
    animation: stormPulse 9s ease-in-out infinite 3s;
    pointer-events:none;
  }
  /* Center dot */
  #fcast-range-radar .radar-center {
    position:absolute;
    width:4px; height:4px;
    top:50%; left:50%;
    transform:translate(-50%,-50%);
    background:rgba(0,255,80,.6);
    border-radius:50%;
    box-shadow:0 0 6px rgba(0,255,80,.4);
    pointer-events:none;
  }
  /* Label */
  #fcast-range-radar .radar-label {
    position:relative;
    z-index:2;
    font-size:.72rem;
    font-weight:800;
    letter-spacing:.12em;
    pointer-events:none;
  }

