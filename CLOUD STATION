        // \u2500\u2500 NOW: Current Conditions \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
        // Lead with the visual Kp scale; geoDetail copy stays compact below.
        h += FS('Current Conditions');
        h += kpScaleBar(currentKp);
        h += '<div style="' + bodyTextStyle + '">' + geoDetail + '</div>';

        // \u2500\u2500 NOW: Solar Wind & IMF \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500
        // Always render the section so the user knows it exists. Show
