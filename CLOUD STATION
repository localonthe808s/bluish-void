  // ── ERO Popup Enrichment Helpers ──
  // Point-in-polygon (ray casting)
  function eroPointInPoly(lat, lon, coords) {
    var inside = false;
    for (var r = 0; r < coords.length; r++) {
      var ring = coords[r];
      for (var i = 0, j = ring.length - 1; i < ring.length; j = i++) {
        var xi = ring[i][1], yi = ring[i][0], xj = ring[j][1], yj = ring[j][0];
        if (((yi > lon) !== (yj > lon)) && (lat < (xj - xi) * (lon - yi) / (yj - yi) + xi)) inside = !inside;
      }
    }
    return inside;
  }

  // Historical rarity context
  var eroRarityContext = {
    'HIGH RISK': 'HIGH is the rarest ERO category — issued only ~4 times per year on average. When WPC issues HIGH, they have very high confidence in widespread, life-threatening flooding. This is a "drop everything and prepare" outlook.',
    'MODERATE RISK': 'MODERATE is issued ~15-20 times per year. It signals high confidence in significant flash flooding over a concentrated area. Historically, ~80% of flash flood fatalities occur within MODERATE+ risk areas.',
    'SLIGHT RISK': 'SLIGHT is issued several times monthly during active seasons. ~40% of flash flood events occur within SLIGHT risk areas. Take seriously if you live near creeks, rivers, or low-lying roads.',
    'MARGINAL RISK': 'MARGINAL is the most common ERO category, issued frequently during warm months. While most MARGINAL areas don\'t flood, isolated spots can still see dangerous water rises — especially where soil is saturated.',
    'OUTLOOK AREA': ''
  };

  // Build enriched ERO popup
  function buildEROPopup(feature, riskName, riskColor, riskDesc, dayStr) {
    var props = feature.properties || {};
    var tt = '';

    // Header
    tt += '<div class="hz-card-head"><div class="hz-accent" style="background:'+riskColor+';"></div><span style="color:'+riskColor+';">EXCESSIVE RAINFALL OUTLOOK \u00b7 ' + dayStr.toUpperCase() + '</span></div>';
    tt += '<div style="display:flex;align-items:center;gap:5px;margin:3px 0;">';
    tt += '<span style="font-size:.85rem;font-weight:800;color:' + riskColor + ';">' + riskName + '</span>';
    tt += '</div>';
    tt += '<div style="font-size:.72rem;color:#ccc;line-height:1.35;margin-bottom:4px;">' + riskDesc + '</div>';

    // ── Inside zone detection ──
    try {
      var uLat = LOCATION ? LOCATION.lat : null;
      var uLon = LOCATION ? LOCATION.lon : null;
      if (uLat && uLon && feature.geometry) {
        var geom = feature.geometry;
        var isInside = false;
        if (geom.type === 'Polygon') isInside = eroPointInPoly(uLat, uLon, geom.coordinates);
        else if (geom.type === 'MultiPolygon') {
          for (var mp = 0; mp < geom.coordinates.length; mp++) { if (eroPointInPoly(uLat, uLon, geom.coordinates[mp])) { isInside = true; break; } }
        }
        if (isInside) {
          tt += '<div style="padding:3px 6px;background:rgba(239,68,68,.15);border:1px solid rgba(239,68,68,.4);border-radius:4px;margin:4px 0;">';
          tt += '<span style="font-size:.75rem;font-weight:800;color:#f87171;">\u26a0 YOUR LOCATION IS INSIDE THIS RISK AREA</span>';
          tt += '</div>';
        }
      }
    } catch(e) {}

    // ── Historical rarity ──
    var rarity = eroRarityContext[riskName] || '';
    if (rarity) {
      tt += '<div style="font-size:.65rem;color:#aaa;line-height:1.3;margin:4px 0;padding:3px 5px;background:rgba(255,255,255,.04);border-radius:3px;border-left:2px solid ' + riskColor + ';">';
      tt += '<span style="font-weight:700;color:#ccc;">HISTORICAL CONTEXT:</span> ' + rarity;
      tt += '</div>';
    }

    // ── Local time conversion ──
    var valid = props.VALID || props.valid || '';
    var expire = props.EXPIRE || props.expire || '';
    if (valid && valid.length >= 12) {
      try {
        var vDate = new Date(Date.UTC(parseInt(valid.substring(0,4)), parseInt(valid.substring(4,6))-1, parseInt(valid.substring(6,8)), parseInt(valid.substring(8,10)), parseInt(valid.substring(10,12))));
        var eDate = expire.length >= 12 ? new Date(Date.UTC(parseInt(expire.substring(0,4)), parseInt(expire.substring(4,6))-1, parseInt(expire.substring(6,8)), parseInt(expire.substring(8,10)), parseInt(expire.substring(10,12)))) : null;
        var vLocal = vDate.toLocaleString('en-US', {weekday:'short', month:'short', day:'numeric', hour:'numeric', minute:'2-digit', timeZoneName:'short'});
        var eLocal = eDate ? eDate.toLocaleString('en-US', {weekday:'short', month:'short', day:'numeric', hour:'numeric', minute:'2-digit', timeZoneName:'short'}) : '';

        tt += '<div style="font-size:.65rem;color:#999;margin-top:3px;border-top:1px solid rgba(255,255,255,.08);padding-top:3px;">';
        tt += '<span style="font-weight:700;color:#bbb;">VALID PERIOD:</span><br>';
        tt += vLocal;
        if (eLocal) tt += ' \u2192 ' + eLocal;

        // Timing guidance
        if (eDate) {
          var now = new Date();
          var hrsToStart = (vDate - now) / 3600000;
          var hrsToEnd = (eDate - now) / 3600000;
          var vHourLocal = vDate.getHours();
          var eHourLocal = eDate.getHours();
          tt += '<br><span style="color:'+riskColor+';font-weight:700;">';
          if (hrsToStart > 0 && hrsToStart < 6) tt += 'Begins within ' + Math.ceil(hrsToStart) + ' hours';
          else if (hrsToStart <= 0 && hrsToEnd > 0) tt += 'ACTIVE NOW';
          else if (hrsToStart > 0 && hrsToStart < 24) tt += 'Starts today';
          else if (hrsToStart >= 24 && hrsToStart < 48) tt += 'Starts tomorrow';
          else tt += 'Starts in ' + Math.round(hrsToStart/24) + ' days';
          // Day vs night guidance
          if (vHourLocal >= 18 || vHourLocal < 6 || eHourLocal >= 18 || eHourLocal < 6) {
            tt += ' \u00b7 Includes overnight hours \u2014 flash floods deadliest after dark';
          }
          tt += '</span>';
        }
        tt += '</div>';
      } catch(e) {
        // Fallback to UTC display
        tt += '<div style="font-size:.65rem;color:#888;margin-top:3px;">' + valid.substring(4,6)+'/'+valid.substring(6,8)+' '+valid.substring(8,10)+':'+valid.substring(10,12)+'Z</div>';
      }
    }

    // ── Cross-reference: nearby flood gauges ──
    try {
      var gauges = window._floodGauges || [];
      if (gauges.length > 0 && feature.geometry) {
        var geom = feature.geometry;
        var gaugesInside = gauges.filter(function(g) {
          if (geom.type === 'Polygon') return eroPointInPoly(g.lat, g.lon, geom.coordinates);
          if (geom.type === 'MultiPolygon') {
            for (var mp = 0; mp < geom.coordinates.length; mp++) { if (eroPointInPoly(g.lat, g.lon, geom.coordinates[mp])) return true; }
          }
          return false;
        });
        var elevated = gaugesInside.filter(function(g) { return g.status === 'major' || g.status === 'moderate' || g.status === 'minor' || g.status === 'action'; });
        if (gaugesInside.length > 0) {
          tt += '<div style="font-size:.65rem;color:#aaa;margin-top:3px;border-top:1px solid rgba(255,255,255,.08);padding-top:3px;">';
          tt += '<span style="font-weight:700;color:#22d3ee;">\ud83c\udf0a RIVER GAUGES IN THIS AREA:</span> ' + gaugesInside.length + ' monitored';
          if (elevated.length > 0) {
            var majC = elevated.filter(function(g){return g.status==='major';}).length;
            var modC = elevated.filter(function(g){return g.status==='moderate';}).length;
            var minC = elevated.filter(function(g){return g.status==='minor';}).length;
            var actC = elevated.filter(function(g){return g.status==='action';}).length;
            tt += '<br><span style="color:#f87171;font-weight:700;">' + elevated.length + ' ALREADY ELEVATED</span>';
            if (majC) tt += ' \u00b7 <span style="color:#9333ea;">' + majC + ' major</span>';
            if (modC) tt += ' \u00b7 <span style="color:#ef4444;">' + modC + ' moderate</span>';
            if (minC) tt += ' \u00b7 <span style="color:#f97316;">' + minC + ' minor</span>';
            if (actC) tt += ' \u00b7 <span style="color:#eab308;">' + actC + ' action</span>';
            tt += '<br><span style="color:#f87171;">Ground already saturated \u2014 additional rainfall will cause rapid rises</span>';
          } else {
            tt += '<br><span style="color:#84cc16;">All gauges currently at normal levels</span>';
          }
          tt += '</div>';
        }
      }
    } catch(e) {}

    // ── Cross-reference: SPC convective outlook overlap ──
    try {
      if (outlookLayers['tornado'] && outlookLayers['tornado'].getLayers) {
        var spcLayers = outlookLayers['tornado'].getLayers();
        if (spcLayers.length > 0) {
          tt += '<div style="font-size:.65rem;color:#aaa;margin-top:3px;border-top:1px solid rgba(255,255,255,.08);padding-top:3px;">';
          tt += '<span style="font-weight:700;color:#f97316;">\u26a1 SPC CONVECTIVE OUTLOOK ALSO ACTIVE</span>';
          tt += '<br>Thunderstorms in this area may produce heavy rainfall AND severe weather simultaneously. Storm-training and slow-moving supercells amplify flash flood risk.';
          tt += '</div>';
        }
      }
    } catch(e) {}

    // Footer
    tt += '<div class="hz-card-footer">WPC Excessive Rainfall Outlook \u00b7 NOAA</div>';
    return tt;
  }

  // Build enriched CPC Precipitation Outlook popup
  function buildCPCPopup(feature, riskName, riskColor, riskDesc, rangeStr) {
    var props = feature.properties || {};
    var tt = '';

    // Header
    tt += '<div class="hz-card-head"><div class="hz-accent" style="background:'+riskColor+';"></div><span style="color:'+riskColor+';">CPC PRECIPITATION OUTLOOK \u00b7 ' + rangeStr.toUpperCase() + '</span></div>';
    tt += '<div style="display:flex;align-items:center;gap:5px;margin:3px 0;">';
    tt += '<span style="font-size:.85rem;font-weight:800;color:' + riskColor + ';">' + riskName + '</span>';
    tt += '</div>';
    tt += '<div style="font-size:.72rem;color:#ccc;line-height:1.35;margin-bottom:4px;">' + riskDesc + '</div>';

    // ── Inside zone detection ──
    try {
      var uLat = LOCATION ? LOCATION.lat : null;
      var uLon = LOCATION ? LOCATION.lon : null;
      if (uLat && uLon && feature.geometry) {
        var geom = feature.geometry;
        var isInside = false;
        if (geom.type === 'Polygon') isInside = eroPointInPoly(uLat, uLon, geom.coordinates);
        else if (geom.type === 'MultiPolygon') {
          for (var mp = 0; mp < geom.coordinates.length; mp++) { if (eroPointInPoly(uLat, uLon, geom.coordinates[mp])) { isInside = true; break; } }
        }
        if (isInside) {
          var insideColor = riskName.indexOf('BELOW') >= 0 ? '#f97316' : riskName.indexOf('ABOVE') >= 0 ? '#06b6d4' : '#84cc16';
          tt += '<div style="padding:3px 6px;background:'+insideColor+'18;border:1px solid '+insideColor+'55;border-radius:4px;margin:4px 0;">';
          tt += '<span style="font-size:.75rem;font-weight:800;color:'+insideColor+';">YOUR LOCATION IS INSIDE THIS OUTLOOK</span>';
          tt += '</div>';
        }
      }
    } catch(e) {}

    // ── Probability data if available ──
    var prob = parseFloat(props.prob || props.PROB || props.Prob || 0);
    if (prob > 0) {
      tt += '<div style="font-size:.65rem;color:#aaa;margin:4px 0;padding:3px 5px;background:rgba(255,255,255,.04);border-radius:3px;border-left:2px solid ' + riskColor + ';">';
      tt += '<span style="font-weight:700;color:#ccc;">PROBABILITY:</span> ' + prob + '% chance of exceeding the median precipitation for this period';
      tt += '</div>';
    }

    // ── What this means practically ──
    var practicalCtx = '';
    if (riskName.indexOf('MUCH ABOVE') >= 0) {
      practicalCtx = 'Expect significantly wetter than average conditions. Rivers may run high, soil saturation increases flood vulnerability. Plan for persistent rain and possible travel disruptions.';
    } else if (riskName.indexOf('ABOVE') >= 0) {
      practicalCtx = 'Wetter than average conditions favored. Cumulative rainfall over the period may stress drainage systems. Check river forecasts if near waterways.';
    } else if (riskName.indexOf('BELOW') >= 0) {
      practicalCtx = 'Drier than average conditions expected. Beneficial for drying saturated areas, but may worsen drought where already dry. Wildfire risk may increase with drying vegetation.';
    } else if (riskName.indexOf('NEAR NORMAL') >= 0) {
      practicalCtx = 'No strong signal for departure from climatological averages. Expect typical precipitation patterns for this time of year.';
    }
    if (practicalCtx) {
      tt += '<div style="font-size:.65rem;color:#aaa;margin:4px 0;padding:3px 5px;background:rgba(255,255,255,.04);border-radius:3px;border-left:2px solid ' + riskColor + ';">';
      tt += '<span style="font-weight:700;color:#ccc;">WHAT THIS MEANS:</span> ' + practicalCtx;
      tt += '</div>';
    }

    // ── Cross-reference: nearby flood gauges ──
    try {
      var gauges = window._floodGauges || [];
      if (gauges.length > 0 && feature.geometry && riskName.indexOf('ABOVE') >= 0) {
        var geom = feature.geometry;
        var gaugesInside = gauges.filter(function(g) {
          if (geom.type === 'Polygon') return eroPointInPoly(g.lat, g.lon, geom.coordinates);
          if (geom.type === 'MultiPolygon') {
            for (var mp = 0; mp < geom.coordinates.length; mp++) { if (eroPointInPoly(g.lat, g.lon, geom.coordinates[mp])) return true; }
          }
          return false;
        });
        var elevated = gaugesInside.filter(function(g) { return g.status === 'major' || g.status === 'moderate' || g.status === 'minor' || g.status === 'action'; });
        if (elevated.length > 0) {
          tt += '<div style="font-size:.65rem;color:#aaa;margin-top:3px;border-top:1px solid rgba(255,255,255,.08);padding-top:3px;">';
          tt += '<span style="font-weight:700;color:#f87171;">\ud83c\udf0a ' + elevated.length + ' RIVER GAUGES ALREADY ELEVATED</span> in this outlook area';
          tt += '<br><span style="color:#f87171;">Above-normal precip on saturated ground amplifies flood risk</span>';
          tt += '</div>';
        }
      }
    } catch(e) {}

    // ── Cross-reference: ERO overlap ──
    try {
      if (outlookLayers['flood'] && outlookLayers['flood'] !== null) {
        // If there's also a near-term ERO active, note the compound signal
        tt += '<div style="font-size:.65rem;color:#aaa;margin-top:3px;border-top:1px solid rgba(255,255,255,.08);padding-top:3px;">';
        tt += '<span style="font-weight:700;color:#22d3ee;">\ud83d\udcc5 EXTENDED OUTLOOK</span>';
        tt += '<br>CPC outlooks show multi-day precipitation trends. Check ERO Day 1-3 for specific flash flood timing. Use together: ERO for "when and where" + CPC for "how wet overall."';
        tt += '</div>';
      }
    } catch(e) {}

    // ── Climatological context ──
    tt += '<div style="font-size:.6rem;color:#777;margin-top:3px;border-top:1px solid rgba(255,255,255,.06);padding-top:2px;">';
    tt += 'CPC outlooks use ensemble model guidance, soil moisture analysis, and teleconnection patterns (MJO, ENSO) to forecast precipitation departures from the 1991-2020 climatological mean.';
    tt += '</div>';

    // Footer
    tt += '<div class="hz-card-footer">CPC ' + rangeStr + ' Precipitation Outlook \u00b7 NOAA</div>';
    return tt;
  }

  // Layer ID mapping from NOAA MapServer docs
  var outlookEndpoints = {
    fire: {
      base: 'https://mapservices.weather.noaa.gov/vector/rest/services/fire_weather/SPC_firewx/MapServer/',
      d1: 1,   // Day 1 Categorical Fire Weather
      d2: 3,   // Day 2 Categorical Fire Weather
      d3: 5    // Day 3-8 Fire Weather
    },
    tornado: {
      base: 'https://mapservices.weather.noaa.gov/vector/rest/services/outlooks/SPC_wx_outlks/MapServer/',
      d1: 1,   // Day 1 Categorical Outlook
      d2: 9,   // Day 2 Categorical Outlook
      d3: 17,  // Day 3 Categorical Outlook
      d48: '_d48' // Days 4-8 extended (special handling)
    },
    flood: {
      base: 'https://mapservices.weather.noaa.gov/vector/rest/services/hazards/wpc_precip_hazards/MapServer/',
      d1: 0,   // Day 1 Excessive Rainfall
      d2: 1,   // Day 2 Excessive Rainfall
      d3: 2,   // Day 3 Excessive Rainfall (also covers 4-5 via combined view)
      d6: '_cpc610',  // CPC 6-10 day precip outlook (special handling)
      d8: '_cpc814'   // CPC 8-14 day precip outlook (special handling)
    }
  };

  // Color schemes for each outlook type
  var outlookColors = {
    fire: function(props){
      var dn = props.dn || props.DN || 0;
      var label = (props.LABEL || props.label || props.idp_source || '').toString().toLowerCase();
      if(dn >= 10 || label.indexOf('extreme') >= 0) return { fill:'#9333ea', stroke:'#7c3aed', opacity:0.35 };
      if(dn >= 8 || label.indexOf('critical') >= 0) return { fill:'#ef4444', stroke:'#dc2626', opacity:0.3 };
      if(dn >= 5 || label.indexOf('elevated') >= 0) return { fill:'#f97316', stroke:'#ea580c', opacity:0.2 };
      if(label.indexOf('dry') >= 0) return { fill:'#eab308', stroke:'#ca8a04', opacity:0.15 };
      return { fill:'#f97316', stroke:'#ea580c', opacity:0.15 };
    },
    tornado: function(props){
      var dn = props.dn || props.DN || 0;
      var label = (props.LABEL || props.label || props.idp_source || '').toString();
      if(dn >= 30 || label.indexOf('High') >= 0) return { fill:'#9333ea', stroke:'#7c3aed', opacity:0.35 };
      if(dn >= 20 || label.indexOf('MDT') >= 0 || label.indexOf('Moderate') >= 0) return { fill:'#ef4444', stroke:'#dc2626', opacity:0.3 };
      if(dn >= 10 || label.indexOf('ENH') >= 0 || label.indexOf('Enhanced') >= 0) return { fill:'#f97316', stroke:'#ea580c', opacity:0.25 };
      if(dn >= 5 || label.indexOf('SLGT') >= 0 || label.indexOf('Slight') >= 0) return { fill:'#eab308', stroke:'#ca8a04', opacity:0.2 };
      if(dn >= 3 || label.indexOf('MRGL') >= 0 || label.indexOf('Marginal') >= 0) return { fill:'#84cc16', stroke:'#65a30d', opacity:0.15 };
      if(dn >= 2) return { fill:'#22c55e', stroke:'#16a34a', opacity:0.1 }; // TSTM
      return { fill:'#60a5fa', stroke:'#3b82f6', opacity:0.1 };
    },
    flood: function(props){
      var label = (props.LABEL || props.label || props.idp_source || props.product || '').toString().toLowerCase();
      if(label.indexOf('high') >= 0) return { fill:'#9333ea', stroke:'#7c3aed', opacity:0.35 };
      if(label.indexOf('moderate') >= 0 || label.indexOf('mdt') >= 0) return { fill:'#ef4444', stroke:'#dc2626', opacity:0.3 };
      if(label.indexOf('slight') >= 0 || label.indexOf('slgt') >= 0) return { fill:'#f97316', stroke:'#ea580c', opacity:0.22 };
      if(label.indexOf('marginal') >= 0 || label.indexOf('mrgl') >= 0) return { fill:'#eab308', stroke:'#ca8a04', opacity:0.15 };
      return { fill:'#06b6d4', stroke:'#0891b2', opacity:0.12 };
    }
  };

  // Fire outlook day colors — distinct hue per time range
  var fireOutlookDayColors = {
    d1: { fill:'#f97316', stroke:'#ea580c', opacity:0.25, dash:'4 2' },   // orange — today
    d2: { fill:'#a855f7', stroke:'#9333ea', opacity:0.2,  dash:'6 4' },   // purple — tomorrow
    d3: { fill:'#06b6d4', stroke:'#0891b2', opacity:0.15, dash:'10 5' }   // cyan — days 3-8
  };

  // Parsed fire outlook summaries per day
  window._fireOutlookSummary = { d1: null, d2: null, d3: null };

  function parseFireOutlookRisk(dn, src) {
    var riskName, riskColor;
    if (dn >= 10) { riskName = 'EXTREMELY CRITICAL'; riskColor = '#9333ea'; }
    else if (dn >= 8) { riskName = 'CRITICAL'; riskColor = '#ef4444'; }
    else if (dn >= 5) { riskName = 'ELEVATED'; riskColor = '#f97316'; }
    else if (dn >= 2) { riskName = 'NON-CRITICAL'; riskColor = '#eab308'; }
    else { riskName = 'GENERAL'; riskColor = '#888'; }
    var threats = [];
    if (src.indexOf('dryltg') >= 0 || src.indexOf('dry_ltg') >= 0) threats.push('Dry Lightning');
    if (src.indexOf('wind') >= 0) threats.push('Critical Wind');
    if (src.indexOf('rh') >= 0 || src.indexOf('humidity') >= 0) threats.push('Low Humidity');
    return { riskName: riskName, riskColor: riskColor, threats: threats, dn: dn };
  }

  function loadAllFireOutlooks(){
    var cfg = outlookEndpoints.fire;
    var days = ['d1','d2','d3'];
    days.forEach(function(day){
      // Remove existing layer for this day
      if(fireOutlookLayers[day]){
        hazardMap.removeLayer(fireOutlookLayers[day]);
        fireOutlookLayers[day] = null;
      }
      window._fireOutlookSummary[day] = null;
      var url = cfg.base + cfg[day] + '/query?where=1%3D1&outFields=*&f=geojson';
      fetch(url).then(function(r){ return r.json(); }).then(function(data){
        if(!data || !data.features || data.features.length === 0) {
          window._fireOutlookSummary[day] = { zones: 0, maxRisk: 'NONE', maxRiskColor: '#4ade80', risks: [], allThreats: [] };
          updateFireOutlookPill();
          return;
        }

        // Parse features — extract regions, risks, threats from each zone
        var zones = [];
        var maxDn = 0;
        data.features.forEach(function(f){
          var p = f.properties || {};
          var dn = p.dn || p.DN || 0;
          var src = (p.idp_source || '').toString().toLowerCase();
          var parsed = parseFireOutlookRisk(dn, src);
          if (dn > maxDn) maxDn = dn;

          // Compute centroid from geometry for region labeling
          var coords = [];
          var geom = f.geometry;
          if(geom){
            if(geom.type === 'Polygon' && geom.coordinates) coords = geom.coordinates[0] || [];
            else if(geom.type === 'MultiPolygon' && geom.coordinates) {
              geom.coordinates.forEach(function(poly){ coords = coords.concat(poly[0] || []); });
            }
          }
          var cLat = 0, cLon = 0;
          if(coords.length > 0){
            coords.forEach(function(c){ cLon += c[0]; cLat += c[1]; });
            cLat /= coords.length; cLon /= coords.length;
          }
          // Map centroid to US region name
          var region = 'US';
          if(cLat > 58) region = 'Alaska';
          else if(cLat > 42 && cLon < -115) region = 'Pacific NW';
          else if(cLat > 42 && cLon >= -115 && cLon < -104) region = 'Northern Rockies';
          else if(cLat > 35 && cLat <= 42 && cLon < -115) region = 'Great Basin';
          else if(cLon < -115 && cLat <= 42 && cLat > 32) region = 'California';
          else if(cLat <= 35 && cLon < -100 && cLon >= -115) region = 'Southwest';
          else if(cLat <= 37 && cLon >= -100 && cLon < -80) region = 'Southern Plains';
          else if(cLat <= 37 && cLon >= -80) region = 'Southeast';
          else if(cLat > 37 && cLon >= -104 && cLon < -80) region = 'Central/Northeast';
          else if(cLat > 42 && cLon >= -104) region = 'Northeast';

          zones.push({
            region: region,
            riskName: parsed.riskName,
            riskColor: parsed.riskColor,
            dn: dn,
            threats: parsed.threats,
            lat: cLat, lon: cLon
          });
        });

        // Group by region, keeping highest risk per region
        var regionMap = {};
        zones.forEach(function(z){
          if(!regionMap[z.region] || z.dn > regionMap[z.region].dn){
            regionMap[z.region] = { riskName: z.riskName, riskColor: z.riskColor, dn: z.dn, threats: z.threats.slice() };
          } else {
            // Merge threats
            z.threats.forEach(function(t){ if(regionMap[z.region].threats.indexOf(t)<0) regionMap[z.region].threats.push(t); });
          }
        });
        // Sort regions by severity
        var regionList = Object.keys(regionMap).map(function(k){ return { name:k, risk:regionMap[k] }; })
          .sort(function(a,b){ return b.risk.dn - a.risk.dn; });

        var topRisk = parseFireOutlookRisk(maxDn, '');
        window._fireOutlookSummary[day] = {
          zones: data.features.length,
          maxRisk: topRisk.riskName,
          maxRiskColor: topRisk.riskColor,
          regions: regionList
        };
        updateFireOutlookPill();

        var dayStyle = fireOutlookDayColors[day];
        var layer = L.geoJSON(data, {
          style: function(feature){
            var dn = (feature.properties || {}).dn || (feature.properties || {}).DN || 0;
            // Boost opacity for higher severity
            var opMult = dn >= 10 ? 2.0 : dn >= 8 ? 1.6 : dn >= 5 ? 1.3 : 1.0;
            return {
              fillColor: dayStyle.fill,
              fillOpacity: dayStyle.opacity * opMult,
              color: dayStyle.stroke,
              weight: 1.5,
              opacity: 0.7,
              dashArray: dayStyle.dash
            };
          }
        });
        fireOutlookLayers[day] = layer;
        // Add to map if fire tab is active
        if(hazardActiveTab === 'fire') layer.addTo(hazardMap);
      }).catch(function(e){
        console.error('Fire outlook fetch error:', day, e);
      });
    });
  }

  function updateFireOutlookPill(){
    var el = document.getElementById('fire-outlook-pill');
    if(!el) return;
    var INK = '#2B22F4';
    var INK_DIM = 'rgba(43,34,244,.68)';
    var INK_MUTE = 'rgba(43,34,244,.45)';
    var INK_GHOST = 'rgba(43,34,244,.28)';
    var FIRE_STRONG = '#c2410c';
    var CLEAR = '#047857';
    var dayLabels = { d1:'Today', d2:'Tomorrow', d3:'Days 3-8' };
    var dayColors = { d1:'#ea580c', d2:'#7e22ce', d3:'#0e7490' };
    var days = ['d1','d2','d3'];
    var threatIcons = {'Dry Lightning':'⚡','Critical Wind':'💨','Low Humidity':'🔻'};

    // Adjust risk colors for legibility on light bg
    function riskColorForLight(c){
      var map = {
        '#9333ea':'#6d28d9', // extreme
        '#ef4444':'#b91c1c', // critical
        '#f97316':'#c2410c', // elevated
        '#eab308':'#a16207', // non-critical
        '#888':INK_MUTE     // general
      };
      return map[c] || c;
    }

    var allLoaded = days.every(function(d){ return window._fireOutlookSummary[d]; });
    var allClear = allLoaded && days.every(function(d){ return window._fireOutlookSummary[d].zones === 0; });

    var h = '';
    if(allLoaded && allClear){
      h += '<div style="display:flex;justify-content:flex-end;margin-bottom:4px;"><span style="font-size:.38rem;color:'+CLEAR+';font-weight:700;padding:2px 7px;background:rgba(4,120,87,.08);border-radius:6px;">ALL CLEAR</span></div>';
    }

    if(allClear){
      h += '<div style="font-size:.42rem;color:'+INK_DIM+';margin-bottom:2px;font-weight:600;">No fire weather risk areas through Day 8</div>';
      h += '<div style="font-size:.32rem;color:'+INK_GHOST+';margin-top:5px;font-weight:700;">SPC / NOAA</div>';
      el.innerHTML = h;
      return;
    }

    days.forEach(function(day, idx){
      var s = window._fireOutlookSummary[day];
      var dc = dayColors[day];
      var isLast = idx === days.length - 1;

      h += '<div style="display:flex;align-items:stretch;gap:0;margin-bottom:'+(isLast?'0':'6px')+';'+(isLast?'':'border-bottom:1px solid rgba(43,34,244,.08);padding-bottom:6px;')+'">';
      h += '<div style="width:3px;background:'+dc+';border-radius:2px;margin-right:10px;flex-shrink:0;"></div>';
      h += '<div style="flex:1;min-width:0;">';

      h += '<div style="display:flex;align-items:center;gap:6px;margin-bottom:2px;">';
      h += '<span style="font-size:.46rem;color:'+dc+';font-weight:800;">'+dayLabels[day]+'</span>';
      if(!s){
        h += '<span style="font-size:.38rem;color:'+INK_MUTE+';font-style:italic;">loading</span>';
      } else if(s.zones === 0){
        h += '<span style="font-size:.38rem;color:'+CLEAR+';font-weight:600;">no risk areas</span>';
      }
      h += '</div>';

      if(s && s.regions && s.regions.length > 0){
        s.regions.forEach(function(r){
          var rc = riskColorForLight(r.risk.riskColor);
          h += '<div style="display:flex;align-items:baseline;gap:5px;margin-top:3px;">';
          h += '<span style="font-size:.42rem;color:'+INK+';font-weight:700;">'+r.name+'</span>';
          h += '<span style="font-size:.34rem;color:'+rc+';font-weight:800;padding:1px 5px;background:'+rc+'15;border:1px solid '+rc+'30;border-radius:4px;">'+r.risk.riskName+'</span>';
          h += '</div>';
          if(r.risk.threats.length > 0){
            h += '<div style="display:flex;gap:4px;flex-wrap:wrap;margin-top:2px;">';
            r.risk.threats.forEach(function(t){
              h += '<span style="font-size:.36rem;color:'+INK_DIM+';padding:1px 5px;background:rgba(43,34,244,.05);border-radius:4px;font-weight:600;">'+(threatIcons[t]||'')+' '+t+'</span>';
            });
            h += '</div>';
          }
        });
      }

      h += '</div></div>';
    });

    h += '<div style="font-size:.30rem;color:'+INK_GHOST+';margin-top:5px;font-weight:700;letter-spacing:.05em;">SPC / NOAA</div>';
    el.innerHTML = h;
  }

  function switchHazardOutlook(hazType, day){
    // Fire outlooks are all loaded simultaneously via loadAllFireOutlooks()
    if(hazType === 'fire') return;

    outlookActiveDay[hazType] = day;

    // Update toggle button states
    var allDays = hazType === 'flood' ? ['d1','d2','d3','d6','d8'] : hazType === 'tornado' ? ['d1','d2','d3','d48'] : ['off','d1','d2','d3'];
    var isFlood = hazType === 'flood';
    allDays.forEach(function(d){
      var btn = document.getElementById(hazType + '-otlk-' + d);
      if(btn){
        if(d === day){
          btn.classList.add('otlk-active');
          btn.style.background = isFlood ? '#fff' : 'rgba(255,255,255,.12)';
          btn.style.borderColor = isFlood ? 'rgba(43,34,244,.25)' : 'rgba(255,255,255,.3)';
          if(isFlood) btn.style.color = '#2B22F4';
        } else {
          btn.classList.remove('otlk-active');
          btn.style.background = isFlood ? 'rgba(255,255,255,.4)' : 'rgba(0,0,0,.45)';
          btn.style.borderColor = isFlood ? 'rgba(43,34,244,.15)' : (d === 'off' ? 'rgba(255,255,255,.1)' : '');
          if(isFlood) btn.style.color = 'rgba(43,34,244,.7)';
        }
      }
    });

