  function updateConditionsBriefing(){
    var el = document.getElementById('conditions-briefing-text');
    if(!el) return;
    var wx = window._wxCurrent;
    if(!wx || wx.temp == null) { el.textContent = ''; return; }
    var now = new Date();
    var hr = now.getHours();
    var hourly = window._wxHourly;
    var daily = window._wxDaily;
    var ni = window._wxNearestIdx || 0;

    // ── Helpers ──
    function compass(deg){ if(deg==null) return ''; var d=['north','NE','east','SE','south','SW','west','NW']; return d[Math.round(deg/45)%8]; }
    function timeWord(h){ return h < 6 ? 'overnight' : h < 12 ? 'this morning' : h < 17 ? 'this afternoon' : h < 21 ? 'this evening' : 'tonight'; }
    function futureTimeWord(dt){
      if(!dt) return '';
      var h = dt instanceof Date ? dt.getHours() : 12;
      var diffH = Math.round((dt - now) / 3600000);
      if(diffH < 1) return 'shortly';
      if(diffH < 3) return 'within a couple hours';
      var dayDiff = dt.getDate() - now.getDate();
      if(dayDiff < 0) dayDiff += 30; // month wrap
      if(dayDiff === 0) return h < 12 ? 'this morning' : h < 17 ? 'this afternoon' : 'this evening';
      if(dayDiff === 1) return h < 6 ? 'overnight' : h < 12 ? 'tomorrow morning' : h < 17 ? 'tomorrow afternoon' : 'tomorrow evening';
      return 'in about ' + dayDiff + ' days';
    }

    var s = '';

    // ════════════════════════════════════════════════════
    // SCAN THE NEXT 24 HOURS — find the story
    // ════════════════════════════════════════════════════
    var precipStart = null, precipType = null, precipPeak = 0, precipPeakHr = null;
    var windPeak = 0, windPeakHr = null;
    var tempMin = 999, tempMax = -999, tempMinHr = null, tempMaxHr = null;
    var snowTotal = 0, windDirStart = null, windDirEnd = null;
    var nightCloudAvg = null, nightCloudSamples = 0, nightCloudSum = 0;

    try {
    if(hourly && hourly.time){
      var sunsetDt = wx.sunset ? new Date(wx.sunset) : null;
      for(var fi = ni; fi < Math.min(ni + 24, hourly.time.length); fi++){
        var fdt = new Date(hourly.time[fi]);
        var pp = hourly.precipitation_probability ? hourly.precipitation_probability[fi] : 0;
        var precip = hourly.precipitation ? hourly.precipitation[fi] : 0;
        var snow = hourly.snowfall ? hourly.snowfall[fi] : 0;
        var t = hourly.temperature_2m ? hourly.temperature_2m[fi] : null;
        var w = hourly.windspeed_10m ? hourly.windspeed_10m[fi] : 0;
        var wg = hourly.windgusts_10m ? hourly.windgusts_10m[fi] : 0;
        var wd = hourly.wind_direction_10m ? hourly.wind_direction_10m[fi] : null;
        var cc = hourly.cloudcover ? hourly.cloudcover[fi] : null;

        // Precip onset
        if(!precipStart && pp >= 60 && fi > ni){
          precipStart = fdt;
          precipType = (t != null && t <= 33) ? 'snow' : (t != null && t <= 36) ? 'mix' : 'rain';
        }
        if(precip > precipPeak){ precipPeak = precip; precipPeakHr = fdt; }
        if(snow) snowTotal += snow;
        if(wg > windPeak){ windPeak = wg; windPeakHr = fdt; }
        if(t != null && t > tempMax){ tempMax = Math.round(t); tempMaxHr = fdt; }
        if(t != null && t < tempMin){ tempMin = Math.round(t); tempMinHr = fdt; }

        // Wind direction at start and end (for cold front detection)
        if(fi === ni) windDirStart = wd;
        if(fi === Math.min(ni + 12, hourly.time.length - 1)) windDirEnd = wd;

        // Night cloud average for aurora viewing (21:00 - 01:00 window)
        if(sunsetDt && cc != null){
          var fh = fdt.getHours();
          if(fdt >= sunsetDt && (fh >= 21 || fh <= 1)){
            nightCloudSum += cc;
            nightCloudSamples++;
          }
        }
      }
      if(nightCloudSamples > 0) nightCloudAvg = Math.round(nightCloudSum / nightCloudSamples);
    }

    // ════════════════════════════════════════════════════
    // BUILD THE NARRATIVE
    // ════════════════════════════════════════════════════
    var alerts = window._nwsAlerts || [];
    var hasAlerts = alerts.length > 0;

    // ── Part 1: Right now — temperature + sky + comfort ──
    var sky = '';
    if(wx.cloudCover != null){
      if(wx.cloudCover <= 10) sky = 'clear skies';
      else if(wx.cloudCover <= 30) sky = 'mostly clear skies';
      else if(wx.cloudCover <= 60) sky = 'partly cloudy skies';
      else if(wx.cloudCover <= 85) sky = 'mostly cloudy skies';
      else sky = 'overcast skies';
    }

    var tempWord = '';
    if(wx.temp <= 10) tempWord = 'Bitterly cold';
    else if(wx.temp <= 25) tempWord = 'Very cold';
    else if(wx.temp <= 32) tempWord = 'Freezing';
    else if(wx.temp <= 45) tempWord = 'Cold';
    else if(wx.temp <= 55) tempWord = 'Cool';
    else if(wx.temp <= 68) tempWord = 'Mild';
    else if(wx.temp <= 78) tempWord = 'Pleasant';
    else if(wx.temp <= 88) tempWord = 'Warm';
    else if(wx.temp <= 95) tempWord = 'Hot';
    else tempWord = 'Dangerously hot';

    s += tempWord + ' ' + timeWord(hr) + ' at ' + wx.temp + '\u00b0';
    if(sky) s += ' under ' + sky;

    // Feels-like with physics explanation (7°+ gap)
    if(wx.feels != null && Math.abs(wx.feels - wx.temp) >= 7){
      if(wx.feels < wx.temp){
        s += ' \u2014 feels ' + wx.feels + '\u00b0';
        if(wx.wind >= 15) s += ' as ' + Math.round(wx.wind) + ' mph ' + compass(wx.windDir) + ' winds strip away body heat';
        else if(wx.wind >= 8) s += ' as ' + Math.round(wx.wind) + ' mph winds add a bite';
        else if(wx.rh > 80) s += ' in raw, damp air';
        else s += ' from wind chill';
      } else {
        s += ' \u2014 feels ' + wx.feels + '\u00b0';
        if(wx.dewpoint >= 72) s += ' with oppressive ' + wx.dewpoint + '\u00b0 dewpoint blocking sweat evaporation';
        else if(wx.dewpoint >= 65) s += ' with a ' + wx.dewpoint + '\u00b0 dewpoint trapping heat';
        else if(wx.solarRad > 500) s += ' under direct sun heating exposed skin';
        else s += ' from high humidity reducing cooling';
      }
    }
    s += '.';

    // Wind context (when not extreme enough for the ramp section)
    if(!hasAlerts && wx.wind != null && wx.wind >= 8 && wx.wind < 25){
      s += ' Winds ' + Math.round(wx.wind) + ' mph' + (wx.windDir != null ? ' from the ' + compass(wx.windDir) : '');
      if(wx.gust != null && wx.gust > wx.wind + 8) s += ', gusting to ' + wx.gust;
      s += '.';
    } else if(!hasAlerts && wx.wind != null && wx.wind < 5 && wx.cloudCover != null && wx.cloudCover < 20){
      s += ' Calm and clear.';
    }

    // Active precipitation — with intensity
    if(wx.precip > 0 || wx.snow > 0 || wx.rain > 0){
      if(wx.snow > 0){
        var sRate = wx.snow; // mm/hr from API
        if(sRate >= 5) s += ' Heavy snow falling now.';
        else if(sRate >= 2) s += ' Moderate snow falling now.';
        else s += ' Light snow falling now.';
      } else if(wx.rain > 0){
        if(wx.rain >= 5) s += ' Heavy rain falling now.';
        else if(wx.rain >= 1.5) s += ' Steady rain falling now.';
        else s += ' Light rain falling now.';
      } else {
        s += ' Precipitation falling now.';
      }
    }

    // Fog / visibility warning
    if(wx.visibility != null && wx.visibility < 1600){
      if(wx.visibility < 400) s += ' Dense fog \u2014 visibility under a quarter mile.';
      else if(wx.visibility < 800) s += ' Foggy with visibility under half a mile.';
      else s += ' Reduced visibility from fog or haze.';
    }

    // ── Part 2: What's changing — atmospheric transition ──
    if(wx.pressureTrend != null){
      if(wx.pressureTrend < -2.5) s += ' Barometer dropping rapidly \u2014 a storm system intensifying nearby.';
      else if(wx.pressureTrend < -1.2) s += ' Pressure falling as a low approaches.';
      else if(wx.pressureTrend > 2.5) s += ' Barometer surging \u2014 high pressure building in.';
      else if(wx.pressureTrend > 1.2) s += ' Pressure rising, gradual improvement coming.';
      else if(Math.abs(wx.pressureTrend) < 0.5 && !hasAlerts) s += ' Pressure steady.';
    }

    // Wind direction shift (cold front signature)
    if(windDirStart != null && windDirEnd != null && !hasAlerts){
      var shift = Math.abs(windDirEnd - windDirStart);
      if(shift > 180) shift = 360 - shift;
      if(shift >= 90){
        var fromDir = compass(windDirStart);
        var toDir = compass(windDirEnd);
        if(fromDir !== toDir) s += ' Winds shifting from ' + fromDir + ' to ' + toDir + ' \u2014 a frontal passage.';
      }
    }

    // Dewpoint comfort (summer context, no alert noise)
    if(!hasAlerts && wx.dewpoint != null && wx.temp > 70){
      if(wx.dewpoint >= 72) s += ' Oppressively humid.';
      else if(wx.dewpoint >= 65) s += ' Uncomfortably muggy.';
