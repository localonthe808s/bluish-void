              }
              _cuInst.sort(function(a,b){ return a.tier - b.tier || a.depth - b.depth; });

              for(var iIter=0;iIter<_cuInst.length;iIter++){
                var _ii = _cuInst[iIter];
                var i = _ii.idx;
                var _depth = _ii.depth;
                var _tierSizeBoost = _ii.tier === 0 ? 0.55 : _ii.tier === 1 ? 0.85 : 1.15;
                var _tierYOffset   = _ii.tier === 0 ? 4    : _ii.tier === 1 ? -4   : -12;
                var _tierAspect    = _ii.tier === 0 ? 0.65 : 1.0;

                var _thIdx = i % _nTherm;
                var cx2 = _thermalCx[_thIdx] + (R()-0.5)*24;
                cx2 = Math.max(xOff+10, Math.min(xOff+pW-10, cx2));
                for (var _pp=0; _pp<_placedCx.length; _pp++) {
                  if (Math.abs(cx2 - _placedCx[_pp]) < 30) {
                    cx2 += (cx2 < _placedCx[_pp] ? -30 : 30);
                  }
                }
                cx2 = Math.max(xOff+10, Math.min(xOff+pW-10, cx2));
                _placedCx.push(cx2);
                _curCx = cx2;

                var bY2 = (isCong?(65+R()*10):(isHum?(82+R()*12):(78+R()*12))) + _tierYOffset;
                var w2 = (isHum?(14+R()*16):(isCong?(20+R()*28):(16+R()*26))) * _tierSizeBoost;
                var h2 = (isHum?(7+R()*5):(isCong?(20+R()*24):(7+R()*10))) * _tierSizeBoost * _tierAspect;

                // ── D2 ASYMMETRIC LIGHTING ──
                // Determine which side the sun is on (-1 = sun on left of cloud,
                // +1 = sun on right). Drives all lighting placement.
                var sunSide = (_sunCx > cx2) ? 1 : -1;

                // Per-puff RADIAL gradient with focal point biased toward the sun.
                // sun on right → bright at 75%, fades toward 25% (shadow side).
                // This gives the cloud a clear "lit side" + "shadow side" — the
                // single biggest realism upgrade over a centered/linear gradient.
                var _gid = panelPrefix + '-cu-' + Math.round(cx2) + '-' + Math.round(bY2);
                var _gdef = document.createElementNS(ns,'defs');
                var _gradCx = (sunSide > 0) ? '75%' : '25%';
                var _gradFx = (sunSide > 0) ? '70%' : '30%';
                _gdef.innerHTML = '<radialGradient id="' + _gid + '" cx="' + _gradCx + '" cy="20%" r="80%" fx="' + _gradFx + '" fy="15%">' +
