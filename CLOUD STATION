                _tubaE.setAttribute('filter', 'url(#cuTinyBlur)');
                g.appendChild(_tubaE);
                // Soft halo around the funnel (debris and condensation around the rotation)
                var _tubaHalo = document.createElementNS(ns,'path');
                _tubaHalo.setAttribute('d', _tubaP);
                _tubaHalo.setAttribute('fill', 'rgb(45,30,55)');
                _tubaHalo.setAttribute('opacity', '0.32');
                _tubaHalo.setAttribute('filter', 'url(#cuHalo)');
                g.appendChild(_tubaHalo);
              }

            }else if(t.genus==='Cumulus'){
              // ───────── APPROACH C: path silhouette + vertical gradient ─────────
              // Replaces the old ellipse-stack-with-displacement-filter rendering
              // (which produced fuzzy blobs at low cover). Each cumulus is now a
              // proper cauliflower-topped path filled with a vertical gradient:
              // white-cream at top (sun-lit), warm orange at bottom (horizon glow).
              // Plus subtle outer halo, top highlight, underside warmth.
              var isCong=t.species==='congestus';
              var isHum=t.species==='humilis';
              var isMed=t.species==='mediocris';
              // Coverage-realistic counts (preview-lab tuned, scaled ~0.7× for the
              // 220px widget panel vs 340px lab canvas). Old formulas undercounted
              // the field at >40% coverage.
              var nC = isHum   ? (2 + Math.round(t.cover/12)) :  // 5%→2, 30%→5, 50%→6, 80%→9
                       isCong ? (2 + Math.round(t.cover/28)) :  // 15%→3, 35%→3, 55%→4, 80%→5
                                (2 + Math.round(t.cover/20));   // mediocris 10%→3, 25%→3, 45%→4, 70%→6

              // Per-render gradient stop colors — branched on lighting state so
