        rbLabel.textContent = 'LOW CHANCE';
        rbLabel.style.color = 'var(--ink-dim)';
        if (rbDetail) rbDetail.textContent = bestScore + '% peak';
      } else {
        // No rainbow today. At night, repurpose the bar for what's visible overhead instead.
        var nowMsRb = (typeof now !== 'undefined' && now) ? now : new Date();
        // Civil twilight ends ~30 min after sunset (sun ≈ -6°); by then planets and
        // bright satellites are visible. Earlier threshold (75 min) was too late.
        var isDarkOut = ssDate && srDate && (nowMsRb > new Date(ssDate.getTime()+30*60000)
                        || nowMsRb < new Date(srDate.getTime()-30*60000));
        var spacePicked = false;

        if (isDarkOut) {
          var spaceLbl = '', spaceDetail = '', spaceIcon = '🌌', spaceColor = 'rgba(180,170,240,.95)';

          // 0) ISS overhead pass (rarest, most time-sensitive — beats meteor showers
          // because passes only last ~5 min and are easily missed).
          if (window._issNextPass && window._issNextPass.distance < 1500) {
            var minsToBest = Math.round((window._issNextPass.time - nowMsRb) / 60000);
            if (minsToBest >= -2 && minsToBest <= 18) {
