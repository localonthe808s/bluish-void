        gj.features.forEach(function(feat) {
          var coneOuter = L.geoJSON(feat, {
            style: {
              color: 'rgba(139,92,246,0.5)', weight: 1.5,
              fillColor: 'rgba(139,92,246,0.09)', fillOpacity: 1,
              dashArray: '6 4', lineCap: 'round', lineJoin: 'round'
            },
            pane: 'hz-track'
          });
          coneOuter.bindTooltip(
            '<div class="hz-tooltip">' +
            '<div class="hz-card-head"><span>' + name + ' — Cone of Uncertainty</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Probability</span><span class="hz-val">~2/3 (67%)</span></div>' +
            '<div style="font-size:.4rem;color:rgba(255,255,255,.45);line-height:1.5;margin-top:4px;">The storm center is expected to remain within this cone about two-thirds of the time. <b>Hazardous conditions extend well beyond the cone</b> — wind, rain, surge, and tornadoes often impact areas outside the shaded region.</div>' +
            '<div class="hz-card-footer">NHC Forecast Cone · Based on historical track errors</div></div>',
            { sticky: true, className: 'hz-tooltip', opacity: 1 }
          );
          coneOuter.addTo(_hurricaneMap);
          _hurricaneLayerObjs.conePolygons.push(coneOuter);
