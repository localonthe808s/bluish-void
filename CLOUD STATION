        }

        // Determine geomagnetic condition
        var geoLabel = 'Quiet', geoColor = '#33cc33', geoDetail = '';
        if (currentKp < 2) { geoLabel = 'Quiet'; geoColor = '#33cc33'; geoDetail = 'Normal geomagnetic conditions. No aurora visible at mid-latitudes.'; }
        else if (currentKp < 4) { geoLabel = 'Unsettled'; geoColor = '#99cc00'; geoDetail = 'Minor geomagnetic activity. Aurora may be visible at high latitudes (>60\u00b0N).'; }
        else if (currentKp < 5) { geoLabel = 'Active'; geoColor = '#ffcc00'; geoDetail = 'Moderate geomagnetic storm. Aurora visible at ~55-60\u00b0N latitudes. Check for G1 storm conditions.'; }
        else if (currentKp < 6) { geoLabel = 'Minor Storm (G1)'; geoColor = '#ff9900'; geoDetail = 'G1 geomagnetic storm. Aurora may reach ~50-55\u00b0N. Weak power grid fluctuations possible. HF radio fading at higher latitudes.'; }
        else if (currentKp < 7) { geoLabel = 'Moderate Storm (G2)'; geoColor = '#ff6600'; geoDetail = 'G2 storm. Aurora visible ~45-50\u00b0N (northern US states). High-latitude power systems may experience voltage alarms. HF radio blackouts at higher latitudes.'; }
