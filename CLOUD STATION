    }

    // Adjust body area to account for bars
    y0 = barY + barH + 8;

    // grid
    var steps = 8;
    for (var i=0;i<=steps;i++){
      var gx = x0 + (i/steps)*(x1-x0);
      var line = svgEl("line");
      line.setAttribute("x1", gx); line.setAttribute("x2", gx);
