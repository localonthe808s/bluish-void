            { attribution: 'NASA GIBS · GOES-East GeoColor', opacity: 1.0, maxZoom: 7, tileSize: 256, minZoom: 2, pane: 'hz-goes', updateWhenZooming: false, updateWhenIdle: true }
          );
        }
        _hurricaneLayerObjs.goes.addTo(_hurricaneMap);
      } else {
        if (_hurricaneLayerObjs.goes && _hurricaneMap.hasLayer(_hurricaneLayerObjs.goes)) _hurricaneMap.removeLayer(_hurricaneLayerObjs.goes);
      }
    }

    // ── SAHARAN AIR LAYER / DUST RGB ─────────────────────────────────────────
    // GOES-East Dust RGB from NASA GIBS — Saharan dust shows as vivid pink/magenta
    if (which === 'sal') {
      if (on) {
        if (!_hurricaneLayerObjs.sal) {
          // GOES-East ABI Dust RGB via NASA GIBS WMTS — confirmed working
          // Saharan dust shows as vivid pink/magenta; blue/cyan = clear humid air; green/red = clouds
          _hurricaneLayerObjs.sal = L.tileLayer(
            'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/GOES-East_ABI_Dust/default/GoogleMapsCompatible_Level7/{z}/{y}/{x}.jpg',
            { attribution: 'NASA GIBS · GOES-East Dust RGB', opacity: 1.0, maxZoom: 7, tileSize: 256, minZoom: 2, pane: 'hz-sal', updateWhenZooming: false, updateWhenIdle: true }
