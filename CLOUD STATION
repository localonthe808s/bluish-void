          // (paint-order:stroke) for additional readability. The inline
          // style override ensures we override any inherited modal `color`
          // that the SVG fill attribute might pick up.
          var labelY = userDotY - 7;
          s += '<text x="'+cx+'" y="'+labelY.toFixed(1)+'" text-anchor="middle" font-size="9" font-weight="700" '+
            'style="fill:#ffffff;paint-order:stroke;stroke:rgba(0,0,0,.55);stroke-width:2.5;stroke-linejoin:round;">'+
            Math.abs(yourLat).toFixed(1)+'°N</text>';
          s += '</svg>';
          // Caption strip below the map
          s += '<div style="display:flex;justify-content:center;gap:14px;font-size:9px;font-weight:700;color:rgba(43,34,244,.55);margin:-2px 0 4px;">'+
            '<span><span style="display:inline-block;width:10px;height:4px;background:linear-gradient(90deg,rgba(40,200,100,0),rgba(120,255,150,.85),rgba(40,200,100,0));border-radius:2px;vertical-align:middle;margin-right:3px;"></span>Auroral oval</span>'+
            '<span><span style="display:inline-block;width:7px;height:7px;background:'+(userInOval?'#88ff99':'#ff8866')+';border-radius:50%;border:1.5px solid #fff;vertical-align:middle;margin-right:3px;"></span>You</span>'+
