      // Cause — skip for prescribed burns (intentionally set by definition)
      if(d.fireCause && !d.isPrescribed) h += '<div class="hz-card-row"><span class="hz-label">Cause</span><span class="hz-val">'+d.fireCause+'</span></div>';

      // Status
      if(p._status) h += '<div class="hz-card-row"><span class="hz-label">Status</span><span class="hz-val">'+p._status+'</span></div>';

      if(d.country === 'SAT'){
        h += '<div style="margin-top:6px;padding:4px 6px;background:rgba(236,72,153,.08);border-radius:4px;border-left:2px solid #ec4899;font-size:8.5px;color:rgba(43,34,244,.55);line-height:1.4;">Unconfirmed — heat detected by NASA VIIRS that does not match agency-reported fires</div>';
        if(p._frp > 0) h += '<div class="hz-card-row"><span class="hz-label">FRP</span><span class="hz-val">'+Math.round(p._frp)+' MW</span></div>';
      }

      // Footer: source + last updated
      var src = d.country === 'CA' ? (p._satellite ? 'NASA FIRMS' : 'CWFIS/NRCan') : d.country === 'SAT' ? 'NASA FIRMS VIIRS' : 'NIFC';
      var updatedStr = '';
      if(p.ModifiedOnDateTime){
        var upd = new Date(p.ModifiedOnDateTime).getTime();
        if(!isNaN(upd)){
          var mins = Math.floor((Date.now() - upd) / 60000);
          if(mins < 60) updatedStr = ' · updated ' + mins + 'm ago';
          else if(mins < 1440) updatedStr = ' · updated ' + Math.floor(mins/60) + 'h ago';
          else updatedStr = ' · updated ' + Math.floor(mins/1440) + 'd ago';
        }
      }
      h += '<div class="hz-card-footer">Source: '+src+updatedStr+'</div>';
      marker.getPopup().setContent(h);
    }

    // ── Plot markers for newly added fires (progressive rendering) ──
    function plotNewFireMarkers(){
      for(var fi = markersPlotted; fi < allFires.length; fi++){
        var fire = allFires[fi];
        var coords = fire.geometry && fire.geometry.coordinates;
        var props = fire.properties || {};
        if (!coords) continue;

        var lat = coords[1], lon = coords[0];
        var name = props.IncidentName || props.FireName || props._name || 'Unknown';
        var acres = props.DailyAcres || props.GISAcres || props._acres || 0;
        var contained = props.PercentContained || props._contained || 0;
        var country = props._country || 'US';
        var fireType = (props.IncidentTypeCategory || props.IncidentType || '').toString().toUpperCase();
        var fireCause = (props.FireCause || '').toString();
        var isPrescribed = fireType.indexOf('RX') >= 0 || fireType.indexOf('PRESCRIBED') >= 0 || fireType.indexOf('USE') >= 0;

        var dLat = lat - LOCATION.lat, dLon = lon - LOCATION.lon;
        var dist = Math.sqrt(dLat * dLat + dLon * dLon) * 69;

        // Size/color by acres + country distinction + prescribed vs wildfire
        var radius, color;
        if (isPrescribed) {
          if (acres >= 10000) { radius = 5.5; color = '#15803d'; }
          else if (acres >= 1000) { radius = 4; color = '#22c55e'; }
          else { radius = 2.5; color = '#4ade80'; }
        } else if (country === 'CA') {
          if (acres >= 50000) { radius = 7; color = '#991b1b'; }
          else if (acres >= 10000) { radius = 5.5; color = '#b91c1c'; }
          else if (acres >= 1000) { radius = 4; color = '#ef4444'; }
          else { radius = 2.5; color = '#f87171'; }
        } else if (country === 'SAT') {
          radius = 2; color = '#ec4899';
        } else {
          if (acres >= 50000) { radius = 7; color = '#7f1d1d'; }
          else if (acres >= 10000) { radius = 5.5; color = '#dc2626'; }
          else if (acres >= 1000) { radius = 4; color = '#f97316'; }
          else { radius = 2.5; color = '#fbbf24'; }
        }

        var marker = L.circleMarker([lat, lon], {
          radius: radius,
          fillColor: color,
          fillOpacity: country === 'SAT' ? 0.6 : 0.85,
          color: color, weight: 0, opacity: 0
        });
        if(window._fireLayerGroup) window._fireLayerGroup.addLayer(marker);
        else marker.addTo(fireMap);

        // Store fire data on marker for lazy popup building
        marker._fireData = { name: name, acres: acres, contained: contained, country: country, isPrescribed: isPrescribed, fireCause: fireCause, props: props };
        marker.bindPopup('', { closeButton: false, className: 'hz-popup', maxWidth: 260 });
        marker.on('popupopen', _buildFirePopup);

        fireMarkers.push(marker);
      }
      markersPlotted = allFires.length;
    }

    function onSourceComplete() {
      sourcesLoaded++;

      // ── Progressive: plot this source's markers immediately ──
      plotNewFireMarkers();

