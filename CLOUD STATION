          out += '<div style="display:flex;align-items:baseline;gap:6px;">';
          out += '<span style="font-size:.44rem;color:'+INK+';font-weight:700;flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">'+f.name+'</span>';
          out += '<span style="font-size:.40rem;color:'+acCol+';font-weight:800;flex-shrink:0;">'+acStr+'</span>';
          out += '</div>';
          // Row 2: meta (distance for nearest, state for largest) + containment bar
          out += '<div style="display:flex;align-items:center;gap:6px;margin-top:3px;">';
          out += '<span style="font-size:.36rem;color:'+INK_MUTE+';font-weight:700;flex-shrink:0;min-width:50px;">'+(f.meta||'')+'</span>';
          out += '<div style="flex:1;height:3px;background:rgba(43,34,244,.08);border-radius:2px;overflow:hidden;min-width:30px;">';
          out += '<div style="width:'+contPct+'%;height:100%;background:'+contCol+';border-radius:2px;"></div>';
          out += '</div>';
          out += '<span style="font-size:.34rem;color:'+contCol+';font-weight:700;flex-shrink:0;min-width:22px;text-align:right;">'+contPct+'%</span>';
          out += '</div></div>';
          return out;
        }

        // Build NEAREST list (within 150mi of user)
        var nearestFires = [];
        if(LOCATION && LOCATION.lat && LOCATION.lon){
          var uLat = LOCATION.lat, uLon = LOCATION.lon;
          fires.forEach(function(f){
            var c = f.geometry && f.geometry.coordinates;
            if(!c) return;
            var fLat = c[1], fLon = c[0];
            var dLat = fLat - uLat, dLon = (fLon - uLon) * Math.cos(uLat * Math.PI / 180);
            var dist = Math.sqrt(dLat * dLat + dLon * dLon) * 69;
            if(dist > 150) return;
            var acres = f.properties.DailyAcres || f.properties.GISAcres || f.properties._acres || 0;
            var name = f.properties.IncidentName || f.properties.FireName || f.properties._name || '';
            if(!name || name === 'Unknown' || name.indexOf('Hotspot') >= 0) return;
            var bearing = Math.atan2(fLon - uLon, fLat - uLat) * 180 / Math.PI;
            if(bearing < 0) bearing += 360;
            var dirs = ['N','NE','E','SE','S','SW','W','NW'];
            var dir = dirs[Math.round(bearing / 45) % 8];
            nearestFires.push({ name:name, acres:acres, contained:f.properties.PercentContained||0, lat:fLat, lon:fLon, meta:Math.round(dist)+'mi '+dir });
          });
          nearestFires.sort(function(a,b){ return parseInt(a.meta) - parseInt(b.meta); });
        }

        // Build LARGEST list (top 4 by acres, excludes SAT)
        var largestFires = fires.slice().sort(function(a,b){
          var aA = a.properties.DailyAcres || a.properties.GISAcres || a.properties._acres || 0;
          var bA = b.properties.DailyAcres || b.properties.GISAcres || b.properties._acres || 0;
          return bA - aA;
        }).slice(0,4).map(function(f){
          var c = f.geometry && f.geometry.coordinates;
          var lat = c ? c[1] : 0, lon = c ? c[0] : 0;
          var name = f.properties.IncidentName || f.properties.FireName || f.properties._name || 'Unknown Fire';
          var acres = f.properties.DailyAcres || f.properties.GISAcres || f.properties._acres || 0;
          var state = f.properties.POOState || f.properties.State || '';
          var stateCode = state ? state.replace('US-','').substring(0,2).toUpperCase() : (f.properties._country === 'CA' ? 'CA' : '');
          var country = f.properties._country === 'CA' ? 'CA' : (stateCode || 'US');
          return { name:name, acres:acres, contained:f.properties.PercentContained||0, lat:lat, lon:lon, meta: country };
        });

        // Render tabbed focus section
        var nearbyHtml = '';
        if(nearestFires.length > 0 || largestFires.length > 0){
          var defaultTab = nearestFires.length > 0 ? 'near' : 'large';
          nearbyHtml = '<div style="margin-top:12px;">';
          // Tab bar header
          nearbyHtml += '<div style="display:flex;align-items:center;gap:10px;margin-bottom:6px;">';
          nearbyHtml += '<span style="width:3px;height:10px;background:'+FIRE_STRONG+';border-radius:2px;"></span>';
          nearbyHtml += '<span onclick="window._switchFireFocusTab(\'near\')" id="fire-focus-tab-near" style="font-size:.36rem;font-weight:800;letter-spacing:.1em;cursor:pointer;padding:2px 0;border-bottom:1.5px solid '+(defaultTab==='near'?FIRE_STRONG:'transparent')+';color:'+(defaultTab==='near'?FIRE_STRONG:INK_MUTE)+';">NEAREST</span>';
          nearbyHtml += '<span onclick="window._switchFireFocusTab(\'large\')" id="fire-focus-tab-large" style="font-size:.36rem;font-weight:800;letter-spacing:.1em;cursor:pointer;padding:2px 0;border-bottom:1.5px solid '+(defaultTab==='large'?FIRE_STRONG:'transparent')+';color:'+(defaultTab==='large'?FIRE_STRONG:INK_MUTE)+';">LARGEST</span>';
          nearbyHtml += '</div>';

          // Nearest panel
          nearbyHtml += '<div id="fire-focus-panel-near" style="display:'+(defaultTab==='near'?'block':'none')+';padding:8px 10px;background:rgba(194,65,12,.04);border:1px solid rgba(194,65,12,.12);border-radius:12px;">';
          if(nearestFires.length > 0){
            nearestFires.slice(0,4).forEach(function(nf, i){
              nearbyHtml += renderFireRow(nf, i === Math.min(3, nearestFires.length - 1));
            });
            if(nearestFires.length > 4) nearbyHtml += '<div style="font-size:.34rem;color:'+INK_MUTE+';margin-top:4px;font-weight:600;">+' + (nearestFires.length - 4) + ' more within 150mi</div>';
          } else {
            nearbyHtml += '<div style="font-size:.38rem;color:'+INK_MUTE+';font-weight:600;text-align:center;padding:6px 0;">No fires within 150mi</div>';
          }
          nearbyHtml += '</div>';

          // Largest panel
          nearbyHtml += '<div id="fire-focus-panel-large" style="display:'+(defaultTab==='large'?'block':'none')+';padding:8px 10px;background:rgba(194,65,12,.04);border:1px solid rgba(194,65,12,.12);border-radius:12px;">';
          largestFires.forEach(function(lf, i){
            nearbyHtml += renderFireRow(lf, i === largestFires.length - 1);
          });
          nearbyHtml += '</div>';

          nearbyHtml += '</div>';

          // Tab switcher function (global, idempotent)
          window._switchFireFocusTab = function(tab){
            var tabs = ['near','large'];
            tabs.forEach(function(t){
              var tabEl = document.getElementById('fire-focus-tab-'+t);
              var panelEl = document.getElementById('fire-focus-panel-'+t);
              if(tabEl){
                tabEl.style.borderBottom = '1.5px solid ' + (t === tab ? '#c2410c' : 'transparent');
                tabEl.style.color = t === tab ? '#c2410c' : 'rgba(43,34,244,.45)';
              }
              if(panelEl){
                panelEl.style.display = t === tab ? 'block' : 'none';
              }
            });
          };
        }

        // ── Smoke impact for your location ──
        var smokeHtml = '';
        var si = window._smokeIntel;
        if(si){
          var sevCol = {none:'#047857', advisory:'#a16207', warning:'#c2410c', emergency:'#b91c1c'};
          var sevLabel = {none:'No smoke impact', advisory:'Smoke advisory', warning:'Smoke warning', emergency:'Smoke emergency'};
          var sev = si.severity || 'none';
