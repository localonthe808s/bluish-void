    // ── TROPICAL CYCLONE HEAT POTENTIAL (TCHP) ────────────────────────────────
    // Approximate TCHP from Open-Meteo Marine API sea surface temperature grid.
    // TCHP measures ocean heat content through the 26°C isotherm — more predictive
    // of intensification than SST alone because shallow warm layers can't sustain TCs.
    // Values: <40 kJ/cm² = marginal, 40-60 = supportive, 60-90 = favorable, >90 = extreme fuel
    if (which === 'tchp') {
      if (on) {
        _fetchTCHP();
