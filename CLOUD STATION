  var _goesIsFetching = false;
  function fetchGoesFrames(){
    if (!goesLiveEl) return Promise.resolve();
    if (_goesIsFetching) return Promise.resolve();
    _goesIsFetching = true;

    var goesSat = goesCurrentSat;
    var goesSector = goesCurrentSector;
    var goesBand = goesCurrentBand;
    var indexUrl = "https://www.star.nesdis.noaa.gov/GOES/sector_band.php?band=" + goesBand + "&sat=" + goesSat + "&sector=" + goesSector + "&length=" + goesLength;
    goesLiveEl.textContent = "• LOADING";

    return fetchWithTimeout(indexUrl, null, 12000)
      .then(function(r){ return r.text(); })
      .then(function(html){
        var goesNum = goesSat === "G18" ? "GOES18" : "GOES19";
        var re = new RegExp("https://cdn\\.star\\.nesdis\\.noaa\\.gov/" + goesNum + "/ABI/SECTOR/" + goesSector + "/" + goesBand + "/[^\"' ]+\\.jpg", "gi");
    
        var goesSubEl = document.getElementById("fcast-source-link");
        var sectorNames = { ne:'NORTHEAST',se:'SOUTHEAST',umv:'UPPER MISS VALLEY',cgl:'GREAT LAKES',smv:'SOUTH MISS VALLEY',sp:'SOUTH PLAINS',nr:'NORTHERN ROCKIES',sr:'SOUTHERN ROCKIES',eus:'EAST COAST',car:'CARIBBEAN',gm:'GULF',pr:'PUERTO RICO',taw:'TROPICAL ATLANTIC',can:'CANADA',pnw:'PACIFIC NW',psw:'PACIFIC SW',wus:'WEST US',np:'NORTH PACIFIC',ep:'EAST PACIFIC',mex:'MEXICO',cam:'CENTRAL AMERICA',nsa:'SOUTH AMERICA N',ssa:'SOUTH AMERICA S' };
        var bandNames = { GEOCOLOR:'GEOCOLOR',AirMass:'AIR MASS',Sandwich:'SANDWICH',DayNightCloudMicroCombo:'CLOUD MICRO',FireTemperature:'FIRE TEMP',Dust:'DUST',EXTENT3:'GLM LIGHTNING',DMW:'MOTION WINDS','01':'B1 BLUE','02':'B2 RED','03':'B3 VEGGIE','04':'B4 CIRRUS','05':'B5 SNOW/ICE','06':'B6 CLOUD','07':'B7 SHORTWAVE IR','08':'B8 UPPER WV','09':'B9 MID WV','10':'B10 LOWER WV','11':'B11 CLOUD PHASE','12':'B12 OZONE','13':'B13 CLEAN IR','14':'B14 LONGWAVE','15':'B15 DIRTY IR','16':'B16 CO2' };
        var satName = goesSat === "G18" ? "GOES-18" : "GOES-19";
        if (goesSubEl && fcastState.range === 'clouds') goesSubEl.textContent = "NESDIS/STAR " + satName + " | " + (sectorNames[goesSector] || goesSector.toUpperCase()) + " • " + (bandNames[goesBand] || goesBand);

        var matches = html.match(re) || [];
        var seen = Object.create(null);
        var uniq = [];

        for (var i=0;i<matches.length;i++){
          var u = matches[i];
          if (seen[u]) continue;
          seen[u] = true;
          uniq.push(u);
        }

        if (uniq.length){
          goesFrames = uniq.slice(-goesLength);
          goesIdx = 0;
          goesLiveEl.textContent = "• LIVE";
          SH.ok('goes');
          if (goesFrameEl) goesFrameEl.textContent = "--/--";
        } else {
          SH.fail('goes', fetchGoesFrames);
          goesLiveEl.textContent = "• OFFLINE";
