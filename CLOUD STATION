          svg += '<div style="display:flex;gap:2px;height:'+labelH+'px;margin-top:2px;">';
          bars.forEach(function(b) {
            var hr = b.t.getHours();
            var hrStr = hr === 0 ? '12a' : hr < 12 ? hr+'a' : hr === 12 ? '12p' : (hr-12)+'p';
