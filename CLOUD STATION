            validStr = vM + '/' + vD + ' ' + vH + ':' + vMin + 'Z';
          }
          if (expire && expire.length >= 12) {
            var eY = expire.substring(0,4), eM = expire.substring(4,6), eD = expire.substring(6,8), eH = expire.substring(8,10), eMin = expire.substring(10,12);
            expireStr = eM + '/' + eD + ' ' + eH + ':' + eMin + 'Z';
