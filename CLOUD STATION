            '</div>' +
          '</div>' +
          // ── Regional breakdown as compact bar chart ──
          (topReg.length > 0 ? (function(){
            var maxC = Math.max.apply(null, topReg.map(function(r){return r.c;}));
            var regionNames = {SE:'Southeast',SP:'S. Plains',SW:'Southwest',CA:'California',GB:'Great Basin',NW:'Pacific NW',NR:'N. Rockies',NE:'Northeast',AK:'Alaska'};
            var out = '<div style="margin-top:12px;">';
            out += sectionHeader('REGIONAL ACTIVITY', INK);
            out += '<div style="display:flex;flex-direction:column;gap:4px;">';
            topReg.forEach(function(r){
              var pct = maxC > 0 ? (r.c / maxC * 100) : 0;
