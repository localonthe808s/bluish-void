      // 3D sphere lighting overlay
      svg += '<circle cx="'+cx+'" cy="'+cy+'" r="'+svgR+'" fill="url(#ic-sphere)" pointer-events="none"/>';
      // Crisp sphere outline
      svg += '<circle cx="'+cx+'" cy="'+cy+'" r="'+svgR+'" fill="none" stroke="rgba(255,255,255,.28)" stroke-width=".7"/>';

      // Labels on right side — leader from layer mid-radius on right side to the label box
      var labelX = cx + svgR + 12;
      var labelSpacing = Math.min(19, (svgH-16) / pi.layers.length);
      var startY = cy - (pi.layers.length * labelSpacing)/2 + labelSpacing/2;
      for (var li=0; li<pi.layers.length; li++) {
        var layer = pi.layers[li];
