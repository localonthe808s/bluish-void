  /* Mobile breakpoint */
  @media (max-width: 768px) {
    /* ========== MOBILE PERF: kill expensive CSS effects ========== */
    /* backdrop-filter is the single most expensive CSS property on
       mobile GPUs — every blur forces a separate compositing layer
       and a Gaussian blur per frame. With 246 instances across the
       page, scrolling on phones turns to mush. Disable site-wide on
       mobile only. The "frosty" look becomes solid; readability is
       unaffected because most cards already have a background color. */
    *, *::before, *::after {
      backdrop-filter: none !important;
      -webkit-backdrop-filter: none !important;
    }

    /* Cap continuous CSS animations — any animation set to
       "infinite" runs every frame even when off-screen. Reduce
       iteration to a single play and throttle their duration so
       they're not actively churning the compositor. The handful of
       must-keep animations (radar sweep, live-tag pulse) stay full
       speed via the override below. */
    *, *::before, *::after {
      animation-duration: 0.001s !important;
      animation-delay: 0s !important;
      animation-iteration-count: 1 !important;
    }
    .live-tag, .live-tag::before, .live-tag::after,
    .radar-beam, .radar-rings,
    [class*="cira-pulse"], [class*="badge-pulse"] {
      animation-duration: revert !important;
      animation-iteration-count: infinite !important;
    }

    /* Cap the most aggressive box-shadow blur radii so the compositor
       can rasterize them once instead of per-frame. */
    .widget, .panel, .card, .left-now,
    [class*="card"], [class*="pill"] {
      will-change: auto !important;
    }

    /* Defer offscreen widget rendering — content-visibility:auto skips
       layout/paint for elements not in the viewport, then catches up
       lazily as the user scrolls. Massive scroll-perf win. Reserve
       contain-intrinsic-size so the scroll bar position is stable. */
    .widget, .panel {
      content-visibility: auto !important;
      contain-intrinsic-size: 0 600px !important;
    }

    /* Disable per-cloud SVG filters (cuFluff, cuFeather, ghCloudHaze,
       ghCloudDiffuse, ghCirrusFil, etc) on mobile. They re-rasterize
       feGaussianBlur on every frame during scroll. Mobile clouds will
       have hard edges instead of wispy soft ones. */
    [filter^="url(#cu"],
    [filter^="url(#gh"],
    [filter^="url(#ic-"],
    [filter*="ghCirrus"],
    [filter*="ghCloud"],
    [filter*="cuFluff"],
    [filter*="cuFeather"],
    [filter*="cuHalo"],
    [filter*="ghBlur"] {
      filter: none !important;
    }
