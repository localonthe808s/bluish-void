          intel.evidenceChain.push('Wind shear convergence: Surface wind from ' + (windDeg != null ? wDirs16[Math.round(windDeg / 22.5) % 16] : '?') + ' opposes 700mb from ' + wDirs16[Math.round(w700d / 22.5) % 16] + ' (' + Math.round(shearAngle) + '° shear). Smoke pileup possible at altitude.');
