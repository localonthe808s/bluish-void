      // Find best rainbow window today
      var bestScore = 0, bestHour = -1, bestType = null, bestDir = null;
      var todayDate = dayLocal.getDate();
      for (var ri = 0; ri < rbResults.length; ri++) {
        var rb = rbResults[ri];
        if (!rb || new Date(rb.time).getDate() !== todayDate) continue;
