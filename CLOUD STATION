          var youCol = yourLat >= threshold ? '#1a8a4a' : '#cc4422';
          var youLabel = (Math.abs(yourLat) === yourLat ? '' : '') + 'YOU ' + Math.abs(yourLat).toFixed(1) + '°';
          // If your-lat label and threshold label are very close, offset YOU
          // label downward to avoid overlap.
          var labelGap = Math.abs(yourPct - thrPct);
          var youOffset = labelGap < 12 ? 22 : 14;
          svg += '<div style="position:absolute;left:'+yourPct.toFixed(2)+'%;top:'+youOffset+'px;font-size:8px;font-weight:700;color:'+youCol+';transform:translateX(-50%);white-space:nowrap;">'+youLabel+'</div>';
          svg += '<div style="position:absolute;left:'+thrPct.toFixed(2)+'%;top:14px;font-size:8px;font-weight:700;color:#1a8a4a;transform:translateX(-50%);white-space:nowrap;">'+threshold+'°N</div>';
