    // ═══ SOURCE 1: NIFC (US) ═══
    var nifcUrl = "https://services9.arcgis.com/RHVPKKiFTONKtxq3/arcgis/rest/services/USA_Wildfires_v1/FeatureServer/0/query?where=1%3D1&outFields=*&outSR=4326&f=geojson";
    if (window._prefetchedNIFC) {
      // Use boot-prefetched data
      var fires = window._prefetchedNIFC.features || [];
      fires.forEach(function(f) { if (f.properties) f.properties._country = 'US'; });
