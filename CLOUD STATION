    }

    // Store terrain reference in smoke intel for downstream use
    intel.terrainIntel = terrain;

    // ── 0f. CONVERGENCE ZONE DETECTION ──
    // When winds at different levels oppose each other, smoke piles up
    // Check for surface vs 700mb wind opposition
    if(has700 && windDeg != null){
