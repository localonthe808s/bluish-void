    if(rh!=null&&rh>60&&wx.precipProb!=null&&wx.precipProb>20&&wx.precipProb<60&&new Date().getHours()>=12) optics.push('🌈 '+K('Rainbow Potential')+' \u2014 afternoon showers ('+wx.precipProb+'%) with clearing. Look east/opposite sun.');
    if(dp!=null&&temp!=null&&(temp-dp)<2&&wind!=null&&wind<5) optics.push('🌫️ '+K('Fog Imminent')+' \u2014 T-Td '+(temp-dp).toFixed(0)+'\u00b0, winds '+wind+' mph. Radiation fog likely overnight. Band 7 definitive.');
    if(optics.length>0){h+=S('Atmospheric Optics');optics.forEach(function(o){h+='<div style="margin:4px 0;">'+o+'</div>';});}

    // ── SUNSET / GOLDEN HOUR ──
    if (sunset) {
      var now = new Date(); var ss = new Date(sunset);
      var sr = sunrise ? new Date(sunrise) : null;
      var mToSS = Math.round((ss-now)/60000);
      if (mToSS > -30 && mToSS < 240) {
        h += S('Sunset & Golden Hour');
        var sc = 5; var facs = [];
        if(cH!=null&&cH>20&&cH<70){sc+=2;facs.push('High clouds ('+cH+'%) catch warm light');}
        else if(cH!=null&&cH>=70){sc+=1;facs.push('Dense high \u2014 intense colors but may block sun');}
        else{sc-=1;facs.push('No high clouds for color');}
        if(cM!=null&&cM>15&&cM<50){sc+=1.5;facs.push('Mid clouds ('+cM+'%) add depth');}
        else if(cM!=null&&cM>=70){sc-=1;facs.push('Thick mid overcast blocks sunset');}
