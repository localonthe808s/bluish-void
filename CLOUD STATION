  // ═══════════════════════════════════════

  var goesBandInfo = {
    'goes-band-GEOCOLOR': '<b>GeoColor — True Color Day / IR Night</b><br><br><span class="k">What it shows:</span> A blended composite that renders <b>near-true-color imagery during the day</b> (using visible channels 1, 2, 3) and transitions to <b>infrared with city lights at night</b>. Daytime imagery shows clouds as white against blue ocean and green/brown land, closely matching what your eyes would see from space.<br><br><span class="k">How to read it:</span> Thick bright white = deep convective clouds or dense stratus. Thin wispy white = cirrus. Gray/translucent = fog or low stratus. At night, low clouds appear blue-gray, high clouds appear dark gray to white, and city lights provide geographic reference.<br><br><span class="k">Why it matters:</span> The most intuitive satellite product — it looks like a photograph from space. Best starting point for understanding the current cloud and weather pattern at a glance. Night imagery is especially useful for tracking low cloud/fog formation.<br><br><span class="k">Best for:</span> General situational awareness, cloud identification, storm tracking, public communication.',

    'goes-band-AirMass': '<b>Air Mass RGB Composite</b><br><br><span class="k">What it shows:</span> A false-color composite using water vapor (bands 8, 10) and ozone (band 12) channels to visualize <b>air mass boundaries, tropopause folds, and jet stream dynamics</b>. Different colors represent distinct air masses with different moisture and temperature characteristics.<br><br><span class="k">How to read it:</span> <b>Red/orange</b> = warm, moist tropical air. <b>Blue/cyan</b> = cold, dry polar/arctic air. <b>Green</b> = stratospheric intrusions and tropopause folds (jet stream). Sharp color boundaries = <b>frontal zones and air mass boundaries</b>. Dark blue tongues diving equatorward = cold air advection.<br><br><span class="k">Why it matters:</span> Reveals the three-dimensional atmospheric structure that drives weather. Tropopause folds (green features) mark where stratospheric air descends — these are jet stream axes and often precede surface cyclogenesis. A powerful synoptic-scale analysis tool.<br><br><span class="k">Best for:</span> Jet stream analysis, front identification, cyclone development, air mass tracking.',

    'goes-band-Sandwich': '<b>Sandwich RGB Product</b><br><br><span class="k">What it shows:</span> Visible imagery (Band 2) <b>draped over infrared imagery</b> (Band 13), creating a 3D-like view where cloud tops are colored by temperature. This "sandwiches" the visual texture of clouds with their altitude information.<br><br><span class="k">How to read it:</span> Warm-colored cloud tops (yellow/red) = low, warm clouds. Cold-colored tops (blue/purple) = high, cold clouds — indicating deep convection. The visible channel provides texture and detail while IR provides the height/intensity context.<br><br><span class="k">Why it matters:</span> Instantly identifies <b>overshooting tops</b> — convective towers punching through the tropopause, which appear as bright white spots on deep purple/blue backgrounds. These are the most reliable satellite signatures of severe storms, large hail, and tornado-producing supercells.<br><br><span class="k">Best for:</span> Severe storm identification, overshooting top detection, convective intensity analysis.',

    'goes-band-DayNightCloudMicroCombo': '<b>Cloud Microphysics RGB</b><br><br><span class="k">What it shows:</span> A composite using near-IR and IR channels to reveal <b>cloud particle size, phase (liquid vs ice), and optical thickness</b>. Different colors correspond to different cloud microphysical properties.<br><br><span class="k">How to read it:</span> <b>White/cyan</b> = thick ice clouds (deep convection). <b>Pink/magenta</b> = thin ice clouds (cirrus). <b>Yellow/gold</b> = liquid water clouds with small droplets. <b>Green</b> = liquid water clouds with large droplets (rain likely). <b>Red</b> = thin supercooled liquid water (aircraft icing risk).<br><br><span class="k">Why it matters:</span> Identifies <b>supercooled water</b> (icing hazard for aviation), distinguishes between convective and stratiform clouds, and reveals precipitation processes. Large-droplet liquid clouds (green) are actively precipitating or about to. Glaciated tops indicate mature convection.<br><br><span class="k">Best for:</span> Aviation icing, precipitation processes, cloud phase analysis, fog detection.',

    'goes-band-FireTemperature': '<b>Fire Temperature RGB</b><br><br><span class="k">What it shows:</span> Combines shortwave IR (Band 7) with longwave IR to detect and characterize <b>active fire hot spots</b> and estimate fire radiative power (FRP). Hot spots appear as bright pixels against the cooler background.<br><br><span class="k">How to read it:</span> <b>Bright yellow/white pixels</b> = active fire. Brighter = more intense fire. <b>Red/orange halos</b> = heated ground surrounding active burning. <b>Dark plumes</b> = smoke, visible in visible/near-IR channels. The product can detect fires as small as ~4 acres under ideal conditions.<br><br><span class="k">Why it matters:</span> Near-real-time fire detection from geostationary orbit — updated every 5-10 minutes. Unlike polar-orbiting satellites (which pass over twice daily), GOES provides <b>continuous monitoring</b> of fire growth, intensity changes, and new fire starts. Critical during wildfire season.<br><br><span class="k">Best for:</span> Wildfire detection, fire growth monitoring, smoke tracking, prescribed burn monitoring.',

    'goes-band-Dust': '<b>Dust RGB Composite</b><br><br><span class="k">What it shows:</span> Combines split-window IR channels (Bands 11, 13, 14, 15) to distinguish <b>airborne dust and sand</b> from clouds and clear sky. Exploits the fact that dust particles have different emissivity signatures than water/ice in certain IR wavelengths.<br><br><span class="k">How to read it:</span> <b>Bright pink/magenta</b> = thick dust (haboobs, Saharan Air Layer). <b>Lighter pink</b> = thin dust. <b>Blue/cyan</b> = humid, clear air. <b>Green/red</b> = clouds (various types). The product works day and night since it uses thermal IR channels.<br><br><span class="k">Why it matters:</span> Dust storms reduce visibility to near-zero, causing deadly pileups on highways. The Saharan Air Layer (SAL) suppresses Atlantic hurricane formation. Volcanic ash (similar signature) is catastrophic for jet engines. This product tracks all of these 24/7.<br><br><span class="k">Best for:</span> Dust storm tracking, Saharan Air Layer monitoring, volcanic ash detection, aviation safety.',

    'goes-band-EXTENT3': '<b>GLM Lightning Density</b><br><br><span class="k">What it shows:</span> Data from the <b>Geostationary Lightning Mapper</b> — a dedicated optical sensor on GOES that detects total lightning (cloud-to-cloud + cloud-to-ground) across the Western Hemisphere continuously. Shows flash density over selected time periods.<br><br><span class="k">How to read it:</span> Brighter/warmer colors = higher flash rates. A single pixel can contain dozens of flashes. <b>Lightning jumps</b> (sudden increases in flash rate) are a key severe weather indicator. Typical rates: moderate storm = 10-30 flashes/min, severe storm = 50-200+ flashes/min.<br><br><span class="k">Why it matters:</span> Total lightning (especially in-cloud lightning) <b>increases 5-20 minutes before severe weather</b> — before radar signatures develop. Lightning jumps are now operationally used by NWS to issue severe thunderstorm and tornado warnings. GLM fills in lightning data over oceans and remote areas where ground networks have no coverage.<br><br><span class="k">Best for:</span> Severe storm nowcasting, convective initiation, lightning safety, oceanic storm monitoring.',

    'goes-band-DMW': '<b>Derived Motion Winds</b><br><br><span class="k">What it shows:</span> Atmospheric wind vectors derived by <b>tracking cloud and water vapor features</b> across consecutive satellite images. The movement of these features reveals wind speed and direction at various levels of the atmosphere.<br><br><span class="k">How to read it:</span> Arrows/barbs show wind direction and speed. Color-coded by altitude: <b>low-level winds</b> (boundary layer, tracked from cumulus), <b>mid-level winds</b> (tracked from altocumulus/water vapor), <b>upper-level winds</b> (tracked from cirrus). Wind barbs follow standard meteorological convention.<br><br><span class="k">Why it matters:</span> Fills massive data gaps in upper-air observations, especially over <b>oceans</b> where there are no radiosondes. These wind observations are assimilated into numerical weather models and significantly improve forecast accuracy. Also reveals mesoscale circulations, outflow boundaries, and wind shear patterns invisible to conventional observations.<br><br><span class="k">Best for:</span> Wind field analysis, model data assimilation, aviation, tropical cyclone structure analysis.',

    'goes-band-01': '<b>Band 1 — Blue Visible (0.47 µm)</b><br><br><span class="k">What it shows:</span> Reflected sunlight in the blue portion of the visible spectrum. At 1km resolution, this channel is particularly sensitive to <b>aerosols, smoke, and haze</b> because blue light scatters more than longer wavelengths (Rayleigh scattering).<br><br><span class="k">How to read it:</span> Bright white = thick clouds. Hazy/milky appearance over land = aerosols or smoke. Clear skies appear dark (land) or bright (ocean due to Rayleigh scattering). Snow and ice are very bright.<br><br><span class="k">Why it matters:</span> The best single channel for <b>detecting thin smoke plumes and haze</b> that may not show up in other visible bands. Also useful for aerosol optical depth estimation. Only works during daytime.<br><br><span class="k">Best for:</span> Smoke detection, air quality, aerosol tracking, wildfire plume monitoring.',

    'goes-band-02': '<b>Band 2 — Red Visible (0.64 µm) — 0.5km Resolution</b><br><br><span class="k">What it shows:</span> The <b>highest resolution channel on GOES-R series</b> at 500 meters. Reflected sunlight in the red portion of visible spectrum. This is the primary visible channel used in GeoColor and most composite products.<br><br><span class="k">How to read it:</span> The sharpest view of cloud structure available from geostationary orbit. Can resolve individual convective towers, cloud streets, gravity waves in cloud decks, and mesoscale vortices. Vegetation appears dark, clouds bright, snow/ice very bright.<br><br><span class="k">Why it matters:</span> The <b>go-to channel for cloud detail</b>. At 0.5km you can see convective turrets punching through capping inversions, identify developing cumulus, track arc clouds from thunderstorm outflows, and spot rotation signatures in severe storms (comma-head patterns). Daytime only.<br><br><span class="k">Best for:</span> Storm structure, convective development, mesoscale features, highest-detail cloud imagery.',

    'goes-band-03': '<b>Band 3 — Veggie Near-IR (0.86 µm)</b><br><br><span class="k">What it shows:</span> Near-infrared reflectance, which is strongly reflected by <b>vegetation</b> (hence the name). Also distinguishes cloud particle phase — liquid water drops scatter strongly at this wavelength while ice crystals do not.<br><br><span class="k">How to read it:</span> Healthy vegetation appears very bright (high reflectance). Bare soil/urban = darker. Liquid water clouds = bright. Ice clouds = dimmer. Water bodies = very dark. Useful for land surface analysis and cloud phase discrimination.<br><br><span class="k">Why it matters:</span> Combined with visible bands, enables <b>true natural color imagery</b> and vegetation health monitoring. The liquid-vs-ice discrimination helps identify supercooled liquid tops on convective storms (glaciation indicates updraft weakening). Also key for burn scar mapping after wildfires.<br><br><span class="k">Best for:</span> Vegetation health, burn scar detection, cloud phase, natural color composites.',

    'goes-band-04': '<b>Band 4 — Cirrus (1.37 µm)</b><br><br><span class="k">What it shows:</span> A unique near-IR channel absorbed by <b>lower atmospheric moisture</b>, making it transparent to low/mid clouds and the surface. Only <b>high-altitude ice clouds (cirrus)</b> above most of the water vapor show up.<br><br><span class="k">How to read it:</span> Bright features = cirrus clouds. Dark = everything else (the surface and low clouds are invisible). This is a "high-pass filter" for the atmosphere — only features in the upper troposphere appear.<br><br><span class="k">Why it matters:</span> Isolates <b>cirrus shields and anvils</b> from thunderstorms, jet stream cirrus, and contrails without confusion from lower clouds. Useful for identifying storm anvil spread (which indicates upper-level outflow and storm maturity) and mapping tropopause-level features. Also detects thin cirrus that can contaminate SST retrievals.<br><br><span class="k">Best for:</span> Cirrus detection, anvil mapping, storm maturity assessment, aviation contrail tracking.',

    'goes-band-05': '<b>Band 5 — Snow/Ice (1.61 µm)</b><br><br><span class="k">What it shows:</span> Near-IR channel where <b>ice and snow absorb strongly</b> but liquid water reflects. This creates a powerful contrast: snow/ice surfaces and ice-topped clouds appear <b>dark</b>, while liquid water clouds appear bright.<br><br><span class="k">How to read it:</span> <b>Dark features</b> = ice/snow (ground or cloud tops). <b>Bright features</b> = liquid water clouds. Land without snow = variable. This is essentially the reverse of visible imagery for frozen surfaces.<br><br><span class="k">Why it matters:</span> The <b>definitive cloud phase channel</b>. Instantly identifies which clouds have glaciated tops (ice) vs liquid tops. Ice-topped convection indicates updrafts strong enough to carry water above the freezing level. Also maps snowcover extent, identifies icing hazards for aviation, and distinguishes fog (liquid, bright) from snow (dark) on the ground — a major challenge for visible-only imagery.<br><br><span class="k">Best for:</span> Cloud phase, snowcover mapping, fog vs snow discrimination, aircraft icing.',

    'goes-band-06': '<b>Band 6 — Cloud Particle (2.24 µm)</b><br><br><span class="k">What it shows:</span> A near-IR channel sensitive to cloud particle size and phase. Reflectance at this wavelength is <b>inversely related to cloud drop size</b> — smaller drops reflect more, larger drops and ice crystals reflect less.<br><br><span class="k">How to read it:</span> Bright = small liquid droplets (non-precipitating clouds). Dimmer = larger drops or ice. Very dark cloud areas = large drops likely producing precipitation or ice crystals. Combined with Band 2, enables cloud effective radius retrievals.<br><br><span class="k">Why it matters:</span> Identifies <b>precipitation onset</b> — as cloud drops grow toward rain-size, reflectance decreases at 2.24µm. This transition visible in satellite imagery indicates collision-coalescence is active and rain is imminent. Also critical for cloud microphysics retrievals used in aviation and climate monitoring.<br><br><span class="k">Best for:</span> Precipitation processes, cloud microphysics, drop size estimation, aviation.',

    'goes-band-07': '<b>Band 7 — Shortwave IR (3.9 µm)</b><br><br><span class="k">What it shows:</span> A hybrid channel responding to both <b>reflected solar radiation (daytime) and emitted thermal radiation</b>. During day, low liquid water clouds glow bright (solar reflection) while ice clouds are dark. At night, it becomes a thermal channel detecting hot spots.<br><br><span class="k">How to read it:</span> <b>Daytime:</b> Bright = low liquid clouds (stratus, fog), dark = ice clouds, ground shows solar heating. <b>Nighttime:</b> warm surfaces = bright, cold clouds = dark. <b>Hot spots</b> (fire, volcanic eruption, gas flares) appear as extremely bright pixels at any time.<br><br><span class="k">Why it matters:</span> The <b>primary fire detection channel</b>. Hot spots from active fires saturate this band long before they\'re visible in longwave IR. Also critical for <b>fog detection at night</b> — the 3.9µm minus 10.3µm brightness temperature difference identifies low stratus/fog. Marine stratus and fog glow distinctively on this channel.<br><br><span class="k">Best for:</span> Fire detection, nighttime fog/stratus, low cloud identification, hot spot monitoring.',

    'goes-band-08': '<b>Band 8 — Upper-Level Water Vapor (6.19 µm)</b><br><br><span class="k">What it shows:</span> Moisture and temperature in the <b>upper troposphere (300-500mb, ~20,000-30,000 ft)</b>. This channel is absorbed by water vapor, so it "sees" the highest moisture layer — revealing upper-tropospheric dynamics invisible to visible/IR imagery.<br><br><span class="k">How to read it:</span> <b>Bright/white</b> = moist upper troposphere (high clouds or deep moisture). <b>Dark/black</b> = dry air, subsidence, or stratospheric intrusions. Swirling patterns reveal upper-level vortices. Dark channels or "dry slots" indicate sinking air from the stratosphere.<br><br><span class="k">Why it matters:</span> Reveals the <b>jet stream, upper-level lows, and tropopause dynamics</b> that drive surface weather systems. Dry intrusions (dark tongues) descending behind cold fronts indicate strong dynamics and deepening cyclones. Upper-level divergence patterns visible here indicate where surface pressure falls will occur — and where storms will develop.<br><br><span class="k">Best for:</span> Jet stream analysis, upper-level lows, cyclogenesis, dynamic meteorology.',

    'goes-band-09': '<b>Band 9 — Mid-Level Water Vapor (6.95 µm)</b><br><br><span class="k">What it shows:</span> Moisture in the <b>mid-troposphere (400-600mb, ~15,000-25,000 ft)</b>. Similar to Band 8 but peaks at a slightly lower altitude, revealing mid-level moisture patterns and atmospheric dynamics.<br><br><span class="k">How to read it:</span> Same brightness convention — bright = moist, dark = dry. The mid-level perspective reveals features at the level where most significant weather develops. Mid-level dry air intrusions can be storm-killers (entrainment weakens updrafts) or storm-enhancers (increased evaporative cooling drives stronger downdrafts and outflows).<br><br><span class="k">Why it matters:</span> Shows the <b>deformation zone</b> between air masses at mid-levels, reveals atmospheric rivers (concentrated moisture plumes), and tracks mid-level circulations. Mid-level dry air interacting with moist convection creates enhanced downdraft potential and severe wind events.<br><br><span class="k">Best for:</span> Atmospheric rivers, mid-level vortices, deformation zones, severe wind potential.',

    'goes-band-10': '<b>Band 10 — Lower-Level Water Vapor (7.34 µm)</b><br><br><span class="k">What it shows:</span> Moisture in the <b>lower-mid troposphere (500-700mb, ~10,000-18,000 ft)</b>. The lowest-peaking water vapor channel, sensitive to moisture closer to the surface than Bands 8 or 9.<br><br><span class="k">How to read it:</span> Bright = moist, dark = dry, same convention. This channel reveals low-level moisture boundaries and the lower portions of weather systems. More sensitive to low/mid-level clouds than the upper WV channels.<br><br><span class="k">Why it matters:</span> Reveals <b>low-level moisture convergence zones</b> where convective initiation is most likely. Also shows the warm conveyor belt in extratropical cyclones — the primary precipitation-producing airstream. The evolution of moisture at this level directly correlates with surface precipitation. Dry air at this level indicates capping and convective inhibition.<br><br><span class="k">Best for:</span> Moisture boundaries, convective initiation, warm conveyor belts, low-level jets.',

    'goes-band-11': '<b>Band 11 — Cloud-Top Phase (8.44 µm)</b><br><br><span class="k">What it shows:</span> An IR window channel particularly sensitive to <b>cloud thermodynamic phase</b>. The difference between Band 11 and Band 14 brightness temperatures varies systematically between liquid and ice clouds due to differences in absorption/emission at these wavelengths.<br><br><span class="k">How to read it:</span> Standard IR brightness temperature display — brighter = colder cloud tops = higher altitude. The primary value is in multi-channel combinations: the 8.4µm-11.2µm brightness temperature difference cleanly separates liquid from ice clouds.<br><br><span class="k">Why it matters:</span> Critical for <b>automated cloud phase retrievals</b> used in aviation icing forecasts, global cloud property databases, and climate monitoring. Supercooled liquid water at high altitudes (glaciation failure) is one of the most dangerous icing scenarios for aircraft.<br><br><span class="k">Best for:</span> Cloud phase retrieval, icing hazards, climate cloud analysis.',

    'goes-band-12': '<b>Band 12 — Ozone (9.61 µm)</b><br><br><span class="k">What it shows:</span> Atmospheric ozone absorption, which peaks in the <b>stratosphere and upper troposphere</b>. This channel detects total column ozone and stratospheric dynamics. Low ozone = stratospheric intrusions bringing dry, high-PV (potential vorticity) air downward.<br><br><span class="k">How to read it:</span> Differences between Band 12 and clean window channels (13, 14) highlight ozone anomalies. Low ozone regions correspond to <b>tropopause folds</b> where stratospheric air descends along the jet stream.<br><br><span class="k">Why it matters:</span> Tropopause folds and stratospheric intrusions are <b>powerful cyclogenesis triggers</b>. High potential vorticity air descending from the stratosphere induces surface pressure falls and spin-up of surface lows. Tracking ozone anomalies is a direct way to identify these features. Also monitors the ozone layer itself for UV protection assessment.<br><br><span class="k">Best for:</span> Tropopause analysis, cyclogenesis, stratospheric intrusions, ozone monitoring.',

    'goes-band-13': '<b>Band 13 — Clean IR Window (10.33 µm)</b><br><br><span class="k">What it shows:</span> The <b>primary infrared channel</b> for cloud-top temperature measurement. "Clean" means this window has minimal atmospheric absorption — what you see is the actual temperature of the cloud top (or surface if clear).<br><br><span class="k">How to read it:</span> Standard enhanced IR: <b>white/cold</b> = high cloud tops (thunderstorms, cirrus). <b>Gray</b> = mid-level clouds. <b>Dark/warm</b> = low clouds or clear sky. Enhanced color curves highlight specific temperature thresholds: overshooting tops appear as coldest pixels (often colder than −70°C / −94°F).<br><br><span class="k">Why it matters:</span> The <b>workhorse IR channel</b> — works 24/7, provides quantitative cloud-top temperatures. Cloud-top temp correlates directly to cloud height: colder = taller = stronger updraft. Temperatures below −60°C indicate deep convection. Below −80°C indicates possible overshooting tops and severe weather. This is the most-used channel for nighttime storm tracking.<br><br><span class="k">Best for:</span> 24/7 storm tracking, cloud-top temperature, nighttime monitoring, quantitative analysis.',

    'goes-band-14': '<b>Band 14 — Longwave IR Window (11.19 µm)</b><br><br><span class="k">What it shows:</span> Another IR window channel, very similar to Band 13 but at a slightly longer wavelength. The small spectral difference makes it critical for <b>split-window techniques</b> when combined with Band 15.<br><br><span class="k">How to read it:</span> Nearly identical to Band 13 in appearance and interpretation. Slight differences in brightness temperature between Bands 13, 14, and 15 are used to retrieve sea surface temperature (SST), low-level moisture, and distinguish thin cirrus from clear sky.<br><br><span class="k">Why it matters:</span> The Band 14-15 <b>split-window difference</b> is the foundation of satellite SST retrievals, which drive ocean/hurricane models. Also reveals <b>low-level moisture gradients</b> — larger split-window differences indicate more boundary layer moisture. Essential for fog prediction models and tropical cyclone intensity estimation.<br><br><span class="k">Best for:</span> SST retrieval, fog detection, moisture gradients, tropical cyclone analysis.',

    'goes-band-15': '<b>Band 15 — Dirty IR Window (12.27 µm)</b><br><br><span class="k">What it shows:</span> An IR window with slightly more water vapor absorption than Bands 13/14 — hence "dirty." The differential absorption between this and the clean windows enables <b>atmospheric correction and surface property retrievals</b>.<br><br><span class="k">How to read it:</span> Visually similar to other IR windows. The key information is in the <b>difference</b> from Bands 13 and 14. Larger differences = more moisture, thin cirrus contamination, or different surface emissivity. Volcanic ash has a distinctive negative split-window signal (Band 14 - Band 15 < 0).<br><br><span class="k">Why it matters:</span> Critical for <b>volcanic ash detection</b> — ash clouds produce a unique "reverse absorption" signature at 12µm vs 11µm that distinguishes them from water/ice clouds. This has saved countless aircraft from flying into invisible ash clouds. Also used in split-window SST algorithms and thin cirrus detection.<br><br><span class="k">Best for:</span> Volcanic ash detection, SST correction, thin cirrus identification, split-window analysis.',

    'goes-band-16': '<b>Band 16 — CO₂ Longwave (13.28 µm)</b><br><br><span class="k">What it shows:</span> CO₂ absorption band sensitive to <b>temperature in the upper troposphere and tropopause region</b>. Because CO₂ is well-mixed, the signal depends primarily on temperature — making this channel a direct <b>tropopause height estimator</b>.<br><br><span class="k">How to read it:</span> Colder brightness temperatures indicate a higher (colder) tropopause. Warmer temperatures = lower tropopause or strong subsidence. The channel effectively "sees" the altitude where CO₂ emission to space occurs, which varies with tropopause height and atmospheric stability.<br><br><span class="k">Why it matters:</span> Tropopause height is a key <b>severe weather parameter</b> — a higher tropopause means more CAPE potential and taller storms. Tropopause depressions (lower height) indicate upper-level troughs and potential vorticity anomalies driving surface cyclogenesis. This channel is also used for <b>cloud-top height retrieval</b> in multi-channel algorithms.<br><br><span class="k">Best for:</span> Tropopause height, cloud-top height retrieval, upper-tropospheric temperature, stability analysis.'
  };

  // Merge GOES band info into radarInfoData (with data source)
  var goesSource = '<br><br><div style="margin-top:8px;padding-top:6px;border-top:1px solid rgba(255,255,255,.06);font-size:.46rem;opacity:.45;"><a href="https://www.star.nesdis.noaa.gov/goes/index.php" target="_blank" rel="noopener" style="color:rgba(120,160,255,.7);">NOAA/NESDIS STAR</a> GOES-R ABI \u00b7 Geostationary orbit 35,786 km \u00b7 CONUS 5-min refresh</div>';
  Object.keys(goesBandInfo).forEach(function(k){ radarInfoData[k] = goesBandInfo[k] + goesSource; });
  Object.keys(productTooltips).forEach(function(k){ radarInfoData[k] = productTooltips[k]; });

  Object.keys(radarInfoData).forEach(function(id){
    var btn = document.getElementById(id);
    if (!btn) return;
    // Make button flex to support the icon on right
    btn.style.display = 'inline-flex';
    btn.style.alignItems = 'center';
    btn.style.gap = '0';
    // Create info icon
    var icon = document.createElement('span');
    icon.className = 'radar-info-icon';
    icon.textContent = '✧';
    icon.addEventListener('click', function(e){
      e.stopPropagation();
      showRadarTooltip(id, icon);
    });
    icon.addEventListener('mouseenter', function(e){
      showRadarTooltip(id, icon);
    });
    btn.appendChild(icon);
  });

  var radarTooltip = document.getElementById('radar-info-tooltip');
  var radarTooltipTimer = null;

  // ── DYNAMIC LIVE DATA INJECTION FOR TOOLTIPS ──
  function injectLiveModelState(id, content) {
    // Extract model key from id: 'fcast-model-hrrr' → 'hrrr'
    var modelKey = id.replace('fcast-model-', '');
    var isActiveModel = fcastState && fcastState.model === modelKey;

    var live = '<div style="background:rgba(255,255,255,.08);border-radius:8px;padding:8px 10px;margin-bottom:10px;border-left:3px solid ';

    if (isActiveModel) {
      // This model is currently selected — show full status
      var cycle = fcastState.cycle || '?';
      var idx = fcastState.idx || 0;
      var allFhrs = fcastState.allFhrs || [];
      var currentFhr = allFhrs[idx] || '?';
      var fhrNum = parseInt(currentFhr, 10);
      var totalFrames = allFhrs.length;
      var maxFhr = allFhrs.length > 0 ? parseInt(allFhrs[allFhrs.length - 1], 10) : '?';

      // Calculate init time in local
      var cycleH = parseInt(cycle, 10);
      var now = new Date();
      var todayUTC = new Date(Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate(), cycleH, 0, 0));
      if (todayUTC > now) todayUTC.setUTCDate(todayUTC.getUTCDate() - 1);
      var initLocal = todayUTC.toLocaleString('en-US', {timeZone: LOCATION.tz, hour:'numeric', minute:'2-digit', hour12:true, month:'short', day:'numeric'});
      var hoursAgo = Math.round((now - todayUTC) / 3600000);

      // Valid time
      var validTime = new Date(todayUTC.getTime() + fhrNum * 3600000);
      var validLocal = validTime.toLocaleString('en-US', {timeZone: LOCATION.tz, weekday:'short', hour:'numeric', minute:'2-digit', hour12:true, month:'short', day:'numeric'});

      // Model freshness assessment  
      var freshColor = '#4f8';
      var freshLabel = 'FRESH';
      if (hoursAgo >= 10) { freshColor = '#f66'; freshLabel = 'STALE'; }
      else if (hoursAgo >= 6) { freshColor = '#f90'; freshLabel = 'AGING'; }

      // Forecast hour quality (model-specific)
      var qualColor = '#4f8';
      var qualLabel = 'Sweet spot';
      if (modelKey === 'hrrr') {
        if (fhrNum > 36) { qualColor = '#f66'; qualLabel = 'Low confidence'; }
        else if (fhrNum > 18) { qualColor = '#f90'; qualLabel = 'Degrading skill'; }
        else { qualLabel = 'Peak accuracy (radar-assimilated)'; }
      } else if (modelKey === 'nam' || modelKey === 'nam_hires') {
        if (fhrNum > 60) { qualColor = '#f90'; qualLabel = 'Extended range'; }
        else if (fhrNum > 36) { qualColor = '#cc0'; qualLabel = 'Good'; }
        else { qualLabel = 'Best performance window'; }
      } else if (modelKey === 'gfs' || modelKey === 'gefs') {
        if (fhrNum > 240) { qualColor = '#f66'; qualLabel = 'Low confidence — pattern only'; }
        else if (fhrNum > 168) { qualColor = '#f90'; qualLabel = 'Moderate confidence'; }
        else if (fhrNum > 72) { qualColor = '#cc0'; qualLabel = 'Good for synoptic pattern'; }
        else { qualLabel = 'Best accuracy range'; }
      } else if (modelKey === 'href') {
        if (fhrNum > 36) { qualColor = '#f90'; qualLabel = 'Extended'; }
        else { qualLabel = 'Peak ensemble value'; }
      } else if (modelKey === 'nbm') {
        if (fhrNum > 168) { qualColor = '#f90'; qualLabel = 'Extended blend'; }
        else { qualLabel = 'Calibrated guidance'; }
      }

      live += '#4a9;">';
      live += '<div style="font-weight:700;font-size:.62rem;color:#4a9;margin-bottom:5px;">📡 ACTIVE — VIEWING NOW</div>';
      live += '<div style="display:grid;grid-template-columns:auto 1fr;gap:2px 8px;font-size:.52rem;">';
      live += '<span style="opacity:.7;">Init:</span><span>' + cycle + 'Z · ' + initLocal + ' <span style="color:' + freshColor + ';">(' + hoursAgo + 'h ago · ' + freshLabel + ')</span></span>';
      live += '<span style="opacity:.7;">Frame:</span><span>Hour +' + fhrNum + ' of ' + maxFhr + ' (frame ' + (idx + 1) + '/' + totalFrames + ')</span>';
      live += '<span style="opacity:.7;">Valid:</span><span>' + validLocal + '</span>';
      live += '<span style="opacity:.7;">Skill:</span><span style="color:' + qualColor + ';">' + qualLabel + '</span>';
      live += '</div>';
      live += '</div>';
    } else {
      // Not the active model — show comparison note
      var activeModelName = {gfs:'GFS', nam:'NAM', nam_hires:'NAM 3km', hrrr:'HRRR', href:'HREF', nbm:'NBM', gefs:'GEFS'};
      var thisName = activeModelName[modelKey] || modelKey.toUpperCase();
      var activeName = fcastState ? (activeModelName[fcastState.model] || fcastState.model.toUpperCase()) : '?';

      live += 'rgba(100,120,160,.5);">';
      live += '<div style="font-size:.52rem;opacity:.8;">Currently viewing <b>' + activeName + '</b>. Click to switch to ' + thisName + '.</div>';
      live += '</div>';
    }

    // Insert after the first <b>...</b> title + first <br><br>
    var firstBreak = content.indexOf('<br><br>');
    if (firstBreak > 0) {
      return content.substring(0, firstBreak + 8) + live + content.substring(firstBreak + 8);
    }
    return live + content;
  }

  // ── LIVE PRODUCT CONTEXT INJECTION FOR PRODUCT TOOLTIPS ──
  function injectLiveProductContext(id, content) {
    var wx = window._wxCurrent;
    var alerts = window._nwsAlerts || [];
    var sw = window._swData || {};
    if (!wx) return content;

    var live = '';
    var S = function(l){ return '<div style="background:rgba(255,255,255,.08);border-radius:8px;padding:8px 10px;margin-bottom:10px;border-left:3px solid ' + l; };
    var E = '</div>';
    var G = '<div style="display:grid;grid-template-columns:auto 1fr;gap:2px 8px;font-size:.52rem;">';
    var GE = '</div>';
    var XS = '<div style="background:rgba(120,160,255,.06);border-radius:6px;padding:6px 8px;margin-top:6px;border-left:2px solid rgba(120,160,255,.4);font-size:.50rem;color:rgba(255,255,255,.85);">';

    // Cross-reference builder: synthesizes all available data into unified insight lines
    // Each product appends its own, but we build shared assessments here
    var geoStorm = sw.kp != null && sw.kp >= 5;
    var geoActive = sw.kp != null && sw.kp >= 4;
    var bzSouth = sw.bz != null && sw.bz <= -5;
    var highSolarWind = sw.speed != null && sw.speed > 500;
    var lat = LOCATION ? LOCATION.lat : 40;
    var auroraVisLat = sw.kp != null ? (sw.kp >= 8 ? 35 : sw.kp >= 6 ? 42 : sw.kp >= 5 ? 48 : sw.kp >= 4 ? 55 : 65) : 99;
    var canSeeAurora = lat >= auroraVisLat - 5; // within range
    var clearSky = wx.cloudCover != null && wx.cloudCover < 30;
    var overcast = wx.cloudCover != null && wx.cloudCover >= 80;
    var goodVis = wx.visibility != null && wx.visibility > 8000;
    var isDark = (function(){ if (!wx.sunrise || !wx.sunset) return null; var now = new Date(); var sr = new Date(wx.sunrise); var ss = new Date(wx.sunset); return now < sr || now > ss; })();
    var severeWx = wx.precip > 0.5 || (wx.gust != null && wx.gust >= 58) || (wx.weatherCode >= 95);
    // ── UPGRADED: Use real CAPE when available, fall back to proxy ──
    var realCAPE = wx.cape != null && wx.cape > 0;
    var convectiveEnv = realCAPE ? wx.cape >= 500 : (wx.dewpoint != null && wx.temp != null && wx.dewpoint >= 55 && wx.temp >= 75);
    var strongConvective = realCAPE ? wx.cape >= 2000 : (wx.dewpoint >= 60 && wx.temp >= 85);
    var extremeConvective = realCAPE ? wx.cape >= 3500 : (wx.dewpoint >= 65 && wx.temp >= 90);
    var strongShear = wx.gust != null && wx.gust >= 35;
    var winterPrecip = wx.temp != null && wx.temp <= 34 && wx.precipProb > 30;
    var fogRisk = wx.temp != null && wx.dewpoint != null && (wx.temp - wx.dewpoint) <= 3 && (wx.wind == null || wx.wind < 8);
    // ── NEW: Frontal detection ──
    var frontalSig = wx.frontalSignature || null;
    var frontalApproaching = frontalSig === 'cold_front_approaching' || frontalSig === 'warm_front_approaching';
    var frontalPassage = frontalSig === 'cold_front_passage' || frontalSig === 'warm_front_passage';
    // ── NEW: AQI cross-reference ──
    var aq = window._aqData || {};
    var aqCurrent = aq.current || {};
    var pm25 = aqCurrent.pm2_5 != null ? aqCurrent.pm2_5 : null;
    var usAqi = aqCurrent.us_aqi != null ? aqCurrent.us_aqi : null;
