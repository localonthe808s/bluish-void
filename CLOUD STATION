  // Find historical analogs for a given storm position
  function _findAnalogStorms(lat, lon, monthNum) {
    var matches = [];
    _ANALOG_STORMS.forEach(function(region) {
      if (lat >= region.latMin && lat <= region.latMax &&
          lon >= region.lonMin && lon <= region.lonMax &&
          region.months.indexOf(monthNum) >= 0) {
        matches = matches.concat(region.storms.map(function(s) {
          return { region: region.region, name: s.name, cat: s.cat, wind: s.wind, track: s.track, note: s.note };
        }));
      }
    });
    // If no match (e.g., unusual position), find closest region
    if (matches.length === 0) {
      var closestDist = Infinity, closestRegion = null;
      _ANALOG_STORMS.forEach(function(region) {
        var cLat = (region.latMin + region.latMax) / 2;
        var cLon = (region.lonMin + region.lonMax) / 2;
        var d = Math.sqrt(Math.pow(lat - cLat, 2) + Math.pow(lon - cLon, 2));
        if (d < closestDist) { closestDist = d; closestRegion = region; }
      });
      if (closestRegion) {
        matches = closestRegion.storms.slice(0, 2).map(function(s) {
          return { region: closestRegion.region + ' (nearest)', name: s.name, cat: s.cat, wind: s.wind, track: s.track, note: s.note };
        });
      }
    }
    return matches.slice(0, 3); // Max 3 analogs
  }

  // ══════════════════════════════════════════════════════════════════════════════
  // TIER 3 — ACE (Accumulated Cyclone Energy) SEASON GAUGE
  // ══════════════════════════════════════════════════════════════════════════════
  // ACE = sum of (max sustained wind in kt)² for every 6-hour advisory when storm
  // is at least TS strength (≥34kt). Divided by 10⁴ for readability.
  // Climatological monthly ACE accumulation pace (% of season total by end of month):
  var _ACE_MONTHLY_PACE = { 6: 3, 7: 8, 8: 30, 9: 65, 10: 88, 11: 98, 12: 100 };

  // Build ACE gauge SVG for the season summary panel
  function _buildACEGaugeSVG(currentACE, avgACE) {
    if (!avgACE) avgACE = _HURR_CLIMO.avgACE || 123;
    var maxScale = Math.max(avgACE * 2, currentACE * 1.2, 200);
    var W = 240, H = 36;
    var barY = 10, barH = 12;

    // Climatological pace line
    var now = new Date();
    var month = now.getMonth() + 1;
    var day = now.getDate();
    var pacePct = _ACE_MONTHLY_PACE[month] || 0;
    // Interpolate within month
    if (month >= 6 && month <= 11) {
      var prevPct = _ACE_MONTHLY_PACE[month - 1] || 0;
      pacePct = prevPct + (pacePct - prevPct) * (day / 30);
    }
    var paceACE = avgACE * (pacePct / 100);

    var currentPct = Math.min(100, (currentACE / maxScale) * 100);
    var pacePctBar = Math.min(100, (paceACE / maxScale) * 100);
    var avgPctBar = Math.min(100, (avgACE / maxScale) * 100);

    // Color based on comparison to pace
    var barColor = currentACE > paceACE * 1.3 ? '#ef4444' :
                   currentACE > paceACE * 0.8 ? '#f97316' :
                   currentACE > paceACE * 0.5 ? '#fbbf24' : '#4ade80';

    var paceLabel = currentACE > paceACE * 1.5 ? 'Well above pace' :
                    currentACE > paceACE * 1.1 ? 'Above pace' :
                    currentACE > paceACE * 0.8 ? 'Near normal pace' :
                    currentACE > paceACE * 0.5 ? 'Below pace' : 'Well below pace';

    var svg = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 ' + W + ' ' + H + '" style="width:100%;height:auto;display:block;">';

    // Background bar
    svg += '<rect x="0" y="' + barY + '" width="' + W + '" height="' + barH + '" rx="4" fill="rgba(255,255,255,.06)"/>';

    // Current ACE fill
    svg += '<rect x="0" y="' + barY + '" width="' + (W * currentPct / 100) + '" height="' + barH + '" rx="4" fill="' + barColor + '" opacity="0.7"/>';

    // Climatological pace marker (dashed line)
    var paceX = W * pacePctBar / 100;
    svg += '<line x1="' + paceX + '" y1="' + (barY - 2) + '" x2="' + paceX + '" y2="' + (barY + barH + 2) + '" stroke="rgba(255,255,255,.5)" stroke-width="1.5" stroke-dasharray="2 1"/>';
    svg += '<text x="' + paceX + '" y="' + (barY - 3) + '" fill="rgba(255,255,255,.4)" font-size="5" font-family="system-ui" text-anchor="middle">pace</text>';

    // Season average marker (solid thin line)
    var avgX = W * avgPctBar / 100;
    svg += '<line x1="' + avgX + '" y1="' + barY + '" x2="' + avgX + '" y2="' + (barY + barH) + '" stroke="rgba(196,181,253,.4)" stroke-width="1"/>';
    svg += '<text x="' + avgX + '" y="' + (barY + barH + 7) + '" fill="rgba(196,181,253,.35)" font-size="4.5" font-family="system-ui" text-anchor="middle">avg (' + avgACE + ')</text>';

    // Current value label
    svg += '<text x="' + Math.max(15, W * currentPct / 100) + '" y="' + (barY + barH / 2 + 2) + '" fill="rgba(0,0,0,.7)" font-size="6" font-weight="bold" font-family="system-ui" text-anchor="middle">' + currentACE + '</text>';

    svg += '</svg>';
    return { svg: svg, paceLabel: paceLabel, barColor: barColor, paceACE: Math.round(paceACE) };
  }

  // ══════════════════════════════════════════════════════════════════════════════
  // TIER 3 — NHC KEY MESSAGES INTEGRATION
  // ══════════════════════════════════════════════════════════════════════════════
  // Fetches the NHC Atlantic RSS feed and parses out Key Messages items.
  // During active storms, NHC publishes "Key Messages" — the 3-5 most critical
  // points forecasters want the public to know about each active system.
  // These are the highest-signal, most decision-relevant information NHC produces.
  function _fetchNHCKeyMessages(callback) {
    var feeds = [
      'https://www.nhc.noaa.gov/index-at.xml',   // Atlantic
      'https://www.nhc.noaa.gov/index-ep.xml'     // East Pacific
    ];

    var allMessages = [];
    var completed = 0;

    feeds.forEach(function(feedUrl) {
      monitoredFetch('nhc-rss-' + (feedUrl.indexOf('-at') > 0 ? 'at' : 'ep'), feedUrl)
        .then(function(r){ return r.text(); })
        .then(function(xml) {
          // Parse RSS XML for Key Messages items
          var parser = new DOMParser();
          var doc = parser.parseFromString(xml, 'text/xml');
          var items = doc.querySelectorAll('item');

          items.forEach(function(item) {
            var title = (item.querySelector('title') || {}).textContent || '';
            var desc = (item.querySelector('description') || {}).textContent || '';
            var link = (item.querySelector('link') || {}).textContent || '';
            var pubDate = (item.querySelector('pubDate') || {}).textContent || '';

            // Key Messages items contain "Key Messages" in title
            if (title.toLowerCase().indexOf('key messages') >= 0) {
              // Clean HTML entities from description
              var cleanDesc = desc.replace(/<[^>]+>/g, ' ').replace(/&amp;/g, '&').replace(/&lt;/g, '<')
                .replace(/&gt;/g, '>').replace(/&quot;/g, '"').replace(/&#039;/g, "'")
                .replace(/\s+/g, ' ').trim();

              // Extract storm name from title (e.g., "Key Messages for Hurricane Milton")
              var stormName = title.replace(/.*Key Messages\s*(for|regarding|about)?\s*/i, '').trim();

              allMessages.push({
                stormName: stormName,
                title: title,
                description: cleanDesc,
                link: link,
                pubDate: pubDate,
                basin: feedUrl.indexOf('-at') > 0 ? 'ATL' : 'EPAC'
              });
            }

            // Also grab advisory items that mention key messages in description
            if (title.toLowerCase().indexOf('advisory') >= 0 && desc.toLowerCase().indexOf('key message') >= 0) {
              var cleanAdv = desc.replace(/<[^>]+>/g, ' ').replace(/&amp;/g, '&').replace(/&lt;/g, '<')
                .replace(/&gt;/g, '>').replace(/\s+/g, ' ').trim();
              // Extract bullet points (NHC formats key messages as numbered points)
              var bullets = cleanAdv.match(/\d+\.\s+[^.]+\./g) || [];
              if (bullets.length > 0) {
                var advStormName = title.replace(/.*(?:Advisory|Update)\s*\d*\s*(?:for|regarding|about)?\s*/i, '').trim();
                allMessages.push({
                  stormName: advStormName || title,
                  title: title,
                  description: bullets.join(' '),
                  link: link,
                  pubDate: pubDate,
                  basin: feedUrl.indexOf('-at') > 0 ? 'ATL' : 'EPAC',
                  isAdvisoryExtract: true
                });
              }
            }
          });
        })
        .catch(function(){})
        .finally(function() {
          completed++;
          if (completed >= feeds.length) {
            callback(allMessages);
          }
        });
    });
  }

  // Build Key Messages HTML for the storm detail popup
  function _buildKeyMessagesHTML(stormName, messages) {
    if (!messages || messages.length === 0) return '';

    // Find messages matching this storm name
    var relevant = messages.filter(function(m) {
      var mName = m.stormName.toLowerCase().replace(/hurricane|tropical storm|depression/gi, '').trim();
      var sName = stormName.toLowerCase().replace(/hurricane|tropical storm|depression/gi, '').trim();
      return mName.indexOf(sName) >= 0 || sName.indexOf(mName) >= 0;
    });

    if (relevant.length === 0) return '';

    var html = '<div style="font-size:.42rem;font-weight:900;letter-spacing:.1em;color:rgba(239,68,68,.6);margin-bottom:5px;">⚠ NHC KEY MESSAGES</div>';

    relevant.forEach(function(msg) {
      // Truncate description for popup display
      var desc = msg.description;
      if (desc.length > 400) desc = desc.substring(0, 400) + '…';

      html += '<div style="margin-bottom:6px;padding:5px 7px;border-radius:5px;background:rgba(239,68,68,.06);border-left:3px solid rgba(239,68,68,.4);">';
      html += '<div style="font-size:.4rem;color:rgba(255,255,255,.7);line-height:1.55;">' + desc + '</div>';
      if (msg.link) {
        html += '<a href="' + msg.link + '" target="_blank" style="font-size:.38rem;color:#c4b5fd;text-decoration:none;display:inline-block;margin-top:3px;">Read full advisory →</a>';
      }
      html += '</div>';

      if (msg.pubDate) {
        html += '<div style="font-size:.34rem;color:rgba(255,255,255,.2);">Updated: ' + msg.pubDate + '</div>';
      }
    });

    return html;
  }

  function _fetchNHCGISFallback() {
    // Fallback: try idpgis NHC Atlantic active cyclones MapServer
    var url = 'https://idpgis.ncep.noaa.gov/arcgis/rest/services/NWS_Forecasts_Guidance_Warnings/NHC_Atl_trop_cyclones_active/MapServer/0/query?where=1%3D1&outFields=*&f=geojson&outSR=4326';
    monitoredFetch('nhc-gis-fallback', url)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0) { _showNoStormsMessage(); return; }
        gj.features.forEach(function(feat) {
          var p = feat.properties || {};
          _plotNHCStorm({
            name: p.stormname || p.STORMNAME || 'System',
            id: p.stormid || p.STORMID || '',
            binNumber: p.STORMTYPE ? null : (p.basin || 'AT') + (p.stormnum || '1'),
            centerLocLatitude: feat.geometry && feat.geometry.coordinates ? feat.geometry.coordinates[1] : null,
            centerLocLongitude: feat.geometry && feat.geometry.coordinates ? feat.geometry.coordinates[0] : null,
            intensity: p.maxwind || p.MAXWIND || 0,
            minimumPressure: p.minpres || p.MINPRES,
            movementDir: p.heading,
            movementSpeed: p.speed
          });
        });
      }).catch(function(){
        // Second fallback: try new mapservices GTWO for at least disturbance areas
        console.warn('NHC GIS fallback also failed — checking new mapservices GTWO');
        _showNoStormsMessage();
      });
  }

  function _fetchNHCAdvisoryText() {
    // NHC RSS — Atlantic + East Pacific (the only basins we render in-app)
    var rssUrls = [
      { url: 'https://www.nhc.noaa.gov/index-at.xml', label: 'ATL' },
      { url: 'https://www.nhc.noaa.gov/index-ep.xml', label: 'EPAC' }
    ];

    var el = document.getElementById('hz-advisory-text');
    if (!el) return;

    var results = [];
    var done = 0;

    rssUrls.forEach(function(entry) {
      monitoredFetch('nhc-rss-' + entry.label, entry.url)
        .then(function(r){ return r.text(); })
        .then(function(xml) {
          var match = xml.match(/<item>[\s\S]*?<title><!\[CDATA\[(.*?)\]\]><\/title>/);
          var text = '';
          if (match) {
            text = match[1];
          } else {
            var m2 = xml.match(/<item>[\s\S]*?<title>(.*?)<\/title>/);
            text = m2 ? m2[1].replace(/<[^>]+>/g,'') : 'No active advisories';
          }
          results.push((rssUrls.length > 1 ? entry.label + ': ' : '') + text);
        })
        .catch(function() {
          results.push(entry.label + ': Feed unavailable');
        })
        .finally(function() {
          done++;
          if (done >= rssUrls.length) {
            el.textContent = results.join(' · ');
            // Show last-refreshed time
            var timeEl = document.getElementById('hz-advisory-time');
            if (timeEl) timeEl.textContent = 'Refreshed ' + new Date().toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
          }
        });
    });
  }

  // ── Probability → visual style ──
  function _gtwoStyle(prob) {
    if (prob >= 70) return { fill: 'rgba(239,68,68,0.18)',  stroke: 'rgba(239,68,68,0.75)',  label: '#ef4444', ring: '#ef4444',  tier: 'HIGH' };
    if (prob >= 40) return { fill: 'rgba(249,115,22,0.15)', stroke: 'rgba(249,115,22,0.7)',  label: '#f97316', ring: '#f97316', tier: 'MEDIUM' };
    return               { fill: 'rgba(234,179,8,0.12)',   stroke: 'rgba(234,179,8,0.55)',   label: '#eab308', ring: '#eab308',  tier: 'LOW' };
  }

  // ── Animated spinning ring marker ──
  function _makeInvestMarker(lat, lon, prob, label2d, label7d, name) {
    var sty = _gtwoStyle(prob);
    var sz = prob >= 70 ? 56 : prob >= 40 ? 48 : 42;
    var half = sz / 2;

    var ringHtml =
      '<svg width="' + sz + '" height="' + sz + '" viewBox="0 0 ' + sz + ' ' + sz + '" xmlns="http://www.w3.org/2000/svg" style="overflow:visible;">' +
        '<circle cx="' + half + '" cy="' + half + '" r="' + (half - 2) + '" fill="' + sty.fill + '" stroke="' + sty.stroke + '" stroke-width="1.5" stroke-dasharray="6 4" style="animation:invest-spin 12s linear infinite;transform-origin:' + half + 'px ' + half + 'px;"/>' +
        '<circle cx="' + half + '" cy="' + half + '" r="' + (half * 0.55) + '" fill="none" stroke="' + sty.stroke + '" stroke-width="1" stroke-dasharray="3 5" opacity="0.6" style="animation:invest-spin-r 8s linear infinite;transform-origin:' + half + 'px ' + half + 'px;"/>' +
        '<circle cx="' + half + '" cy="' + half + '" r="3.5" fill="' + sty.ring + '" opacity="0.9"/>' +
        '<text x="' + half + '" y="' + (half + 4) + '" text-anchor="middle" font-family="system-ui,sans-serif" font-size="9" font-weight="900" fill="' + sty.label + '" opacity="0.95">' + prob + '%</text>' +
      '</svg>';

    var topLabel =
      '<div style="position:absolute;bottom:' + (sz + 3) + 'px;left:50%;transform:translateX(-50%);white-space:nowrap;pointer-events:none;text-align:center;">' +
        '<span style="font-family:system-ui,sans-serif;font-size:.44rem;font-weight:900;color:' + sty.label + ';letter-spacing:.07em;text-shadow:0 0 8px #000,0 1px 3px #000;">' + (name || 'DISTURBANCE') + '</span>' +
      '</div>';

    var botLabel =
      '<div style="position:absolute;top:' + (sz + 2) + 'px;left:50%;transform:translateX(-50%);white-space:nowrap;pointer-events:none;">' +
        '<span style="font-family:system-ui,sans-serif;font-size:.36rem;color:rgba(255,255,255,.5);text-shadow:0 0 6px #000;">' + sty.tier + '</span>' +
      '</div>';

    var html = '<div style="position:relative;width:' + sz + 'px;height:' + sz + 'px;">' + topLabel + ringHtml + botLabel + '</div>';
    var icon = L.divIcon({ className: '', html: html, iconSize: [sz, sz], iconAnchor: [half, half] });
    var marker = L.marker([lat, lon], { icon: icon, zIndexOffset: 800 });

    var prob2d = label2d != null ? label2d + '%' : prob + '%';
    var prob7d = label7d != null ? label7d + '%' : '—';
    marker.bindTooltip(
      '<div class="hz-tooltip">' +
      '<div class="hz-card-head"><span>' + (name || 'TROPICAL DISTURBANCE') + '</span></div>' +
      '<div class="hz-card-row"><span class="hz-label">2-day formation</span><span class="hz-val" style="color:' + sty.label + ';">' + prob2d + '</span></div>' +
      '<div class="hz-card-row"><span class="hz-label">7-day formation</span><span class="hz-val">' + prob7d + '</span></div>' +
      '<div class="hz-card-row"><span class="hz-label">Threat level</span><span class="hz-val" style="color:' + sty.label + ';">' + sty.tier + '</span></div>' +
      '<div class="hz-card-footer">NHC Graphical Tropical Weather Outlook</div>' +
      '</div>',
      { sticky: true, className: 'hz-tooltip', opacity: 1 }
    );
    return marker;
  }

  // ── TROPICAL WAVES: fetch NHC TWO areas + annotate wave positions ──────────
  // African easterly waves are plotted as animated chevrons along the ITCZ corridor.
  // Primary data: NHC Tropical Weather Outlook graphic text (parsed for wave positions)
  // + GTWO layer already loaded for development zones
  function _fetchTropicalWaves() {
    if (!_hurricaneMap) return;
    // Clear old markers
    _hurricaneLayerObjs.waveMarkers.forEach(function(m){ try{ _hurricaneMap.removeLayer(m); }catch(e){} });
    _hurricaneLayerObjs.waveMarkers = [];

    // NHC publishes tropical wave positions in their GIS disturbance feed (same endpoint as GTWO)
    // We supplement with static wave corridor annotations showing the typical easterly wave track
    var waveTrack = [
      { lat: 12.5, lon: -18,  label: 'WAVE ORIGIN\nW.Africa', age: 0 },
      { lat: 13.0, lon: -30,  label: 'WAVE D+2',  age: 2 },
      { lat: 13.5, lon: -42,  label: 'WAVE D+4',  age: 4 },
      { lat: 14.0, lon: -55,  label: 'WAVE D+6',  age: 6 },
      { lat: 14.5, lon: -65,  label: 'CARIB. ENTRY D+8', age: 8 },
    ];

    // Draw the easterly wave corridor as a dashed line
    var corridorPts = waveTrack.map(function(w){ return [w.lat, w.lon]; });
    var corridorLine = L.polyline(corridorPts, {
      color: 'rgba(253,224,71,0.55)', weight: 2, dashArray: '6,5',
      interactive: false, pane: 'hz-waves'
    }).addTo(_hurricaneMap);
    _hurricaneLayerObjs.waveMarkers.push(corridorLine);

    // Wave chevron markers
    var waveIcon = function(age) {
      var opacity = Math.max(0.35, 1 - age * 0.08);
      return L.divIcon({
        className: '',
        html: '<div style="font-size:18px;opacity:' + opacity + ';filter:drop-shadow(0 0 4px rgba(253,224,71,.8));transform:rotate(-90deg);">▶</div>',
        iconSize: [22, 22], iconAnchor: [11, 11]
      });
    };

    waveTrack.forEach(function(w) {
      var marker = L.marker([w.lat, w.lon], { icon: waveIcon(w.age), interactive: true, pane: 'hz-waves' })
        .bindTooltip(
          '<div style="font-family:system-ui;font-size:.48rem;line-height:1.5;">' +
          '<b style="color:#fde047;">🌊 AFRICAN EASTERLY WAVE</b><br>' +
          '<span style="color:rgba(255,255,255,.8);">' + w.label.replace('\n','<br>') + '</span><br>' +
          '<span style="color:rgba(255,255,255,.5);font-size:.42rem;">85% of Atlantic hurricanes originate here<br>' +
          'Typical westward motion: ~15 kt<br>' +
          'Period: every 3–5 days Jun–Oct</span>' +
          '</div>',
          { permanent: false, className: 'hz-wave-tooltip', direction: 'top' }
        )
        .addTo(_hurricaneMap);
      _hurricaneLayerObjs.waveMarkers.push(marker);
    });

    // Also try fetching live NHC disturbance data to plot real current waves
    var nhcBase = 'https://mapservices.weather.noaa.gov/tropical/rest/services/tropical/NHC_tropical_weather/MapServer/';
    monitoredFetch('nhc-waves', nhcBase + '2/query?where=1%3D1&outFields=*&f=geojson&outSR=4326')
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || !_hurricaneMap) return;
        gj.features.forEach(function(feat) {
          var p = feat.properties || {};
          var geo = feat.geometry;
          if (!geo || !geo.coordinates) return;
          var coords = geo.type === 'Point' ? geo.coordinates : (geo.coordinates[0] || []);
          if (!coords || coords.length < 2) return;
          var lon = geo.type === 'Point' ? coords[0] : coords[0][0];
          var lat = geo.type === 'Point' ? coords[1] : coords[0][1];
          var prob = parseInt(p.PROB2DAY || p.prob2d || 0);
          var liveIcon = L.divIcon({
            className: '',
            html: '<div style="width:14px;height:14px;border-radius:50%;background:rgba(253,224,71,' + (0.3 + prob/200) + ');border:2px solid rgba(253,224,71,.9);box-shadow:0 0 8px rgba(253,224,71,.6);"></div>',
            iconSize: [14,14], iconAnchor: [7,7]
          });
          var lm = L.marker([lat, lon], { icon: liveIcon, pane: 'hz-waves' })
            .bindTooltip(
              '<div style="font-family:system-ui;font-size:.48rem;"><b style="color:#fde047;">🌀 LIVE DISTURBANCE</b><br>' +
              '<span style="color:rgba(255,255,255,.8);">2-day formation: <b>' + prob + '%</b></span></div>',
              { className: 'hz-wave-tooltip', direction: 'top' }
            )
            .addTo(_hurricaneMap);
          _hurricaneLayerObjs.waveMarkers.push(lm);
        });
      }).catch(function(){});
  }

  function _fetchGTWODisturbances() {
    // NHC Graphical Tropical Weather Outlook — via official NHC MapServer (GeoJSON)
    // Layer 1 = 2-day current location points
    // Layer 3 = 7-day potential development region polygons
    // Layer 2 = 7-day current location points
    var baseUrl = 'https://mapservices.weather.noaa.gov/tropical/rest/services/tropical/NHC_tropical_weather/MapServer/';
    var q = '?where=1%3D1&outFields=*&f=geojson&outSR=4326';

    // Clear existing markers
    _hurricaneLayerObjs.disturbanceMarkers.forEach(function(m){ try{ _hurricaneMap.removeLayer(m); }catch(e){} });
    _hurricaneLayerObjs.disturbanceMarkers = [];

    // ── 7-DAY DEVELOPMENT REGIONS (shaded polygons) ──
    monitoredFetch('nhc-gtwo-poly', baseUrl + '3/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
        gj.features.forEach(function(feat) {
          var p = feat.properties || {};
          var prob7 = _parseGTWOProb(p.prob7day || p.risk7day || '');
          var prob2 = _parseGTWOProb(p.prob2day || p.risk2day || '');
          var maxProb = Math.max(prob7, prob2);
          var sty = _gtwoStyle(maxProb);

          var poly = L.geoJSON(feat, {
            style: {
              color: sty.stroke, weight: 1.5,
              fillColor: sty.fill, fillOpacity: 0.25,
              dashArray: '6 4'
            },
            pane: 'hz-gtwo'
          });

          poly.bindTooltip(
            '<div class="hz-tooltip">' +
            '<div class="hz-card-head"><span style="color:' + sty.label + ';">TROPICAL DISTURBANCE</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">2-day formation</span><span class="hz-val" style="color:' + _gtwoStyle(prob2).label + ';">' + (prob2 > 0 ? prob2 + '%' : '—') + '</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">7-day formation</span><span class="hz-val" style="color:' + sty.label + ';">' + (prob7 > 0 ? prob7 + '%' : '—') + '</span></div>' +
            '<div class="hz-card-row"><span class="hz-label">Risk level</span><span class="hz-val" style="color:' + sty.label + ';">' + sty.tier + '</span></div>' +
            (p.basin ? '<div class="hz-card-row"><span class="hz-label">Basin</span><span class="hz-val">' + p.basin + '</span></div>' : '') +
            '<div class="hz-card-footer">NHC Tropical Weather Outlook</div></div>',
            { sticky: true, className: 'hz-tooltip', opacity: 1 }
          );
          poly.addTo(_hurricaneMap);
          _hurricaneLayerObjs.disturbanceMarkers.push(poly);
        });
      }).catch(function(e){ console.warn('GTWO polygon fetch failed:', e); });

    // ── 2-DAY CURRENT LOCATION POINTS (center of disturbance) ──
    monitoredFetch('nhc-gtwo-2d', baseUrl + '1/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
        gj.features.forEach(function(feat) {
          if (!feat.geometry || feat.geometry.type !== 'Point') return;
          var p = feat.properties || {};
          var coords = feat.geometry.coordinates;
          var lat = coords[1], lon = coords[0];
          var prob2 = _parseGTWOProb(p.prob2day || p.risk2day || '');
          var prob7 = _parseGTWOProb(p.prob7day || p.risk7day || '');
          var maxProb = Math.max(prob2, prob7);
          var name = (p.basin || 'ATL').toUpperCase() + ' DISTURBANCE';

          var marker = _makeInvestMarker(lat, lon, maxProb, prob2, prob7, name);
          marker.addTo(_hurricaneMap);
          _hurricaneLayerObjs.disturbanceMarkers.push(marker);
        });
      }).catch(function(e){ console.warn('GTWO 2-day points fetch failed:', e); });

    // ── 7-DAY CURRENT LOCATION POINTS ──
    monitoredFetch('nhc-gtwo-7d', baseUrl + '2/query' + q)
      .then(function(r){ return r.json(); })
      .then(function(gj) {
        if (!gj.features || gj.features.length === 0 || !_hurricaneMap) return;
        gj.features.forEach(function(feat) {
          if (!feat.geometry || feat.geometry.type !== 'Point') return;
          var p = feat.properties || {};
          var coords = feat.geometry.coordinates;
          var lat = coords[1], lon = coords[0];
          var prob2 = _parseGTWOProb(p.prob2day || p.risk2day || '');
          var prob7 = _parseGTWOProb(p.prob7day || p.risk7day || '');
          // Only plot 7-day points that aren't already covered by a 2-day point nearby
          // (avoid duplicate markers for the same disturbance)
          var isDuplicate = _hurricaneLayerObjs.disturbanceMarkers.some(function(m) {
            if (!m.getLatLng) return false;
            var ll = m.getLatLng();
            return Math.abs(ll.lat - lat) < 2 && Math.abs(ll.lng - lon) < 2;
          });
          if (isDuplicate) return;

          var maxProb = Math.max(prob2, prob7);
          var name = (p.basin || 'ATL').toUpperCase() + ' INVEST';
          var marker = _makeInvestMarker(lat, lon, maxProb, prob2, prob7, name);
          marker.addTo(_hurricaneMap);
          _hurricaneLayerObjs.disturbanceMarkers.push(marker);
        });
      }).catch(function(e){ console.warn('GTWO 7-day points fetch failed:', e); });

    // ── FALLBACK: if new MapServer returns empty, try legacy KMZ via proxy ──
    setTimeout(function() {
      if (_hurricaneLayerObjs.disturbanceMarkers.length === 0) {
        _fetchGTWOKmzFallback();
      }
    }, 5000);
  }

  // Parse NHC probability strings like "Low (<40%)", "Medium (40-60%)", "High (>60%)" or just "20"
  function _parseGTWOProb(val) {
    if (!val) return 0;
    var s = String(val).toLowerCase().trim();
    // Direct number
    var num = parseInt(s);
    if (!isNaN(num) && num >= 0 && num <= 100) return num;
    // NHC risk labels
    if (s.indexOf('high') >= 0) return 70;
    if (s.indexOf('medium') >= 0 || s.indexOf('med') >= 0) return 50;
    if (s.indexOf('low') >= 0) return 20;
    // Extract number from strings like "40-60%"
    var m = s.match(/(\d+)/);
    return m ? parseInt(m[1]) : 0;
  }

  // Legacy KMZ fallback — only used if new MapServer returns empty
  function _fetchGTWOKmzFallback() {
    var kmzUrl = 'https://www.nhc.noaa.gov/xgtwo/gtwo_atl.kmz';
    var proxyUrl = 'https://api.allorigins.win/raw?url=' + encodeURIComponent(kmzUrl);

    monitoredFetch('nhc-gtwo-kmz', proxyUrl)
      .then(function(r){ return r.arrayBuffer(); })
      .then(function(buf) {
        if (window.JSZip) {
          return window.JSZip.loadAsync(buf).then(function(zip) {
            var kmlFile = Object.keys(zip.files).find(function(f){ return f.endsWith('.kml'); });
            return kmlFile ? zip.files[kmlFile].async('string') : Promise.reject('no kml');
          });
        }
        return Promise.reject('no JSZip');
      })
      .then(function(kmlText) {
        _parseGTWOKml(kmlText);
      })
      .catch(function(e) {
        console.info('GTWO KMZ fallback also failed (likely off-season):', e);
      });
  }

  function _parseGTWOKml(kmlText) {
    var parser = new DOMParser();
    var doc = parser.parseFromString(kmlText, 'text/xml');
    var placemarks = doc.querySelectorAll('Placemark');

    // Style id → probability level mapping
    // NHC uses styleUrl #1=low, #2=medium, #3=high for polygon areas
    // and #lowx, #medx, #higx for point markers
    var styleProb = { '1': 20, '2': 50, '3': 80, 'lowx': 20, 'medx': 50, 'higx': 80 };

    var areas = [], points = [];

    placemarks.forEach(function(pm) {
      var styleUrl = (pm.querySelector('styleUrl') || {}).textContent || '';
      var styleId = styleUrl.replace('#', '').trim();
      var prob = styleProb[styleId] || 0;
      var name = (pm.querySelector('name') || {}).textContent || '';

      // Polygon areas
      var polyEl = pm.querySelector('Polygon');
      if (polyEl) {
        var coordsEl = polyEl.querySelector('coordinates');
        if (coordsEl) {
          var coordStr = coordsEl.textContent.trim();
          var latlngs = coordStr.split(/\s+/).map(function(c) {
            var parts = c.split(',');
            return [parseFloat(parts[1]), parseFloat(parts[0])];
          }).filter(function(ll){ return !isNaN(ll[0]) && !isNaN(ll[1]); });

          if (latlngs.length > 2) {
            var sty = _gtwoStyle(prob);
            var poly = L.polygon(latlngs, {
              color: sty.stroke, weight: 1.5, fillColor: sty.fill,
              fillOpacity: 0.25, dashArray: '6 4', pane: 'hz-gtwo'
            });
            poly.addTo(_hurricaneMap);
            _hurricaneLayerObjs.disturbanceMarkers.push(poly);
            // Centroid for label
            var sumLat = 0, sumLon = 0;
            latlngs.forEach(function(ll){ sumLat += ll[0]; sumLon += ll[1]; });
            points.push({ lat: sumLat / latlngs.length, lon: sumLon / latlngs.length, prob: prob, name: name });
          }
        }
      }

      // Point markers (icon placemarks with #lowx/#medx/#higx)
      if (styleId === 'lowx' || styleId === 'medx' || styleId === 'higx') {
        var ptEl = pm.querySelector('Point coordinates');
        if (ptEl) {
          var parts = ptEl.textContent.trim().split(',');
          var lon = parseFloat(parts[0]), lat = parseFloat(parts[1]);
          if (!isNaN(lat) && !isNaN(lon)) {
            var marker = _makeInvestMarker(lat, lon, prob, prob, null, name || 'INVEST');
            marker.addTo(_hurricaneMap);
            _hurricaneLayerObjs.disturbanceMarkers.push(marker);
          }
        }
      }
    });

    // If no polygons/points found (off-season quiet), show a quiet label on map
    if (_hurricaneLayerObjs.disturbanceMarkers.length === 0) {
