                '<span style="display:flex;align-items:center;gap:4px;"><span style="width:5px;height:5px;border-radius:50%;background:#ec4899;"></span><span style="color:#be185d;">Sat</span></span>' +
              '</div>' +
              '<div style="display:flex;flex-wrap:wrap;align-items:center;gap:8px 10px;font-size:.36rem;color:#555;margin-top:6px;padding-top:6px;border-top:1px solid rgba(43,34,244,.06);font-weight:600;">' +
                '<span style="font-size:.32rem;color:'+INK_MUTE+';font-weight:800;letter-spacing:.06em;">OUTLOOK</span>' +
                '<span style="display:flex;align-items:center;gap:4px;"><span style="width:14px;height:3px;background:#f97316;border-radius:2px;"></span><span style="color:#c2410c;">Today</span></span>' +
