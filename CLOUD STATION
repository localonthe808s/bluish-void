      if(d300!=null&&d700!=null){var vr=d300-d700;if(vr>180)vr-=360;if(vr<-180)vr+=360;if(Math.abs(vr)>45){h+='<div style="margin:3px 0;opacity:.7;">🔄 '+(vr>0?'Veering (warm advection) \u2014 layers move differently.':'Backing (cold advection) \u2014 destabilizing profile.')+'</div>';}}
    }

    // ── CLOUD PHYSICS ──
    if (pbl != null && temp != null && dp != null) {
      var lclM = 125*(temp-dp); var lclFt = Math.round(lclM*3.281);
      if (lclM > 0) {
        h += S('Cloud Physics');
        h += '<div style="margin:3px 0;">'+K('LCL (Cloud Base): ')+'~'+lclFt.toLocaleString()+' ft ('+Math.round(lclM)+'m)</div>';
        h += '<div style="margin:3px 0;">'+K('PBL Height: ')+Math.round(pbl)+'m \u2014 '+(pbl>lclM?'above LCL, <b>cumulus forming</b>':'below LCL, thermals not reaching condensation')+'</div>';
