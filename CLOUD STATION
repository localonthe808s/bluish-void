    .today-tl-legend-item.planet-item[onclick*="saturn"] > div {
      transform: scale(0.42) rotate(27deg) !important;
    }
    .today-tl-legend-item.planet-item[onclick*="uranus"] > div {
      transform: scale(0.55) !important;
    }
    /* Reserve a 60px square footprint for both so the labels below stay
       aligned with the other planets. */
    .today-tl-legend-item.planet-item[onclick*="saturn"] > div,
    .today-tl-legend-item.planet-item[onclick*="uranus"] > div {
      width: 60px !important;
      height: 60px !important;
      overflow: visible !important;
    }
    .today-tl-legend-item.planet-item[onclick*="saturn"] svg,
    .today-tl-legend-item.planet-item[onclick*="uranus"] svg {
      flex-shrink: 0 !important;
