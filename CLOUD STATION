      h += '<div style="font-size:8px;color:rgba(255,255,255,.4);line-height:1.4;margin-top:4px;padding:4px 6px;background:rgba(255,255,255,.02);border-radius:4px;">'+_kmToMi(pi.note)+'</div>';
    }

    // ── ATMOSPHERE & WEATHER ──
    var pa = PLANET_ATMOSPHERE[planetKey];
    if (pa) {
      h += FS('Atmosphere & Weather');
      h += '<div style="display:flex;flex-wrap:wrap;gap:3px;margin-bottom:6px;">';
      pa.composition.forEach(function(c) {
        h += '<span style="font-size:9px;background:rgba(43,34,244,.06);border:1px solid rgba(43,34,244,.10);border-radius:4px;padding:2px 7px;color:rgba(43,34,244,.7);font-weight:600;">'+c+'</span>';
