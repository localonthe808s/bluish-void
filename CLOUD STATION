                    acHalo.setAttribute('transform', 'translate(0 0.5)');
                    acHalo.setAttribute('fill', botColor);
                    acHalo.setAttribute('opacity', '0.20');
                    acHalo.setAttribute('filter', 'url(#cuHalo)');
                    g.appendChild(acHalo);

                    var acBody = document.createElementNS(ns,'path');
                    acBody.setAttribute('d', _acPath.d);
                    acBody.setAttribute('fill', 'url(#'+_agid+')');
                    acBody.setAttribute('opacity', bodyOpacity);
                    acBody.setAttribute('filter', 'url(#cuFluff)');
                    g.appendChild(acBody);

                    // Sun-side crown (less for distant)
                    var _acCrownR,_acCrownG,_acCrownB;
                    if (isGoldenHour) { _acCrownR=255; _acCrownG=Math.round(253-depth*15); _acCrownB=Math.round(238-depth*30); }
                    else if (isNight) { _acCrownR=160; _acCrownG=168; _acCrownB=195; }
                    else { _acCrownR=255; _acCrownG=255; _acCrownB=Math.round(245-depth*15); }
                    var acHi = document.createElementNS(ns,'ellipse');
                    acHi.setAttribute('cx', (px + acSunSide*pw*0.35).toFixed(1));
                    acHi.setAttribute('cy', (py - ph*0.10).toFixed(1));
                    acHi.setAttribute('rx', (pw*0.42).toFixed(1));
                    acHi.setAttribute('ry', (ph*0.40).toFixed(1));
                    acHi.setAttribute('fill', 'rgb('+_acCrownR+','+_acCrownG+','+_acCrownB+')');
                    acHi.setAttribute('opacity', (0.42-depth*0.18).toFixed(2));
                    acHi.setAttribute('filter', 'url(#cuTinyBlur)');
                    g.appendChild(acHi);

                    // Specular — only on close cells
                    if (depth < 0.5) {
                      var _acSpec = document.createElementNS(ns,'ellipse');
                      _acSpec.setAttribute('cx', (px + acSunSide*pw*0.50).toFixed(1));
                      _acSpec.setAttribute('cy', (py - ph*0.20).toFixed(1));
                      _acSpec.setAttribute('rx', (pw*0.16).toFixed(1));
                      _acSpec.setAttribute('ry', (ph*0.22).toFixed(1));
                      _acSpec.setAttribute('fill', isNight ? 'rgb(195,200,225)' : 'rgb(255,255,250)');
                      _acSpec.setAttribute('opacity', (0.55-depth*0.20).toFixed(2));
                      _acSpec.setAttribute('filter', 'url(#cuTinyBlur)');
