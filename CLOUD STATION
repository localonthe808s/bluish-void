        planetsHtml += '<div class="today-tl-planet-row" data-planet="' + body + '" data-color="' + encodeURIComponent(color) + '" style="cursor:pointer;" onclick="showPlanetInsight(\'' + body + '\',decodeURIComponent(\'' + encodeURIComponent(color) + '\'),event)">';
        var tlPlanetImgs = {
          moon:'',
          mercury:"url('data:image/jpeg;base64,')",
          venus:"url('data:image/jpeg;base64,')",
