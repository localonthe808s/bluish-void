            var _auBaseY = 78;
            var _auTopY = 38;
            var _auArcCx = xOff + pW*0.5 + (R()-0.5)*pW*0.2;
            // Soft green glow base (oxygen 557.7 nm)
            var _auGlowGid = panelPrefix+'-aurora-glow-'+seed;
            var _auGlowDef = document.createElementNS(ns,'defs');
            _auGlowDef.innerHTML =
              '<linearGradient id="'+_auGlowGid+'" x1="0" y1="0" x2="0" y2="1">'+
                '<stop offset="0%"  stop-color="rgba(120,255,180,0)"/>'+
                '<stop offset="35%" stop-color="rgba(120,255,180,'+(0.18*_auIntensity).toFixed(2)+')"/>'+
                '<stop offset="80%" stop-color="rgba(60,220,140,'+(0.32*_auIntensity).toFixed(2)+')"/>'+
                '<stop offset="100%" stop-color="rgba(40,180,110,0)"/>'+
              '</linearGradient>';
            _auG.appendChild(_auGlowDef);
            var _auGlow = document.createElementNS(ns,'rect');
            _auGlow.setAttribute('x', (xOff-5).toString());
            _auGlow.setAttribute('y', _auTopY.toString());
            _auGlow.setAttribute('width', (pW+10).toString());
            _auGlow.setAttribute('height', (_auBaseY-_auTopY).toString());
            _auGlow.setAttribute('fill', 'url(#'+_auGlowGid+')');
            _auGlow.setAttribute('filter', 'url(#ghCloudHaze)');
            _auG.appendChild(_auGlow);
            // Vertical ray curtains — irregular widths, fade top + bottom
            var _auNRays = 8 + Math.round(_auIntensity*6);
            for (var _aR = 0; _aR < _auNRays; _aR++) {
              var _auT = _aR / Math.max(1, _auNRays-1);
              // Cluster rays around _auArcCx with falloff to edges
              var _auX = _auArcCx + (_auT-0.5) * pW * 0.85 + (R()-0.5)*4;
              if (_auX < xOff-5 || _auX > xOff+pW+5) continue;
              var _auRayHeight = (_auBaseY - _auTopY) * (0.55 + R()*0.45);
              var _auRayBaseY = _auBaseY - 2 - R()*4;
              var _auRayTopY = _auRayBaseY - _auRayHeight;
              var _auRayW = 1.5 + R()*2.5;
              // Per-ray gradient — fades to 0 at top + bottom, peaks in middle
              var _auRayGid = panelPrefix+'-aurora-ray-'+seed+'-'+_aR;
              var _auRayDef = document.createElementNS(ns,'defs');
              // Top color: 5% chance red (rare, strong storm), else green
              var _isRedTop = (_auroraKp != null && _auroraKp >= 6) && R() < 0.30;
              var _auTopRgba = _isRedTop ? '255,90,80' : '140,255,180';
              _auRayDef.innerHTML =
                '<linearGradient id="'+_auRayGid+'" x1="0" y1="0" x2="0" y2="1">'+
                  '<stop offset="0%"  stop-color="rgba('+_auTopRgba+',0)"/>'+
                  '<stop offset="20%" stop-color="rgba('+_auTopRgba+','+(0.45*_auIntensity).toFixed(2)+')"/>'+
                  '<stop offset="55%" stop-color="rgba(80,240,150,'+(0.55*_auIntensity).toFixed(2)+')"/>'+
                  '<stop offset="90%" stop-color="rgba(50,200,120,'+(0.30*_auIntensity).toFixed(2)+')"/>'+
                  '<stop offset="100%" stop-color="rgba(40,180,110,0)"/>'+
                '</linearGradient>';
              _auG.appendChild(_auRayDef);
              var _auRay = document.createElementNS(ns,'rect');
              _auRay.setAttribute('x', (_auX - _auRayW/2).toFixed(1));
              _auRay.setAttribute('y', _auRayTopY.toFixed(1));
              _auRay.setAttribute('width', _auRayW.toFixed(1));
              _auRay.setAttribute('height', _auRayHeight.toFixed(1));
              _auRay.setAttribute('fill', 'url(#'+_auRayGid+')');
              _auRay.setAttribute('filter', 'url(#cuFeather)');
              _auG.appendChild(_auRay);
            }
            svgEl.insertBefore(_auG, refEl);
          }

          // ══ LAYER 0.6: MILKY WAY (rural night) ══
          // Research: pale milky strip from horizon to horizon, brightest near
          // the Galactic Center (Sagittarius region), ~60° from the ecliptic.
          // Visible only in low-light-pollution skies (Bortle 1–3) and during
          // true night (sa<-10). Fades when cloud cover dims the view. Dark
          // dust lanes within (Great Rift) interrupt the band.
          // Suppress Milky Way in the golden-hour widget context — even in
          // dark sky, the widget previews sunrise/sunset where MW visibility
          // is contextually wrong (by the time golden hour arrives, MW is
          // gone). City landscapes also suppress for light-pollution reasons.
          var _mwIsRural = window._ghLandscapeCurrent !== 'city'
                           && (typeof panelPrefix !== 'string' || panelPrefix.indexOf('gh') !== 0);
          var _mwTotalCover = (cloudData && cloudData.cT != null) ? cloudData.cT : 0;
          if (_mwIsRural && _renderSa < -10 && _mwTotalCover < 50) {
            var _mwG = makeG('milkyway');
            // Cloud-cover dims the band
            var _mwIntensity = Math.max(0.4, 1 - _mwTotalCover/60);
            // Diagonal band — angle ~30° from horizontal, spanning panel
            var _mwAngle = 0.55; // radians
            var _mwCx = xOff + pW*0.5;
            var _mwCy = 50;
            var _mwLen = pW*1.2;
            // Build using a series of overlapping soft ellipses along the
            // diagonal axis, with brightness peaking near the center (GC).
            var _mwNSegments = 14;
            for (var _mwS = 0; _mwS < _mwNSegments; _mwS++) {
              var _mwT = (_mwS + 0.5) / _mwNSegments;
              var _mwAxisOff = (_mwT - 0.5) * _mwLen;
              var _mwSx = _mwCx + Math.cos(_mwAngle) * _mwAxisOff;
              var _mwSy = _mwCy + Math.sin(_mwAngle) * _mwAxisOff;
              // Brightness peaks near center, falls off to edges (GC at middle)
              var _mwBrightness = Math.exp(-Math.pow((_mwT - 0.55)*2.2, 2));
              // Slight per-segment width jitter for natural texture
              var _mwSegW = 12 + R()*4;
              var _mwSegH = 5 + R()*2;
              // Tone — slightly warm/yellow toward GC, cooler at edges
              var _mwR = Math.round(220 + _mwBrightness*25);
              var _mwG_g = Math.round(220 + _mwBrightness*15);
              var _mwB = Math.round(245 - _mwBrightness*20);
              var _mwAlpha = (0.05 + _mwBrightness * 0.10) * _mwIntensity;
              var _mwE = document.createElementNS(ns,'ellipse');
              _mwE.setAttribute('cx', _mwSx.toFixed(1));
              _mwE.setAttribute('cy', _mwSy.toFixed(1));
              _mwE.setAttribute('rx', _mwSegW.toFixed(1));
              _mwE.setAttribute('ry', _mwSegH.toFixed(1));
              // Rotate ellipse along the band axis
              _mwE.setAttribute('transform', 'rotate('+(_mwAngle*180/Math.PI).toFixed(1)+' '+_mwSx.toFixed(1)+' '+_mwSy.toFixed(1)+')');
              _mwE.setAttribute('fill', 'rgba('+_mwR+','+_mwG_g+','+_mwB+','+_mwAlpha.toFixed(3)+')');
              _mwE.setAttribute('filter', 'url(#ghCloudHaze)');
              _mwG.appendChild(_mwE);
            }
            // Dark dust lane (Great Rift) — thin darker streak within the band
            var _mwDustNSeg = 8;
            for (var _mwD = 0; _mwD < _mwDustNSeg; _mwD++) {
              var _mwDt = (_mwD + 0.5) / _mwDustNSeg;
              if (_mwDt < 0.30 || _mwDt > 0.85) continue; // dust lane covers center portion
              var _mwDoff = (_mwDt - 0.5) * _mwLen;
              var _mwDx = _mwCx + Math.cos(_mwAngle) * _mwDoff;
              var _mwDy = _mwCy + Math.sin(_mwAngle) * _mwDoff + 1.2; // slightly below band axis
              var _mwDe = document.createElementNS(ns,'ellipse');
              _mwDe.setAttribute('cx', _mwDx.toFixed(1));
              _mwDe.setAttribute('cy', _mwDy.toFixed(1));
              _mwDe.setAttribute('rx', '7');
              _mwDe.setAttribute('ry', '1.4');
              _mwDe.setAttribute('transform', 'rotate('+(_mwAngle*180/Math.PI).toFixed(1)+' '+_mwDx.toFixed(1)+' '+_mwDy.toFixed(1)+')');
              _mwDe.setAttribute('fill', 'rgba(8,10,28,'+(0.35*_mwIntensity).toFixed(2)+')');
              _mwDe.setAttribute('filter', 'url(#ghCloudHaze)');
              _mwG.appendChild(_mwDe);
            }
            // Densified star field along the band — small bright dots
            var _mwNStars = Math.round(20 * _mwIntensity);
            for (var _mwSt = 0; _mwSt < _mwNStars; _mwSt++) {
              var _mwStT = R();
              var _mwStOff = (_mwStT - 0.5) * _mwLen * 0.95;
              var _mwStX = _mwCx + Math.cos(_mwAngle) * _mwStOff + (R()-0.5)*8;
              var _mwStY = _mwCy + Math.sin(_mwAngle) * _mwStOff + (R()-0.5)*4;
              var _mwStR = 0.3 + R()*0.6;
              var _mwStBri = Math.exp(-Math.pow((_mwStT - 0.55)*2.0, 2));
              var _mwStEl = document.createElementNS(ns,'circle');
              _mwStEl.setAttribute('cx', _mwStX.toFixed(1));
              _mwStEl.setAttribute('cy', _mwStY.toFixed(1));
              _mwStEl.setAttribute('r', _mwStR.toFixed(2));
              _mwStEl.setAttribute('fill', 'rgba(255,250,235,'+(0.35 + _mwStBri*0.40).toFixed(2)+')');
              _mwG.appendChild(_mwStEl);
            }
            svgEl.insertBefore(_mwG, refEl);
          }

          // ══ LAYER 1: HIGH CLOUDS ══
          types.forEach(function(t){
            if(t.layer!=='high'||t.cover<2)return;
            var g=makeG('cloud-high');
            var a=Math.min(0.5,t.cover/100*0.6);
            // Night adjustment: clouds visible in proportion to available light
            // Moon illumination makes clouds distinctly visible as silvery forms
            var _hsa=_renderSa;
            if(_hsa<-6){
              var moonBoost=0;
              if(window._moonPhase!=null&&typeof moonInfo==='function'){
                var _mi=moonInfo(window._moonPhase);
                if(_mi) moonBoost=(_mi.illum||0)/100*0.45; // 50% moon → +0.225 boost
              }
              a*=(0.3+moonBoost); // base 30% + up to 45% from moon = 30-75%
            }
            else if(_hsa<-2) a*=0.5+Math.max(0,(_hsa+6)/4)*0.2; // blue hour
            else if(_hsa<0) a*=0.7+Math.max(0,(_hsa+2)/2)*0.15; // twilight

            if(t.genus==='Cirrus'){
              var nS=Math.max(2,Math.round(t.cover/12));
              var isIntortus=t.species==='intortus';
              var isSpissatus=t.species==='spissatus';
              var isFibratus=t.species==='fibratus';
              // Field alignment: all wisps share a wind-driven drift direction.
              // wd300 is meteorological FROM direction; sin((wd-180)) projects to
              // the panel's horizontal axis (W-facing view): W-wind → drift right,
              // E-wind → drift left. Magnitude scales with how close wind aligns.
              var _fDrift = (cloudData.wd300!=null) ? Math.sin((cloudData.wd300-180)*Math.PI/180) : 0;
              // Regular spacing so wisps form a parallel field, not random scatter
              var _spacing = (pW-20)/Math.max(1,nS);
              if (isFibratus) {
                // ── PREVIEW-LAB FIBRATUS — parallel sub-fiber bundles ──
                // Research: "long fine filaments drawn out by wind, like hair
                // run through with a comb". Each bundle is a cluster of 2-5
                // closely-spaced parallel sub-fibers; bundles fade in/out at
                // both ends (drawn-out filament look). One shared jet-stream
                // angle/curve so the whole field reads as a coherent comb.
                var nBundles = 5 + Math.round(t.cover/8);
                var globalAngle = (R()-0.5)*0.06;
                var globalCurveAmt = (R()-0.5)*5.0;
                var globalCurveSign = globalCurveAmt < 0 ? -1 : 1;
                for (var s = 0; s < nBundles; s++) {
                  var bundleY = 4 + (s/Math.max(1,nBundles-1)) * 36 + (R()-0.5)*3;
                  var bundleStartX = xOff - 6 + R()*pW*0.18;
                  var bundleEndX = bundleStartX + pW*0.55 + R()*pW*0.40;
                  bundleEndX = Math.min(bundleEndX, xOff+pW+6);
                  var bundleLen = bundleEndX - bundleStartX;
                  var bundleMidX = (bundleStartX + bundleEndX)/2;
                  var bundleCurve = globalCurveAmt + (R()-0.5)*1.5*globalCurveSign;
                  var bundleSlant = bundleLen * globalAngle + (R()-0.5)*4;
                  var nSubs = 2 + Math.round(R()*3);
                  var fbGid = panelPrefix+'-cifib-'+seed+'-'+Math.round(t.cover)+'-'+s;
                  var fbDef = document.createElementNS(ns,'defs');
                  fbDef.innerHTML =
                    '<linearGradient id="'+fbGid+'" gradientUnits="userSpaceOnUse" '+
                      'x1="'+bundleStartX.toFixed(1)+'" y1="0" '+
                      'x2="'+bundleEndX.toFixed(1)+'" y2="0">'+
                      '<stop offset="0%" stop-color="'+col('high',0,0.85)+'"/>'+
                      '<stop offset="18%" stop-color="'+col('high',a*(0.42+R()*0.18),0.85)+'"/>'+
                      '<stop offset="82%" stop-color="'+col('high',a*(0.34+R()*0.16),0.85)+'"/>'+
                      '<stop offset="100%" stop-color="'+col('high',0,0.85)+'"/>'+
                    '</linearGradient>';
                  g.appendChild(fbDef);
                  for (var sb = 0; sb < nSubs; sb++) {
                    var subOff = (sb - (nSubs-1)/2) * (1.4 + R()*1.0);
                    var dF = 'M '+bundleStartX.toFixed(1)+' '+(bundleY+subOff).toFixed(1)+
                             ' Q '+bundleMidX.toFixed(1)+' '+(bundleY+bundleCurve+subOff).toFixed(1)+
                             ' '+bundleEndX.toFixed(1)+' '+(bundleY+bundleSlant+subOff*0.85).toFixed(1);
                    var fbP = document.createElementNS(ns,'path');
                    fbP.setAttribute('d', dF);
                    fbP.setAttribute('stroke', 'url(#'+fbGid+')');
                    fbP.setAttribute('stroke-width', (0.5+R()*0.6).toFixed(2));
                    fbP.setAttribute('fill', 'none');
                    fbP.setAttribute('stroke-linecap', 'round');
                    fbP.setAttribute('filter', 'url(#cuTinyBlur)');
                    g.appendChild(fbP);
                  }
                }
              } else if (isIntortus) {
                // ── PREVIEW-LAB INTORTUS — tangled crossing fibers ──
                // Research: "filaments very irregularly arranged or curved,
                // orderless or tangled, sometimes look like spiderwebs". Each
                // fiber has independent direction (±46°), unique wave pattern,
                // and ~22% are strongly curled. NOT a coherent K-H wave field.
                var nFibers = 16 + Math.round(t.cover/4);
                for (var fIn = 0; fIn < nFibers; fIn++) {
                  var orientAngle = (R()-0.5) * 1.6;
                  var fiberLen = pW * (0.18 + R()*0.40);
                  var startX = (xOff - 6) + R()*(pW*0.95);
                  var startY = 4 + R()*36;
                  var dxIn = Math.cos(orientAngle) * fiberLen;
                  var dyIn = Math.sin(orientAngle) * fiberLen;
                  var endX = startX + dxIn;
                  var endY = startY + dyIn;
                  var isCurl = R() < 0.22;
                  var perpX = -Math.sin(orientAngle);
                  var perpY = Math.cos(orientAngle);
                  var waveAmp = isCurl ? (7 + R()*6) : (1.5 + R()*3);
                  var waveCount = isCurl ? (1 + Math.round(R())) : (1 + Math.round(R()*2));
                  var wavePhase = R() * Math.PI * 2;
                  var nPts = 16;
                  var dInt = 'M '+startX.toFixed(1)+' '+startY.toFixed(1);
                  for (var ipt = 1; ipt <= nPts; ipt++) {
                    var tInt = ipt/nPts;
                    var bxIn = startX + tInt*dxIn;
                    var byIn = startY + tInt*dyIn;
                    var wave = Math.sin(tInt*Math.PI*waveCount + wavePhase)*waveAmp;
                    var jitterInt = (R()-0.5)*1.2;
                    dInt += ' L '+(bxIn + perpX*wave).toFixed(1)+' '+(byIn + perpY*wave + jitterInt).toFixed(1);
                  }
                  var inGid = panelPrefix+'-ciint-'+seed+'-'+Math.round(t.cover)+'-'+fIn;
                  var inDef = document.createElementNS(ns,'defs');
                  inDef.innerHTML =
                    '<linearGradient id="'+inGid+'" gradientUnits="userSpaceOnUse" '+
                      'x1="'+startX.toFixed(1)+'" y1="'+startY.toFixed(1)+'" '+
                      'x2="'+endX.toFixed(1)+'" y2="'+endY.toFixed(1)+'">'+
                      '<stop offset="0%" stop-color="'+col('high',0,0.85)+'"/>'+
                      '<stop offset="22%" stop-color="'+col('high',a*(0.34+R()*0.18),0.85)+'"/>'+
                      '<stop offset="78%" stop-color="'+col('high',a*(0.30+R()*0.16),0.85)+'"/>'+
                      '<stop offset="100%" stop-color="'+col('high',0,0.85)+'"/>'+
                    '</linearGradient>';
                  g.appendChild(inDef);
                  var inP = document.createElementNS(ns,'path');
                  inP.setAttribute('d', dInt);
                  inP.setAttribute('stroke', 'url(#'+inGid+')');
                  inP.setAttribute('stroke-width', (0.5+R()*0.6).toFixed(2));
                  inP.setAttribute('fill', 'none');
                  inP.setAttribute('stroke-linecap', 'round');
                  inP.setAttribute('filter', 'url(#cuTinyBlur)');
                  g.appendChild(inP);
                }
              } else {
              for(var i=0;i<nS;i++){
                var x1 = xOff - 10 + i*_spacing + (R()-0.3)*6;
                var y = 4 + R()*28;
                var len = isIntortus?(30+R()*80):(50+R()*120);
                _curCx = x1 + len/2; // sun-distance lighting key
                // Drift direction biased by wind; small random component for naturalness
                var _baseD = isIntortus?22:12;
                var drift = _baseD*_fDrift + (R()-0.5)*(isIntortus?12:7);
                var thick=isSpissatus?(5+R()*7):(2.5+R()*5);
                var wPath='M'+x1+' '+y;
                var segs=isIntortus?(6+Math.round(R()*4)):(4+Math.round(R()*3));
                var waveAmp=isIntortus?10:6;
                var waveFreq=isIntortus?(2.5+R()*2):1.5;
                for(var s=1;s<=segs;s++){
                  var frac=s/segs;
                  var sx=x1+frac*len;
                  var sy=y+drift*frac+Math.sin(frac*Math.PI*waveFreq+R()*2)*waveAmp*(R()-0.3);
                  if(isIntortus) sy+=Math.sin(frac*Math.PI*4.5+i*1.7)*5*R();
                  if(isFibratus) sy=y+drift*frac+(R()-0.5)*2;
                  var cpx=x1+(frac-0.5/segs)*len;
                  var cpy=sy+(R()-0.5)*(isIntortus?14:8);
                  wPath+=' Q'+cpx.toFixed(1)+' '+cpy.toFixed(1)+' '+sx.toFixed(1)+' '+sy.toFixed(1);
                }
                var endY=y+drift;
                var thickMult=isSpissatus?1.5:1.0;
                for(var s=segs;s>=0;s--){
                  var frac=s/segs;
                  var sx=x1+frac*len;
                  var sy=y+drift*frac+Math.sin(frac*Math.PI*waveFreq+R()*2)*waveAmp*(R()-0.3)+thick*thickMult*(0.5+R()*0.5);
                  if(isIntortus) sy+=Math.sin(frac*Math.PI*4.5+i*1.7)*4*R();
                  if(isFibratus) sy=y+drift*frac+(R()-0.5)*2+thick*(0.5+R()*0.5);
                  var cpx=x1+(frac+0.5/segs)*len;
                  var cpy=sy+(R()-0.5)*4;
                  wPath+=' Q'+cpx.toFixed(1)+' '+cpy.toFixed(1)+' '+sx.toFixed(1)+' '+sy.toFixed(1);
                }
                wPath+=' Z';
                var glowA=isSpissatus?(a*0.28):(a*0.18);
                var glow=document.createElementNS(ns,'path');
                glow.setAttribute('d',wPath);
                glow.setAttribute('fill',col('high',glowA,0.7));
                glow.setAttribute('filter','url(#ghCloudDiffuse)');
                g.appendChild(glow);
                if(isSpissatus){
                  var spiDense=document.createElementNS(ns,'path');
                  spiDense.setAttribute('d',wPath);
                  spiDense.setAttribute('fill',col('high',a*0.2,0.45));
                  spiDense.setAttribute('filter','url(#ghCloudSoft)');
                  g.appendChild(spiDense);

                  // ── PREVIEW-LAB SPISSATUS DETAIL — anvil-debris character ──
                  // Wave-curved internal fibers (richer interior than the existing
                  // dense layer alone). Varied length, more wave amplitude than
                  // uniform horizontal lines.
                  var spiCx = x1 + len*0.5;
                  var spiCy = y + drift*0.5;
                  var nIntFibers = 6 + Math.round(R()*4);  // 6-10 internal fibers per spissatus wisp
                  for (var ifi = 0; ifi < nIntFibers; ifi++) {
                    var fy = spiCy + (R()-0.5)*thick*1.4;
                    var fLenRatio = 0.4 + R()*0.6;  // partial-length fibers for richness
                    var fxA = spiCx - len*(0.45+R()*0.15)*fLenRatio;
                    var fxB = spiCx + len*(0.45+R()*0.15)*fLenRatio;
                    var fxMidIn = (fxA+fxB)/2;
                    var fyMidIn = fy + (R()-0.5)*1.5;  // wave amplitude
                    var spiFib = document.createElementNS(ns,'path');
                    spiFib.setAttribute('d','M '+fxA.toFixed(1)+' '+fy.toFixed(1)+
                                            ' Q '+fxMidIn.toFixed(1)+' '+fyMidIn.toFixed(1)+
                                            ' '+fxB.toFixed(1)+' '+(fy+(R()-0.5)*1.2).toFixed(1));
                    spiFib.setAttribute('stroke',col('high',a*0.28,0.65));
                    spiFib.setAttribute('stroke-width',(0.4+R()*0.5).toFixed(2));
                    spiFib.setAttribute('fill','none');
                    spiFib.setAttribute('stroke-linecap','round');
                    spiFib.setAttribute('filter','url(#cuTinyBlur)');
                    g.appendChild(spiFib);
                  }

                  // Density knot — 55% of patches get a brighter denser core
                  // (real spissatus has thicker concentrations of ice crystals)
                  if (R() < 0.55) {
                    var knX = spiCx + (R()-0.5)*len*0.5;
                    var knY = spiCy + (R()-0.5)*thick*0.4;
                    var spiKnot = document.createElementNS(ns,'ellipse');
                    spiKnot.setAttribute('cx',knX.toFixed(1));
                    spiKnot.setAttribute('cy',knY.toFixed(1));
                    spiKnot.setAttribute('rx',(len*0.18).toFixed(1));
                    spiKnot.setAttribute('ry',(thick*1.4).toFixed(1));
                    spiKnot.setAttribute('fill',col('high',a*0.22,0.95));
                    spiKnot.setAttribute('filter','url(#ghCloudDiffuse)');
                    g.appendChild(spiKnot);
                  }

                  // Frayed edge wisps — 2-4 small wispy fragments at lens ends
                  // (anvil-remnants are frayed, not lens-clean)
                  var nFray = 2 + Math.round(R()*2);
                  for (var fr = 0; fr < nFray; fr++) {
                    var frSide = (R() < 0.5) ? -1 : 1;
                    var frX = spiCx + frSide*len*(0.55 + R()*0.20);
                    var frY = spiCy + (R()-0.5)*thick*1.0;
                    var frW = 4 + R()*8;
                    var frH = 0.8 + R()*0.8;
                    var spiFray = document.createElementNS(ns,'ellipse');
                    spiFray.setAttribute('cx',(frX + frSide*frW*0.3).toFixed(1));
                    spiFray.setAttribute('cy',frY.toFixed(1));
                    spiFray.setAttribute('rx',frW.toFixed(1));
                    spiFray.setAttribute('ry',frH.toFixed(1));
                    spiFray.setAttribute('fill',col('high',a*0.22,0.85));
                    spiFray.setAttribute('filter','url(#ghCloudDiffuse)');
                    g.appendChild(spiFray);
                  }
                }
