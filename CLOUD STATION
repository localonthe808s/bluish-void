        drainMsg += terrain.terrainClass === 'basin' ? 'Basin terrain (' + Math.round(terrain.valleyDepth) + 'm below ridgelines)' : 'Valley terrain (' + Math.round(terrain.valleyDepth) + 'm below surroundings)';
        if(terrain.valleyAxis) drainMsg += ' with ' + terrain.valleyAxis.map(function(b){var dirs=['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];return dirs[Math.round(b/22.5)%16];}).join('\u2013') + ' corridor';
        drainMsg += '. ';
