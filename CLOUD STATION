                var nFloc = 4 + Math.round(t.cover/8);  // 4 at low cover, ~12 at high
                // Lighting palette — same as cumulus, scaled for thinner mid-level cloud
                var _wmFl = Math.max(0, Math.min(1, 1 - _renderSa/10));
