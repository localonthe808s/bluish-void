      var ci=window._cloudIntel||{};
      var cn2=ci.cnData||{cL:0,cM:0,cH:0,rh:50,vis:30000,pr:0,snow:0};

      // ── SKY GRADIENT (physics engine) ──
      function lerpH(a,b,t){
        t=Math.max(0,Math.min(1,t));
        var ar=parseInt(a.slice(1,3),16),ag=parseInt(a.slice(3,5),16),ab=parseInt(a.slice(5,7),16);
        var br=parseInt(b.slice(1,3),16),bg=parseInt(b.slice(3,5),16),bb=parseInt(b.slice(5,7),16);
        return '#'+((1<<24)+(Math.round(ar+(br-ar)*t)<<16)+(Math.round(ag+(bg-ag)*t)<<8)+Math.round(ab+(bb-ab)*t)).toString(16).slice(1);
      }
      function blG(base,tgt,t){return[lerpH(base[0],tgt[0],t),lerpH(base[1],tgt[1],t),lerpH(base[2],tgt[2],t),lerpH(base[3],tgt[3],t)];}
      // ── DATABASE LOOKUP (uses global SKY_DB) ──
      var sky;
      if(typeof window._SKY_DB!=='undefined'){
        var SKY_DB=window._SKY_DB;
