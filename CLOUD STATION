          var dirCaption = elevDeg > 60 ? 'Look up — aurora is overhead' :
                           elevDeg > 30 ? 'Look high in the northern sky' :
                                          'Look low on the northern horizon';
          s += '<div style="font-size:10px;text-align:center;color:rgba(43,34,244,.7);font-weight:700;margin:-4px 0 4px;">'+dirCaption+'</div>';
          return s;
        };

        // gScaleCards — compact horizontal cards for G1-G5 with current
        // level highlighted.
        var gScaleCards = function(currentKp) {
          var levels = [
            { g:'G1', kp:5, c:'#ff9900', desc:'Minor — aurora to 55°N, weak grid fluctuations' },
            { g:'G2', kp:6, c:'#ff6600', desc:'Moderate — 50°N, HF radio fading at high lat' },
            { g:'G3', kp:7, c:'#ff3300', desc:'Strong — 45°N (mid-US), GPS drift' },
            { g:'G4', kp:8, c:'#cc0000', desc:'Severe — 40°N, widespread voltage problems' },
            { g:'G5', kp:9, c:'#990033', desc:'Extreme — 30°N, possible grid collapse' }
          ];
          var svg = '<div style="display:flex;flex-direction:column;gap:3px;margin:4px 0;">';
          levels.forEach(function(l) {
            var active = currentKp >= l.kp;
            svg += '<div style="display:flex;align-items:center;gap:8px;padding:5px 8px;background:'+(active?l.c+'22':'rgba(43,34,244,.03)')+';border-radius:5px;border-left:3px solid '+l.c+';opacity:'+(active?'1':'0.65')+';">' +
              '<div style="font-weight:900;font-size:11px;color:'+l.c+';min-width:24px;">'+l.g+'</div>' +
              '<div style="font-size:9px;font-weight:700;color:'+(active?l.c:'rgba(43,34,244,.55)')+';min-width:34px;">Kp '+l.kp+'</div>' +
              '<div style="font-size:9.5px;color:rgba(43,34,244,.7);line-height:1.3;flex:1;">'+l.desc+'</div>' +
            '</div>';
          });
          svg += '</div>';
          return svg;
        };

        // Current KP
        var currentKp = 0;
        if (kpData && kpData.length > 0) {
          var nowT = Date.now();
          for (var ck = 0; ck < kpData.length; ck++) {
