  function _smokeAnimLoop(timestamp){
    if(!_smokeTransportVisible || hazardActiveTab !== 'fire'){
      _smokeAnimFrame = null;
      return;
    }
    var dt = (timestamp - _smokeLastFrameTime) / 1000; // seconds
    _smokeLastFrameTime = timestamp;

    // Wind-proportional drift speed: faster wind = faster smoke movement
    var hourly = window._wxHourly;
    var ni = window._wxNearestIdx;
    var windSpd = 10;
    if(hourly && hourly.windspeed_10m && ni != null){
      windSpd = Math.max(3, hourly.windspeed_10m[ni] || 10);
    }
    // Scale drift: 5mph wind ≈ 0.03/s, 20mph ≈ 0.12/s, 40mph ≈ 0.24/s
    var driftRate = windSpd * 0.006;
    window._smokeTimeOffset += driftRate * dt;

    // Only re-render every ~1.8 seconds to balance smoothness vs performance
    // But accumulate drift continuously
    if(!_smokeNeedsRender){
      _smokeNeedsRender = true;
      setTimeout(function(){
        _smokeNeedsRender = false;
        renderSmokeTransport();
      }, 1800);
    }

    _smokeAnimFrame = requestAnimationFrame(_smokeAnimLoop);
  }

