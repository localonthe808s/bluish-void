  function injectLiveCloudContext(id, content) {
    var wx = window._wxCurrent || {};
    var cL = wx.cloudLow, cH = wx.cloudHigh, rh = wx.rh, dp = wx.dewpoint;
    var temp = wx.temp, vis = wx.visibility, cape = wx.cape, frzLvl = wx.freezingLevel;
    var cT = wx.cloudCover, wind = wx.wind;
    var sunrise = wx.sunrise, sunset = wx.sunset;

    // Band-specific contextual note only (universal intelligence is in the info panel)
    var note = '';
    if (id === 'goes-band-GEOCOLOR') {
      var isNight = false;
      if (sunrise && sunset) { var n = new Date(); isNight = n < new Date(sunrise) || n > new Date(sunset); }
      note = isNight ? '🌙 Nighttime mode — IR + city lights composite. Low clouds appear blue-gray.' : '☀️ Daytime true-color. Cloud cover: ' + (cT != null ? cT + '%' : '--') + '.';
    }
    else if (id === 'goes-band-AirMass') {
      var p = wx.pressureTrend;
      note = p != null ? '📊 Pressure ' + (p > 0 ? 'rising +' : '') + p.toFixed(1) + ' mb/3h' + (p < -2 ? ' — active cyclogenesis signatures likely on this product.' : p > 2 ? ' — high pressure building, dry intrusion signatures visible.' : '.') : '';
    }
    else if (id === 'goes-band-Sandwich') {
      note = cape != null && cape > 500 ? '⛈️ CAPE ' + Math.round(cape) + ' J/kg — watch for overshooting tops (bright on purple) indicating severe storms.' : '';
    }
    else if (id === 'goes-band-DayNightCloudMicroCombo') {
      note = frzLvl != null ? '❄️ Freezing level ' + Math.round(frzLvl*3.281).toLocaleString() + ' ft. Clouds above = ice (cyan/white), below = liquid (yellow/green).' : '';
    }
    else if (id === 'goes-band-FireTemperature') {
      note = (rh != null && rh < 25 && wind != null && wind > 15) ? '🔥 Fire weather: RH ' + rh + '%, winds ' + wind + ' mph — elevated fire detection sensitivity.' : '';
    }
    else if (id === 'goes-band-Dust') {
      note = (vis != null && vis < 8000) ? '👁️ Visibility ' + (vis/1000).toFixed(1) + 'km — check for dust/haze signatures (pink/magenta on this product).' : '';
    }
    else if (id === 'goes-band-EXTENT3') {
      note = cape != null ? '⚡ CAPE ' + Math.round(cape) + ' J/kg — lightning potential ' + (cape > 1500 ? '<b>HIGH</b>' : cape > 800 ? 'MODERATE' : 'LOW') + '.' : '';
    }
    else if (id === 'goes-band-DMW') {
      var w3 = wx.wind300spd, w7 = wx.wind700spd;
      if (w3 != null && w7 != null) {
        var shear = Math.round((w3 - w7) * 0.621371);
        note = '🌬️ Wind shear ' + shear + ' mph (300-700mb) — ' + (shear > 40 ? 'strong directional divergence in motion vectors expected.' : 'moderate, vectors may show layer separation.');
      }
    }
    else if (id === 'goes-band-01') {
      note = (vis != null && vis < 10000) ? '💨 Visibility ' + (vis/1000).toFixed(1) + 'km — blue channel most sensitive to smoke/haze scattering.' : '';
    }
    else if (id === 'goes-band-02') {
      note = cL != null && cL > 40 ? '☁️ Low clouds ' + cL + '% — 0.5km resolution captures fine stratus/cumulus structure in this layer.' : '';
    }
    else if (id === 'goes-band-04') {
      note = cH != null ? (cH > 30 ? '🏔️ High clouds ' + cH + '% — cirrus channel showing extensive ice crystal returns.' : '🔵 High clouds ' + cH + '% — mostly clear upper troposphere.') : '';
    }
    else if (id === 'goes-band-05') {
      note = frzLvl != null ? '❄️ Freezing level ' + Math.round(frzLvl) + 'm. Ice/snow = dark, liquid water = bright on this channel.' : '';
    }
    else if (id === 'goes-band-07') {
      note = (vis != null && vis < 5000) ? '🌫️ Visibility ' + (vis/1000).toFixed(1) + 'km — fog/stratus signature expected. 3.9µm-10.3µm difference is definitive.' : '';
    }
    else if (id === 'goes-band-08' || id === 'goes-band-09' || id === 'goes-band-10') {
      var lvl = id === 'goes-band-08' ? 'upper (300-500mb)' : id === 'goes-band-09' ? 'mid (400-600mb)' : 'lower (500-700mb)';
      note = rh != null ? '💧 Surface RH ' + rh + '%, dew point ' + (dp != null ? dp + '°' : '--') + '. ' + (rh > 70 ? 'Bright ' + lvl + ' WV returns expected.' : 'Dry ' + lvl + ' air — dark signatures likely.') : '';
    }
    else if (id === 'goes-band-12') {
      var p6 = wx.pressureTrend6hr;
      note = p6 != null && p6 < -3 ? '🌀 Pressure falling ' + p6.toFixed(1) + ' mb/6h — check for tropopause fold ozone signatures indicating cyclogenesis.' : '';
    }
    else if (id === 'goes-band-13' || id === 'goes-band-14') {
      var isNt = false;
      if (sunrise && sunset) { var nn = new Date(); isNt = nn < new Date(sunrise) || nn > new Date(sunset); }
      note = isNt ? '🌙 Nighttime — this IR window is your primary storm tracker. Cloud-top temps directly indicate storm intensity.' : '';
    }
    else if (id === 'goes-band-16') {
      note = cape != null && cape > 1000 ? '📏 CAPE ' + Math.round(cape) + ' J/kg — high tropopause likely, enabling taller storms visible as cold-top signals on CO₂ channel.' : '';
    }

    if (!note) return content;
    var live = '<div style="background:rgba(255,255,255,.06);border-radius:6px;padding:6px 10px;margin-bottom:8px;font-size:.50rem;color:rgba(255,255,255,.75);border-left:3px solid rgba(100,170,255,.5);">' + note + '</div>';
    return live + content;
  }

  function showRadarTooltip(id, anchor){
    if (!radarInfoData[id] || !radarTooltip) return;
    var content = radarInfoData[id];
    // Inject live model state for model tooltips
    var isModel = id.indexOf('fcast-model-') === 0;
    if (isModel) content = injectLiveModelState(id, content);
    // Inject live product context for product tab tooltips
    var isProduct = id.indexOf('fcast-tab-') === 0;
    if (isProduct) content = injectLiveProductContext(id, content);
    // Inject live cloud intelligence for GOES band tooltips
    var isGoesBand = id.indexOf('goes-band-') === 0;
    if (isGoesBand) content = injectLiveCloudContext(id, content);
    radarTooltip.innerHTML = content;
    radarTooltip.style.display = 'block';
    // Determine if this is a left-panel (model) or right-panel (product) icon
    var isRightPanel = id.indexOf('fcast-tab-') === 0 || id.indexOf('goes-band-') === 0;
    var mapEl = document.getElementById('fcast-img-container');
    var anchorRect = anchor.getBoundingClientRect();
    var ttH = radarTooltip.offsetHeight;
    var winH = window.innerHeight;
    if (mapEl) {
      var mapRect = mapEl.getBoundingClientRect();
      if (isRightPanel) {
        // Position to the left of the right panel, vertically near the anchor
        var rightPanel = document.getElementById('fcast-right-panel');
        var rpLeft = rightPanel ? rightPanel.getBoundingClientRect().left : mapRect.right - 130;
        radarTooltip.style.left = (rpLeft - 348) + 'px';
      } else {
        // Left-panel icons: position to the right of left panel
        var leftPanel = document.getElementById('fcast-left-panel');
        var lpRight = leftPanel ? leftPanel.getBoundingClientRect().right : mapRect.left + 140;
        radarTooltip.style.left = (lpRight + 8) + 'px';
      }
      // Vertical: center on anchor, clamped to viewport
      var idealTop = anchorRect.top + anchorRect.height / 2 - ttH / 2;
      var clampedTop = Math.max(mapRect.top + 4, Math.min(idealTop, winH - ttH - 8));
      radarTooltip.style.top = clampedTop + 'px';
    } else {
      radarTooltip.style.left = (anchorRect.left - 350) + 'px';
      radarTooltip.style.top = Math.max(8, anchorRect.top - ttH / 2) + 'px';
    }
    clearTimeout(radarTooltipTimer);
  }

  // Hide on mouse leave from both icon and tooltip
  if (radarTooltip) {
    radarTooltip.addEventListener('mouseleave', function(){
      radarTooltipTimer = setTimeout(function(){ radarTooltip.style.display = 'none'; }, 200);
    });
    radarTooltip.addEventListener('mouseenter', function(){
      clearTimeout(radarTooltipTimer);
    });
