                  _topRAc=248; _topGAc=250; _topBAc=255;
                  _midRAc=212; _midGAc=216; _midBAc=226;
                  _botRAc=168; _botGAc=174; _botBAc=192;
                  _hazeR=140;  _hazeG=150;  _hazeB=170;  // day haze
                }
                var _acFade = function(R0,G0,B0, fa) {
                  return 'rgb('+Math.round(R0*(1-fa)+_hazeR*fa)+','+Math.round(G0*(1-fa)+_hazeG*fa)+','+Math.round(B0*(1-fa)+_hazeB*fa)+')';
                };

                // Build grid with row depth + sinusoidal undulation
                var _acGrid = [];
                var _acYTop = 30, _acYBot = 64;
                for (var rr = 0; rr < nRows; rr++) {
                  _acGrid[rr] = [];
                  var rowOff = (rr % 2) * (cellW/2);
