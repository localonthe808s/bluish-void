            var tMin = Math.min(-300, lo - 20);
            var tMax = Math.max(900, hi + 20);
            var loPct = ((lo - tMin) / (tMax - tMin)) * 100;
            var hiPct = ((hi - tMin) / (tMax - tMin)) * 100;
            // Pick labels — Day/Night vs Cold/Hot
            var loLabel = /night/i.test(st) ? 'NIGHT' : (/avg/i.test(st) || /min/i.test(st)) ? 'MIN' : 'COLD';
            var hiLabel = /day/i.test(st) ? 'DAY' : /max/i.test(st) ? 'MAX' : 'HOT';
            h += '<div style="margin:6px 0 14px;">';
            h += '<div style="font-size:9px;font-weight:700;color:rgba(43,34,244,.55);letter-spacing:.04em;margin-bottom:6px;">SURFACE TEMPERATURE</div>';
