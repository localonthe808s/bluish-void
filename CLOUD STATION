        }
      } catch(e){}
      if (!tempVizDone) h += gL('Surface temp', pa.surfTemp);
      h += gL('Pressure', pa.pressure);
      h += '<div style="font-size:11px;color:rgba(43,34,244,.7);line-height:1.5;margin-top:6px;">'+pa.weather+'</div>';
