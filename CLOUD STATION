  function initUnifiedHazardMap(){
    var container = document.getElementById('hazard-map');
    if (!container || typeof L === 'undefined') return;

    if (hazardMap){ hazardMap.remove(); hazardMap = null; }

    // Determine best initial view from location.
    // Mobile starts one zoom-level wider (3 vs 4) so the entire
    // continental US fits a phone-narrow viewport.
    var isMobile = window.matchMedia('(max-width: 1100px)').matches;
    var mapCenter = [39, -98], mapZoom = isMobile ? 3 : 4;

    hazardMap = L.map(container, {
      center: mapCenter,
      zoom: mapZoom,
      zoomControl: false,
      attributionControl: false,
      minZoom: 2,
      maxZoom: 14,
      worldCopyJump: true,
      scrollWheelZoom: false,
      // Mobile interaction model:
      //  • Pinch with two fingers → zoom the map (always enabled,
      //    can't conflict with page scroll which is one-finger).
      //  • Single-finger swipe → page scrolls past the map untouched
      //    (dragging stays disabled until the user explicitly taps
      //    the map to engage roaming mode).
      //  • Double-click zoom + tap-pan → off so single touches never
      //    zoom by accident.
      dragging: !isMobile,
      touchZoom: true,
      doubleClickZoom: !isMobile,
      tap: !isMobile,
      preferCanvas: true,
      zoomAnimation: true,
      zoomAnimationThreshold: 2,
      fadeAnimation: false,
      markerZoomAnimation: false,
      wheelDebounceTime: 80,
      wheelPxPerZoomLevel: 120
    });

    // ── Scroll guard: protects page scrolling, but never blocks map interaction ──
    // Dismisses on any click within the hazard widget (map body, tabs, overlays).
    // Re-engages scroll-zoom lock when user clicks outside, but the guard overlay
    // is invisible and non-blocking — only scroll-zoom is disabled.
    (function(){
      var guard = document.getElementById('hazard-scroll-guard');
      var mapActive = false;
      var widget = document.getElementById('hazard-widget');

      function dismiss(){
        if(guard) guard.classList.remove('visible');
        if(hazardMap) {
          hazardMap.scrollWheelZoom.enable();
          // On mobile, dragging / doubleClickZoom / tap stay gated
          // behind the explicit tap so single-finger gestures don't
          // hijack page scroll. touchZoom stays always-on so two-
          // finger pinch always works.
          if (isMobile) {
            hazardMap.dragging.enable();
            hazardMap.doubleClickZoom.enable();
            if (hazardMap.tap) hazardMap.tap.enable();
          }
        }
        mapActive = true;
      }

      function reengage(){
        if(!mapActive) return;
        if(hazardMap) {
          hazardMap.scrollWheelZoom.disable();
          if (isMobile) {
            hazardMap.dragging.disable();
            hazardMap.doubleClickZoom.disable();
            if (hazardMap.tap) hazardMap.tap.disable();
          }
        }
        mapActive = false;
      }

      window.dismissMapGuard = function(){
        dismiss();
      };

      container.addEventListener('click', function(e){ e.stopPropagation(); dismiss(); });
      container.addEventListener('wheel', function(e){
        if(e.ctrlKey || e.metaKey) dismiss();
      });

      // Any click within the hazard widget (tabs, overlays, etc.) also dismisses
      if(widget){
        widget.addEventListener('click', function(){
          if(!mapActive) dismiss();
        });
      }

      // Re-engage scroll-zoom lock when clicking outside the widget
      document.addEventListener('click', function(e){
        if(mapActive && widget && !widget.contains(e.target)){
          reengage();
        }
      });
      // Also re-engage when scrolling outside the map area
      var _mapScrollTick = false;
      document.addEventListener('scroll', function(){
        if(!mapActive || _mapScrollTick) return;
        _mapScrollTick = true;
        requestAnimationFrame(function(){
          var rect = container.getBoundingClientRect();
          if(rect.bottom < 100 || rect.top > window.innerHeight - 100){
            reengage();
          }
          _mapScrollTick = false;
        });
      }, {passive:true});
    })();

    // Satellite basemap
    var baseTiles = L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}', {
      attribution: '&copy; Esri',
      errorTileUrl: 'data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==',
      maxNativeZoom: 17,
      updateWhenZooming: false,
      updateWhenIdle: true,
      keepBuffer: 4
    }).addTo(hazardMap);

    // Retry failed tiles once after a short delay
    baseTiles.on('tileerror', function(e){
      var tile = e.tile;
      var src = tile._originalSrc || tile.src;
      var retries = tile._retryCount || 0;
      if(retries < 2 && src.includes('arcgisonline')){
        tile._retryCount = retries + 1;
        tile._originalSrc = src;
        setTimeout(function(){ tile.src = src; }, 2000 * Math.pow(2, retries));
      }
    });

    // Hide preview image once satellite tiles have fully loaded
    // Use 'load' event which fires when ALL visible tiles finish, not just some
    var _previewHidden = false;
    function hidePreview(){
      if(_previewHidden) return;
      _previewHidden = true;
      ['hazard-preview-img','hazard-preview-fires'].forEach(function(id){
        var el = document.getElementById(id);
        if(el){ el.style.transition='opacity .6s ease'; el.style.opacity='0'; el._tilesLoaded=true; setTimeout(function(){ el.style.display='none'; },700); }
      });
    }
    baseTiles.on('load', hidePreview);
    // Safety fallback: hide preview after 8s even if some tiles are slow
    setTimeout(hidePreview, 8000);

    // Labels on top
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_only_labels/{z}/{x}/{y}{r}.png', {
      attribution: TILE_ATTRIB,
      pane: 'shadowPane',
      updateWhenZooming: false,
      updateWhenIdle: true,
      keepBuffer: 4
    }).addTo(hazardMap);

    // Create layer groups for each hazard type
    window._fireLayerGroup = L.layerGroup().addTo(hazardMap);
    window._tornadoLayerGroup = L.layerGroup().addTo(hazardMap);
    window._tornadoOutlookGroup = L.layerGroup();
    window._quakeLayerGroup = L.layerGroup();

    // Alias all three map variables to the shared map
    fireMap = hazardMap;
    tornadoMap = hazardMap;
    quakeMap = hazardMap;

    // Custom panes for deterministic smoke layer stacking
    hazardMap.createPane('smokeWms');
    hazardMap.getPane('smokeWms').style.zIndex = 350;
    hazardMap.getPane('smokeWms').style.mixBlendMode = 'multiply';
    hazardMap.createPane('smokeHms');
    hazardMap.getPane('smokeHms').style.zIndex = 420;

    // Macrostrat geology overlay (starts OFF — user toggles on)
    window._quakeGeoVisible = false;
    window.quakeGeoTileLayer = L.tileLayer('https://tiles.macrostrat.org/carto/{z}/{x}/{y}.png', {
      attribution: '&copy; Macrostrat',
      opacity: 0.6,
      updateWhenZooming: false,
      updateWhenIdle: true,
      keepBuffer: 3
    });

    // Pause expensive CSS animations during zoom/pan
    var mapContainer = hazardMap.getContainer();
    hazardMap.on('zoomstart movestart', function(){
      mapContainer.classList.add('hz-map-moving');
    });
    hazardMap.on('zoomend moveend', function(){
      // Small delay so the final repaint settles before re-enabling animations
      setTimeout(function(){ mapContainer.classList.remove('hz-map-moving'); }, 300);
    });

    // Click handler for geology popup (only active in quake mode)
    hazardMap.on('click', function(e){
      if (hazardActiveTab === 'quake' && window._quakeGeoVisible) {
        fetchGeologyForQuakeMap(e.latlng.lat, e.latlng.lng, e.latlng);
      }
    });

    // Location marker removed for cleaner map

    // ── LAZY TAB INIT: only load the active tab's heavy data ──
    // Badge counts are already populated by the boot prefetch (Tier 2),
    // so tabs show counts immediately. Map layers load on first switch.
    window._hazardTabLoaded = {};

    // Fire is the default tab — init it now
    initFireData();
    window._hazardTabLoaded.fire = true;

    // Set initial tab state — init fire data but show overview by default
    window._hazardTabInitializing = true;
    switchHazardTab('fire');
    switchHazardTab('overview');
    setTimeout(function(){ window._hazardTabInitializing = false; }, 2000);
    // Re-apply after fire data loads (markers load async)
    setTimeout(function(){ if(hazardActiveTab !== 'overview') switchHazardTab(hazardActiveTab); }, 5000);
    setTimeout(function(){ if(hazardActiveTab !== 'overview') switchHazardTab(hazardActiveTab); }, 7000);
  }

