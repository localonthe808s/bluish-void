  // ── STORM SWITCHER — clickable pill bar for multi-storm navigation ──────────
  function _buildStormSwitcher(storms) {
    var existing = document.getElementById('hz-storm-switcher');
    if (existing) existing.remove();
    if (!storms || storms.length === 0 || !_hurricaneMap) return;

    var container = document.getElementById('hazard-hurricane-container');
    if (!container) return;

    var sw = document.createElement('div');
    sw.id = 'hz-storm-switcher';
    sw.style.cssText = 'position:absolute;top:8px;left:50%;transform:translateX(-50%);z-index:900;display:flex;gap:4px;pointer-events:auto;font-family:system-ui,sans-serif;max-width:calc(100% - 320px);overflow-x:auto;scrollbar-width:none;';

    storms.forEach(function(storm, idx) {
      var name = (storm.name || storm.stormName || 'System').toUpperCase();
      var windKt = parseInt(storm.intensity || storm.maxWinds || 0);
      var color = hurricaneIntensityColor(windKt);
      var cat = windKt < 34 ? 'TD' : windKt < 64 ? 'TS' : windKt < 83 ? 'C1' : windKt < 96 ? 'C2' : windKt < 113 ? 'C3' : windKt < 137 ? 'C4' : 'C5';
      var lat = parseFloat(storm.centerLocLatitude || storm.lat);
      var lon = parseFloat(storm.centerLocLongitude || storm.lon);

      var pill = document.createElement('button');
      pill.style.cssText = 'display:flex;align-items:center;gap:5px;padding:6px 12px;border-radius:20px;border:1px solid ' + color + '40;background:rgba(0,0,0,.82);backdrop-filter:blur(14px);color:' + color + ';font-size:.56rem;font-weight:800;cursor:pointer;white-space:nowrap;letter-spacing:.04em;transition:all .15s;';
      pill.innerHTML = '<span style="width:8px;height:8px;border-radius:50%;background:' + color + ';display:inline-block;flex-shrink:0;"></span>' + name + ' <span style="font-weight:500;opacity:.6;">' + cat + '</span>';

      pill.addEventListener('mouseenter', function() { pill.style.background = color + '20'; pill.style.borderColor = color + '80'; });
      pill.addEventListener('mouseleave', function() { pill.style.background = 'rgba(0,0,0,.82)'; pill.style.borderColor = color + '40'; });

      pill.addEventListener('click', function() {
        if (!isNaN(lat) && !isNaN(lon)) {
          _hurricaneMap.flyTo([lat, lon], 6, { duration: 1 });
          // Find and open the corresponding storm marker popup
          setTimeout(function() {
            _hurricaneLayerObjs.stormMarkers.forEach(function(m) {
              try {
                var mLatLng = m.getLatLng();
                if (Math.abs(mLatLng.lat - lat) < 0.5 && Math.abs(mLatLng.lng - lon) < 0.5) {
                  m.openPopup();
                }
              } catch(e){}
            });
          }, 1100);
        }
      });

      sw.appendChild(pill);
    });

    // Only show switcher if 1+ storms (even 1 storm benefits from a quick-access pill)
    container.appendChild(sw);
  }

  function _plotNHCStorm(storm) {
    if (!_hurricaneMap) return;
    var lat = parseFloat(storm.centerLocLatitude || storm.lat);
    var lon = parseFloat(storm.centerLocLongitude || storm.lon);
    if (isNaN(lat) || isNaN(lon)) return;

    var windKt = parseInt(storm.intensity || storm.maxWinds || 0);
    var color = hurricaneIntensityColor(windKt);
    var label = hurricaneCategoryLabel(windKt);
    var name = (storm.name || storm.stormName || 'Unnamed').toUpperCase();
    var windMph = Math.round(windKt * 1.15078);
    var pressure = storm.minimumPressure || storm.minPressure || '—';
    var movDir = parseFloat(storm.movementDir) || null;
    var movSpd = parseFloat(storm.movementSpeed) || null;
    var _dirs16 = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
    var movCompass = movDir != null ? _dirs16[Math.round(movDir / 22.5) % 16] : '';
    var movText = movDir != null ? movCompass + ' at ' + movSpd + ' mph (' + movDir + '°)' : '—';

    // Size by category
    var sz = windKt < 34 ? 36 : windKt < 64 ? 44 : windKt < 83 ? 52 : windKt < 113 ? 60 : 70;
    var half = sz / 2;

    // SVG spiral arms (3-arm cyclonic shape)
    function spiralSVG(size, col) {
      var c = size / 2;
      var r1 = size * 0.38, r2 = size * 0.18, r3 = size * 0.08;
      // 3 arms offset 120deg each, curving inward
      function arm(startDeg) {
        var pts = [];
        for (var i = 0; i <= 12; i++) {
          var t = i / 12;
          var angle = (startDeg + t * 200) * Math.PI / 180;
          var r = r1 * (1 - t * 0.72);
          pts.push((c + Math.cos(angle) * r).toFixed(2) + ',' + (c + Math.sin(angle) * r).toFixed(2));
        }
        return pts.join(' ');
      }
      var svgParts = [
        '<svg width="' + size + '" height="' + size + '" viewBox="0 0 ' + size + ' ' + size + '" xmlns="http://www.w3.org/2000/svg" style="overflow:visible;">',
        // Outer glow ring — pulsing
        '<circle cx="' + c + '" cy="' + c + '" r="' + (r1 + 4) + '" fill="none" stroke="' + col + '" stroke-width="' + (size * 0.04) + '" opacity="0.18" style="animation:badge-pulse-critical 1.8s ease-in-out infinite;transform-origin:' + c + 'px ' + c + 'px"/>',
        // Mid ring
        '<circle cx="' + c + '" cy="' + c + '" r="' + (r2 + 2) + '" fill="none" stroke="' + col + '" stroke-width="' + (size * 0.025) + '" opacity="0.4"/>',
        // 3 spiral arms
        '<polyline points="' + arm(0) + '" fill="none" stroke="' + col + '" stroke-width="' + (size * 0.055) + '" stroke-linecap="round" opacity="0.9"/>',
        '<polyline points="' + arm(120) + '" fill="none" stroke="' + col + '" stroke-width="' + (size * 0.055) + '" stroke-linecap="round" opacity="0.9"/>',
        '<polyline points="' + arm(240) + '" fill="none" stroke="' + col + '" stroke-width="' + (size * 0.055) + '" stroke-linecap="round" opacity="0.9"/>',
        // Eye — dark center dot
        '<circle cx="' + c + '" cy="' + c + '" r="' + r3 + '" fill="#0a0a14" stroke="' + col + '" stroke-width="1.5" opacity="1"/>',
        '</svg>'
      ];
      return svgParts.join('');
    }

    // Movement arrow SVG (drawn separately, anchored at storm center)
    var arrowHtml = '';
    if (movDir != null && movSpd != null) {
      var arrowLen = Math.max(20, Math.min(50, movSpd * 2.2));
      var rad = (movDir - 90) * Math.PI / 180; // rotate so 0=north
      var dx = Math.cos(rad) * arrowLen;
      var dy = Math.sin(rad) * arrowLen;
      var cx = arrowLen + 6, cy = arrowLen + 6;
      var x2 = cx + dx, y2 = cy + dy;
      var svgW = (arrowLen + 6) * 2, svgH = (arrowLen + 6) * 2;
      arrowHtml = '<div style="position:absolute;top:' + (half - cy) + 'px;left:' + (half - cx) + 'px;pointer-events:none;z-index:2;">' +
        '<svg width="' + svgW + '" height="' + svgH + '" viewBox="0 0 ' + svgW + ' ' + svgH + '" xmlns="http://www.w3.org/2000/svg">' +
        '<defs><marker id="arrowhead-' + name + '" markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto">' +
        '<path d="M0,0 L6,3 L0,6 Z" fill="' + color + '" opacity="0.85"/></marker></defs>' +
        '<line x1="' + cx + '" y1="' + cy + '" x2="' + x2 + '" y2="' + y2 + '" stroke="' + color + '" stroke-width="1.8" opacity="0.7" marker-end="url(#arrowhead-' + name + ')"/>' +
        '</svg></div>';
    }

    // Name label above marker
    var catShort = windKt < 34 ? 'TD' : windKt < 64 ? 'TS' : windKt < 83 ? 'C1' : windKt < 96 ? 'C2' : windKt < 113 ? 'C3' : windKt < 137 ? 'C4' : 'C5';
    var labelHtml = '<div style="position:absolute;bottom:' + (sz + 4) + 'px;left:50%;transform:translateX(-50%);white-space:nowrap;pointer-events:none;text-align:center;">' +
      '<span style="font-family:system-ui,sans-serif;font-size:.5rem;font-weight:900;color:' + color + ';letter-spacing:.08em;text-shadow:0 0 8px #000,0 1px 3px #000;">' + name + '</span>' +
      '<span style="font-family:system-ui,sans-serif;font-size:.38rem;font-weight:700;color:' + color + ';background:rgba(0,0,0,.65);border-radius:3px;padding:0 3px;margin-left:4px;letter-spacing:.04em;">' + catShort + '</span>' +
      '</div>';

    // Wind speed label below
    var windLabel = '<div style="position:absolute;top:' + (sz + 2) + 'px;left:50%;transform:translateX(-50%);white-space:nowrap;pointer-events:none;">' +
      '<span style="font-family:system-ui,sans-serif;font-size:.38rem;color:rgba(255,255,255,.6);text-shadow:0 0 6px #000;">' + windMph + ' mph</span>' +
      '</div>';

    // ── RI (Rapid Intensification) probability indicator ──
    var ri = _assessRIProbability(storm);
    var riHtml = '';
    if (ri.label) {
      var riRing = sz * 0.55;
      riHtml = '<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:3;">' +
        '<div style="width:' + (sz + 16) + 'px;height:' + (sz + 16) + 'px;border-radius:50%;border:2px solid ' + ri.color + ';opacity:0.6;animation:badge-pulse-critical 1.2s ease-in-out infinite;"></div>' +
        '</div>' +
        '<div style="position:absolute;top:-2px;right:-8px;z-index:4;pointer-events:none;">' +
        '<span style="display:inline-block;padding:1.5px 4px;border-radius:3px;font-family:system-ui;font-size:.3rem;font-weight:900;letter-spacing:.06em;background:' + ri.color + ';color:#000;text-shadow:none;white-space:nowrap;">RI ' + ri.label + '</span>' +
        '</div>';
    }

    var markerHtml = '<div style="position:relative;width:' + sz + 'px;height:' + sz + 'px;">' +
      labelHtml + arrowHtml + riHtml + spiralSVG(sz, color) + windLabel +
      '</div>';

    var stormIcon = L.divIcon({
      className: '',
      html: markerHtml,
      iconSize: [sz, sz],
      iconAnchor: [half, half]
    });

    var marker = L.marker([lat, lon], { icon: stormIcon, zIndexOffset: 1000, pane: 'hz-track' });
    // ── Hover tooltip — compact quick-glance ──
    marker.bindTooltip(
      '<div class="hz-tooltip">' +
      '<div class="hz-card-head"><span>' + name + '</span></div>' +
      '<div class="hz-card-row"><span class="hz-label">Type</span><span class="hz-val" style="color:' + color + ';">' + label + '</span></div>' +
      '<div class="hz-card-row"><span class="hz-label">Winds</span><span class="hz-val">' + windMph + ' mph (' + windKt + ' kt)</span></div>' +
      '<div class="hz-card-row"><span class="hz-label">Pressure</span><span class="hz-val">' + pressure + ' mb</span></div>' +
      '<div class="hz-card-row"><span class="hz-label">Movement</span><span class="hz-val">' + movText + '</span></div>' +
      (ri.label ? '<div class="hz-card-row"><span class="hz-label">RI Risk</span><span class="hz-val" style="color:' + ri.color + ';font-weight:900;">' + ri.label + ' (' + ri.prob + '%)</span></div>' : '') +
      '<div class="hz-card-footer">Click for full details</div>' +
      '</div>',
      { sticky: true, className: 'hz-tooltip', opacity: 1 }
    );

    // ── Click popup — rich storm detail card ──
    var stormBin = _resolveStormBin(storm);
    var popupHtml = _buildStormDetailPopup(storm, name, windKt, windMph, color, label, pressure, movDir, movSpd, lat, lon, stormBin);
    marker.bindPopup(popupHtml, {
      className: 'hz-storm-popup',
      maxWidth: 320,
      minWidth: 260,
      autoPan: true,
      autoPanPaddingTopLeft: [10, 60],
      autoPanPaddingBottomRight: [10, 20]
    });

    // Trigger async wind history + CPA fetch when popup opens
    marker.on('popupopen', function() {
      if (stormBin) _enrichStormPopup(stormBin, lat, lon, name);
    });

    marker.addTo(_hurricaneMap);
    _hurricaneLayerObjs.stormMarkers.push(marker);

    // Fetch storm-specific GIS data (cone + track + wind radii) from NHC MapServer
    if (_hurricaneLayers.track) {
      _fetchStormTrackFromNowcoast(storm.id || storm.atcfID, name, color);
    }
  }

  // ── Build rich storm detail popup HTML ──────────────────────────────────────
  function _buildStormDetailPopup(storm, name, windKt, windMph, color, label, pressure, movDir, movSpd, lat, lon, stormBin) {
    var stormId = storm.id || storm.atcfID || '';
    var classification = (storm.classification || '').toUpperCase();
    var lastUpdate = storm.lastUpdate || '';

    // ── Compass bearing from degrees ──
    function compassDir(deg) {
      if (deg == null) return '—';
      var dirs = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
      return dirs[Math.round(deg / 22.5) % 16];
    }
    var movCompass = movDir != null ? compassDir(movDir) : null;
    var movText = movCompass ? movCompass + ' at ' + movSpd + ' mph (' + movDir + '°)' : '—';

    // ── Saffir-Simpson intensity bar (0-160kt range) ──
    var barPct = Math.min(100, Math.max(2, (windKt / 160) * 100));
    // Gradient stops matching Saffir-Simpson scale
    var barGrad = 'linear-gradient(90deg, #5eead4 0%, #5eead4 21%, #67e8f9 21%, #67e8f9 40%, #fde68a 40%, #fde68a 52%, #fbbf24 52%, #fbbf24 60%, #f97316 60%, #f97316 71%, #ef4444 71%, #ef4444 86%, #9333ea 86%)';
    // Category thresholds as % of 160kt: TD<34=21%, TS<64=40%, C1<83=52%, C2<96=60%, C3<113=71%, C4<137=86%

    // ── Pressure analysis ──
    var pressVal = parseInt(pressure);
    var pressContext = '';
    var pressColor = 'rgba(255,255,255,.6)';
    if (!isNaN(pressVal)) {
      if (pressVal <= 920) { pressContext = 'Extremely intense'; pressColor = '#9333ea'; }
      else if (pressVal <= 945) { pressContext = 'Very intense'; pressColor = '#ef4444'; }
      else if (pressVal <= 965) { pressContext = 'Intense'; pressColor = '#f97316'; }
      else if (pressVal <= 985) { pressContext = 'Moderate'; pressColor = '#fbbf24'; }
      else if (pressVal <= 1000) { pressContext = 'Weak low'; pressColor = '#67e8f9'; }
      else { pressContext = 'Minimal'; pressColor = 'rgba(255,255,255,.5)'; }
    }

    // ── Rapid intensification check ──
    // RI definition: ≥30kt increase in 24h (we flag if winds already at RI-threshold categories)
    var riRisk = '';
    var riColor = '';
    // SST-based RI potential: if storm is between 10-25°N and over warm water (proxy: in MDR), flag it
    var inMDR = lat >= 8 && lat <= 25 && lon >= -80 && lon <= -15;
    var isStrong = windKt >= 50 && windKt <= 110; // Sweet spot for RI
    if (inMDR && isStrong) {
      riRisk = 'ELEVATED';
      riColor = '#f97316';
    } else if (windKt >= 111) {
      riRisk = 'AT/NEAR PEAK';
      riColor = '#ef4444';
    } else if (windKt < 50 && inMDR) {
      riRisk = 'POSSIBLE';
      riColor = '#fbbf24';
    }

    // ── Storm size context ──
    var sizeNote = '';
    if (windKt >= 137) sizeNote = 'Catastrophic wind field — life-threatening surge, extreme destruction within eyewall';
    else if (windKt >= 113) sizeNote = 'Devastating damage expected — complete roof failures, large trees uprooted';
    else if (windKt >= 96) sizeNote = 'Extensive damage — well-built homes sustain major roof & siding damage';
    else if (windKt >= 83) sizeNote = 'Dangerous winds — some structural damage to well-built homes';
    else if (windKt >= 64) sizeNote = 'Minimal hurricane — some damage to roofing, siding, gutters, large branches';
    else if (windKt >= 50) sizeNote = 'Strong tropical storm — significant tree and power line damage likely';
    else if (windKt >= 34) sizeNote = 'Tropical storm force — minor structural damage, power outages possible';
    else sizeNote = 'Depression-strength circulation — heavy rain primary threat';

    // ── NHC direct links ──
    var nhcBaseId = stormId.toLowerCase();
    var nhcLinks = '';
    if (nhcBaseId) {
      // NHC advisory URL patterns
      nhcLinks += '<a class="sd-link" href="https://www.nhc.noaa.gov/refresh/graphics_' + nhcBaseId.substring(0,2) + nhcBaseId.substring(2,4) + '+shtml/' + nhcBaseId + '_5day_cone_with_line_and_wind.png" target="_blank">Cone Graphic</a>';
      nhcLinks += '<a class="sd-link" href="https://www.nhc.noaa.gov/storm_graphics/' + nhcBaseId.toUpperCase() + '/' + nhcBaseId + '_wind_probs_34_F120.png" target="_blank">Wind Probabilities</a>';
    }
    nhcLinks += '<a class="sd-link" href="https://www.nhc.noaa.gov/" target="_blank">NHC Home</a>';

    // ── Assemble the popup HTML ──
    var R = function(lbl, val, valColor) {
      return '<div class="sd-row"><span class="sd-label">' + lbl + '</span><span class="sd-val"' + (valColor ? ' style="color:' + valColor + ';"' : '') + '>' + val + '</span></div>';
    };

    var html = '<div class="hz-storm-detail">';

    // Header
    html += '<div class="sd-head" style="color:' + color + ';">' + name + '</div>';
    var subParts = [label];
    if (stormId) subParts.push(stormId.toUpperCase());
    if (lastUpdate) subParts.push('Updated ' + lastUpdate);
    html += '<div class="sd-sub">' + subParts.join(' · ') + '</div>';

    // Intensity bar
    html += '<div class="sd-section">INTENSITY</div>';
    html += '<div class="sd-bar-track" style="background:rgba(255,255,255,.04);">';
    html += '<div style="position:absolute;inset:0;border-radius:4px;' + barGrad + ';opacity:0.25;"></div>';
    html += '<div class="sd-bar-fill" style="width:' + barPct + '%;background:' + color + ';position:relative;z-index:1;"></div>';
    html += '</div>';
    html += '<div class="sd-bar-labels"><span>TD</span><span>TS</span><span>C1</span><span>C2</span><span>C3</span><span>C4</span><span>C5</span></div>';

    html += R('Maximum sustained winds', windMph + ' mph (' + windKt + ' kt)', color);
    html += R('Minimum central pressure', pressure + ' mb' + (!isNaN(pressVal) ? ' — ' + pressContext : ''), pressColor);

    // Wind speed in other units (kt, km/h) — professionals think in kt
    var windKmh = Math.round(windKt * 1.852);
    html += '<div style="font-size:.38rem;color:rgba(255,255,255,.25);margin-top:1px;">' + windKmh + ' km/h · Gusts estimated at ' + Math.round(windMph * 1.2) + ' mph</div>';

    // Pressure-wind relationship check — if pressure is anomalously low for the wind speed, note it
    if (!isNaN(pressVal) && windKt >= 64) {
      // Dvorak pressure-wind: expected P ≈ 1015 - (windKt/1.08)^1.18 (rough approximation)
      var expectedP = Math.round(1015 - Math.pow(windKt / 1.08, 1.18));
      if (pressVal < expectedP - 8) {
        html += '<div style="font-size:.38rem;color:rgba(139,92,246,.5);margin-top:1px;">Pressure unusually low for wind speed — may still be intensifying</div>';
      } else if (pressVal > expectedP + 8) {
        html += '<div style="font-size:.38rem;color:rgba(255,255,255,.3);margin-top:1px;">Pressure higher than typical for this intensity — possible weakening trend</div>';
      }
    }

    if (riRisk) {
      html += '<div style="margin:5px 0;"><span class="sd-ri-badge" style="background:' + riColor.replace(')', ',.15)').replace('rgb','rgba') + ';color:' + riColor + ';border:1px solid ' + riColor.replace(')', ',.3)').replace('rgb','rgba') + ';">RI POTENTIAL: ' + riRisk + '</span></div>';
    }

    // Show RI factors from the detailed assessment (Tier 1 _assessRIProbability)
    var riDetail = _assessRIProbability(storm);
    if (riDetail.factors && riDetail.factors.length > 0) {
      html += '<div style="font-size:.36rem;color:rgba(255,255,255,.3);margin:2px 0 0;">';
      html += 'Factors: ' + riDetail.factors.join(' · ');
      html += ' · Score: ' + riDetail.prob + '%</div>';
    }

    // SST at storm position (async-filled by _enrichStormPopup)
    html += '<div id="hz-sst-at-storm-' + (stormBin || stormId) + '" style="min-height:0;"></div>';

    // Impact context
    html += '<div style="font-size:.4rem;color:rgba(255,255,255,.45);margin:4px 0 2px;line-height:1.5;font-style:italic;">' + sizeNote + '</div>';

    html += '<hr class="sd-divider">';

    // Position & Movement
    html += '<div class="sd-section">POSITION & MOVEMENT</div>';
    html += R('Center', lat.toFixed(1) + '°N, ' + Math.abs(lon).toFixed(1) + '°' + (lon < 0 ? 'W' : 'E'));
    html += R('Movement', movText);

    // Distance from nearest US coast (approximate — major reference points)
    var coastPts = [
      [25.8,-80.1,'Miami'],[30.4,-87.2,'Pensacola'],[29.9,-90.1,'New Orleans'],
      [27.8,-97.4,'Corpus Christi'],[32.8,-79.9,'Charleston'],[34.7,-76.7,'Cape Hatteras'],
      [29.0,-95.1,'Galveston'],[30.2,-85.7,'Panama City'],[26.1,-81.8,'Naples'],
      [40.5,-74.0,'NYC'],[41.8,-71.4,'Providence'],[18.5,-66.1,'San Juan']
    ];
    var nearestDist = 99999, nearestName = '';
    coastPts.forEach(function(cp) {
      var dLat = (lat - cp[0]) * 69;
      var dLon = (lon - cp[1]) * 69 * Math.cos(lat * Math.PI / 180);
      var d = Math.sqrt(dLat * dLat + dLon * dLon);
      if (d < nearestDist) { nearestDist = d; nearestName = cp[2]; }
    });
    if (nearestDist < 2000) {
      html += R('Nearest coast', Math.round(nearestDist) + ' mi from ' + nearestName);
      if (movSpd > 0 && nearestDist < 500) {
        var etaHrs = Math.round(nearestDist / movSpd);
        html += '<div style="font-size:.38rem;color:rgba(255,255,255,.35);margin-top:1px;">At current speed: ~' + etaHrs + ' hours to ' + nearestName + '</div>';
      }
    }
    if (movSpd != null) {
      var spdContext = movSpd < 5 ? 'Near-stationary — prolonged rainfall threat' :
                       movSpd < 10 ? 'Slow mover — extended wind & rain impacts' :
                       movSpd < 20 ? 'Moderate forward speed' :
                       'Fast mover — less rain but broader wind swath';
      html += '<div style="font-size:.38rem;color:rgba(255,255,255,.35);margin-top:1px;">' + spdContext + '</div>';
    }

    html += '<hr class="sd-divider">';

    // ── Wind History Sparkline placeholder (collapsible, async-filled) ──
    var whId = 'sd-wh-' + (stormBin || stormId);
    html += '<div style="margin:0 -16px;"><label for="' + whId + '-tog" style="display:flex;justify-content:space-between;align-items:center;cursor:pointer;padding:4px 16px;"><span class="sd-section" style="margin:0;">INTENSITY TIMELINE</span><span class="sd-tog" style="font-size:.38rem;color:rgba(255,255,255,.25);">▾</span></label>';
    html += '<input type="checkbox" id="' + whId + '-tog" checked style="display:none;">';
    html += '<div class="sd-collapse" style="padding:0 16px;">';
    html += '<div id="hz-wind-history-' + stormBin + '" style="min-height:20px;"></div>';
    html += '</div></div>';

    // ── Model Intensity Guidance placeholder (collapsible, async-filled from ATCF) ──
    var igId = 'sd-ig-' + (stormBin || stormId);
    html += '<div style="margin:0 -16px;"><label for="' + igId + '-tog" style="display:flex;justify-content:space-between;align-items:center;cursor:pointer;padding:4px 16px;"><span class="sd-section" style="margin:0;">INTENSITY GUIDANCE</span><span class="sd-tog" style="font-size:.38rem;color:rgba(255,255,255,.25);">▾</span></label>';
    html += '<input type="checkbox" id="' + igId + '-tog" style="display:none;">';
    html += '<div class="sd-collapse" style="padding:0 16px;">';
    html += '<div id="hz-intensity-guidance-' + stormBin + '" style="min-height:10px;"></div>';
    html += '</div></div>';

    // ── GOES Satellite Floater (collapsible, shows live storm imagery) ──
    var satId = 'sd-sat-' + (stormBin || stormId);
    html += '<div style="margin:0 -16px;"><label for="' + satId + '-tog" style="display:flex;justify-content:space-between;align-items:center;cursor:pointer;padding:4px 16px;"><span class="sd-section" style="margin:0;">SATELLITE IMAGERY</span><span class="sd-tog" style="font-size:.38rem;color:rgba(255,255,255,.25);">▾</span></label>';
    html += '<input type="checkbox" id="' + satId + '-tog" checked style="display:none;">';
    html += '<div class="sd-collapse" style="padding:0 16px;">';
    html += '<div id="hz-sat-floater-' + (stormBin || stormId) + '" style="min-height:20px;"></div>';
    html += '</div></div>';

    html += '<hr class="sd-divider">';

    // ── Closest Approach Calculator placeholder (collapsible, async-filled) ──
    var cpId = 'sd-cp-' + (stormBin || stormId);
    html += '<div style="margin:0 -16px;"><label for="' + cpId + '-tog" style="display:flex;justify-content:space-between;align-items:center;cursor:pointer;padding:4px 16px;"><span class="sd-section" style="margin:0;">YOUR LOCATION</span><span class="sd-tog" style="font-size:.38rem;color:rgba(255,255,255,.25);">▾</span></label>';
    html += '<input type="checkbox" id="' + cpId + '-tog" checked style="display:none;">';
    html += '<div class="sd-collapse" style="padding:0 16px;">';
    html += '<div id="hz-cpa-' + stormBin + '" style="min-height:20px;"></div>';
    html += '</div></div>';

    html += '<hr class="sd-divider">';

    // ── NHC Key Messages placeholder (collapsible, async-filled) ──
    html += '<div id="hz-keymsg-' + (stormBin || stormId) + '" style="min-height:10px;"></div>';

    // ── Historical Analog Storms (collapsible, static) ──
    var analogs = _findAnalogStorms(lat, lon, new Date().getMonth() + 1);
    if (analogs.length > 0) {
      html += '<hr class="sd-divider">';
      var anId = 'sd-an-' + (stormBin || stormId);
      html += '<div style="margin:0 -16px;"><label for="' + anId + '-tog" style="display:flex;justify-content:space-between;align-items:center;cursor:pointer;padding:4px 16px;"><span class="sd-section" style="margin:0;">HISTORICAL ANALOGS</span><span class="sd-tog" style="font-size:.38rem;color:rgba(255,255,255,.25);">▾</span></label>';
      html += '<input type="checkbox" id="' + anId + '-tog" style="display:none;">';
      html += '<div class="sd-collapse" style="padding:0 16px;">';
      html += '<div style="font-size:.36rem;color:rgba(255,255,255,.3);margin-bottom:4px;">Storms that tracked through this region at similar times</div>';
      analogs.forEach(function(a) {
        var aCatColor = hurricaneIntensityColor(a.wind);
        // Compare analog peak intensity to current storm
        var comparison = '';
        var aWindKt = Math.round(a.wind / 1.15);
        if (aWindKt > windKt + 15) comparison = '<span style="font-size:.36rem;color:rgba(239,68,68,.5);"> — peaked stronger</span>';
        else if (aWindKt < windKt - 15) comparison = '<span style="font-size:.36rem;color:rgba(74,222,128,.5);"> — peaked weaker</span>';
        else comparison = '<span style="font-size:.36rem;color:rgba(255,255,255,.3);"> — similar peak</span>';
        html += '<div style="margin-bottom:5px;padding:4px 6px;border-radius:5px;background:rgba(255,255,255,.03);border-left:3px solid ' + aCatColor + ';">';
        html += '<div style="font-size:.44rem;font-weight:700;color:' + aCatColor + ';">' + a.name + ' <span style="font-weight:400;color:rgba(255,255,255,.4);">' + a.cat + ' · ' + a.wind + ' mph</span>' + comparison + '</div>';
        html += '<div style="font-size:.38rem;color:rgba(255,255,255,.5);margin-top:1px;">' + a.track + '</div>';
        html += '<div style="font-size:.36rem;color:rgba(255,255,255,.35);font-style:italic;margin-top:1px;">' + a.note + '</div>';
        html += '</div>';
      });
      html += '<div style="font-size:.32rem;color:rgba(255,255,255,.18);margin-top:2px;">Source: HURDAT2 / IBTrACS · Analogs are informational, not forecasts</div>';
      html += '</div></div>'; // close sd-collapse + outer wrapper
    }

    html += '<hr class="sd-divider">';

    // NHC Links
    html += '<div class="sd-section">NHC RESOURCES</div>';
    html += '<div style="display:flex;flex-wrap:wrap;gap:0;">' + nhcLinks + '</div>';

    // Attribution
    html += '<div style="margin-top:8px;font-size:.34rem;color:rgba(255,255,255,.2);">Source: NHC Official Advisory · mapservices.weather.noaa.gov</div>';

    html += '</div>';
    return html;
  }

  // ── Map storm binNumber → base layer IDs in the new NHC MapServer ──
  // AT1=4, AT2=30, AT3=56, AT4=82, AT5=108, EP1=134, EP2=160, EP3=186, EP4=212, EP5=238, CP1=264...
  var _NHC_STORM_LAYER_MAP = {};
  (function(){
    var bins = ['AT1','AT2','AT3','AT4','AT5','EP1','EP2','EP3','EP4','EP5','CP1','CP2','CP3','CP4','CP5'];
    bins.forEach(function(b, i){ _NHC_STORM_LAYER_MAP[b] = 4 + i * 26; });
  })();

  // Resolve the bin slot from storm data — NHC CurrentStorms.json includes binNumber (e.g. "AT1")
  // or we derive it from the ATCF ID (e.g. "al012025" → AT1)
  function _resolveStormBin(storm) {
    if (storm.binNumber) return storm.binNumber.toUpperCase();
    var id = (storm.id || storm.atcfID || '').toLowerCase();
    if (!id || id.length < 4) return null;
    var basin = id.substring(0,2);
    var num = parseInt(id.substring(2,4));
    if (isNaN(num) || num < 1 || num > 5) return null;
    if (basin === 'al') return 'AT' + num;
    if (basin === 'ep') return 'EP' + num;
    if (basin === 'cp') return 'CP' + num;
    return null;
  }

  function _fetchStormTrackFromNowcoast(stormId, name, color) {
    if (!_hurricaneMap) return;

    // ── New NHC MapServer at mapservices.weather.noaa.gov ──
    var baseUrl = 'https://mapservices.weather.noaa.gov/tropical/rest/services/tropical/NHC_tropical_weather/MapServer/';
    var q = '?where=1%3D1&outFields=*&f=geojson&outSR=4326';

    // Resolve which storm slot to query
    var bin = _resolveStormBin({ id: stormId, binNumber: window._nhcActiveStorms ?
      (window._nhcActiveStorms.find(function(s){ return (s.id||s.atcfID) === stormId; }) || {}).binNumber : null
    });

    // If we can resolve the bin, use per-storm layers (most accurate)
    if (bin && _NHC_STORM_LAYER_MAP[bin] != null) {
      var base = _NHC_STORM_LAYER_MAP[bin];
      // Per-storm layer offsets from base:
      //   +2 = Forecast Points, +3 = Forecast Track, +4 = Forecast Cone, +5 = Watch-Warning
      //   +7 = Past Points, +8 = Past Track, +9 = Cumulative Wind Swath
      //   +12 = Forecast Wind Radii, +13 = Advisory Wind Field
      //   +14 = Arrival Time of TS Winds (group), +21 = Inundation Image (raster)
      var coneLyr   = base + 4;  // Forecast Cone
      var fPtsLyr   = base + 2;  // Forecast Points
      var fTrackLyr = base + 3;  // Forecast Track (line)
      var wwLyr     = base + 5;  // Watch-Warning
      var pastPtsLyr  = base + 7;   // Past Points
      var pastTrackLyr = base + 8;  // Past Track (line)
      var windSwathLyr = base + 9;  // Cumulative Wind Swath (past)
      var windRadiiLyr = base + 12; // Forecast Wind Radii (current position)
      var windFieldLyr = base + 13; // Advisory Wind Field (wind radii at forecast hours)
      var arrivalEarlyLyr = base + 15; // Earliest Reasonable Arrival Time of TS Winds
      var arrivalLikelyLyr = base + 16; // Most Likely Arrival Time of TS Winds
      var surgeLyr     = base + 21; // Inundation Image (raster)

      _fetchStormCone(baseUrl, coneLyr, q, name);
      _fetchStormForecastPts(baseUrl, fPtsLyr, q, name);
      _fetchStormForecastLine(baseUrl, fTrackLyr, q, name, color);
      _fetchStormWatchWarn(baseUrl, wwLyr, q, name);
      _fetchStormPastTrack(baseUrl, pastPtsLyr, pastTrackLyr, q, name);
      _fetchStormWindRadii(baseUrl, windRadiiLyr, q, name);
      _fetchForecastWindField(baseUrl, windFieldLyr, q, name);
      _fetchWindArrivalTime(baseUrl, arrivalEarlyLyr, arrivalLikelyLyr, q, name);
      _fetchCumulativeWindSwath(baseUrl, windSwathLyr, q, name);
      _fetchStormSurgeInundation(baseUrl, surgeLyr, bin, name);

      // Wind probability contours — 34/50/64 kt probability from NHC
      // These are in a separate MapServer: NHC_tropical_cyclone_wind_speed_probabilities
      _fetchWindProbability(name);

      // Global overlays triggered by active storms:
      // QPF / Excessive Rainfall outlook from WPC
      _fetchWPCExcessiveRainfall(name);
      // SPC tornado probabilities (if within CONUS landfall window)
      var stormLat = parseFloat(stormId ? ((window._nhcActiveStorms||[]).find(function(s){return (s.id||s.atcfID)===stormId;})||{}).centerLocLatitude : 0);
      var stormLon = parseFloat(stormId ? ((window._nhcActiveStorms||[]).find(function(s){return (s.id||s.atcfID)===stormId;})||{}).centerLocLongitude : 0);
      if (stormLat > 20 && stormLat < 50 && stormLon > -105 && stormLon < -60) {
        _fetchSPCTornadoOutlook(name);
      }
      // Recon data (fetched globally, not per-bin)
      _fetchReconData(name);
    } else {
      // Fallback: query all AT slots (AT1-AT5) and hope for the best
      console.warn('Hurricane: could not resolve bin for', stormId, '— scanning all AT slots');
      for (var i = 1; i <= 5; i++) {
        var fallbackBase = _NHC_STORM_LAYER_MAP['AT' + i];
        _fetchStormCone(baseUrl, fallbackBase + 4, q, name);
        _fetchStormForecastPts(baseUrl, fallbackBase + 2, q, name);
        _fetchStormForecastLine(baseUrl, fallbackBase + 3, q, name, color);
        _fetchStormPastTrack(baseUrl, fallbackBase + 7, fallbackBase + 8, q, name);
      }
    }
  }

  // ── CONE OF UNCERTAINTY ──
