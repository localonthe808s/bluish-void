    // ── Lazy popup builder — only constructs HTML when marker is clicked ──
    function _buildFirePopup(e){
      var marker = e.target;
      var d = marker._fireData;
      if (!d) return;
      var p = d.props || {};
      var acresStr = d.acres > 0 ? (p._unit === 'ha' ? d.acres.toLocaleString() + ' ha (' + Math.round(d.acres * 2.471).toLocaleString() + ' acres)' : d.acres.toLocaleString() + ' acres') : 'Size unknown';
      var typeLabel = d.isPrescribed ? 'PRESCRIBED BURN' : (d.country === 'SAT' ? 'THERMAL DETECTION' : 'WILDFIRE');
      var ac = d.isPrescribed ? '#15803d' : d.country === 'SAT' ? '#be185d' : '#c2410c';
      var h = '<div class="hz-card-head"><div class="hz-accent" style="background:'+ac+';"></div><span style="color:'+ac+';">'+typeLabel+'</span></div>';

      h += '<div class="hz-card-row"><span class="hz-label">Name</span><span class="hz-val">'+d.name+'</span></div>';

      // Location: County, State
      if(p.POOCounty || p.POOState){
        var loc = '';
        if(p.POOCounty) loc += p.POOCounty + (p.POOCounty.toString().toLowerCase().indexOf('county') < 0 ? ' County' : '');
        if(p.POOState) loc += (loc ? ', ' : '') + p.POOState.toString().replace('US-','');
        h += '<div class="hz-card-row"><span class="hz-label">Location</span><span class="hz-val">'+loc+'</span></div>';
      }

      // Size with growth indicator
      var sizeHtml = acresStr;
      if(d.acres > 0 && p.DiscoveryAcres && p.DiscoveryAcres > 0 && d.acres > p.DiscoveryAcres){
        var growthX = (d.acres / p.DiscoveryAcres);
        if(growthX >= 2){
          var gCol = growthX >= 100 ? '#b91c1c' : growthX >= 10 ? '#c2410c' : '#a16207';
          sizeHtml += ' <span style="color:'+gCol+';font-size:9px;font-weight:700;">(' + (growthX >= 10 ? Math.round(growthX) : growthX.toFixed(1)) + '× growth)</span>';
        }
      }
      h += '<div class="hz-card-row"><span class="hz-label">Size</span><span class="hz-val">'+sizeHtml+'</span></div>';

      // Containment
      if(d.contained > 0){
        var contCol = d.contained >= 80 ? '#047857' : d.contained >= 40 ? '#a16207' : '#b91c1c';
        h += '<div class="hz-card-row"><span class="hz-label">Contained</span><span class="hz-val" style="color:'+contCol+';">'+d.contained+'%</span></div>';
      }

      // Burning for N days
      if(p.FireDiscoveryDateTime){
        var discoTime = new Date(p.FireDiscoveryDateTime).getTime();
        if(!isNaN(discoTime)){
          var days = Math.floor((Date.now() - discoTime) / (24*60*60*1000));
          var dayStr = days === 0 ? 'Today' : days === 1 ? 'Yesterday' : days + ' days ago';
          h += '<div class="hz-card-row"><span class="hz-label">Discovered</span><span class="hz-val">'+dayStr+'</span></div>';
        }
      }

      // Personnel deployed
      if(p.TotalIncidentPersonnel && p.TotalIncidentPersonnel > 0){
        h += '<div class="hz-card-row"><span class="hz-label">Personnel</span><span class="hz-val">'+parseInt(p.TotalIncidentPersonnel).toLocaleString()+'</span></div>';
      }

      // Incident management complexity — Type 1 is most complex
      if(p.FireMgmtComplexity){
        var complexity = p.FireMgmtComplexity.toString();
        var cplxCol = complexity.indexOf('1') >= 0 ? '#b91c1c' : complexity.indexOf('2') >= 0 ? '#c2410c' : complexity.indexOf('3') >= 0 ? '#a16207' : 'rgba(43,34,244,.68)';
        h += '<div class="hz-card-row"><span class="hz-label">Complexity</span><span class="hz-val" style="color:'+cplxCol+';">'+complexity+'</span></div>';
      }

      // Incident management organization (e.g. Type 1 IMT)
      if(p.IncidentManagementOrganization && !p.FireMgmtComplexity){
        h += '<div class="hz-card-row"><span class="hz-label">Managed by</span><span class="hz-val">'+p.IncidentManagementOrganization+'</span></div>';
      }

      // Impact — only show if non-zero (critical info)
      var fatalities = parseInt(p.Fatalities) || 0;
      var injuries = parseInt(p.Injuries) || 0;
      var residences = parseInt(p.ResidencesDestroyed) || 0;
      var otherStructs = parseInt(p.OtherStructuresDestroyed) || 0;
      if(fatalities > 0 || injuries > 0 || residences > 0 || otherStructs > 0){
        var impactParts = [];
        if(fatalities > 0) impactParts.push('<span style="color:#7f1d1d;font-weight:800;">'+fatalities+' killed</span>');
        if(injuries > 0) impactParts.push('<span style="color:#b91c1c;font-weight:800;">'+injuries+' injured</span>');
        if(residences > 0) impactParts.push('<span style="color:#c2410c;font-weight:800;">'+residences+' homes</span>');
        if(otherStructs > 0) impactParts.push(otherStructs+' structures');
        h += '<div class="hz-card-row"><span class="hz-label">Impact</span><span class="hz-val">'+impactParts.join(' · ')+'</span></div>';
      }

      // Fuel group (what it's burning in)
      if(p.PredominantFuelGroup){
        h += '<div class="hz-card-row"><span class="hz-label">Fuel</span><span class="hz-val">'+p.PredominantFuelGroup+'</span></div>';
