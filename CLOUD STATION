    }
    if (!_hurricaneMap) return;

    if (which === 'sst') {
      if (on) {
        if (!_hurricaneLayerObjs.sst) {
          // GHRSST MUR L4 SST via NASA GIBS WMTS — confirmed working
          // JPL Multi-scale Ultra-high Resolution SST, ~1km daily blended product
          _hurricaneLayerObjs.sst = L.tileLayer(
            'https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/GHRSST_L4_MUR_Sea_Surface_Temperature/default/GoogleMapsCompatible_Level7/{z}/{y}/{x}.png',
