  function preloadGoesImages(){
    if (!goesFrames.length) return;
    goesImages = [];
    var loaded = 0;
    var total = goesFrames.length;
    var overlay = document.getElementById('goes-loading-overlay');
    var loadText = document.getElementById('goes-loading-text');
    if (overlay) { overlay.style.opacity = '1'; overlay.style.display = 'flex'; }
    if (loadText) loadText.textContent = 'CHASING CLOUDS 0/' + total;
    if (goesLiveEl) goesLiveEl.textContent = "• LOADING 0%";

    var INITIAL_BATCH = Math.min(6, total);
    var BG_BATCH_SIZE = 3;
    var animStarted = false;
    var safetyTimer = null;

    function updateProgress(){
      loaded++;
      var pct = Math.round(loaded/total*100);
      if (goesLiveEl) goesLiveEl.textContent = animStarted ? "• LIVE " + pct + "%" : "• LOADING " + pct + "%";
      if (loadText) loadText.textContent = 'CHASING CLOUDS ' + loaded + '/' + total;
      if (loaded === total){
        if (goesLiveEl) goesLiveEl.textContent = "• LIVE";
        if (loadText) loadText.textContent = '';
        // Rebuild stream with all frames — cancel old loop first
        if (animStarted) {
          if (goesAnimId) { cancelAnimationFrame(goesAnimId); goesAnimId = null; }
          startGoesCanvasAnim();
        }
      }
    }

    function loadFrame(i, cb){
      var img = new Image();
      img.crossOrigin = "anonymous";
      img.onload = function(){ updateProgress(); if (cb) cb(); };
      img.onerror = function(){ updateProgress(); if (cb) cb(); };
      img.src = goesFrames[i];
      goesImages[i] = img;
    }

    var initialLoaded = 0;
    for (var i = 0; i < INITIAL_BATCH; i++){
      (function(idx){
        loadFrame(idx, function(){
          initialLoaded++;
          if (initialLoaded >= INITIAL_BATCH && !animStarted){
            animStarted = true;
            if (safetyTimer) { clearTimeout(safetyTimer); safetyTimer = null; }
            if (overlay) { overlay.style.opacity = '0'; setTimeout(function(){ overlay.style.display = 'none'; }, 600); }
            startGoesCanvasAnim();
            loadBackgroundBatch(INITIAL_BATCH);
          }
        });
      })(i);
    }

    function loadBackgroundBatch(startIdx){
      if (startIdx >= total) return;
      var end = Math.min(startIdx + BG_BATCH_SIZE, total);
      var batchDone = 0;
      var batchSize = end - startIdx;
      for (var j = startIdx; j < end; j++){
        (function(idx){
          loadFrame(idx, function(){
            batchDone++;
            if (batchDone >= batchSize){
              setTimeout(function(){ loadBackgroundBatch(end); }, 100);
            }
          });
        })(j);
      }
    }

    // Safety: if initial batch takes >8s, start with whatever we have
    safetyTimer = setTimeout(function(){
      safetyTimer = null;
      if (!animStarted && loaded > 0){
        animStarted = true;
        if (overlay) { overlay.style.opacity = '0'; setTimeout(function(){ overlay.style.display = 'none'; }, 600); }
        startGoesCanvasAnim();
        loadBackgroundBatch(INITIAL_BATCH);
      }
    }, 8000);
  }

  function drawGoesFrame(ctx, img, w, h){
    if (!img || !img.complete || !img.naturalWidth) return;
    // Cover the canvas (like object-fit:cover)
    var iw = img.naturalWidth, ih = img.naturalHeight;
    var scale = Math.max(w/iw, h/ih);
    var dw = iw * scale, dh = ih * scale;
    var dx = (w - dw) / 2, dy = (h - dh) / 2;
    ctx.drawImage(img, dx, dy, dw, dh);
  }

  function startGoesCanvasAnim(){
    if (!goesCanvas || goesImages.length < 2) {
      // If only 1 frame, just draw it
      if (goesCanvas && goesImages.length === 1){
        var ctx = goesCanvas.getContext('2d');
        var rect = goesCanvas.getBoundingClientRect();
        goesCanvas.width = rect.width * (window.devicePixelRatio || 1);
        goesCanvas.height = rect.height * (window.devicePixelRatio || 1);
        ctx.setTransform(window.devicePixelRatio || 1, 0, 0, window.devicePixelRatio || 1, 0, 0);
        drawGoesFrame(ctx, goesImages[0], rect.width, rect.height);
      }
      return;
    }

    if (goesAnimId) cancelAnimationFrame(goesAnimId);

    var s = goesAnimState;
    s.position = 0;
    s.lastTime = 0;
    s.playing = true;

    var ctx = goesCanvas.getContext('2d');
    if (typeof window._goesSleeping === 'undefined') window._goesSleeping = false;

    var STEPS = 10;
    // Free previous stream canvases
    if (window._goesStream) {
      window._goesStream.length = 0;
    }
    window._goesStream = [];
    var stream = window._goesStream;
    var streamReady = false;
    var _goesLastStreamFrame = -1;

    function buildStream(){
      var n = goesImages.length;
      if (n < 2) { streamReady = true; return; }

      var rect = goesCanvas.getBoundingClientRect();
      var w = Math.round(rect.width);
      var h = Math.round(rect.height);
      var comp = document.createElement('canvas');
      comp.width = w;
      comp.height = h;
      var cctx = comp.getContext('2d');
      stream.length = 0;
      var pair = 0;

      function processPair(){
        if (pair >= n - 1) {
          streamReady = true;
          comp = null; cctx = null;
          return;
        }
        var imgA = goesImages[pair];
        var imgB = goesImages[pair + 1];
        for (var step = 0; step < STEPS; step++){
          var blend = step / STEPS;
          cctx.globalAlpha = 1;
          cctx.clearRect(0, 0, w, h);
          drawGoesFrame(cctx, imgA, w, h);
          if (blend > 0) {
            cctx.globalAlpha = blend;
            drawGoesFrame(cctx, imgB, w, h);
            cctx.globalAlpha = 1;
          }
          var snap = document.createElement('canvas');
          snap.width = w;
          snap.height = h;
          snap.getContext('2d').drawImage(comp, 0, 0);
          stream.push(snap);
        }
        pair++;
        if (pair % 3 === 0) { setTimeout(processPair, 0); }
        else { processPair(); }
      }
      processPair();
    }

    buildStream();

    // Playback — forward only with hold on last frame + subtle opacity dip on reset
    var HOLD_MS = 2000;       // hold last frame 2s
    var DIP_MS = 200;         // opacity dip duration
    var holdStart = 0;
    var dipPhase = 0;         // 0=normal, 1=holding, 2=dipping-down, 3=dipping-up

    function animate(timestamp){
      // Always keep this closure as the latest resume target.
      window._goesResumeFn = animate;
      // Full pause (no rAF reschedule) when tab is hidden or canvas off-screen.
      if (document.hidden || !window._goesCanvasVisible) { return; }
      if (!s.playing || window._goesSleeping) { goesAnimId = requestAnimationFrame(animate); return; }
      if (!streamReady || stream.length === 0) { goesAnimId = requestAnimationFrame(animate); return; }

      if (!s.lastTime) s.lastTime = timestamp;
      var dt = timestamp - s.lastTime;
      s.lastTime = timestamp;
      if (dt > 200) dt = 16;

      var total = stream.length;
      var n = goesImages.length;

      // Handle hold + dip at end of loop
      if (dipPhase === 1) {
        // Holding on last frame
        if (timestamp - holdStart >= HOLD_MS) {
          dipPhase = 2;
          holdStart = timestamp;
        }
        goesAnimId = requestAnimationFrame(animate);
        return;
      }
      if (dipPhase === 2) {
        // Dipping opacity down
        var dipProg = Math.min((timestamp - holdStart) / DIP_MS, 1);
        goesCanvas.style.opacity = 1 - (dipProg * 0.15);
        if (dipProg >= 1) {
          // Jump to frame 0
          s.position = 0;
          _goesLastStreamFrame = -1;
          dipPhase = 3;
          holdStart = timestamp;
        }
        goesAnimId = requestAnimationFrame(animate);
        return;
      }
      if (dipPhase === 3) {
        // Dipping opacity back up
        var upProg = Math.min((timestamp - holdStart) / DIP_MS, 1);
        goesCanvas.style.opacity = 0.85 + (upProg * 0.15);
        if (upProg >= 1) {
          goesCanvas.style.opacity = 1;
          dipPhase = 0;
        }
        goesAnimId = requestAnimationFrame(animate);
        return;
      }

      // Normal forward playback
      s.position += dt / 65;

      // Reached the end — draw final frame, then enter hold phase
      if (s.position >= total) {
        s.position = total - 1;
        var pw = window._goesDisplaySize.w || goesCanvas.width;
        var ph = window._goesDisplaySize.h || goesCanvas.height;
        if (goesCanvas.width !== pw || goesCanvas.height !== ph){
          goesCanvas.width = pw; goesCanvas.height = ph;
          ctx = goesCanvas.getContext('2d');
        }
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.drawImage(stream[total - 1], 0, 0, pw, ph);
        if (goesFrameEl) goesFrameEl.textContent = n + "/" + n;
        _goesLastStreamFrame = total - 1;
        dipPhase = 1;
        holdStart = timestamp;
        goesAnimId = requestAnimationFrame(animate);
        return;
      }

      var frame = Math.floor(s.position) % total;

      if (frame !== _goesLastStreamFrame) {
        _goesLastStreamFrame = frame;

        var pw = window._goesDisplaySize.w || goesCanvas.width;
        var ph = window._goesDisplaySize.h || goesCanvas.height;
        if (goesCanvas.width !== pw || goesCanvas.height !== ph){
          goesCanvas.width = pw;
          goesCanvas.height = ph;
          ctx = goesCanvas.getContext('2d');
        }
        ctx.setTransform(1, 0, 0, 1, 0, 0);
        ctx.drawImage(stream[frame], 0, 0, pw, ph);

        if (goesFrameEl) goesFrameEl.textContent = Math.floor(frame / STEPS + 1) + "/" + n;
      }

      goesAnimId = requestAnimationFrame(animate);
    }

    goesAnimId = requestAnimationFrame(animate);

    // Refresh frames periodically
    if (goesRefreshTimer) clearInterval(goesRefreshTimer);
    goesRefreshTimer = setInterval(function(){
      if (document.hidden) return;
      fetchGoesFrames().then(function(){ preloadGoesImages(); });
    }, 5 * 60 * 1000);
  }

  function startGoesAutoplay(){
    fetchGoesFrames().then(function(){ preloadGoesImages(); });
  }

  /* =========================================================
     SPACE WEATHER ANIMATIONS
     (Geospace Velocity/Density/Pressure, WSA-Enlil, LASCO C2/C3)
     ========================================================= */
  
  // Animation state for each widget
  var animations = {
    geoVel:  { frames: [], idx: 0, playing: true, timer: null, imgEl: null, liveEl: null, btnEl: null },
    geoDen:  { frames: [], idx: 0, playing: true, timer: null, imgEl: null, liveEl: null, btnEl: null },
    geoPre:  { frames: [], idx: 0, playing: true, timer: null, imgEl: null, liveEl: null, btnEl: null },
    enlil:   { frames: [], idx: 0, playing: true, timer: null, imgEl: null, liveEl: null, btnEl: null },
    lascoC3: { frames: [], idx: 0, playing: true, timer: null, imgEl: null, liveEl: null, btnEl: null },
    lascoC2: { frames: [], idx: 0, playing: true, timer: null, imgEl: null, liveEl: null, btnEl: null }
  };
  

  
  // Generic animation runner
  function runAnimation(key, fps){
    var anim = animations[key];
    if (!anim || !anim.imgEl) return;
    var delay = adjustedDelay(fps, anim.frames);
    
    function step(){
      if (anim.playing && anim.frames.length > 0){
        anim.imgEl.src = anim.frames[anim.idx];
        anim.idx = (anim.idx + 1) % anim.frames.length;
      }
      anim.timer = setTimeout(step, delay);
    }
    step();
  }
  
  // Load animation frames from SWPC JSON
  function loadAnimationFrames(jsonUrl, key, fps, fallbackUrl){
    var anim = animations[key];
    if (!anim || !anim.imgEl) return;
    var shMap = {enlil:'swpc-enlil', lascoC3:'soho-c3', lascoC2:'soho-c2'};
    var shId = shMap[key];
    
    if (anim.liveEl) anim.liveEl.textContent = "• LOADING";
    
    fetchWithTimeout(jsonUrl, null, 15000)
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data && data.length > 0){
          anim.frames = thinFrames(data.map(function(f){
            return "https://services.swpc.noaa.gov" + f.url;
          }), 60);
          if (anim.liveEl) anim.liveEl.textContent = "• LIVE";
          if (shId) SH.ok(shId);
          runAnimation(key, fps);
        } else {
          throw new Error("No frames");
        }
      })
      .catch(function(){
        if (shId) SH.fail(shId, function(){ loadAnimationFrames(jsonUrl, key, fps, fallbackUrl); });
        // Fallback to static image
        if (fallbackUrl){
          anim.imgEl.src = fallbackUrl + "?cb=" + Date.now();
        }
        if (anim.liveEl) anim.liveEl.textContent = "• LIVE";
        if (anim.btnEl) anim.btnEl.style.display = "none";
      });
  }
  
  // Load static/GIF images with periodic refresh (for sources without JSON)
  
    // Frame budget — skip every other frame for large animation sets (200+)
    // For sets under 200, keep all frames for smooth playback
    function thinFrames(arr, maxFrames) {
      if (!arr || arr.length <= 200) return arr;
      var result = [];
      for (var i = 0; i < arr.length; i += 2) {
        result.push(arr[i]);
      }
      result.push(arr[arr.length - 1]);
      result._origLen = arr.length;
      return result;
    }

    // Calculate adjusted delay so thinned animation plays at same total duration as original
    function adjustedDelay(originalFps, frames) {
      if (!frames || !frames._origLen || frames._origLen <= frames.length) {
        return 1000 / originalFps;
      }
      return (frames._origLen / originalFps * 1000) / frames.length;
    }

    function initSpaceWeatherAnimations(){
    // Bind DOM elements
    animations.enlil.imgEl = document.getElementById("enlil-img");
    animations.enlil.liveEl = document.getElementById("enlil-live");
    animations.enlil.btnEl = document.getElementById("enlil-btn");
    
    animations.lascoC3.imgEl = document.getElementById("lasco-c3-img");
    animations.lascoC3.liveEl = document.getElementById("lasco-c3-live");
    animations.lascoC3.btnEl = document.getElementById("lasco-c3-btn");
    
    animations.lascoC2.imgEl = document.getElementById("lasco-c2-img");
    animations.lascoC2.liveEl = document.getElementById("lasco-c2-live");
    animations.lascoC2.btnEl = document.getElementById("lasco-c2-btn");
    
    // Load WSA-Enlil animation (8 fps - faster for solar wind)
    loadAnimationFrames(
      "https://services.swpc.noaa.gov/products/animations/enlil.json",
      "enlil", 8,
      "https://services.swpc.noaa.gov/images/animations/enlil/latest.jpg"
    );
    
    // Stagger LASCO + Geospace to avoid saturating SWPC connections
    setTimeout(function(){
      loadAnimationFrames(
        "https://services.swpc.noaa.gov/products/animations/lasco-c3.json",
        "lascoC3", 6,
        "https://soho.nascom.nasa.gov/data/realtime/c3/512/latest.jpg"
      );
    }, 800);
    
    setTimeout(function(){
      loadAnimationFrames(
        "https://services.swpc.noaa.gov/products/animations/lasco-c2.json",
        "lascoC2", 6,
        "https://soho.nascom.nasa.gov/data/realtime/c2/512/latest.jpg"
      );
    }, 1600);
    
    // Load Geospace animated images (after LASCO starts)
    setTimeout(function(){
      loadGeospaceAnimations();
    }, 2400);
  }
  
  function loadGeospaceAnimations(){
    var geoWidgets = [
      { id: "geo-vel-img", liveId: "geo-vel-live", jsonUrl: "https://services.swpc.noaa.gov/products/animations/geospace/velocity.json" },
      { id: "geo-den-img", liveId: "geo-den-live", jsonUrl: "https://services.swpc.noaa.gov/products/animations/geospace/density.json" },
      { id: "geo-pre-img", liveId: "geo-pre-live", jsonUrl: "https://services.swpc.noaa.gov/products/animations/geospace/pressure.json" }
    ];
    
    geoWidgets.forEach(function(w){
      var imgEl = document.getElementById(w.id);
      var liveEl = document.getElementById(w.liveId);
      if (!imgEl) return;
      
      var frames = [];
      var frameIndex = 0;
      var animInterval = null;
      var frameDelay = 150; // base: ~6.6 fps for full frame set, adjusted after thinning
      
      function fetchFrames(){
        if (liveEl) liveEl.textContent = "• LOADING";
        var shId = w.id === 'geo-vel-img' ? 'swpc-geo-vel' : w.id === 'geo-den-img' ? 'swpc-geo-den' : 'swpc-geo-pre';
        
        fetch(w.jsonUrl + "?cb=" + Date.now())
          .then(function(r){ 
            if (!r.ok) throw new Error("Fetch failed");
            return r.json(); 
          })
          .then(function(data){
            if (!Array.isArray(data) || data.length === 0) throw new Error("No frames");
            SH.ok(shId);
            frames = thinFrames(data.map(function(f){ return "https://services.swpc.noaa.gov" + f.url; }));
            if (frames._origLen) frameDelay = adjustedDelay(6.67, frames);
            if (liveEl) { liveEl.style.color = ''; }
            preloadFrames();
          })
          .catch(function(err){
            console.error("Geospace animation error:", err);
            SH.fail(shId, fetchFrames);
            if (liveEl) { liveEl.textContent = "• SWPC OFFLINE"; liveEl.style.color = 'rgba(239,68,68,.7)'; }
            imgEl.style.opacity = "0.15";
            imgEl.alt = "SWPC Geospace feed temporarily unavailable";
          });
      }
      
      function preloadFrames(){
        var loaded = 0;
        var total = Math.min(frames.length, 50);
        var INITIAL = Math.min(5, total);
        var animStarted = false;

        function loadOne(i, cb){
          var img = new Image();
          img.onload = img.onerror = function(){ loaded++; if (cb) cb(); };
          img.src = frames[i];
        }

        // Phase 1: Load first 5, start animation
        var initDone = 0;
