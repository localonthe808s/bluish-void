    }

    // CPC 6-10 and 8-14 day precipitation outlooks use a different service
    var url;
    var isCPC = false;
    if(layerId === '_cpc610'){
      url = 'https://mapservices.weather.noaa.gov/vector/rest/services/outlooks/cpc_6_10_day_outlk/MapServer/1/query?where=1%3D1&outFields=*&f=geojson';
      isCPC = true;
    } else if(layerId === '_cpc814'){
      url = 'https://mapservices.weather.noaa.gov/vector/rest/services/outlooks/cpc_8_14_day_outlk/MapServer/1/query?where=1%3D1&outFields=*&f=geojson';
      isCPC = true;
    } else if(day === 'd3' && hazType === 'flood'){
      // Merge ERO days 3, 4, 5 into one view (flood only)
      var urls = [2,3,4].map(function(id){ return cfg.base + id + '/query?where=1%3D1&outFields=*&f=geojson'; });
      Promise.all(urls.map(function(u){ return fetch(u).then(function(r){ return r.json(); }).catch(function(){ return {features:[]}; }); }))
        .then(function(results){
          var allFeatures = [];
          results.forEach(function(d){ if(d && d.features) allFeatures = allFeatures.concat(d.features); });
          if(!allFeatures.length) return;
          var merged = { type:'FeatureCollection', features: allFeatures };
          var colorFn = outlookColors[hazType];
          var layer = L.geoJSON(merged, {
            style: function(feature){
              var c = colorFn(feature.properties || {});
              return { fillColor: c.fill, fillOpacity: c.opacity, color: c.stroke, weight: 1.5, opacity: 0.6 };
            },
            onEachFeature: function(feature, lyr){
              var props = feature.properties || {};
              var label = (props.outlook || props.LABEL || props.label || props.idp_source || '').toLowerCase();
              var dn = props.dn || props.DN || 0;
              var riskName, riskColor, riskDesc;
              if (dn >= 4 || label.indexOf('high') >= 0) { riskName = 'HIGH RISK'; riskColor = '#9333ea'; riskDesc = 'High confidence in life-threatening flash flooding. Extreme rainfall rates expected. This is a rare, dangerous outlook — issued only a few times per year.'; }
              else if (dn >= 3 || label.indexOf('moderate') >= 0) { riskName = 'MODERATE RISK'; riskColor = '#ef4444'; riskDesc = 'Significant flash flooding likely over a broad area. Rainfall rates may exceed 2-3\"/hr. Urban flooding and dangerous river rises expected.'; }
              else if (dn >= 2 || label.indexOf('slight') >= 0) { riskName = 'SLIGHT RISK'; riskColor = '#f97316'; riskDesc = 'Flash flooding possible, especially in poor-drainage and low-lying areas. Localized rainfall could exceed flash flood guidance.'; }
              else if (dn >= 1 || label.indexOf('marginal') >= 0) { riskName = 'MARGINAL RISK'; riskColor = '#eab308'; riskDesc = 'Limited flash flood risk. Brief heavy rainfall may cause localized ponding or minor urban flooding in susceptible areas.'; }
              else { riskName = 'OUTLOOK AREA'; riskColor = '#06b6d4'; riskDesc = 'Precipitation hazard area identified by WPC for the extended period.'; }

              // Get day from product field
              var dayStr = 'Days 3-5';
              var product = props.product || '';
              if (product.indexOf('Day 3') >= 0) dayStr = 'Day 3';
              else if (product.indexOf('Day 4') >= 0) dayStr = 'Day 4';
              else if (product.indexOf('Day 5') >= 0) dayStr = 'Day 5';

              // Override valid/expire from actual fields for buildEROPopup
              if (props.start_time && !props.VALID) {
                var st = new Date(props.start_time);
                var et = props.end_time ? new Date(props.end_time) : null;
                if (!isNaN(st.getTime())) {
                  props.VALID = st.getUTCFullYear().toString() + String(st.getUTCMonth()+1).padStart(2,'0') + String(st.getUTCDate()).padStart(2,'0') + String(st.getUTCHours()).padStart(2,'0') + String(st.getUTCMinutes()).padStart(2,'0');
                }
                if (et && !isNaN(et.getTime())) {
                  props.EXPIRE = et.getUTCFullYear().toString() + String(et.getUTCMonth()+1).padStart(2,'0') + String(et.getUTCDate()).padStart(2,'0') + String(et.getUTCHours()).padStart(2,'0') + String(et.getUTCMinutes()).padStart(2,'0');
                }
              }

              var tt = buildEROPopup(feature, riskName, riskColor, riskDesc, dayStr);
              lyr.bindPopup(tt, { className: 'hz-popup', maxWidth: 340 });
            }
          });
          outlookLayers[hazType] = layer;
          if (hazType === 'flood') SH.ok('wpc-ero');
          layer.addTo(hazardMap);
        });
      return;
    } else {
      url = cfg.base + layerId + '/query?where=1%3D1&outFields=*&f=geojson';
    }

    fetch(url).then(function(r){ return r.json(); }).then(function(data){
      if(!data || !data.features || data.features.length === 0) return;

      var colorFn = isCPC ? function(props){
        var cat = (props.cat || props.Cat || props.CAT || props.LABEL || props.label || '').toString().toLowerCase();
        if(cat.indexOf('above') >= 0 || cat.indexOf('much above') >= 0) return { fill:'#06b6d4', stroke:'#0891b2', opacity:0.3 };
        if(cat.indexOf('below') >= 0 || cat.indexOf('much below') >= 0) return { fill:'#f97316', stroke:'#ea580c', opacity:0.2 };
        if(cat.indexOf('near normal') >= 0 || cat.indexOf('normal') >= 0) return { fill:'#84cc16', stroke:'#65a30d', opacity:0.1 };
        // Probability-based
        var prob = parseFloat(props.prob || props.PROB || props.Prob || 0);
        if(prob >= 60) return { fill:'#06b6d4', stroke:'#0891b2', opacity:0.35 };
        if(prob >= 40) return { fill:'#22d3ee', stroke:'#06b6d4', opacity:0.25 };
        if(prob >= 33) return { fill:'#67e8f9', stroke:'#22d3ee', opacity:0.15 };
        return { fill:'#06b6d4', stroke:'#0891b2', opacity:0.12 };
      } : outlookColors[hazType];

      var dayLabels = {d1:'Day 1', d2:'Day 2', d3:'Days 3-5', d6:'6-10 Day', d8:'8-14 Day'};
      var sourceLabels = isCPC ? 'CPC Precipitation Outlook' : 'WPC Excessive Rainfall';
      var typeLabels = {fire:'Fire Weather', tornado:'Convective', flood: isCPC ? 'CPC Precip' : 'Excessive Rainfall'};
      var typeEmoji = {fire:'🔥', tornado:'🌪️', flood:'🌊'};

      var layer = L.geoJSON(data, {
        style: function(feature){
