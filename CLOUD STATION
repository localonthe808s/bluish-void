            if (typeof hourly.cloud_cover_high[cli]==='number') hSum+=hourly.cloud_cover_high[cli];
          }
        }
        var aL = lCnt>0?Math.round(lSum/lCnt):0, aM = lCnt>0?Math.round(mSum/lCnt):0, aH = lCnt>0?Math.round(hSum/lCnt):0;
        // Get current wind at each layer for shear arrows
        var _ni = nearestIndex != null ? nearestIndex : (window._wxNearestIdx || 0);
        var _wdH = hourly.winddirection_300hPa ? hourly.winddirection_300hPa[_ni] : null;
        var _wsH = hourly.windspeed_300hPa ? Math.round(hourly.windspeed_300hPa[_ni] * 0.621) : null; // km/h to mph
        var _wdM = hourly.winddirection_500hPa ? hourly.winddirection_500hPa[_ni] : null;
