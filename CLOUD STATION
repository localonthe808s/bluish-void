                _topG=Math.round(248-_rd*40);
                _topB=Math.round(228-_rd*60);
                _midR=Math.round(238+_wm*15-_rd*5);
                _midG=Math.round(200-_wm*15-_rd*22);
                _midB=Math.round(165-_wm*22-_rd*30);
                _botR=Math.round(220+_wm*30);
                _botG=Math.round(155-_wm*30);
                _botB=Math.round(110-_wm*40);
                _shR=Math.round(180+_wm*15); _shG=Math.round(125-_wm*15); _shB=Math.round(85-_wm*20);
                _hiR=255; _hiG=253; _hiB=240; _hiOp=1.0;
              } else if(isNight){
                // Moonlit cumulus — dim cool blue-grey, very low tonal range
                _topR=78;  _topG=82;  _topB=108;
                _midR=52;  _midG=56;  _midB=84;
                _botR=34;  _botG=37;  _botB=60;
                _shR=26;   _shG=28;   _shB=48;
                _hiR=140;  _hiG=148;  _hiB=178; _hiOp=0.32;
              } else if(_renderSa<=0){
                // Civil twilight — blue-purple dim
                _topR=118; _topG=120; _topB=150;
                _midR=82;  _midG=84;  _midB=118;
                _botR=55;  _botG=56;  _botB=92;
                _shR=42;   _shG=43;   _shB=78;
                _hiR=190;  _hiG=190;  _hiB=215; _hiOp=0.45;
              } else {
                // Daytime — bright neutral white-grey
                _topR=248; _topG=250; _topB=255;
                _midR=212; _midG=216; _midB=226;
                _botR=168; _botG=174; _botB=192;
                _shR=138;  _shG=144;  _shB=162;
                _hiR=255;  _hiG=255;  _hiB=255; _hiOp=0.85;
              }
              // Underside warmth + top highlight colors (only used at golden hour)
              var _underR=Math.min(255,_botR+30), _underG=Math.max(120,_botG-5), _underB=Math.max(80,_botB-10);

              // Thermal-cluster layout (unchanged from prior — still good)
              var _blKm = Math.max(0.5, (cloudData.blh||1500)/1000);
              var _nTherm = Math.max(1, Math.min(nC, Math.round(3/Math.sqrt(_blKm))));
              var _thermalCx = [];
              for(var _ti=0; _ti<_nTherm; _ti++){
                _thermalCx.push(xOff + 25 + _ti*((pW-50)/_nTherm) + (R()-0.5)*12);
              }
              var _placedCx = [];

              // Pre-assign depth tier per cloud (preview-lab tuned). 35% far /
              // 35% mid / 30% near distributes the field for receding-toward-
              // horizon perspective. Far tier sits at horizon (smaller, flatter,
              // hazier). Near tier sits higher in panel (larger, crisp). Sort
              // far→near so near clouds occlude distant ones.
              var _cuInst = [];
              for (var _ci = 0; _ci < nC; _ci++) {
                var _tRoll = R();
                var _tier = (_tRoll < 0.35) ? 0 : (_tRoll < 0.70) ? 1 : 2;
                var _tierD = _tier === 0 ? (0.20 + R()*0.20) : _tier === 1 ? (0.50 + R()*0.20) : (0.78 + R()*0.20);
