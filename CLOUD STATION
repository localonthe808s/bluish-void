          svg += '<div style="position:absolute;left:'+pct.toFixed(2)+'%;top:-3px;bottom:-3px;width:3px;background:rgba(43,34,244,.95);border-radius:2px;box-shadow:0 0 0 2px rgba(255,255,255,.85);transform:translateX(-50%);"></div>';
          svg += '</div>';
          // Scale labels
          svg += '<div style="display:flex;justify-content:space-between;font-size:8px;font-weight:700;color:rgba(43,34,244,.5);letter-spacing:.04em;margin-top:4px;margin-bottom:6px;">' +
            '<span>0 QUIET</span><span style="color:#99cc00;">3</span><span style="color:#ff9900;">5 G1</span><span style="color:#ff3300;">7 G3</span><span style="color:#990033;">9 G5</span>' +
