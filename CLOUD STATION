      var badge = tag.querySelector('.sh-badge-dot');
      if (health !== 'ok') {
        if (!badge) {
          badge = document.createElement('span');
          badge.className = 'sh-badge-dot';
          tag.appendChild(badge);
        }
        badge.style.background = health === 'offline' ? '#ef4444' : '#f97316';
      } else if (badge) {
        badge.remove();
      }
    },

    setLiveTag: function(widgetId, liveTagId) {
      if (!SH.widgets[widgetId]) SH.widgets[widgetId] = { liveTagId:null, sourceIds:[] };
      SH.widgets[widgetId].liveTagId = liveTagId;
    },

    _timeAgo: function(ts) {
      if (!ts) return '—';
      var sec = Math.round((Date.now() - ts) / 1000);
      if (sec < 5) return 'now';
      if (sec < 60) return sec + 's';
      var m = Math.round(sec / 60);
      if (m < 60) return m + 'm';
      return Math.round(m / 60) + 'h';
    },

    buildInline: function(widgetId) {
      var w = SH.widgets[widgetId]; if (!w) return '';
      var html = '';
      w.sourceIds.forEach(function(sid) {
        var s = SH.sources[sid]; if (!s) return;
        var dotCls = s.status === 'ok' ? 'ok' : (s.status === 'retry' ? 'retry' : 'dead');
        var isRetrying = s.status === 'retry' || s.status === 'dead';
        var clickable = isRetrying ? ' sh-clickable" data-sh-retry="' + sid : '';
        var right = '';
        if (s.status === 'ok') {
          right = '<span class="sh-ago">' + SH._timeAgo(s.lastOk) + '</span>';
        } else if (s.status === 'retry') {
          var secLeft = s._nextRetry ? Math.max(0, Math.round((s._nextRetry - Date.now()) / 1000)) : '?';
          right = '<span class="sh-retry">↻' + secLeft + 's · click to retry</span>';
        }
        html += '<span class="sh-item' + clickable + '"><span class="sh-dot ' + dotCls + '"></span><span class="sh-name">' + s.name + '</span>' + right + '</span>';
      });
      return html;
    },

    buildDropdown: function(widgetId) {
      var w = SH.widgets[widgetId]; if (!w) return '';
      var ok = 0, total = w.sourceIds.length;
      var rows = '';
      w.sourceIds.forEach(function(sid) {
        var s = SH.sources[sid]; if (!s) return;
        var dotCls = s.status === 'ok' ? 'ok' : (s.status === 'retry' ? 'retry' : 'dead');
        if (s.status === 'ok') ok++;
        var right = '';
        if (s.status === 'ok') {
          right = '<span class="sh-ago">' + SH._timeAgo(s.lastOk) + '</span>';
        } else if (s.status === 'retry') {
          var secLeft = s._nextRetry ? Math.max(0, Math.round((s._nextRetry - Date.now()) / 1000)) : '?';
          right = '<span class="sh-retry">↻ ' + secLeft + 's · retry now</span>';
        } else {
          right = '<span class="sh-ago">pending</span>';
        }
        var isRetrying = s.status === 'retry' || s.status === 'dead';
        var rowClass = 'sh-row' + (isRetrying ? ' sh-clickable" data-sh-retry="' + sid : '"');
        rows += '<div class="' + rowClass + '><div class="sh-dot ' + dotCls + '"></div><span class="sh-name">' + s.name + '</span>' + right + '</div>';
