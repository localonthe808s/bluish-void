                _haloBlue.setAttribute('cy',_csHaloCy.toFixed(1));
                _haloBlue.setAttribute('rx','64');
                _haloBlue.setAttribute('ry','27.5');
                _haloBlue.setAttribute('fill','none');
                _haloBlue.setAttribute('stroke','rgba(170,200,240,0.10)');
                _haloBlue.setAttribute('stroke-width','0.8');
                _haloBlue.setAttribute('filter','url(#cuFeather)');
                g.appendChild(_haloBlue);
              }
              // Dense concentration streaks — 3 long thin bands per preview-lab.
              // State-aware fill (cool at night, neutral at day, warm at golden).
              // Skip for nebulosus (featureless veil — no internal density variation).
              var _csDenseFill;
              if (isNight) _csDenseFill = 'rgba(160,170,200,0.18)';
              else if (isGoldenHour) _csDenseFill = 'rgba(255,238,220,0.22)';
              else _csDenseFill = 'rgba(248,252,255,0.26)';
              var _csNStreaks = _csIsNebulosus ? 0 : 3;
              for (var csI = 0; csI < _csNStreaks; csI++) {
                var _csDx = xOff + (csI+0.5)/3*pW + (R()-0.5)*25;
                var _csDy = csVeilTop + 12 + R()*(csVeilBot-csVeilTop-20);
                var _csDe = document.createElementNS(ns,'ellipse');
                _csDe.setAttribute('cx',_csDx.toFixed(1));
                _csDe.setAttribute('cy',_csDy.toFixed(1));
                _csDe.setAttribute('rx',(28+R()*16).toFixed(1));
                _csDe.setAttribute('ry','2.5');
                _csDe.setAttribute('fill',_csDenseFill);
                _csDe.setAttribute('filter','url(#ghCirrusFil)');
                g.appendChild(_csDe);
              }
            }else if(t.genus==='Cirrocumulus'){
              // Mackerel sky — preview-lab-validated rebuild:
              // - TINY discrete cloudlets ("no larger than a finger at arm's length")
              // - Arranged in parallel ridges; cells stay distinct (fish-scale texture)
              // - PATCHY along each ridge: 2-4 dense clusters per row with clear gaps
              // - Within each patch, cells align into 2-3 sub-rows ("barred markings")
              // - Faint warm carrier glow ties cells together as one cloud unit
              // - Brightness/sharpness/shape variation for richer detail
              // - Pink-tinted undersides at golden hour
              renderSheetSunGlow(g, 5, 30, 0.18);
              var ccTop=5, ccBot=55;

              // Pink underside color (golden only)
              var _ccUnderFill = isGoldenHour ? 'rgba(255,180,170,1)' : null;

              var nRidges=3+Math.round(t.cover/20);
              for(var rIdx=0;rIdx<nRidges;rIdx++){
                var ridgeY=ccTop+4+(rIdx+0.5)*(ccBot-ccTop-8)/nRidges;
                var ridgeAmp=1.5+R()*1.0;
                var ridgeFreq=0.020+R()*0.012;
                var ridgePhase=rIdx*1.3+R()*0.5;

                // Build 2-4 patch envelopes per ridge with width/density variety
                var nPatches=2+Math.round(R()*2);
                var ccPatches=[];
                for(var pp=0;pp<nPatches;pp++){
                  var isWide=R()<0.4;
                  ccPatches.push({
                    cx: xOff + (pp+0.2+R()*0.6)*(pW/nPatches),
                    hw: isWide ? (28+R()*22) : (14+R()*16),  // panel-scaled (was 40-70/20-42 in lab)
                    peakDensity: isWide ? (0.55+R()*0.25) : (0.78+R()*0.18),
                    nSubRows: 2+Math.round(R()*1.5),
                    subRowSpacing: 1.6+R()*0.7
                  });
                }

                // Per-patch warm carrier glow + 1-3 anchor cells per patch
                for(var pp3=0;pp3<ccPatches.length;pp3++){
                  var pt=ccPatches[pp3];
                  var carrierY=ridgeY+Math.sin((pt.cx-xOff)*ridgeFreq+ridgePhase)*ridgeAmp;
                  var ccCarrier=document.createElementNS(ns,'ellipse');
                  ccCarrier.setAttribute('cx',pt.cx.toFixed(1));
                  ccCarrier.setAttribute('cy',carrierY.toFixed(1));
                  ccCarrier.setAttribute('rx',(pt.hw*0.85).toFixed(1));
                  ccCarrier.setAttribute('ry',(pt.subRowSpacing*pt.nSubRows*0.9+1.5).toFixed(1));
                  ccCarrier.setAttribute('fill',col('high',a*(0.10+pt.peakDensity*0.08),0.85));
                  ccCarrier.setAttribute('filter','url(#ghCloudDiffuse)');
                  g.appendChild(ccCarrier);

                  // Anchor cells — slightly larger, brighter, crisper edges
                  var nAnchors=1+Math.round(R()*1.5);
                  for(var ah=0;ah<nAnchors;ah++){
                    var ancRowIdx=Math.floor(R()*pt.nSubRows);
                    var ancRowOff=(ancRowIdx-(pt.nSubRows-1)/2)*pt.subRowSpacing;
                    var ancX=pt.cx+(R()-0.5)*pt.hw*0.7;
                    var ancY=carrierY+ancRowOff;
                    var ancRx=2.6+R()*1.0;
                    var ancRy=1.4+R()*0.5;
                    var ccAnc=document.createElementNS(ns,'ellipse');
                    ccAnc.setAttribute('cx',ancX.toFixed(1));
                    ccAnc.setAttribute('cy',ancY.toFixed(1));
                    ccAnc.setAttribute('rx',ancRx.toFixed(1));
                    ccAnc.setAttribute('ry',ancRy.toFixed(1));
                    ccAnc.setAttribute('fill',col('high',a*(0.62+R()*0.12),0.85));
                    ccAnc.setAttribute('filter','url(#ghCloudSoft)');
                    g.appendChild(ccAnc);
                  }
                }

                // Dense cell field with sub-row snap. Each cell rolls a brightness
                // tier (faint/mid/bright) for tonal variation, picks a shape (round
                // vs wind-stretched), and 25% get crisper sharpness.
                var nCellSlots=90+Math.round(t.cover*1.2);  // panel-scaled
                for(var ci=0;ci<nCellSlots;ci++){
                  var pxBase=xOff-6+(ci/(nCellSlots-1))*(pW+12);

                  // Find host patch (highest-density patch wins) at this x
                  var density=0;
                  var hostPatch=null;
                  for(var pp2=0;pp2<ccPatches.length;pp2++){
                    var dx=Math.abs(pxBase-ccPatches[pp2].cx);
                    if(dx<ccPatches[pp2].hw){
                      var falloff=0.5+0.5*Math.cos((dx/ccPatches[pp2].hw)*Math.PI);
                      var pd=ccPatches[pp2].peakDensity*falloff;
                      if(pd>density){density=pd;hostPatch=ccPatches[pp2];}
                    }
                  }
                  if(density<0.05||!hostPatch)continue;
                  if(R()>density)continue;

                  // Sub-row snap (mackerel bar alignment)
                  var subRowIdx=Math.floor(R()*hostPatch.nSubRows);
                  var subRowOffset=(subRowIdx-(hostPatch.nSubRows-1)/2)*hostPatch.subRowSpacing;

                  var px=pxBase+(R()-0.5)*2.4;
                  var py=ridgeY+Math.sin(pxBase*ridgeFreq+ridgePhase)*ridgeAmp+subRowOffset+(R()-0.5)*0.8;
                  if(px<xOff-3||px>xOff+pW+3)continue;
                  if(py<ccTop||py>ccBot)continue;

                  // Brightness tier
                  var bRoll=R();
                  var brightTier = bRoll<0.15 ? 'faint' : (bRoll<0.40 ? 'bright' : 'mid');
                  // Shape variety
                  var isElongated=R()<0.25;
                  var crx,cry;
                  if(isElongated){crx=2.0+R()*1.4;cry=0.7+R()*0.4;}
                  else{crx=1.5+R()*1.1;cry=0.9+R()*0.5;}
                  // Mixed sharpness
                  var cellFilter=R()<0.25 ? 'ghCloudSoft' : 'ghCloudDiffuse';
                  var sunBoost=(_sunCx>px)?0.06:0;
                  var baseAlpha;
                  if(brightTier==='faint')baseAlpha=0.18+R()*0.10;
                  else if(brightTier==='bright')baseAlpha=0.58+R()*0.14;
                  else baseAlpha=0.38+R()*0.14;
                  var alpha=baseAlpha+sunBoost;

                  var ccCell=document.createElementNS(ns,'ellipse');
                  ccCell.setAttribute('cx',px.toFixed(1));
                  ccCell.setAttribute('cy',py.toFixed(1));
                  ccCell.setAttribute('rx',crx.toFixed(1));
                  ccCell.setAttribute('ry',cry.toFixed(1));
                  ccCell.setAttribute('fill',col('high',a*alpha,0.85));
                  ccCell.setAttribute('filter','url(#'+cellFilter+')');
                  g.appendChild(ccCell);

                  // Pink-tinted underside catch (golden hour, mid+ tier only)
                  if(_ccUnderFill && brightTier!=='faint'){
                    var underAlpha = brightTier==='bright' ? (0.30+R()*0.10) : (0.20+R()*0.08);
                    var ccUnder=document.createElementNS(ns,'ellipse');
                    ccUnder.setAttribute('cx',px.toFixed(1));
                    ccUnder.setAttribute('cy',(py+cry*0.55).toFixed(1));
                    ccUnder.setAttribute('rx',(crx*0.85).toFixed(1));
                    ccUnder.setAttribute('ry',(cry*0.45).toFixed(1));
                    ccUnder.setAttribute('fill',_ccUnderFill.replace(',1)',','+(a*underAlpha).toFixed(2)+')'));
                    ccUnder.setAttribute('filter','url(#ghCloudDiffuse)');
                    g.appendChild(ccUnder);
                  }

                  // Wisp tail — 8% of brighter cells get a short fibrous trail
                  if(R()<0.08 && brightTier!=='faint'){
                    var wispLen=3+R()*4;
                    var wispDir=R()<0.5?-1:1;
                    var ccWisp=document.createElementNS(ns,'ellipse');
                    ccWisp.setAttribute('cx',(px+wispDir*wispLen*0.5).toFixed(1));
                    ccWisp.setAttribute('cy',py.toFixed(1));
                    ccWisp.setAttribute('rx',wispLen.toFixed(1));
                    ccWisp.setAttribute('ry',(cry*0.5).toFixed(1));
                    ccWisp.setAttribute('fill',col('high',a*(0.18+R()*0.10),0.85));
                    ccWisp.setAttribute('filter','url(#ghCloudDiffuse)');
                    g.appendChild(ccWisp);
                  }

                  // Negative-space gap — 10% of cells in dense patch interiors
                  if(R()<0.10 && density>0.55){
                    var gapDir=R()<0.5?-1:1;
                    var gapColor = isNight ? 'rgba(8,8,28,0.30)'
                                 : (!isGoldenHour && _renderSa>5) ? 'rgba(80,110,160,0.20)'
                                 : 'rgba(50,30,55,0.30)';
                    var ccGap=document.createElementNS(ns,'ellipse');
                    ccGap.setAttribute('cx',(px+gapDir*(crx+0.6)).toFixed(1));
                    ccGap.setAttribute('cy',py.toFixed(1));
                    ccGap.setAttribute('rx',(0.5+R()*0.4).toFixed(2));
                    ccGap.setAttribute('ry',(0.4+R()*0.3).toFixed(2));
                    ccGap.setAttribute('fill',gapColor);
                    ccGap.setAttribute('filter','url(#ghCloudDiffuse)');
                    g.appendChild(ccGap);
                  }
                }
              }
            }
            svgEl.insertBefore(g,refEl);
          });

          // ══ LAYER 1.5: ICE-CRYSTAL OPTICAL PHENOMENA ══
          // Sun pillar (vertical beam above sun) + sundogs / parhelia (bright
          // spots 22° on either side of the sun). Both require ice-crystal
          // clouds (Cs or Ci) and a low sun. Sun pillars are essentially a
          // golden-hour phenomenon (sun ≤ 6° altitude); sundogs peak at sun
          // 0–30°. Sun must be above horizon — at deep twilight/night the
          // refracting geometry breaks down.
          var _hasIce = types.some(function(t){
            return (t.genus === 'Cirrostratus' || t.genus === 'Cirrus') && t.cover > 5;
          });
          if (_hasIce && _renderSa > -3) {
            var _opG = makeG('cloud-optical');
            // Same approximate sun-y formula as the panel sun renderer at
            // line ~17852 (we don't have direct access to that scope from
            // here). Sun sits at the horizon line (~95) when sa=0 and rises
            // toward y=15 as sun altitude increases.
            var _opSunY = _renderSa > 0 ? Math.max(15, 95 - _renderSa*8) : 95;

            // ── SUN PILLAR — visible when sun is within 6° of horizon ──
            if (_renderSa < 6) {
              var _pilColor;
              // Sun is gated < 6° altitude; the third (cream) branch was
              // unreachable. Pillar warmth tracks actual altitude — golden-
              // hour-or-low-sun gets warm, deeper twilight gets cool.
              if (_renderSa < 0) _pilColor = '230,200,180';
              else _pilColor = '255,225,170';
              var _pilGid = panelPrefix+'-sunpillar-'+seed;
              var _pilDef = document.createElementNS(ns,'defs');
              _pilDef.innerHTML =
                '<linearGradient id="'+_pilGid+'" x1="0" y1="0" x2="0" y2="1">'+
                  '<stop offset="0%" stop-color="rgb('+_pilColor+')" stop-opacity="0"/>'+
                  '<stop offset="50%" stop-color="rgb('+_pilColor+')" stop-opacity="0.40"/>'+
                  '<stop offset="100%" stop-color="rgb('+_pilColor+')" stop-opacity="0.62"/>'+
                '</linearGradient>';
              _opG.appendChild(_pilDef);
              var _pilHeight = 50;
              var _pilWidth = 8;
              var _pilEl = document.createElementNS(ns,'rect');
              _pilEl.setAttribute('x', (_sunCx - _pilWidth/2).toFixed(1));
              _pilEl.setAttribute('y', (_opSunY - _pilHeight).toFixed(1));
              _pilEl.setAttribute('width', _pilWidth.toFixed(1));
              _pilEl.setAttribute('height', _pilHeight.toFixed(1));
              _pilEl.setAttribute('fill', 'url(#'+_pilGid+')');
              _pilEl.setAttribute('filter', 'url(#cuFluff)');
              _opG.appendChild(_pilEl);
            }

            // ── SUNDOGS / PARHELIA — bright spots at ±22° on sun's altitude ──
            // 22° in panel pixels = 62 (matches Cs halo rx). Sundogs have a
            // slight rainbow tint: warm/red on the sun-facing inner edge,
            // cooler/violet on the outer edge. Visible when sun is 0–30°.
            if (_renderSa >= 0 && _renderSa <= 30) {
              // Photo-tuned (Wikimedia Fargo Sundogs reference): real
              // parhelia are vertical pillars/columns, NOT round spots.
              // They're nearly as bright as the sun itself, with a strong
              // warm inner edge and a cooler outer edge. Render as tall
              // narrow ellipses (rx<ry) and add a tall central highlight
              // streak so the column shape reads at panel scale.
              var _sdOffset = 62;
              for (var _sd = 0; _sd < 2; _sd++) {
                var _sdSide = _sd === 0 ? -1 : 1;
                var _sdCx = _sunCx + _sdSide * _sdOffset;
                if (_sdCx < xOff-5 || _sdCx > xOff+pW+5) continue;
                var _sdInnerRgb = isGoldenHour ? '255,210,160' : '255,238,210';
                var _sdOuterRgb = isGoldenHour ? '200,170,200' : '210,220,240';
                var _sdFx = _sdSide < 0 ? '70%' : '30%';
                // Outer halo — soft glow surrounding the bright core
                var _sdHaloGid = panelPrefix+'-sundog-halo-'+seed+'-'+_sd;
                var _sdHaloDef = document.createElementNS(ns,'defs');
                _sdHaloDef.innerHTML =
                  '<radialGradient id="'+_sdHaloGid+'" cx="50%" cy="50%" r="55%" fx="'+_sdFx+'" fy="50%">'+
                    '<stop offset="0%" stop-color="rgb('+_sdInnerRgb+')" stop-opacity="0.45"/>'+
                    '<stop offset="55%" stop-color="rgb('+_sdInnerRgb+')" stop-opacity="0.22"/>'+
                    '<stop offset="100%" stop-color="rgb('+_sdOuterRgb+')" stop-opacity="0"/>'+
                  '</radialGradient>';
                _opG.appendChild(_sdHaloDef);
                var _sdHalo = document.createElementNS(ns,'ellipse');
                _sdHalo.setAttribute('cx', _sdCx.toFixed(1));
                _sdHalo.setAttribute('cy', _opSunY.toFixed(1));
                _sdHalo.setAttribute('rx', '8');
                _sdHalo.setAttribute('ry', '12');
                _sdHalo.setAttribute('fill', 'url(#'+_sdHaloGid+')');
                _sdHalo.setAttribute('filter', 'url(#cuFeather)');
                _opG.appendChild(_sdHalo);
                // Bright vertical core — the diagnostic "pillar" appearance
                var _sdCoreGid = panelPrefix+'-sundog-core-'+seed+'-'+_sd;
                var _sdCoreDef = document.createElementNS(ns,'defs');
                _sdCoreDef.innerHTML =
                  '<linearGradient id="'+_sdCoreGid+'" x1="0" y1="0" x2="0" y2="1">'+
                    '<stop offset="0%" stop-color="rgb('+_sdInnerRgb+')" stop-opacity="0"/>'+
                    '<stop offset="35%" stop-color="rgb('+_sdInnerRgb+')" stop-opacity="0.78"/>'+
                    '<stop offset="55%" stop-color="rgb(255,245,225)" stop-opacity="0.92"/>'+
                    '<stop offset="75%" stop-color="rgb('+_sdInnerRgb+')" stop-opacity="0.62"/>'+
                    '<stop offset="100%" stop-color="rgb('+_sdInnerRgb+')" stop-opacity="0"/>'+
                  '</linearGradient>';
                _opG.appendChild(_sdCoreDef);
                var _sdCore = document.createElementNS(ns,'ellipse');
                _sdCore.setAttribute('cx', _sdCx.toFixed(1));
                _sdCore.setAttribute('cy', _opSunY.toFixed(1));
                _sdCore.setAttribute('rx', '3.2');
                _sdCore.setAttribute('ry', '8');
                _sdCore.setAttribute('fill', 'url(#'+_sdCoreGid+')');
                _sdCore.setAttribute('filter', 'url(#cuTinyBlur)');
                _opG.appendChild(_sdCore);
              }
            }

            svgEl.insertBefore(_opG, refEl);
          }

          // ══ LAYER 1.6: CREPUSCULAR RAYS ══
          // Pillars of sunlight passing through gaps in cloud cover. Research:
          // appear to radiate from the sun (perspective effect — actually
          // parallel), most visible when contrast between light and dark is
          // high. Need broken cloud (Sc perlucidus, scattered Cu, broken Ac)
          // for the sun to peek through gaps. Orange/red tint at golden hour
          // from Rayleigh scattering of the lower-atmosphere path. Rendered
          // BEFORE mid/low clouds so foreground clouds occlude them naturally.
          var _hasBrokenCloud = types.some(function(t){
            // Broken low/mid cover that creates gaps for sunbeams. Floor at
            // 15% (was 20%) lets sparse Cu and very-perlucidus Sc still
            // generate rays — at 5–15% cover gaps are too narrow for the
            // beam structure to read at panel scale.
            if (t.layer !== 'low' && t.layer !== 'mid') return false;
            if (t.cover < 15 || t.cover > 75) return false;
            return t.genus === 'Stratocumulus' ||
                   t.genus === 'Cumulus' ||
                   t.genus === 'Altocumulus';
          });
          if (_hasBrokenCloud && _renderSa > -3 && _renderSa < 12) {
            var _crG = makeG('cloud-crepuscular');
            var _crSunY = _renderSa > 0 ? Math.max(15, 95 - _renderSa*8) : 95;
            // Ray color — warm orange at golden hour (Rayleigh-reddened),
            // pale cream at higher sun. Low alpha so they read as light
            // shafts, not solid bars.
            var _crColor = isGoldenHour ? '255,210,160' : '255,245,220';
            var _crAlphaPeak = isGoldenHour ? 0.18 : 0.13;
            // Build a fan of 5-7 rays spreading outward from the sun.
            // Each ray is a thin triangular polygon: narrow at sun, wider at
            // the panel edge. Angles span roughly ±35° from vertical so the
            // fan looks natural.
            var _crNRays = 5 + Math.round(R()*2);
            var _crGid = panelPrefix+'-crepray-'+seed;
            var _crDef = document.createElementNS(ns,'defs');
            _crDef.innerHTML =
              '<linearGradient id="'+_crGid+'" gradientUnits="userSpaceOnUse" '+
                'x1="'+_sunCx.toFixed(1)+'" y1="'+_crSunY.toFixed(1)+'" '+
                'x2="'+_sunCx.toFixed(1)+'" y2="'+(_crSunY+90).toFixed(1)+'">'+
                '<stop offset="0%" stop-color="rgb('+_crColor+')" stop-opacity="0"/>'+
                '<stop offset="25%" stop-color="rgb('+_crColor+')" stop-opacity="'+(_crAlphaPeak).toFixed(2)+'"/>'+
                '<stop offset="100%" stop-color="rgb('+_crColor+')" stop-opacity="0"/>'+
              '</linearGradient>';
            _crG.appendChild(_crDef);
            for (var cri = 0; cri < _crNRays; cri++) {
              // Spread rays across an arc fanning down from sun
              var _crT = (cri + 0.5) / _crNRays;
              // Photo-tuned (Wikimedia Australian suburbs reference): real
              // crepuscular ray fans span about ±25–30° from vertical, not
              // the wider ±37° earlier value. Narrower fan reads more like
              // the actual perspective convergence pattern.
              var _crAngle = (-0.50 + _crT * 1.00) + (R()-0.5)*0.08;
              var _crLen = 75 + R()*15;
              var _crWidthAtSun = 1.5;
              var _crWidthAtEnd = 5 + R()*4;
              // Direction unit vector (downward + lateral)
              var _crDx = Math.sin(_crAngle);
              var _crDy = Math.cos(_crAngle);
              // Perpendicular for width
              var _crPx = _crDy;
              var _crPy = -_crDx;
              var _crX0 = _sunCx;
              var _crY0 = _crSunY;
              var _crX1 = _crX0 + _crDx*_crLen;
              var _crY1 = _crY0 + _crDy*_crLen;
              // Polygon corners: narrow at sun, wider at end
              var _crP =
                'M ' + (_crX0 - _crPx*_crWidthAtSun*0.5).toFixed(1) + ' ' + (_crY0 - _crPy*_crWidthAtSun*0.5).toFixed(1) +
                ' L ' + (_crX0 + _crPx*_crWidthAtSun*0.5).toFixed(1) + ' ' + (_crY0 + _crPy*_crWidthAtSun*0.5).toFixed(1) +
                ' L ' + (_crX1 + _crPx*_crWidthAtEnd*0.5).toFixed(1) + ' ' + (_crY1 + _crPy*_crWidthAtEnd*0.5).toFixed(1) +
                ' L ' + (_crX1 - _crPx*_crWidthAtEnd*0.5).toFixed(1) + ' ' + (_crY1 - _crPy*_crWidthAtEnd*0.5).toFixed(1) +
                ' Z';
              var _crEl = document.createElementNS(ns,'path');
              _crEl.setAttribute('d', _crP);
              _crEl.setAttribute('fill', 'url(#'+_crGid+')');
              _crEl.setAttribute('filter', 'url(#cuFeather)');
              _crG.appendChild(_crEl);
            }
            svgEl.insertBefore(_crG, refEl);
          }

          // ══ LAYER 1.7: CLOUD IRIDESCENCE ══
          // Pastel mother-of-pearl color bands (pinks, blues, greens, purples)
          // visible on the edges of Ac stratiformis and Cc clouds within
          // ~80° of the sun. Research: "appear as bands parallel to the edge
          // of the clouds," "pastel," "best near sunrise/sunset when sun is
          // lower." Most prominent at golden hour. Rendered as 3-4 thin
          // arc-bands hugging the sun's vicinity — a global overlay rather
          // than per-cell so it survives panel-scale.
          var _hasIrid = types.some(function(t){
            return ((t.genus === 'Altocumulus' && t.species === 'stratiformis') ||
                    t.genus === 'Cirrocumulus') && t.cover > 5;
          });
          // isGoldenHour implies low sun, so it's redundant with _renderSa < 20;
          // gate on altitude alone. Body still uses isGoldenHour to pick the
          // brighter / more saturated pastel palette.
          if (_hasIrid && _renderSa > 0 && _renderSa < 20) {
            var _irG = makeG('cloud-iridescence');
            var _irSunY = Math.max(15, 95 - _renderSa*8);
            // Pastel band colors — soft pinks/blues/greens/purples (research:
            // mother-of-pearl). Each band a different pastel hue at low alpha.
            var _irColors = isGoldenHour
              ? ['rgba(255,200,210,0.20)', 'rgba(190,210,250,0.18)', 'rgba(200,240,210,0.16)', 'rgba(220,200,240,0.18)']
              : ['rgba(255,220,230,0.14)', 'rgba(210,230,255,0.12)', 'rgba(220,250,225,0.11)', 'rgba(235,220,250,0.13)'];
            // Render bands as nested ellipses (parallel to sun arc), slightly
            // offset from sun, fading as they get further out. The "near the
            // edge of the cloud" requirement is approximated by placing the
            // bands tangent to where Ac cells typically render (y ≈ 30–60).
            for (var _ir = 0; _ir < _irColors.length; _ir++) {
              var _irRx = 28 + _ir*6;
              var _irRy = 16 + _ir*4;
              var _irE = document.createElementNS(ns,'ellipse');
              _irE.setAttribute('cx', _sunCx.toFixed(1));
              _irE.setAttribute('cy', (_irSunY + 4 + _ir*1.5).toFixed(1));
              _irE.setAttribute('rx', _irRx.toFixed(1));
              _irE.setAttribute('ry', _irRy.toFixed(1));
