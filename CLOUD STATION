        cells.push({
          hr: (hr % 12 || 12) + (hr < 12 ? 'a' : 'p'),
          low: hourly.cloud_cover_low[idx] || 0,
          mid: hourly.cloud_cover_mid ? (hourly.cloud_cover_mid[idx] || 0) : 0,
          high: hourly.cloud_cover_high ? (hourly.cloud_cover_high[idx] || 0) : 0,
