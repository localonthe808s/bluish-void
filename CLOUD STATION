        // Color helper for magnitude — matches map marker colors
        function magColor(m){
          if(m >= 7) return '#7f1d1d';
          if(m >= 6.5) return '#dc2626';
          if(m >= 5.5) return '#ef4444';
          if(m >= 4.5) return '#f97316';
