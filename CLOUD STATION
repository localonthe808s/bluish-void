        if (startX === null) return;
        var diff = e.changedTouches[0].clientX - startX;
        if (Math.abs(diff) > 40){
          cycleTo(locIndex + (diff < 0 ? 1 : -1));
        }
        startX = null;
      }, {passive:true});
    }
    
    function switchLocation(id){
      var newLoc = null;
      for (var i = 0; i < LOCATIONS.length; i++){
        if (LOCATIONS[i].id === id){
          newLoc = LOCATIONS[i];
          break;
        }
      }
      if (!newLoc) return;
      
      // Clear existing timers
      if (radarRefreshTimer) { clearInterval(radarRefreshTimer); radarRefreshTimer = null; }
      if (goesTimer) { clearInterval(goesTimer); goesTimer = null; }
      if (goesRefreshTimer) { clearInterval(goesRefreshTimer); goesRefreshTimer = null; }
      
      // Prevent rapid switching
      if (window.locationSwitching) return;
      window.locationSwitching = true;
      setTimeout(function(){ window.locationSwitching = false; }, 1000);
      
      LOCATION = newLoc;
      TZ = newLoc.tz;
      window._geoMeta = null; // Reset for fresh landscape detection
      
      // Update location name display with loading state
      if (locNameEl) { locNameEl.textContent = newLoc.name; locNameEl.classList.remove("pulse-hint"); }
      if (locMetaEl) locMetaEl.textContent = "Loading...";
      if (tempEl) tempEl.style.opacity = "0.5";
      
      // Reload all data
      loadWeatherForLocation(LOCATION);
      loadAirQuality();
      loadPollen();
      loadWeatherAlerts();
      switchRadarMode("reflectivity");
      startRadarNwsLoop();
      // Update GOES satellite and sector from new location
      if (LOCATION.goes) {
        goesCurrentSector = LOCATION.goes.sector || goesCurrentSector;
        goesCurrentSat = LOCATION.goes.sat || goesCurrentSat;
        // Update satellite button styling
        var g19btn = document.getElementById('goes-sat-g19');
        var g18btn = document.getElementById('goes-sat-g18');
        if (g19btn){ g19btn.style.background = goesCurrentSat==='G19' ? 'rgba(255,140,0,.15)' : 'rgba(200,200,210,.25)'; g19btn.style.color = goesCurrentSat==='G19' ? 'rgba(255,140,0,.95)' : 'rgba(43,34,244,.65)'; }
        if (g18btn){ g18btn.style.background = goesCurrentSat==='G18' ? 'rgba(255,140,0,.15)' : 'rgba(200,200,210,.25)'; g18btn.style.color = goesCurrentSat==='G18' ? 'rgba(255,140,0,.95)' : 'rgba(43,34,244,.65)'; }
        // Auto-switch forecast area to match new location
        var sectorToArea = { 'ne':'us-ne', 'se':'us-se', 'umv':'upper-ms', 'cgl':'us-nc', 'smv':'south-ms', 'sp':'s-plains', 'nr':'n-rockies', 'sr':'s-rockies', 'pnw':'us-nw', 'psw':'us-sw', 'wus':'us-sw', 'eus':'us-ne', 'np':'north-pac', 'ep':'east-pac', 'taw':'atlantic', 'car':'pr', 'gm':'us-se', 'can':'namer' };
        var matchedArea = sectorToArea[goesCurrentSector];
        if (matchedArea && typeof switchFcastArea === 'function') {
          try { switchFcastArea(matchedArea); } catch(e){}
        }
      }
      // Clean up existing GOES animation before restarting
      if (typeof goesAnimId !== 'undefined' && goesAnimId) { cancelAnimationFrame(goesAnimId); goesAnimId = null; }
      if (typeof goesRefreshTimer !== 'undefined' && goesRefreshTimer) { clearInterval(goesRefreshTimer); goesRefreshTimer = null; }
      goesFrames = [];
      goesImages = [];
      goesIdx = 0;
      // Clear forecast playback state
      if (typeof fcastState !== 'undefined') {
        if (fcastState.timer) { clearInterval(fcastState.timer); fcastState.timer = null; }
        fcastState.playing = false;
        fcastState.idx = 0;
      }
      startGoesAutoplay();
      updateSolarMini();
      if (fireMap) {
        var fc = [45, -100], fz = 3;
        if (LOCATION.lon > -85 && LOCATION.lat > 38) { fc = [44, -74]; fz = 5; }
        else if (LOCATION.lon > -90 && LOCATION.lat <= 38 && LOCATION.lat > 25) { fc = [32, -82]; fz = 5; }
        else if (LOCATION.lon > -100 && LOCATION.lon <= -85 && LOCATION.lat > 36) { fc = [42, -90]; fz = 5; }
        else if (LOCATION.lon <= -110 && LOCATION.lat <= 42 && LOCATION.lat > 30) { fc = [36, -118]; fz = 5; }
        else if (LOCATION.lon <= -115 && LOCATION.lat > 42) { fc = [46, -122]; fz = 5; }
        else if (LOCATION.lon > -105 && LOCATION.lon <= -90 && LOCATION.lat <= 36) { fc = [31, -98]; fz = 5; }
        else if (LOCATION.lon <= -100 && LOCATION.lon > -115 && LOCATION.lat > 36) { fc = [42, -110]; fz = 5; }
        fireMap.setView(fc, fz);
      }
      if (quakeMap) quakeMap.setView([LOCATION.lat, LOCATION.lon], 6);
      if (lightningMap) lightningMap.setView([LOCATION.lat, LOCATION.lon], 3);
      
      // Update lightning iframe location
      var lIframe = document.getElementById('lightning-iframe');
