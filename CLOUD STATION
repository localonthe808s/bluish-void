          svg += '<div style="position:absolute;left:'+pct.toFixed(2)+'%;top:-3px;bottom:-3px;width:3px;background:#fff;border-radius:2px;box-shadow:0 0 0 1.5px rgba(43,34,244,.85);transform:translateX(-50%);"></div>';
