      fld+=R('vs monthly avg (~'+flAvg+')','<span style="color:'+flTColor+'">'+flTrend+'</span>');
      fld+=R('Flood season',flPhases[flMo]);
      fld+=R('Risk profile',flRisks[flMo]);
      fld+='<div style="text-align:right;font-size:.42rem;color:rgba(30,30,50,.25);margin-top:3px;">Updated '+new Date().toLocaleTimeString([],{hour:'numeric',minute:'2-digit'})+'</div>';
      _h('hz-dash-flood-detail',fld);

      // ── LIGHTNING ──
      var tsW=al.filter(function(a){return(a.event||'').toLowerCase().indexOf('thunderstorm')>=0;}).length;
      var hr=window._hourlyData;
      var wxL=window._wxCurrent||{};
      var ld='';
      // Scan next 24h for thunderstorm windows
      var stormHours=[];var peakCapeH=0;var peakCapeVal=0;var maxPrecipP=0;
      if(hr&&hr.time&&hr.cape){
        var nowMs=Date.now();
        for(var li=0;li<hr.time.length&&li<48;li++){
          var tMs=new Date(hr.time[li]).getTime();
          if(tMs<nowMs) continue;
          if(tMs>nowMs+86400000) break;
          var cape=hr.cape[li]||0;
          var wc=hr.weathercode?hr.weathercode[li]:0;
          var pp=hr.precipitation_probability?hr.precipitation_probability[li]:0;
          if(pp>maxPrecipP) maxPrecipP=pp;
          if(cape>peakCapeVal){peakCapeVal=cape;peakCapeH=li;}
          if(wc>=95||(cape>=500&&pp>=40)){
            stormHours.push({
              time:new Date(hr.time[li]),
              cape:cape,
              code:wc,
              prob:pp
            });
          }
        }
      }
      var hasStorms=stormHours.length>0;
      var highCape=peakCapeVal>=500;
      // Set count display
      // Filter storm hours to today only
      var todayEnd=new Date();todayEnd.setHours(23,59,59,999);
      var todayStorms=stormHours.filter(function(s){return s.time<=todayEnd;});
      var _lc = document.getElementById('hz-dash-lightning-count');
      if(_lc){ _lc.style.display = 'none'; }
      if(todayStorms.length){
        _d('hz-dash-lightning-label', todayStorms.length + 'h STORMS TODAY');
      } else if(highCape){
        _d('hz-dash-lightning-label','LOW RISK TODAY');
      } else {
        _d('hz-dash-lightning-label','NO STORMS TODAY');
      }
      // Find next storm day for detail section
      var _nextStormDay='';
      if(hr&&hr.cape&&hr.time){
        for(var nsi=0;nsi<Math.min(hr.cape.length,168);nsi++){
          var nsTime=new Date(hr.time[nsi]);
          if(nsTime<=todayEnd) continue;
          var nsCape=hr.cape[nsi]||0;
          var nsWc=hr.weathercode?hr.weathercode[nsi]:0;
          var nsPp=hr.precipitation_probability?hr.precipitation_probability[nsi]:0;
          if(nsWc>=95||(nsCape>=500&&nsPp>=40)){
            var dayNames=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
            _nextStormDay=dayNames[nsTime.getDay()];
            break;
          }
        }
      }

      if(todayStorms.length){
        ld+=H('⚡ STORMS TODAY','rgba(250,204,21,.85)');
        // Time window
        var firstStorm=todayStorms[0].time;
        var lastStorm=todayStorms[todayStorms.length-1].time;
        var fmt=function(d){return d.toLocaleTimeString([],{hour:'numeric',minute:'2-digit'});};
        ld+=R('Window',fmt(firstStorm)+' – '+fmt(lastStorm));
        ld+=R('Duration',todayStorms.length+' hour'+(todayStorms.length>1?'s':''));
        // Peak intensity
        var peakStorm=stormHours.reduce(function(a,b){return a.cape>b.cape?a:b;});
        var intensity=peakStorm.cape<1000?'Isolated/weak':peakStorm.cape<2000?'<span style="color:#f59e0b">Moderate</span>':'<span style="color:#ef4444;font-weight:700">Strong/severe</span>';
        ld+=R('Peak intensity',intensity);
        ld+=R('Peak CAPE',peakStorm.cape+' J/kg @ '+fmt(peakStorm.time));
        // Check for hail codes
        var hailH=stormHours.filter(function(s){return s.code===96||s.code===99;}).length;
        if(hailH) ld+=R('⚠ Hail risk','<span style="color:#ef4444">'+hailH+' hour'+(hailH>1?'s':'')+'</span>');
        ld+=R('Max precip prob',maxPrecipP+'%');
      }else if(highCape){
        ld+=H('MARGINAL RISK','rgba(250,204,21,.7)');
        ld+=R('Status','Instability present but no storms forecast');
        if(hr&&hr.time&&peakCapeH){
          ld+=R('Peak CAPE',peakCapeVal+' J/kg @ '+new Date(hr.time[peakCapeH]).toLocaleTimeString([],{hour:'numeric',minute:'2-digit'}));
        }
        ld+=R('Precip probability',maxPrecipP+'%');
        ld+=R('Assessment','Monitor for isolated development');
        if(_nextStormDay) ld+=R('Next storms','<span style="color:#ca8a04">'+_nextStormDay+'</span>');
      }else{
        ld+=H('NO STORMS EXPECTED','rgba(250,204,21,.5)');
        ld+=R('Status','Stable atmosphere');
        ld+=R('CAPE',peakCapeVal<50?'< 50 J/kg (stable)':peakCapeVal+' J/kg (low)');
        ld+=R('Precip probability',maxPrecipP+'%');
        if(_nextStormDay) ld+=R('Next storms','<span style="color:#ca8a04">'+_nextStormDay+'</span>');
        else ld+=R('7-day outlook','Clear — no storms forecast');
      }
      // Alerts
      if(tsW){ld+=H('NWS ALERTS','rgba(250,204,21,.6)');ld+=R('T-storm alerts active','<span style="color:#f59e0b;font-weight:700">'+tsW+'</span>');}
      // Current conditions
      ld+=H('CURRENT CONDITIONS','rgba(250,204,21,.4)');
      if(wxL.cape!=null) ld+=R('CAPE now',wxL.cape+' J/kg');
      if(wxL.liftedIndex!=null) ld+=R('Lifted index',wxL.liftedIndex.toFixed(1));
      if(wxL.cloudCover!=null) ld+=R('Cloud cover',wxL.cloudCover+'%');
      ld+='<div style="text-align:right;font-size:.42rem;color:rgba(30,30,50,.25);margin-top:3px;">Updated '+new Date().toLocaleTimeString([],{hour:'numeric',minute:'2-digit'})+'</div>';
      _h('hz-dash-lightning-detail',ld);

      // ── HURRICANE ──
      var hc=window._activeStorms?window._activeStorms.length:0;
      _d('hz-dash-hurricane-count',hc);
      var hd='';
      var hMo=new Date().getMonth();
      if(hc&&window._activeStorms){
        hd+=H('ACTIVE SYSTEMS','rgba(139,92,246,.75)');
        window._activeStorms.slice(0,4).forEach(function(s){
          hd+=R(s.name||'System',(s.category?'Cat '+s.category:'TD')+(s.winds?' · '+s.winds+'kt':''));
        });
        if(hc>4) hd+=R('Additional systems',hc-4);
      }
      hd+=H('ATLANTIC BASIN','rgba(139,92,246,.6)');
      if(hMo>=5&&hMo<=10){
        hd+=R('Season','<span style="color:#a78bfa">Active</span> (Jun 1 – Nov 30)');
        var peakNote=hMo===7?'Approaching peak':'';
        if(hMo===8||hMo===9) peakNote='<span style="color:#f59e0b">Peak activity months</span>';
        if(hMo===10) peakNote='Late-season systems possible';
        if(hMo===5) peakNote='Pre-season; early storms possible';
        if(hMo===6) peakNote='Early-season; tropical Atlantic warming';
        if(peakNote) hd+=R('Phase',peakNote);
      }else{
        hd+=R('Season','Off-season (Dec – May)');
        hd+=R('Next season','June 1');
      }
      if(!hc) hd+=R('Active storms','None');
      hd+=R('Monitoring','NHC / CPHC');
      hd+=R('East Pacific',hMo>=4&&hMo<=10?'Active':'Off-season');
      // Historical note
      var hNotes=['Historically quiet; rare off-season storms','Pre-season; SSTs still below threshold','Pre-season; dust layer suppresses development','Early-season analogs: subtropical storms possible','Season opens Jun 1; named storms rare before Aug','Early storms in Gulf of Mexico & western Caribbean','Cape Verde season begins; activity shifts east','<span style="color:#f59e0b">Peak month — 96% of major hurricanes form Aug-Oct</span>','<span style="color:#f59e0b">Most active month for US landfalls historically</span>','Late-season Caribbean threats; recurving storms','Post-season; rare but can produce subtropical storms','Season over; reanalysis period'];
      // SST context — seasonal estimate for main development region (MDR: 10-20°N, 20-60°W)
      var sstBaseline=[25.5,25.0,25.2,26.0,27.0,27.8,28.3,28.8,28.9,28.5,27.5,26.3]; // monthly avg MDR SST °C
      var sstBase=sstBaseline[hMo];
      // Estimate anomaly from recent global trend (~+0.5-1.0°C above 1991-2020 baseline)
      var sstAnom=0.7; // conservative current-era anomaly
      var sstNow=(sstBase+sstAnom).toFixed(1);
      var sstLabel=sstAnom>1.0?'<span style="color:#ef4444;font-weight:700">+'+sstAnom.toFixed(1)+'°C — fuel for rapid intensification</span>':sstAnom>0.5?'<span style="color:#f59e0b">+'+sstAnom.toFixed(1)+'°C — above normal</span>':'Normal range';
      hd+=H('OCEAN & SST','rgba(139,92,246,.45)');
      hd+=R('MDR SST estimate','~'+sstNow+'°C · '+sstLabel);
      var threshold=26.5;
      hd+=R('vs 26.5°C threshold',sstBase+sstAnom>=threshold?'<span style="color:#f59e0b">Above — supports development</span>':'Below threshold');

      hd+=H('CONTEXT','rgba(139,92,246,.35)');
      hd+=R('Historical',hNotes[hMo]);
      hd+='<div style="text-align:right;font-size:.42rem;color:rgba(30,30,50,.25);margin-top:3px;">Updated '+new Date().toLocaleTimeString([],{hour:'numeric',minute:'2-digit'})+'</div>';
      _h('hz-dash-hurricane-detail',hd);

      // ── MOBILE SUMMARY SNIPPETS ──
      // Short location-focused lines visible when cards are collapsed
      (function(){
        var _s = function(id, txt){ var el=document.getElementById(id); if(el) el.innerHTML=txt; };

        // Fire: top 2-3 fire names + locations
        var fireSummary = '';
        var named = f.filter(function(x){return x.properties.IncidentName;})
          .sort(function(a,b){return(b.properties.DailyAcres||0)-(a.properties.DailyAcres||0);});
        if(named.length){
          fireSummary = named.slice(0,3).map(function(t){
            var n=t.properties.IncidentName||'';
            var st=t.properties.POOState||t.properties.State||'';
            return n+(st?' · '+st:'');
          }).join(' · ');
        } else if(f.length){ fireSummary=f.length+' hotspots detected'; }
        else { fireSummary='No active fires'; }
        _s('hz-summary-fire', fireSummary);

        // Quake: top 2 locations
        var qs2=q.slice().sort(function(a,b){return(b.properties.mag||0)-(a.properties.mag||0);});
        var quakeSummary = qs2.length ?
          qs2.slice(0,2).map(function(t){ return 'M'+t.properties.mag.toFixed(1)+' '+(t.properties.place||''); }).join(' · ') :
          'No significant activity';
        _s('hz-summary-quake', quakeSummary);

        // Tornado/Severe: warnings, reports with locations, SPC, or NWS alerts
        var torSummary = '';
        var sevAlerts = al.filter(function(a){var e=(a.event||'').toLowerCase();return e.indexOf('tornado')>=0||e.indexOf('severe thunderstorm')>=0;});
        if(sevAlerts.length){
          torSummary = sevAlerts.slice(0,2).map(function(a){
            var area = (a.areaDesc||'').split(';')[0].split(',')[0].trim();
            return a.event + (area ? ' · ' + area : '');
          }).join(' · ');
        } else if(tc > 0){
          // Tornado reports — use parsed locations from CSV, report objects, or top reports
          var tReports = window._tornadoReports||[];
          var tParsedLocs = window._tornadoLocations||[];
          var tTop = typeof tornadoTopReports!=='undefined' ? tornadoTopReports : [];
          if(tReports.length){
            torSummary = tc + ' report' + (tc>1?'s':'') + ' · ' +
              tReports.slice(0,2).map(function(r){ return (r.location||'') + (r.state ? ', '+r.state : ''); }).join(' · ');
          } else if(tParsedLocs.length){
            torSummary = tc + ' report' + (tc>1?'s':'') + ' · ' + tParsedLocs.slice(0,2).join(' · ');
          } else if(tTop.length){
            torSummary = tc + ' report' + (tc>1?'s':'') + ' · ' +
              tTop.slice(0,2).map(function(r){ return (r.location||'') + (r.state ? ', '+r.state : ''); }).join(' · ');
          } else {
            torSummary = tc + ' tornado report' + (tc>1?'s':'') + ' today';
          }
        } else if(al.length){
          // General NWS alerts (wind, heat, winter, etc)
          var topAlerts = al.slice(0,2).map(function(a){
            var area = (a.areaDesc||'').split(';')[0].split(',')[0].trim();
            return a.event + (area ? ' · ' + area : '');
          });
          torSummary = topAlerts.join(' · ');
        } else if(spcMaxDn>0){
          torSummary = 'SPC outlook: ' + spcMaxRisk;
        } else {
          torSummary = 'No active warnings';
        }
        _s('hz-summary-tornado', torSummary);

        // Flood: top flooding locations
        var sevGauges2 = (window._floodGauges||[]).filter(function(g){return g.status&&g.status.priority>=3;})
          .sort(function(a,b){return(b.status.priority||0)-(a.status.priority||0);});
        var floodSummary = '';
        if(sevGauges2.length){
          floodSummary = sevGauges2.slice(0,2).map(function(g){
            return (g.waterbody||g.name||'')+(g.status?' · '+g.status.label:'');
          }).join(' · ');
        } else if(fc>0){ floodSummary = fc+' gauges above normal'; }
        else { floodSummary = 'All gauges normal'; }
        _s('hz-summary-flood', floodSummary);

        // Lightning
        _s('hz-summary-lightning', typeof stormHours!=='undefined'&&stormHours&&stormHours.length ?
          stormHours.length+'h of storm activity expected' : 'No storms expected');

        // Hurricane
        var hcStorms = window._hurricaneStorms||[];
        var hSummary = hcStorms.length ?
          hcStorms.slice(0,2).map(function(s){return s.name||'System';}).join(' · ') :
          'No active tropical systems';
        _s('hz-summary-hurricane', hSummary);
      })();

      // ── NEAREST THREAT BANNER ──
      var threats=[];
      // Check fires
      if(f.length&&_loc){
        var nfires=f.filter(function(x){return x.geometry&&x.geometry.coordinates;});
        if(nfires.length){
          var closest=nfires.reduce(function(b,x){var d=Math.sqrt(Math.pow(x.geometry.coordinates[1]-_loc.lat,2)+Math.pow(x.geometry.coordinates[0]-_loc.lon,2));return d<b.d?{d:d,f:x}:b;},{d:999,f:null});
          if(closest.f) threats.push({type:'🔥',name:closest.f.properties.IncidentName||'Fire',dist:Math.round(closest.d*69),color:'#c2410c'});
        }
      }
      // Check earthquakes M4.5+
      if(q.length&&_loc){
        var bigQ=q.filter(function(x){return(x.properties.mag||0)>=4.5&&x.geometry&&x.geometry.coordinates;});
        if(bigQ.length){
          var cq=bigQ.reduce(function(b,x){var d=Math.sqrt(Math.pow(x.geometry.coordinates[1]-_loc.lat,2)+Math.pow(x.geometry.coordinates[0]-_loc.lon,2));return d<b.d?{d:d,q:x}:b;},{d:999,q:null});
          if(cq.q) threats.push({type:'🌍',name:'M'+cq.q.properties.mag.toFixed(1),dist:Math.round(cq.d*69),color:'#2563eb'});
        }
      }
      // Check flood gauges
      var sevG=(window._floodGauges||[]).filter(function(g){return g.status&&g.status.priority>=4;});
      if(sevG.length&&_loc){
        var cf=sevG.reduce(function(b,g){var d=Math.sqrt(Math.pow(g.lat-_loc.lat,2)+Math.pow(g.lon-_loc.lon,2));return d<b.d?{d:d,g:g}:b;},{d:999,g:null});
        if(cf.g) threats.push({type:'🌊',name:(cf.g.waterbody||'Flood')+' '+cf.g.status.label,dist:Math.round(cf.d*69),color:'#0891b2'});
      }
      // Local alerts
      var localAlerts=al.length;
      // Build banner
      var ntEl=document.getElementById('hz-nearest-text');
      if(ntEl){
        if(threats.length){
          threats.sort(function(a,b){return a.dist-b.dist;});
          var t=threats[0];
          var extras=threats.length>1?' · <span style="opacity:.6">+'+( threats.length-1)+' other threat'+(threats.length>2?'s':'')+'</span>':'';
          ntEl.innerHTML='<span style="color:'+t.color+';font-weight:700;">'+t.type+' '+t.name+'</span> · ~'+t.dist+' mi away'+(localAlerts?' · <span style="color:#f59e0b;font-weight:600;">'+localAlerts+' NWS alert'+(localAlerts>1?'s':'')+'</span>':' · No local alerts')+extras;
        } else {
          ntEl.innerHTML='<span style="color:#22c55e;">No active threats nearby</span>'+(localAlerts?' · <span style="color:#f59e0b;">'+localAlerts+' NWS alert'+(localAlerts>1?'s':'')+'</span>':' · All clear');
        }
      }

      // ── HOT/QUIET CARD STATE — status dots, glow intensity, animated borders ──
      var hotThresholds = {fire:50,quake:100,tornado:1,flood:1,lightning:1,hurricane:1};
      var critThresholds = {fire:500,quake:200,tornado:3,flood:5,lightning:3,hurricane:2};
      var hotCounts = {fire:f.length,quake:q.length,tornado:al.filter(function(a){var e=(a.event||'').toLowerCase();return e.indexOf('tornado')>=0||e.indexOf('severe')>=0;}).length,flood:fc,lightning:typeof stormHours!=='undefined'&&stormHours&&stormHours.length?stormHours.length:0,hurricane:hc};
      ['fire','quake','tornado','flood','lightning','hurricane'].forEach(function(k){
        var card=document.querySelector('.hz-dash-card[data-hz="'+k+'"]');
        var bar=document.getElementById('hz-bar-'+k);
        var dot=document.getElementById('hz-dot-'+k);
        if(!card)return;
        var cnt=hotCounts[k];
        var isHot=cnt>=hotThresholds[k];
        var isCrit=cnt>=critThresholds[k];
        var isQuiet=cnt===0;
        card.classList.toggle('hz-hot',isHot);
        card.classList.toggle('hz-quiet',isQuiet);
        if(bar) bar.style.opacity=isHot?'.7':'0';
        if(dot){
          dot.className='hz-status-dot '+(isCrit?'hz-dot-red':isHot?'hz-dot-amber':'hz-dot-green');
        }
      });

      // ── SPARKLINE TREND CHARTS ──
      // Store history every cycle (3s), keep last 30 data points (~90s of trend)
      if(!window._hzSparkHistory) window._hzSparkHistory={fire:[],quake:[],tornado:[],flood:[],lightning:[],hurricane:[]};
      var _sh=window._hzSparkHistory;
      var _now={fire:f.length,quake:q.length,tornado:al.filter(function(a){var e=(a.event||'').toLowerCase();return e.indexOf('tornado')>=0||e.indexOf('severe')>=0;}).length,flood:fc,lightning:typeof stormHours!=='undefined'&&stormHours?stormHours.length:0,hurricane:hc};
      ['fire','quake','tornado','flood','lightning','hurricane'].forEach(function(k){
        _sh[k].push(_now[k]);
        if(_sh[k].length>30) _sh[k].shift();
        var svg=document.getElementById('hz-spark-'+k);
        if(!svg||_sh[k].length<2) return;
        var pts=_sh[k],len=pts.length;
        var mx=Math.max.apply(null,pts)||1,mn=Math.min.apply(null,pts);
        if(mx===mn) mx=mn+1;
        var w=90,h=28,pad=1;
        var d='M';
        for(var si=0;si<len;si++){
          var x=(si/(len-1))*w;
          var y=pad+(1-(pts[si]-mn)/(mx-mn))*(h-pad*2);
          d+=(si?'L':'')+x.toFixed(1)+','+y.toFixed(1);
        }
        var area=d+'L'+w+','+h+'L0,'+h+'Z';
        var path=svg.querySelector('path');
        if(path) path.setAttribute('d',area);
      });

    }catch(e){console.error('dash crash:',e.message,e.stack);}
  }
  // Run after data has had time to load, then every 3s
  // Initial updates after data loads, then every 5s only when visible
  setTimeout(_hzDashUpdate, 1500);
  setTimeout(_hzDashUpdate, 5000);
  setInterval(function(){
    if(document.hidden) return;
    var el = document.getElementById('hazard-dashboard');
    if (!el) return;
    var rect = el.getBoundingClientRect();
    if (rect.bottom > 0 && rect.top < window.innerHeight) _hzDashUpdate();
  }, 5000);
})();
</script>

<script>
  // Tag the radar widget body with a data-cira-tab attribute so CSS can
  // hide the live GOES image when ARCHIVE / HIGHLIGHT is active. CSS
  // :has() matching on inline style="display: block/flex" was unreliable
  // across browsers / Wix iframes.
  (function(){
    var origSwitch = window.switchCiraTab;
    if (typeof origSwitch !== 'function') return;
    window.switchCiraTab = function(tab){
      var body = document.getElementById('radar-widget-body');
      if (body) body.setAttribute('data-cira-tab', tab || '');
      return origSwitch.apply(this, arguments);
    };
    // Also tag on initial load (default tab is 'goes')
    var body0 = document.getElementById('radar-widget-body');
    if (body0 && !body0.hasAttribute('data-cira-tab')) body0.setAttribute('data-cira-tab', 'goes');
  })();

  /* Defensive fix: on mobile, the archive pane has an inline
     `padding:54px 14px 14px` (originally there to clear the absolute
     desktop tab bar). On mobile the tab bar is in normal flex flow,
     so that 54px top padding becomes a huge grey strip above the
     first card row. CSS overrides via !important + ID selectors are
     getting beaten somewhere, so just modify the inline style
     directly when on mobile. */
  (function(){
    if (!window.matchMedia('(max-width: 768px)').matches) return;
    var pane = document.getElementById('cira-pane-archive');
    if (pane) {
      pane.style.setProperty('padding-top', '10px', 'important');
      pane.style.setProperty('padding-bottom', '14px', 'important');
      pane.style.setProperty('padding-left', '8px', 'important');
      pane.style.setProperty('padding-right', '8px', 'important');
    }
  })();

  /* Watch the archive inline player (#cira-arch-player) for display
     state changes and tag the parent pane with data-arch-view="player"
     while the player is showing. CSS uses that to flow the player as
     a normal block with the title/desc/meta below the video on
     mobile, matching the TODAYS HIGHLIGHT layout. */
  (function(){
    function syncArchView(){
      var player = document.getElementById('cira-arch-player');
      var pane   = document.getElementById('cira-pane-archive');
      if (!player || !pane) return;
      var isOpen = player.style.display && player.style.display !== 'none';
      if (isOpen) pane.setAttribute('data-arch-view', 'player');
      else pane.removeAttribute('data-arch-view');
    }
    // Initial
    syncArchView();
    // Observe inline style changes
    var player = document.getElementById('cira-arch-player');
    if (player && window.MutationObserver) {
      new MutationObserver(syncArchView).observe(player, { attributes: true, attributeFilter: ['style'] });
    }
  })();
</script>

<script>
  /* ========== MOBILE PERF: throttle setInterval + pause when tab hidden ========== */
  /* On mobile (≤768px), every setInterval call gets its delay 2x'd
     (so radar refresh every 4min instead of 2min, etc), and all
     intervals are paused while the tab is in the background.
     Saves significant battery + cell data. */
  (function(){
    if (!window.matchMedia('(max-width: 768px)').matches) return;
    var origSetInterval = window.setInterval;
    var origClearInterval = window.clearInterval;
    var registry = {};  // id -> {fn, ms, handle}
    var nextId = 1;
    var paused = false;

    window.setInterval = function(fn, ms){
      ms = (typeof ms === 'number' ? ms : 0);
      // Throttle to 2x on mobile, with a 1s minimum to avoid spinning
      var throttledMs = Math.max(1000, ms * 2);
      var id = nextId++;
      var handle = paused ? null : origSetInterval(fn, throttledMs);
      registry[id] = { fn: fn, ms: throttledMs, handle: handle };
      // Return a sentinel that clearInterval can recognize
      return { __mobileIntervalId: id };
    };

    window.clearInterval = function(token){
      if (token && typeof token === 'object' && token.__mobileIntervalId != null) {
        var entry = registry[token.__mobileIntervalId];
        if (entry && entry.handle != null) origClearInterval(entry.handle);
        delete registry[token.__mobileIntervalId];
        return;
      }
      // Pass-through for legacy numeric handles (e.g. third-party libs)
      return origClearInterval.apply(this, arguments);
    };

    // Pause / resume on visibility change
    document.addEventListener('visibilitychange', function(){
      var hidden = document.visibilityState === 'hidden';
      if (hidden && !paused) {
        paused = true;
        Object.keys(registry).forEach(function(id){
          var e = registry[id];
          if (e.handle != null) { origClearInterval(e.handle); e.handle = null; }
        });
      } else if (!hidden && paused) {
        paused = false;
        Object.keys(registry).forEach(function(id){
          var e = registry[id];
          if (e.handle == null) { e.handle = origSetInterval(e.fn, e.ms); }
        });
      }
    });
  })();
</script>

<script>
  /* ========== MOBILE PERF: lazy-init the hazard map ========== */
  /* Don't load Leaflet tiles + ArcGIS feature layers + USGS quake feed
     etc until the hazard widget actually scrolls into view. Saves the
     initial page-load network/CPU storm on phones where the user might
     never scroll there at all. */
  (function(){
    if (!window.matchMedia('(max-width: 768px)').matches) return;
    if (!('IntersectionObserver' in window)) return;
    var widget = document.getElementById('hazard-widget');
    if (!widget) return;
    if (window._hazardInited) return;  // already engaged

    var io = new IntersectionObserver(function(entries){
      entries.forEach(function(entry){
        if (entry.isIntersecting && !window._hazardInited) {
          window._hazardInited = true;
          io.disconnect();
          try { if (typeof initUnifiedHazardMap === 'function') initUnifiedHazardMap(); } catch(e){ console.warn('lazy hazard init', e); }
          setTimeout(function(){ try { if (typeof initGeologyMaps === 'function') initGeologyMaps(); } catch(e){} }, 200);
          var fireOv = document.getElementById('hazard-fire-overlays');
          if (fireOv) fireOv.style.display = '';
        }
      });
    }, { rootMargin: '200px' });  // start init slightly before the widget enters
    io.observe(widget);
  })();
</script>

