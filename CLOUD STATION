        svg += '<line x1="'+anchorX.toFixed(2)+'" y1="'+anchorY.toFixed(2)+'" x2="'+labelX+'" y2="'+ly+'" stroke="'+layer.color+'" stroke-width=".45" opacity=".55"/>';
