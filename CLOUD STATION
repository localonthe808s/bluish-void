        var salTip = document.getElementById('hz-sal-info');
        if (salTip) salTip.style.display = 'none';
      }
    }

    // ── WIND SHEAR ────────────────────────────────────────────────────────────
    // 850–200mb deep-layer wind shear via CIMSS Tropical Cyclones WMS
    // Values >20kt suppress TC development; >30kt is hostile to intensification
    if (which === 'shear') {
      if (on) {
        if (!_hurricaneLayerObjs.shear) {
