    // ── Part 3: Precip + wind forecast from hourly scan ──
    if(!hasAlerts && precipStart && !wx.precip && !wx.snow && !wx.rain){
      var ptName = precipType === 'snow' ? 'Snow' : precipType === 'mix' ? 'A wintry mix' : 'Rain';
      s += ' ' + ptName + ' moves in ' + futureTimeWord(precipStart);
      if(precipType === 'snow' && snowTotal > 0){
        var snowIn = (snowTotal / 2.54).toFixed(1);
        if(parseFloat(snowIn) >= 0.5) s += ' with ' + snowIn + '" possible';
      }
      s += '.';
    }

    // Wind ramp
    if(!hasAlerts && windPeak >= 30 && windPeakHr && wx.wind < windPeak - 10){
      s += ' Winds ramp to ' + Math.round(windPeak) + ' mph ' + futureTimeWord(windPeakHr) + '.';
    }

    // ── Part 4: Temperature trajectory ──
    {
      if(hr < 14 && tempMax > wx.temp + 6) s += ' Warming to ' + tempMax + '\u00b0 ' + futureTimeWord(tempMaxHr) + '.';
      else if(hr >= 14 && tempMin < wx.temp - 6) s += ' Dropping to ' + tempMin + '\u00b0 ' + futureTimeWord(tempMinHr) + '.';
      else if(hr >= 18 && daily && daily.temperature_2m_min && daily.temperature_2m_min[0] != null){
        var tonightLow = Math.round(daily.temperature_2m_min[0]);
        if(tonightLow < wx.temp - 8) s += ' Overnight low near ' + tonightLow + '\u00b0.';
      }
    }

    // UV warning (summer)
    if(!hasAlerts && wx.uv != null && wx.uv >= 8 && hr >= 10 && hr <= 16){
      if(wx.uv >= 11) s += ' Extreme UV \u2014 avoid prolonged sun exposure.';
      else s += ' UV index ' + Math.round(wx.uv) + ' \u2014 sunscreen recommended.';
    }

    // ── Part 5: THE ALERT — headline story ──
    if(hasAlerts){
      function eventRank(e){
        e = (e||'').toLowerCase();
        if(e.indexOf('tornado') >= 0) return 0;
        if(e.indexOf('hurricane') >= 0 || e.indexOf('typhoon') >= 0) return 1;
        if(e.indexOf('blizzard') >= 0) return 2;
        if(e.indexOf('ice storm') >= 0) return 3;
        if(e.indexOf('winter storm') >= 0) return 4;
        if(e.indexOf('severe thunderstorm') >= 0) return 5;
        if(e.indexOf('flash flood') >= 0) return 6;
        if(e.indexOf('extreme wind') >= 0) return 7;
        if(e.indexOf('fire') >= 0) return 8;
        if(e.indexOf('flood') >= 0) return 10;
        if(e.indexOf('wind') >= 0) return 12;
        if(e.indexOf('heat') >= 0) return 13;
        if(e.indexOf('cold') >= 0 || e.indexOf('chill') >= 0) return 14;
        if(e.indexOf('frost') >= 0 || e.indexOf('freeze') >= 0) return 15;
        return 20;
      }

      var sorted = alerts.slice().sort(function(a,b){
        var rank = {extreme:0, severe:1, moderate:2, minor:3};
        var ra = rank[a.severity] != null ? rank[a.severity] : 4;
        var rb = rank[b.severity] != null ? rank[b.severity] : 4;
        if(ra !== rb) return ra - rb;
        return eventRank(a.event) - eventRank(b.event);
      });

      var top = sorted[0];
      var evtName = top.event || 'Alert';
      var evtLower = evtName.toLowerCase();
      var desc = top.description || '';
      var hasStarted = top.onset && top.onset <= now;

      // Urgent tone for life-threatening events
      var isUrgent = evtLower.indexOf('tornado') >= 0 || evtLower.indexOf('hurricane') >= 0 ||
                     (evtLower.indexOf('flash flood') >= 0 && evtLower.indexOf('emergency') >= 0);

      // ── Extract numbers from alert description ──
      var stNums = [];
      // Snow accumulation (contextual — only if near snow/blizzard/winter)
      var isSnowEvent = evtLower.indexOf('snow') >= 0 || evtLower.indexOf('blizzard') >= 0 ||
                        evtLower.indexOf('winter') >= 0 || evtLower.indexOf('ice') >= 0;
      if(isSnowEvent){
        var sm = desc.match(/(?:total\s+)?(?:snow\s+)?(?:accumulations?\s+)?(?:between\s+|of\s+)?(\d+)\s*(?:and|to|-)\s*(\d+)\s*inch(?:es)?/i);
        if(sm) stNums.push(sm[1] + ' to ' + sm[2] + ' inches of snow');
        else {
          var smSingle = desc.match(/(?:up\s+to|around|near)\s+(\d+)\s*inch(?:es)?\s*(?:of\s+)?snow/i);
          if(smSingle) stNums.push('up to ' + smSingle[1] + ' inches of snow');
        }
      }
      // Rain
      var rm = desc.match(/(\d+\.?\d*)\s*(?:to|-)\s*(\d+\.?\d*)\s*inch(?:es)?\s*(?:of\s+)?rain/i);
      if(rm) stNums.push(rm[1] + ' to ' + rm[2] + ' inches of rain');
      // Surge / flood depth
      var fm = desc.match(/(\d+)\s*(?:to|-)\s*(\d+)\s*(?:ft|feet)\s*(?:of\s+)?(?:inundation|surge|flooding|water|storm surge)/i);
      if(fm) stNums.push(fm[1] + ' to ' + fm[2] + ' ft of surge');
      // Wind (gusts prioritized)
      var gm = desc.match(/gust[s]?[^.]*?(?:up\s+to|as\s+high\s+as|could\s+reach|of|to)\s+(\d+)\s*mph/i);
      var wm = desc.match(/wind[s]?[^.]*?(\d+)\s*(?:to|-)\s*(\d+)\s*mph/i);
      if(gm && stNums.length < 3) stNums.push('gusts up to ' + gm[1] + ' mph');
      else if(wm && stNums.length < 3) stNums.push('winds of ' + wm[1] + ' to ' + wm[2] + ' mph');
      // Ice
      var icm = desc.match(/ice\s*(?:accumulations?\s*)?(?:of\s+)?(\d+\.?\d*)\s*(?:to|-)\s*(\d+\.?\d*)\s*inch/i);
      if(icm && stNums.length < 3) stNums.push(icm[1] + ' to ' + icm[2] + '" of ice');

      // Visibility / whiteout
      var whiteout = desc.match(/whiteout|near[\s-]*zero\s*visibility|blinding|zero\s*visibility/i);

      // Build the alert sentence
      if(isUrgent){
        s += ' \u26a0\ufe0f ' + evtName.toUpperCase();
        if(hasStarted) s += ' IS ACTIVE.';
        else s += ' ISSUED.';
        if(stNums.length > 0) s += ' ' + stNums.join(', ') + '.';
        s += ' Take shelter immediately.';
      } else if(hasStarted){
        s += ' ' + evtName + ' is active';
        if(top.expires){
          var leftH = Math.round((top.expires - now) / 3600000);
          if(leftH <= 2) s += ' and winding down';
          else if(leftH < 10) s += ' for the next ' + leftH + ' hours';
          else if(leftH < 20) s += ' through ' + (hr < 15 ? 'tonight' : 'tomorrow');
          else s += ' through ' + futureTimeWord(top.expires);
        }
        if(stNums.length > 0) s += ' with ' + stNums.join(', ');
        if(whiteout) s += ' and whiteout conditions';
        s += '.';

        // Cross-reference: connect alert to live observations
        if(wx.snow > 0 && isSnowEvent){
          if(wx.snow >= 5) s += ' Heavy snow falling and accumulating.';
          else s += ' Snow falling now, intensifying later.';
        }
        if(windPeak >= 40 && windPeakHr && windPeakHr > now) s += ' Peak winds hit ' + futureTimeWord(windPeakHr) + '.';
      } else {
        s += ' ' + evtName + ' begins ' + futureTimeWord(top.onset);
        if(stNums.length > 0) s += ' bringing ' + stNums.join(', ');
        if(whiteout) s += ' with possible whiteout conditions';
        s += '.';

        // Cross-reference: bridge current conditions → incoming storm
        if(precipStart){
          var ptWord = precipType === 'snow' ? 'Snow' : precipType === 'mix' ? 'A wintry mix' : 'Rain';
          if(precipStart < top.onset) s += ' ' + ptWord + ' arrives first ' + futureTimeWord(precipStart) + ' before conditions worsen.';
          else if(wx.precip > 0 || wx.snow > 0) s += ' Precipitation already underway and intensifying.';
        }
      }

      // Temperature crash (for any alert scenario)
      if(tempMin < wx.temp - 10 && tempMinHr) s += ' Temperatures crash to ' + tempMin + '\u00b0 as the storm moves through.';

      // Wind ramp during alerts
      if(windPeak >= 45 && windPeakHr && windPeakHr > now && !stNums.some(function(n){ return n.indexOf('gust') >= 0 || n.indexOf('wind') >= 0; })){
        s += ' Wind peaks near ' + Math.round(windPeak) + ' mph ' + futureTimeWord(windPeakHr) + '.';
      }

      // Additional alerts — with key metric extraction
      if(sorted.length > 1){
        var others = [];
        for(var ai = 1; ai < Math.min(sorted.length, 4); ai++){
          var otherEvt = sorted[ai].event;
          if(others.indexOf(otherEvt) === -1 && otherEvt !== evtName){
            // Try to extract a key number from secondary alert
            var oDesc = sorted[ai].description || '';
            var oMetric = '';
            var oFm = oDesc.match(/(\d+)\s*(?:to|-)\s*(\d+)\s*(?:ft|feet)/i);
            var oSm = oDesc.match(/(\d+)\s*(?:to|-)\s*(\d+)\s*inch/i);
            if(oFm) oMetric = ' (' + oFm[1] + '-' + oFm[2] + ' ft)';
            else if(oSm) oMetric = ' (' + oSm[1] + '-' + oSm[2] + '")';
            others.push(otherEvt + oMetric);
          }
        }
        if(others.length > 0) s += ' ' + others.join(' and ') + ' also in effect.';
      }
    }

    // ── Part 6: Tomorrow preview ──
    if(daily && daily.temperature_2m_max && daily.temperature_2m_max[1] != null){
      var tmHi = Math.round(daily.temperature_2m_max[1]);
      var tmLo = Math.round(daily.temperature_2m_min[1]);
      var tmCode = daily.weathercode ? daily.weathercode[1] : null;
      var tmDesc = '';
      if(tmCode != null){
        if(tmCode <= 1) tmDesc = 'sunny';
        else if(tmCode <= 3) tmDesc = 'cloudy';
        else if(tmCode <= 48) tmDesc = 'foggy';
        else if(tmCode <= 57) tmDesc = 'drizzly';
        else if(tmCode <= 67) tmDesc = 'rainy';
        else if(tmCode <= 77) tmDesc = 'snowy';
        else if(tmCode <= 82) tmDesc = 'showery';
        else if(tmCode <= 86) tmDesc = 'snowy';
        else tmDesc = 'stormy';
      }
      if(hr >= 15) s += ' Tomorrow: ' + (tmDesc ? tmDesc + ', ' : '') + tmHi + '\u00b0/' + tmLo + '\u00b0.';
    }

    // ── Part 6.5: AIR QUALITY & POLLEN ──
    try {
      var aqB = window._aqData;
      var polB = window._pollenData;
      var aqiNow = (aqB && aqB.current && aqB.current.us_aqi != null) ? aqB.current.us_aqi : null;

      var aqiBand = function(v){
        if(v<=50) return 'good';
        if(v<=100) return 'moderate';
        if(v<=150) return 'unhealthy for sensitive groups';
        if(v<=200) return 'unhealthy';
        if(v<=300) return 'very unhealthy';
        return 'hazardous';
      };

      // Hourly AQI peak in next 12h
      var aqiPeak = null, aqiPeakAt = null;
      if (aqB && aqB.hourly && aqB.hourly.us_aqi && aqB.hourly.time) {
        var aArr = aqB.hourly.us_aqi, tArr = aqB.hourly.time, nowMs = now.getTime();
        var startI = 0;
        for (var ai = 0; ai < tArr.length; ai++){ if (new Date(tArr[ai]).getTime() >= nowMs) { startI = ai; break; } }
        for (var aj = startI; aj < Math.min(startI + 12, aArr.length); aj++){
          if (aArr[aj] != null && (aqiPeak == null || aArr[aj] > aqiPeak)){ aqiPeak = aArr[aj]; aqiPeakAt = new Date(tArr[aj]); }
        }
      }

      // Pollen: name notable players (currently High+, or surging to High+, or jumping ≥3 levels);
      // bundle the rest as a generic suffix. Detail lives in the pollen popup.
      var polLabels = {0:'none',1:'very low',2:'low',3:'moderate',4:'high',5:'very high'};
      var polTypeName = {TREE:'tree',GRASS:'grass',WEED:'ragweed'};
      var polNowHigh = [];        // [name] currently High+
      var polNotableSurges = [];  // [{type,peakLabel,dayOffset}] big future jumps
      var polMildRises = 0;       // count of types rising mildly but not notable
      var polFlat = 0;            // count of types low and flat
      if (polB && polB.dailyInfo && polB.dailyInfo.length){
        ['TREE','GRASS','WEED'].forEach(function(code){
          var todayV = null, peakV = null, peakDi = null, anyDay = false;
          for (var di = 0; di < polB.dailyInfo.length; di++){
            var di_ = polB.dailyInfo[di]; if (!di_ || !di_.pollenTypeInfo) continue;
            for (var pi2 = 0; pi2 < di_.pollenTypeInfo.length; pi2++){
              var pt = di_.pollenTypeInfo[pi2];
              if (pt.code !== code) continue;
              anyDay = true;
              var v = (pt.indexInfo && pt.indexInfo.value != null) ? pt.indexInfo.value : 0;
              if (di === 0) todayV = v;
              if (peakV == null || v > peakV){ peakV = v; peakDi = di; }
            }
          }
          if (!anyDay) return;
          var t0 = todayV || 0, pk = peakV || 0, dlt = pk - t0;
          if (t0 >= 4) {
            polNowHigh.push(polTypeName[code]);
          } else if (peakDi > 0 && (pk >= 4 || (pk >= 3 && dlt >= 3))) {
            polNotableSurges.push({ type: polTypeName[code], peakLabel: polLabels[pk], dayOffset: peakDi });
          } else if (peakDi > 0 && pk >= 2 && dlt >= 1) {
            polMildRises++;
          } else {
            polFlat++;
          }
        });
      }

      var aqSent = '';
      if (aqiNow != null){
        var nowBand = aqiBand(aqiNow);
        var nowR = Math.round(aqiNow);
        if (aqiPeak != null && aqiPeak > aqiNow + 20 && aqiBand(aqiPeak) !== nowBand){
          aqSent = ' Air ' + nowBand + ' (AQI ' + nowR + '), climbing to ' + aqiBand(aqiPeak) + ' by ' + futureTimeWord(aqiPeakAt) + '.';
        } else if (aqiNow > 100){
          aqSent = ' Air ' + nowBand + ' (AQI ' + nowR + ') — sensitive groups limit outdoor exertion.';
        } else {
          aqSent = ' Air ' + nowBand + ' (AQI ' + nowR + ').';
        }
      }

      // Compose: named callouts for the headliners, generalized suffix for the rest.
      var polParts = [];
      if (polNowHigh.length){
        polParts.push(polNowHigh.join(' and ') + ' pollen ' + (polNowHigh.length>1?'are':'is') + ' high today');
      }
      polNotableSurges.forEach(function(sg){
        var dayWord = sg.dayOffset === 1 ? 'tomorrow' : 'in ' + sg.dayOffset + ' days';
        polParts.push(sg.type + ' pollen rises to ' + sg.peakLabel + ' ' + dayWord);
      });

      var headlined = polNowHigh.length + polNotableSurges.length;
      if (polMildRises > 0 && headlined > 0){
        polParts.push('other types ticking up too');
      } else if (polMildRises > 0){
        polParts.push('pollen ticking up modestly across types');
      } else if (polFlat > 0 && headlined > 0){
        polParts.push('other types staying low');
      }

      var polSent = '';
      if (polParts.length){
        var polStr = polParts.join('; ');
        polSent = ' ' + polStr.charAt(0).toUpperCase() + polStr.slice(1) + '.';
      } else if (polB && polB.dailyInfo && polB.dailyInfo.length){
        polSent = ' Pollen low across the board.';
      }

      s += aqSent + polSent;
    } catch (aqpErr) { console.warn('[Briefing] AQ/pollen section error:', aqpErr.message); }

    // ── Part 7: AURORA & SPACE WEATHER intelligence ──
    var sw = window._swData || {};
    if(sw.kp != null){
      var kp = sw.kp;
      var userLat = window.LOCATION ? LOCATION.lat : 40.7;

      // Aurora visibility latitude thresholds
      var auroraLat = 67;
      if(kp >= 9) auroraLat = 30;
      else if(kp >= 8) auroraLat = 35;
      else if(kp >= 7) auroraLat = 40;
      else if(kp >= 6) auroraLat = 45;
      else if(kp >= 5) auroraLat = 50;
      else if(kp >= 4) auroraLat = 55;
      else if(kp >= 3) auroraLat = 60;

      var canSeeAurora = userLat >= (auroraLat - 5);
      var isAfterSunset = wx.sunset ? now >= new Date(wx.sunset) : hr >= 18;
      var isBeforeSunrise = wx.sunrise ? now < new Date(wx.sunrise) : hr < 6;
      var isNight = isAfterSunset || isBeforeSunrise;

      // Moon phase — bright moon washes out aurora
      var moonInfo = typeof approximateMoonPhase === 'function' ? approximateMoonPhase(now) : null;
      var moonIllum = moonInfo ? moonInfo.illum : 0;
      var moonBright = moonIllum > 60;

      // Night cloud average (21:00-01:00 from scan above, fallback to current)
      var nightClouds = nightCloudAvg != null ? nightCloudAvg : (wx.cloudCover != null ? wx.cloudCover : null);

      // Solar flare + space weather alert context
      var flareNote = '';
      if(sw.xrayClass){
        var fc = sw.xrayClass.charAt(0);
        if(fc === 'X') flareNote = 'X-class solar flare detected \u2014 major geomagnetic storm possible';
        else if(fc === 'M') flareNote = 'M-class solar flare detected \u2014 elevated aurora chances';
      }
      if(!flareNote && sw.spaceAlerts && sw.spaceAlerts.length > 0){
        var geomAlerts = sw.spaceAlerts.filter(function(a){ return a.type && a.type.toLowerCase().indexOf('geomagnetic') >= 0; });
        if(geomAlerts.length > 0) flareNote = 'Geomagnetic storm watch active';
      }

      // Bz + solar wind speed
      var bzFavorable = sw.bz != null && sw.bz < -5;
      var fastWind = sw.speed != null && sw.speed > 600;

      // Build aurora narrative only when noteworthy
      if(kp >= 4 && canSeeAurora){
        var stormName = kp >= 8 ? 'Extreme geomagnetic storm' :
                        kp >= 7 ? 'Severe geomagnetic storm' :
                        kp >= 6 ? 'Strong geomagnetic storm' :
                        kp >= 5 ? 'Geomagnetic storm' : 'Elevated geomagnetic activity';

        s += ' \u2728 ' + stormName + ' (Kp ' + kp.toFixed(0) + ')';

        // Enhancement factors
        var enhancers = [];
        if(bzFavorable) enhancers.push('southward Bz');
        if(fastWind) enhancers.push(Math.round(sw.speed) + ' km/s solar wind');
        if(enhancers.length > 0) s += ' with ' + enhancers.join(' and ') + ' boosting aurora';

        s += ' \u2014 aurora may be visible';
        if(userLat >= auroraLat) s += ' overhead';
        else s += ' low on the northern horizon';

        if(!isNight) s += '. Best viewing after dark tonight';

        // Conditions assessment
        if(nightClouds != null){
          if(nightClouds <= 20){
            s += moonBright ? ', clear skies but a ' + moonIllum + '% moon will wash out fainter displays' : ' under clear skies \u2014 excellent conditions';
          } else if(nightClouds <= 50){
            s += moonBright ? ', partly cloudy with bright moonlight' : ', partly cloudy but gaps should offer views';
          } else if(nightClouds <= 80){
            s += ', mostly cloudy \u2014 look for breaks';
          } else {
            s += ', but overcast skies will likely block the view';
          }
        }
        s += '.';
        if(flareNote) s += ' ' + flareNote + '.';

      } else if(flareNote && canSeeAurora){
        s += ' \u2600\ufe0f ' + flareNote + '. Watch for aurora tonight if Kp rises above ' + Math.ceil(userLat >= 55 ? 3 : userLat >= 45 ? 5 : 7) + '.';
      } else if(kp >= 5 && !canSeeAurora){
        s += ' Geomagnetic storm underway (Kp ' + kp.toFixed(0) + ') but aurora unlikely at ' + Math.round(userLat) + '\u00b0N.';
      }
    }
    // ── Part 8: SPACE EVENTS — solar activity, meteor showers, conjunctions, oppositions ──
    var spaceNotes = [];
    var today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

    // Solar activity / Kp — mention even if aurora isn't visible at user's latitude
    if(sw.kp != null && sw.kp >= 4 && !(sw.kp >= 4 && canSeeAurora)){
      // Only add if not already mentioned in the aurora section above
      var kpLabel = sw.kp >= 7 ? 'Severe geomagnetic storm' : sw.kp >= 5 ? 'Geomagnetic storm' : 'Elevated solar activity';
      spaceNotes.push('☀️ ' + kpLabel + ' (Kp ' + sw.kp.toFixed(1) + ') — aurora visible at higher latitudes');
    }

    // Recent solar flare (from _swData)
    if(sw.xrayClass && !flareNote){
      var fc2 = sw.xrayClass.charAt(0);
      if(fc2 === 'X') spaceNotes.push('☀️ X-class solar flare detected — watch for geomagnetic storm arrival in 24-72h');
      else if(fc2 === 'M') spaceNotes.push('☀️ M-class solar flare detected — minor geomagnetic effects possible');
    }

    // Meteor shower — active OR starting this week
    if(typeof METEOR_SHOWERS !== 'undefined'){
      var yr = now.getFullYear();
      for(var mi = 0; mi < METEOR_SHOWERS.length; mi++){
        var ms = METEOR_SHOWERS[mi];
        var actStart = new Date(yr, ms.activeStart.m - 1, ms.activeStart.d);
        var actEnd = new Date(yr, ms.activeEnd.m - 1, ms.activeEnd.d);
        if(actEnd < actStart) actEnd = new Date(yr + 1, ms.activeEnd.m - 1, ms.activeEnd.d);
        var peakS = new Date(yr, ms.peakStart.m - 1, ms.peakStart.d);
        var daysToStart = Math.round((actStart - today) / 86400000);
        var daysToPeak = Math.round((peakS - today) / 86400000);

        if(now >= actStart && now <= actEnd){
          // Currently active
          if(daysToPeak >= -1 && daysToPeak <= 1){
            spaceNotes.push('🌠 ' + ms.name + ' meteor shower peaks tonight (' + ms.zhr + '/hr). Best viewing ' + ms.bestView + ' looking ' + ms.direction);
          } else if(daysToPeak > 1 && daysToPeak <= 7){
            spaceNotes.push('🌠 ' + ms.name + ' meteor shower active — peak in ' + daysToPeak + ' days (' + ms.zhr + '/hr at peak)');
          } else {
            spaceNotes.push('🌠 ' + ms.name + ' meteor shower active — early activity, peak ' + daysToPeak + ' days away');
          }
          break;
        } else if(daysToStart > 0 && daysToStart <= 7){
          // Starting this week
          spaceNotes.push('🌠 ' + ms.name + ' meteor shower begins in ' + daysToStart + ' day' + (daysToStart > 1 ? 's' : '') + ' (peaks ' + daysToPeak + ' days away, ' + ms.zhr + '/hr)');
          break;
        }
      }
    }

    // Upcoming conjunction (within 7 days)
    if(typeof nextConjunction === 'function'){
      var conj = nextConjunction(today);
      if(conj){
        var conjDays = Math.round((conj.d - today) / 86400000);
        if(conjDays <= 0) spaceNotes.push('🪐 ' + conj.bodies + ' conjunction tonight (' + conj.separation + ' apart) — look ' + conj.direction + ' at ' + conj.time.toLowerCase());
        else if(conjDays <= 7) spaceNotes.push('🪐 ' + conj.bodies + ' conjunction in ' + conjDays + ' day' + (conjDays > 1 ? 's' : '') + ' — ' + conj.note);
      }
    }

    // Upcoming opposition (within 7 days)
    if(typeof nextOpposition === 'function'){
      var opp = nextOpposition(today);
      if(opp){
        var oppDays = Math.round((opp.d - today) / 86400000);
        if(oppDays <= 0) spaceNotes.push('🔭 ' + opp.planet + ' at opposition tonight (mag ' + opp.magnitude + ') in ' + opp.constellation + ' — visible all night');
        else if(oppDays <= 7) spaceNotes.push('🔭 ' + opp.planet + ' opposition in ' + oppDays + ' day' + (oppDays > 1 ? 's' : '') + ' — ' + opp.note);
      }
    }

    if(spaceNotes.length > 0) s += ' ' + spaceNotes.join('. ') + '.';

    } catch(advErr) { console.warn('[Briefing] Advanced section error:', advErr.message); }

    el.textContent = s;
  }


