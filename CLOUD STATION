    /* Both columns get explicit grid-rows so each row pairs cleanly
       between weather (left) and air-quality / pollen (right). */
    .weather-stat:has(#precip-amt)   { grid-column: 1 !important; grid-row: 3 !important; }
    .weather-stat:has(#forecast-row) { grid-column: 1 !important; grid-row: 4 !important; }
    .weather-stat:has(#wind)         { grid-column: 1 !important; grid-row: 5 !important; }
    .weather-stat:has(#gusts)        { grid-column: 1 !important; grid-row: 6 !important; }
