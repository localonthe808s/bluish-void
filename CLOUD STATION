      evidenceChain: [],          // array of evidence strings
      severity: 'none',            // 'none','advisory','warning','emergency'
      // ── PROFESSIONAL ATMOSPHERIC DISPERSION FIELDS ──
      stabilityClass: null,        // Pasquill-Gifford: A-F
      stabilityLabel: null,        // 'Very Unstable' → 'Very Stable'
      mixingHeight: null,          // meters — max height smoke can rise
      ventilationIndex: null,      // mixing height × transport wind (m²/s) — dispersion capacity
      dispersionRating: null,      // 'excellent','good','moderate','poor','stagnant'
      transportWindSpd: null,      // mean transport wind in mixing layer (mph)
      transportWindDir: null,      // transport wind direction
      plumeRiseEst: null,          // estimated plume rise height (m) for nearby fires
      smokeAloft: false,           // smoke detected above PBL but not at surface
      aloftDetail: null,
