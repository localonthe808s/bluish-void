    _spcFetchTotal++;
    var url = spcBaseUrl + layerId + '/query?where=1%3D1&outFields=*&f=geojson';
    fetch(url).then(function(r){
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    }).then(function(data){
      if (data.features && data.features.length > 0) callback(data);
    }).catch(function(err){
      _spcFetchErrors++;
      console.warn('[SPC] Layer ' + layerId + ' failed:', err.message || err);
      var pill = document.getElementById('tornado-status-pill');
      if (pill && _spcFetchErrors >= 3) {
        pill.style.display = 'block';
        pill.innerHTML = '⚠ SPC data partially unavailable <span style="opacity:.5;font-size:.4rem;">(' + _spcFetchErrors + '/' + _spcFetchTotal + ' failed)</span>';
