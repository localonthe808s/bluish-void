  // Auto-detect landscape from elevation data or let user override
  window._ghLandscape = null; // null = auto-detect, or 'plains'|'beach'|'city'|'mountains'|'forest'

  function detectLandscape(){
    if(window._ghLandscape) return window._ghLandscape;
    var loc = window.LOCATION || {};
    // Hardcoded location hint
    if(loc.landscape) return loc.landscape;
    // NYC metro area hardcode — generous bounds covering all five boroughs
    // plus Newark/Jersey City/Hoboken to the west, Yonkers/southern Westchester
    // to the north, and western Long Island (Nassau county). Anything within
    // the metro reads as 'city' so the Manhattan skyline silhouette applies.
    //   lat 40.45 - 41.10  (Staten Island south → Yonkers north)
    //   lon -74.50 - -73.40  (Newark west → western Nassau east)
    if(loc.lat>=40.45&&loc.lat<=41.10&&loc.lon>=-74.50&&loc.lon<=-73.40) return 'city';
    var geo = window._geoMeta || {};
    var elev = loc.elevation != null ? loc.elevation : geo.elevation;
    var pop = geo.population || 0;
    var fc = (geo.featureCode || '').toUpperCase();

    // Feature code signals (from GeoNames via Open-Meteo geocoding)
    // PPL* = populated place, MT/PK/HLL = mountain/peak/hills, PRK/RESF = park/forest
    // BCH/COVE/ISL = beach/coastal, FRST = forest
    if(fc.indexOf('MT') >= 0 || fc === 'PK' || fc === 'PASS' || fc === 'VLC') return 'mountains';
    if(fc === 'BCH' || fc === 'COVE' || fc === 'ISL' || fc === 'ISLS' || fc === 'CAPE') return 'beach';
    if(fc === 'FRST' || fc === 'RESF' || fc === 'RESN') return 'forest';

    // Population: cities > 50k people
    if(pop > 50000 || fc.indexOf('PPLC') >= 0) return 'city';
    // PPL with decent population
    if(fc.indexOf('PPL') >= 0 && pop > 20000) return 'city';

    // Elevation-based fallback
    if(elev != null){
      if(elev < 10) return 'beach';
      if(elev > 600) return 'mountains';
      if(elev > 300) return 'forest';
    }

    // Small populated places default to plains
    return 'plains';
  }

