                  var dirs = ['N','NE','E','SE','S','SW','W','NW'];
                  best = { time: new Date(p.timestamp*1000), distance: dist, direction: dirs[Math.round(br/45)%8] };
                }
              }
              window._issNextPass = best;
            }).catch(function(){});
        } catch(e){}
