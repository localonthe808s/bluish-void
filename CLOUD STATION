            { layers: 'GOES-East_ABI_Band13_Clean_Infrared', format: 'image/png', transparent: true, opacity: 1.0, attribution: 'NASA GIBS · GOES-East Band 13 IR', version: '1.3.0', pane: 'hz-wv', updateWhenZooming: false, updateWhenIdle: true }
          );
        }
        _hurricaneLayerObjs.wv.addTo(_hurricaneMap);
      } else {
        if (_hurricaneLayerObjs.wv && _hurricaneMap.hasLayer(_hurricaneLayerObjs.wv)) _hurricaneMap.removeLayer(_hurricaneLayerObjs.wv);
      }
    }

    // ── TROPICAL WAVES ────────────────────────────────────────────────────────
    // African easterly waves — the seeds of 85% of Atlantic hurricanes.
    // Fetched from NHC's publicly accessible GIS feed for tropical weather outlook
    if (which === 'waves') {
      if (on) {
        _hurricaneLayerObjs.waveMarkers.forEach(function(m){ try{ _hurricaneMap.removeLayer(m); }catch(e){} });
        _hurricaneLayerObjs.waveMarkers = [];
        _fetchTropicalWaves();
      } else {
        _hurricaneLayerObjs.waveMarkers.forEach(function(m){ try{ _hurricaneMap.removeLayer(m); }catch(e){} });
        _hurricaneLayerObjs.waveMarkers = [];
      }
    }

    if (which === 'gtwo') {
      if (on) _fetchGTWODisturbances();
      else {
        _hurricaneLayerObjs.disturbanceMarkers.forEach(function(m){ try{ _hurricaneMap.removeLayer(m); }catch(e){} });
        _hurricaneLayerObjs.disturbanceMarkers = [];
      }
    }

    if (which === 'track') {
      var showFn = on ? 'addTo' : 'removeFrom';
      _hurricaneLayerObjs.conePolygons.forEach(function(m){ try{ if(on) m.addTo(_hurricaneMap); else _hurricaneMap.removeLayer(m); }catch(e){} });
      _hurricaneLayerObjs.trackLines.forEach(function(m){ try{ if(on) m.addTo(_hurricaneMap); else _hurricaneMap.removeLayer(m); }catch(e){} });
      // Re-fetch if toggled on with no data
      if (on && _hurricaneLayerObjs.conePolygons.length === 0 && window._nhcActiveStorms) {
        window._nhcActiveStorms.forEach(function(s) {
          _fetchStormTrackFromNowcoast(s.id || s.atcfID, (s.name||'Storm').toUpperCase(), hurricaneIntensityColor(parseInt(s.intensity||0)));
        });
      }
    }
  }

  function initHurricaneTab() {
    if (_hurricaneInited) return;
    _hurricaneInited = true;

    var mapDiv = document.getElementById('hurricane-map');
    if (!mapDiv) return;

    // Init Leaflet map — full Atlantic view: Africa west coast → US East Coast
    _hurricaneMap = L.map('hurricane-map', {
