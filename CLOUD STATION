  function loadWeatherForLocation(loc){
    if (!locNameEl) return;

    setText(locNameEl, loc.name);

    // Auto-populate geo metadata for landscape detection if not set by search
    if(!window._geoMeta || !window._geoMeta.population){
      try {
        fetch('https://geocoding-api.open-meteo.com/v1/search?name=' + encodeURIComponent(loc.name) + '&count=1&language=en&format=json')
          .then(function(r){ return r.json(); })
          .then(function(d){
            if(d && d.results && d.results[0]){
              var r = d.results[0];
              window._geoMeta = { population: r.population || 0, featureCode: r.feature_code || '', elevation: r.elevation || null };
              try { setGHLandscape(detectLandscape()); } catch(e){}
            }
          }).catch(function(){});
      } catch(e){}
    }

    var url =
      "https://api.open-meteo.com/v1/forecast" +
      "?latitude=" + loc.lat +
      "&longitude=" + loc.lon +
      "&timezone=" + encodeURIComponent(TZ) +
      "&temperature_unit=fahrenheit" +
      "&windspeed_unit=mph" +
      "&precipitation_unit=inch" +
      "&hourly=temperature_2m,apparent_temperature,relativehumidity_2m,dewpoint_2m,precipitation_probability,precipitation,cloudcover,windspeed_10m,windgusts_10m,wind_direction_10m,visibility,pressure_msl,uv_index,weathercode,snowfall,rain,cape,lifted_index,freezinglevel_height,soil_moisture_0_to_1cm,boundary_layer_height,shortwave_radiation,direct_radiation,cloud_cover_low,cloud_cover_mid,cloud_cover_high,windspeed_300hPa,winddirection_300hPa,windspeed_500hPa,winddirection_500hPa,windspeed_700hPa,winddirection_700hPa" +
      "&daily=weathercode,temperature_2m_max,temperature_2m_min,precipitation_probability_max,precipitation_sum,sunrise,sunset,uv_index_max,windspeed_10m_max,windgusts_10m_max,snowfall_sum,rain_sum,wind_direction_10m_dominant,showers_sum,et0_fao_evapotranspiration" +
      "&forecast_days=10&past_days=1";

    // ── Multi-tier weather data fallback ─────────────────────────────
    // 1. Direct fetch to api.open-meteo.com
    // 2. If 429/error: try via corsproxy.io (different IP, separate quota)
    // 3. If that fails too: fall back to in-memory or localStorage cache
    //    (Tracking Prevention can block localStorage in iframes — use both)
    // 4. Cache successful responses in BOTH memory + localStorage with a 7d
    //    window so a single good fetch keeps the UI populated across reloads
    var WX_CACHE_KEY = 'bluish_wx_cache_v1';
    var WX_MAX_AGE = 7 * 24 * 60 * 60 * 1000; // 7 days
    var loadFromCache = function(){
      // In-memory wins (still fresh after reload won't help, but covers
      // re-fetches during a session)
      if (window._wxMemCache && window._wxMemCache.lat === loc.lat
          && window._wxMemCache.lon === loc.lon
          && (Date.now() - window._wxMemCache.savedAt) < WX_MAX_AGE) {
        return window._wxMemCache.data;
      }
      try{
        var raw = localStorage.getItem(WX_CACHE_KEY);
        if (!raw) return null;
        var parsed = JSON.parse(raw);
        if (parsed && parsed.savedAt && (Date.now() - parsed.savedAt) < WX_MAX_AGE
            && parsed.lat === loc.lat && parsed.lon === loc.lon) {
          return parsed.data;
        }
      } catch(e){}
      return null;
    };
    var saveToCache = function(data){
      window._wxMemCache = { lat: loc.lat, lon: loc.lon, savedAt: Date.now(), data: data };
      try{
        localStorage.setItem(WX_CACHE_KEY, JSON.stringify(window._wxMemCache));
      } catch(e){}  // localStorage may be blocked — memory cache still works
    };

    // Try several CORS proxies in sequence. corsproxy.io has been
    // returning 403 from this origin; codetabs is more reliable.
    var WX_PROXIES = [
      'https://api.codetabs.com/v1/proxy?quest=',
      'https://corsproxy.io/?',
      'https://api.allorigins.win/raw?url='
    ];
    var tryViaProxy = function(idx){
      idx = idx || 0;
      if (idx >= WX_PROXIES.length) return Promise.reject(new Error('all proxies failed'));
      var proxied = WX_PROXIES[idx] + encodeURIComponent(url);
      console.log('[Weather] retrying via', WX_PROXIES[idx]);
      return fetchWithTimeout(proxied, null, 12000).then(function(r){
        if (!r.ok) throw new Error('proxy HTTP ' + r.status);
        return r.json();
      }).catch(function(){ return tryViaProxy(idx + 1); });
    };

    var directFetch;
    if (window._earlyWxFetch && window._earlyWxUrl === url) {
      // Use the head-fired early fetch instead of issuing a duplicate request.
      directFetch = window._earlyWxFetch.then(function(data){
        if (!data) throw new Error('early fetch returned null');
        return data;
