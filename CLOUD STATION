  function fetchGoesTimestamps(){
    var eastEl  = document.getElementById('cira-goes-sectors');
    var westEl  = document.getElementById('cira-goes-sectors-west');
    var mesoEl  = document.getElementById('cira-goes-meso');
    if(eastEl)  eastEl.innerHTML='';
    if(westEl)  westEl.innerHTML='';
    if(mesoEl)  mesoEl.innerHTML='';

    var sectors=[
      {sat:'goes-19',sector:'full_disk',  label:'Full Disk',   target:'east', extra:'GeoColor'},
      {sat:'goes-19',sector:'conus',      label:'CONUS',       target:'east', extra:'GeoColor · 5-min'},
      {sat:'goes-18',sector:'full_disk',  label:'Full Disk',   target:'west', extra:'GeoColor'},
      {sat:'goes-18',sector:'conus',      label:'CONUS West',  target:'west', extra:'GeoColor'},
      {sat:'goes-19',sector:'mesoscale_01',label:'Meso-1',     target:'meso', extra:'1-min · mobile sector'},
      {sat:'goes-19',sector:'mesoscale_02',label:'Meso-2',     target:'meso', extra:'1-min · mobile sector'}
    ];

    // Try multiple CORS proxies — allorigins.win has been intermittently
    // 408ing and CORS-blocked, corsproxy.io 403s. codetabs is the most
    // reliable from this origin.
    var GOES_PROXIES = [
      { url: 'https://api.codetabs.com/v1/proxy?quest=', wrap: false },
      { url: 'https://corsproxy.io/?', wrap: false },
      { url: 'https://api.allorigins.win/get?url=', wrap: true }
    ];
    var fetchViaProxy = function(rawUrl, idx){
      idx = idx || 0;
      if (idx >= GOES_PROXIES.length) return Promise.reject(new Error('all proxies failed'));
      var p = GOES_PROXIES[idx];
      return fetch(p.url + encodeURIComponent(rawUrl))
        .then(function(r){
          if (!r.ok) throw new Error('HTTP '+r.status);
          return r.json();
        })
        .then(function(d){ return p.wrap ? JSON.parse(d.contents) : d; })
        .catch(function(){ return fetchViaProxy(rawUrl, idx+1); });
    };
    sectors.forEach(function(s){
      var rawUrl = SLIDER+s.sat+'/'+s.sector+'/geocolor/latest_times.json';
      fetchViaProxy(rawUrl)
        .then(function(d){
          if(!d||!d.timestamps_int||!d.timestamps_int.length)return;
          var latest=d.timestamps_int[0];
          var el = s.target==='east'?eastEl : s.target==='west'?westEl : mesoEl;
          renderGoesRow(el, s.label, latest, s.extra);
        }).catch(function(){
          var el = s.target==='east'?eastEl : s.target==='west'?westEl : mesoEl;
          if(el){
            var row=document.createElement('div');
            row.style.cssText='font-family:system-ui,sans-serif;font-size:.3rem;color:rgba(43,34,244,.3);padding:2px 0;';
            row.textContent=s.label+' · unavailable';
            el.appendChild(row);
          }
        });
    });
  }

  function init(){
    // Open default tab
    switchCiraTab('goes');
    // Load LOD posts — feeds both Events and Archive tabs.
    // Try direct first, fall back through CORS proxies if blocked
    // (satlib.cira.colostate.edu is sometimes CORS-strict from
    // third-party origins like Wix iframes).
    var lodUrl = SATLIB+'lod?per_page=72&orderby=date&order=desc&_embed';
    var lodProxies = [
      '',
      'https://api.codetabs.com/v1/proxy?quest=',
      'https://corsproxy.io/?'
    ];
    var fetchLodViaProxy = function(idx){
      idx = idx || 0;
      if (idx >= lodProxies.length) return Promise.reject(new Error('all proxies failed'));
      var u = idx === 0 ? lodUrl : lodProxies[idx] + encodeURIComponent(lodUrl);
      return fetch(u).then(function(r){
        if (!r.ok) throw new Error('HTTP ' + r.status);
        return r.json();
      }).catch(function(){ return fetchLodViaProxy(idx + 1); });
    };
    fetchLodViaProxy()
      .then(function(posts){
        if(!posts||!posts.length){
          _ciraError('No satellite events available');
          return;
        }
        _allPosts = posts;
        loadLOD(extractMedia(posts[0]));
        renderEvents(posts);
        // If the user already navigated to ARCHIVE before LOD finished
        // loading, render the grid now — otherwise the first click on
        // ARCHIVE silently drops with `_allPosts.length === 0` and the
        // user has to click the tab a second time.
        if (_currentTab === 'archive' && !_archiveRendered) {
          _archiveRendered = true;
          renderArchive(_allPosts);
          fetchAndInjectThumbs(_allPosts);
        }
      }).catch(function(e){
        console.warn('[CIRA]',e);
        _ciraError('Unable to load satellite data');
      });
    fetchGoesTimestamps(); // still run for potential future use
    // setInterval(fetchGoesTimestamps, 600000);
  }

  if(document.readyState==='loading'){
    document.addEventListener('DOMContentLoaded',init);
  }else{
    setTimeout(init,0);
  }

