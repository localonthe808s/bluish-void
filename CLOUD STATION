  function parseTornadoCSV(csv){
    var lines = csv.trim().split('\n');
    var reports = [];
    // Skip header line
    for (var i = 1; i < lines.length; i++){
      var line = lines[i];
      if (!line.trim()) continue;
      // Format: Time,F_Scale,Location,County,State,Lat,Lon,Comments
      var parts = line.split(',');
      if (parts.length < 7) continue;
      var time = parts[0].trim();
      var scale = parts[1].trim();
      var location = parts[2].trim();
      var county = parts[3].trim();
      var state = parts[4].trim();
      var lat = parseFloat(parts[5]);
      var lon = parseFloat(parts[6]);
      var comment = parts.slice(7).join(',').trim();
      if (!isNaN(lat) && !isNaN(lon)){
        reports.push({
          time: time,
          scale: scale,
          location: location,
          county: county,
          state: state,
          lat: lat,
          lon: lon,
          comment: comment
        });
      }
    }
    return reports;
  }

  function efColor(scale){
    switch(scale){
      case 'EF0': return '#66bb6a';
      case 'EF1': return '#fdd835';
      case 'EF2': return '#ffa726';
      case 'EF3': return '#ef5350';
      case 'EF4': return '#ab47bc';
      case 'EF5': return '#ec407a';
      default: return '#90caf9'; // UNK
    }
  }

  function efRadius(scale){
    switch(scale){
      case 'EF0': return 18;
      case 'EF1': return 22;
      case 'EF2': return 26;
      case 'EF3': return 30;
      case 'EF4': return 34;
      case 'EF5': return 38;
      default: return 18;
    }
  }

  function plotTornadoes(reports, dateLabel){
    if (!tornadoMap) return;
    reports.forEach(function(r){
      var color = efColor(r.scale);
      var sz = efRadius(r.scale) + 4;
      var tornadoIcon = L.divIcon({
        className: '',
        iconSize: [sz, sz],
        iconAnchor: [sz/2, sz/2],
        html: '<svg width="'+sz+'" height="'+sz+'" viewBox="0 0 24 24">' +
          '<defs><filter id="tg" x="-40%" y="-40%" width="180%" height="180%"><feDropShadow dx="0" dy="0" stdDeviation="2.5" flood-color="#ef4444" flood-opacity=".7"/></filter></defs>' +
          '<polygon points="4,4 20,4 12,21" fill="#dc2626" fill-opacity="0.95" stroke="#7f1d1d" stroke-width="1.8" stroke-linejoin="round" filter="url(#tg)"/>' +
          '</svg>'
      });
      var tornadoLocalTime = (function(){ var h=parseInt(r.time.slice(0,2),10),m=r.time.slice(2,4); var d=new Date(); d.setUTCHours(h,parseInt(m,10),0,0); return d.toLocaleTimeString('en-US',{timeZone:(LOCATION&&LOCATION.tz)||'America/New_York',hour:'numeric',minute:'2-digit',hour12:true}); })();
      var tornadoOfficeMatch = r.comment ? r.comment.match(/\(([A-Z]{3})\)\s*$/) : null;
      var tornadoOffice = tornadoOfficeMatch ? tornadoOfficeMatch[1] : '';
      var rawComment = r.comment ? r.comment.replace(/\s*\([A-Z]{3}\)\s*$/, '').trim() : '';

      // ── Parse intelligence from comment ──
      var fatalMatch  = rawComment.match(/\*+\s*(\d+)\s*FATAL/i);
      var injMatch    = rawComment.match(/\*+\s*(\d+)\s*INJ/i);
      var windMatch   = rawComment.match(/(\d+)\s*(?:to\s*\d+\s*)?mph/i);
      // Path: prefer "X.X mile" from survey text
      var pathMatch   = rawComment.match(/(\d+\.?\d*)\s*mile/i);
      var widthMatch  = rawComment.match(/(\d+)\s*yard/i);
      // EF buried in comment (survey confirmed before official rating)
      var efInComment = rawComment.match(/\bEF[0-5]\b/);
      var confirmedEF = efInComment ? efInComment[0] : null;
      // Landspout
      var isLandspout = /landspout/i.test(rawComment);
      // Corrects previous report
      var isCorrection = /corrects previous/i.test(rawComment);
      // Time estimated flag
      var timeEst = /time estimated/i.test(rawComment);
      // Tornado type
      var torType = '';
      if (isLandspout) torType = 'Landspout';
      else if (/wedge/i.test(rawComment)) torType = 'Wedge';
      else if (/rope/i.test(rawComment)) torType = 'Rope';
      else if (/cone/i.test(rawComment)) torType = 'Cone';
      else if (/stovepipe/i.test(rawComment)) torType = 'Stovepipe';
      else if (/elephant.?trunk/i.test(rawComment)) torType = 'Elephant Trunk';
      else if (/brief/i.test(rawComment)) torType = 'Brief';
      // Detection / confirmation source (priority order)
      var detMethod = '';
      if (/survey/i.test(rawComment)) detMethod = 'NWS Survey ✓';
      else if (/TDS|debris signature/i.test(rawComment)) detMethod = 'Radar TDS';
      else if (/spotter/i.test(rawComment)) detMethod = 'Trained Spotter';
      else if (/chaser/i.test(rawComment)) detMethod = 'Storm Chaser';
      else if (/video|social media/i.test(rawComment)) detMethod = 'Video Confirmed';
      else if (/911|EMA|emergency/i.test(rawComment)) detMethod = '911 / EMA';
      else if (/broadcast|media/i.test(rawComment)) detMethod = 'Broadcast Media';
      else if (/radar/i.test(rawComment)) detMethod = 'Radar Indicated';
      // Damage keywords — structure type
      var dmgTypes = [];
      if (/manufactur|mobile home|trailer/i.test(rawComment)) dmgTypes.push('Mobile homes');
      if (/barn/i.test(rawComment)) dmgTypes.push('Barn');
      if (/roof/i.test(rawComment)) dmgTypes.push('Roof damage');
      if (/tree|timber/i.test(rawComment)) dmgTypes.push('Tree damage');
      if (/power.?line|power.?pole|power.?flash/i.test(rawComment)) dmgTypes.push('Power lines');
      if (/solar/i.test(rawComment)) dmgTypes.push('Solar farm');
      if (/vehicle|car/i.test(rawComment)) dmgTypes.push('Vehicle');
      var dmgStr = dmgTypes.length ? dmgTypes.slice(0,3).join(', ') : '';

      // Clean comment — truncate at word boundary
      var cleanTornadoComment = rawComment;
      if (cleanTornadoComment.length > 160) cleanTornadoComment = cleanTornadoComment.substring(0, cleanTornadoComment.lastIndexOf(' ', 160)) + '…';

      // Build extra rows — only when data present
      var extraRows = '';
      if (fatalMatch) extraRows += '<div class="hz-card-row"><span class="hz-label" style="color:#f87171;">Fatalities</span><span class="hz-val" style="color:#f87171;font-weight:700;">⚠ ' + fatalMatch[1] + '</span></div>';
      if (injMatch)   extraRows += '<div class="hz-card-row"><span class="hz-label" style="color:#fbbf24;">Injuries</span><span class="hz-val" style="color:#fbbf24;">' + injMatch[1] + '</span></div>';
      if (confirmedEF && r.scale === 'UNK') extraRows += '<div class="hz-card-row"><span class="hz-label">Survey Rating</span><span class="hz-val" style="color:' + efColor(confirmedEF) + ';">' + confirmedEF + ' <span style="font-size:.42rem;color:rgba(255,255,255,.4);">pending official</span></span></div>';
      if (windMatch)  extraRows += '<div class="hz-card-row"><span class="hz-label">Est. Winds</span><span class="hz-val">' + windMatch[1] + ' mph</span></div>';
      if (torType)    extraRows += '<div class="hz-card-row"><span class="hz-label">Type</span><span class="hz-val">' + torType + '</span></div>';
      if (pathMatch)  extraRows += '<div class="hz-card-row"><span class="hz-label">Path</span><span class="hz-val">' + pathMatch[1] + ' mi' + (widthMatch ? ' · ' + widthMatch[1] + ' yd wide' : '') + '</span></div>';
      if (detMethod)  extraRows += '<div class="hz-card-row"><span class="hz-label">Confirmed by</span><span class="hz-val" style="color:rgba(255,255,255,.7);">' + detMethod + '</span></div>';
      if (dmgStr)     extraRows += '<div class="hz-card-row"><span class="hz-label">Damage</span><span class="hz-val" style="color:rgba(255,255,255,.6);">' + dmgStr + '</span></div>';
      if (isCorrection) extraRows += '<div style="margin:3px 0 0;font-size:.4rem;color:rgba(255,200,80,.6);font-style:italic;">↺ Corrected report</div>';
      if (timeEst)    extraRows += '<div style="margin:3px 0 0;font-size:.4rem;color:rgba(255,255,255,.3);font-style:italic;">⏱ Time estimated by radar</div>';

      var marker = L.marker([r.lat, r.lon], { icon: tornadoIcon, interactive: true, zIndexOffset: 1000 }).addTo(tornadoLayerGroup||tornadoMap);
      marker.bindPopup(
        '<div class="hz-card-head"><div class="hz-accent" style="background:' + color + ';"></div><span style="color:' + color + ';">TORNADO' + (r.scale !== 'UNK' ? ' · ' + r.scale : '') + '</span></div>' +
        '<div class="hz-card-row"><span class="hz-label">Location</span><span class="hz-val">' + r.location + ', ' + r.state + '</span></div>' +
        '<div class="hz-card-row"><span class="hz-label">County</span><span class="hz-val">' + r.county + '</span></div>' +
        '<div class="hz-card-row"><span class="hz-label">Time</span><span class="hz-val">' + tornadoLocalTime + '</span></div>' +
        extraRows +
        (cleanTornadoComment ? '<div style="margin-top:5px;font-size:.46rem;color:rgba(255,255,255,.45);line-height:1.4;max-width:220px;border-top:1px solid rgba(255,255,255,.08);padding-top:4px;">' + cleanTornadoComment + '</div>' : '') +
        '<div class="hz-card-footer">' + dateLabel + ' · SPC' + (tornadoOffice ? ' · NWS ' + tornadoOffice : '') + '</div>',
        {className: 'hz-popup', maxWidth: 260}
      );
      tornadoMarkers.push(marker);
    });
  }

  function loadTornadoReports(){
    // Skip if just loaded (guards against interval + switchHazardTab overlap)
    if(!shouldRefetch('tornado-reports', 8 * 60 * 1000) && !window._prefetchedTornCSV) return;

    if(!tornadoLayerGroup && tornadoMap){
      tornadoLayerGroup = L.layerGroup().addTo(tornadoMap);
    }
    var statusEl = document.getElementById('tornado-status-pill');
    var liveEl = document.getElementById('tornado-live');
    var yearCountEl = document.getElementById('tornado-year-count');
    var listEl = document.getElementById('hz-pill-tornado-list');
    var totalCount = 0;
    var allReports = [];
    var numDays = getDaysForRange(tornadoCurrentRange);
    var rangeLabel = tornadoCurrentRange.toUpperCase();

    // Generate date strings
    var dates = [];
    var now = new Date();
    for (var d = 0; d < numDays; d++){
      var dt = new Date(now);
      dt.setDate(dt.getDate() - d);
      var yy = String(dt.getFullYear()).slice(-2);
      var mm = String(dt.getMonth()+1).padStart(2,'0');
      var dd = String(dt.getDate()).padStart(2,'0');
      dates.push({str: yy+mm+dd, label: (dt.getMonth()+1)+'/'+dt.getDate()+'/'+dt.getFullYear()});
    }

    var fetched = 0;

    function fetchDay(dateObj, delay){
      setTimeout(function(){
      var url = 'https://www.spc.noaa.gov/climo/reports/' + dateObj.str + '_rpts_torn.csv';
      var isToday = (dateObj.str === dates[0].str);
      // Today uses a different URL
      if (isToday){
        url = 'https://www.spc.noaa.gov/climo/reports/today_torn.csv';
      }

      // ── Use boot-prefetched today CSV if available ──
      if (isToday && window._prefetchedTornCSV) {
        var csv = window._prefetchedTornCSV;
        window._prefetchedTornCSV = null; // free memory
        var reports = parseTornadoCSV(csv);
        totalCount += reports.length;
        reports.forEach(function(r){ r.dateLabel = dateObj.label; });
        allReports = allReports.concat(reports);
        plotTornadoes(reports, dateObj.label);
        fetched++;
        if (fetched === dates.length){
          finalizeTornado(allReports, totalCount, statusEl, liveEl, yearCountEl, listEl, rangeLabel);
        }
        return; // skip fetch for today
      }

      fetch(url).then(function(r){ return r.text(); }).then(function(csv){
        var reports = parseTornadoCSV(csv);
        totalCount += reports.length;
        reports.forEach(function(r){ r.dateLabel = dateObj.label; });
        allReports = allReports.concat(reports);
        plotTornadoes(reports, dateObj.label);
        fetched++;
        if (fetched === dates.length){
          finalizeTornado(allReports, totalCount, statusEl, liveEl, yearCountEl, listEl, rangeLabel);
        }
      }).catch(function(){
        fetched++;
        if (fetched === dates.length){
          finalizeTornado(allReports, totalCount, statusEl, liveEl, yearCountEl, listEl, rangeLabel);
        }
      });
      }, delay);
    }

    // Today first (0ms), then stagger historical days 400ms apart
    for (var di = 0; di < dates.length; di++){
      fetchDay(dates[di], di === 0 ? 0 : 400 * di);
    }

    // Also fetch yearly total from SPC filtered reports (Jan 1 to now)
    loadTornadoYearCount(yearCountEl);
  }

  var tornadoTopReports = [];

  function efRank(scale){
    switch(scale){
      case 'EF5': return 6;
      case 'EF4': return 5;
      case 'EF3': return 4;
      case 'EF2': return 3;
      case 'EF1': return 2;
      case 'EF0': return 1;
      default: return 0;
    }
  }

  function loadTornadoYearCount(yearCountEl){
    var now = new Date();
    var fullYear = now.getFullYear();
    var yy = String(fullYear).slice(-2);
    var todayStr = yy + String(now.getMonth()+1).padStart(2,'0') + String(now.getDate()).padStart(2,'0');
    var cacheKey = 'tornYearCache_' + fullYear;
    var cached = null;
    try { cached = JSON.parse(sessionStorage.getItem(cacheKey)); } catch(e){}

    // Restore cached state: past-day counts + top reports
    var totalYear = 0;
    tornadoTopReports = [];
    var cachedDays = {};
    if (cached && cached.days) {
      cachedDays = cached.days;
      Object.keys(cachedDays).forEach(function(ds){
        if (ds === todayStr) return; // always re-fetch today
        var entry = cachedDays[ds];
        totalYear += entry.count;
        (entry.tops || []).forEach(function(r){
          if (tornadoTopReports.length < 5){
            tornadoTopReports.push(r);
            tornadoTopReports.sort(function(a,b){ return efRank(b.scale) - efRank(a.scale); });
          } else if (efRank(r.scale) > efRank(tornadoTopReports[4].scale)){
            tornadoTopReports[4] = r;
            tornadoTopReports.sort(function(a,b){ return efRank(b.scale) - efRank(a.scale); });
          }
        });
      });
      if (yearCountEl) yearCountEl.textContent = totalYear.toLocaleString();
      updateTop5Dropdown();
    }

    // Build list of days that still need fetching (today + any uncached past days)
    var totalMonths = now.getMonth() + 1;
    var daysToFetch = [];
    for (var m = 1; m <= totalMonths; m++){
      var daysInMonth = new Date(fullYear, m, 0).getDate();
      var endDay = (m === totalMonths) ? now.getDate() : daysInMonth;
      for (var d = 1; d <= endDay; d++){
        var mm = String(m).padStart(2,'0');
        var dd = String(d).padStart(2,'0');
        var dateStr = yy + mm + dd;
        var dateLabel = m + '/' + d + '/' + fullYear;
        if (dateStr === todayStr || !cachedDays[dateStr]) {
          daysToFetch.push({ str: dateStr, label: dateLabel, isToday: dateStr === todayStr });
        }
      }
    }

    if (daysToFetch.length === 0) return;

    var fetched = 0;
    var pendingCount = daysToFetch.length;

    function saveCache(){
      try { sessionStorage.setItem(cacheKey, JSON.stringify({ days: cachedDays })); } catch(e){}
    }

    function fetchDayYear(dayObj, delay){
      setTimeout(function(){
        var url = dayObj.isToday
          ? 'https://www.spc.noaa.gov/climo/reports/today_torn.csv'
          : 'https://www.spc.noaa.gov/climo/reports/' + dayObj.str + '_rpts_torn.csv';

        fetch(url).then(function(r){ return r.text(); }).then(function(csv){
          var reports = parseTornadoCSV(csv);
          var dayTops = [];
          totalYear += reports.length;
          reports.forEach(function(r){
            r.dateLabel = dayObj.label;
            var rank = efRank(r.scale);
            if (dayTops.length < 5){ dayTops.push(r); dayTops.sort(function(a,b){ return efRank(b.scale)-efRank(a.scale); }); }
            else if (rank > efRank(dayTops[4].scale)){ dayTops[4]=r; dayTops.sort(function(a,b){ return efRank(b.scale)-efRank(a.scale); }); }
            if (tornadoTopReports.length < 5){
              tornadoTopReports.push(r);
              tornadoTopReports.sort(function(a,b){ return efRank(b.scale) - efRank(a.scale); });
            } else if (rank > efRank(tornadoTopReports[4].scale)){
              tornadoTopReports[4] = r;
              tornadoTopReports.sort(function(a,b){ return efRank(b.scale) - efRank(a.scale); });
            }
          });
          if (!dayObj.isToday) {
            cachedDays[dayObj.str] = { count: reports.length, tops: dayTops.map(function(r){ return {scale:r.scale,location:r.location,state:r.state,lat:r.lat,lon:r.lon,dateLabel:r.dateLabel}; }) };
          }
          if (yearCountEl) yearCountEl.textContent = totalYear.toLocaleString();
          var sp = document.getElementById('tornado-status-pill');
          var yearStr = String(fullYear);
          if (sp && sp.innerHTML.indexOf(yearStr + ':') >= 0){
            sp.innerHTML = sp.innerHTML.replace(new RegExp(yearStr + ': [^<]+'), yearStr + ': ' + totalYear.toLocaleString());
          }
          updateTop5Dropdown();
          fetched++;
          if (fetched === pendingCount) saveCache();
        }).catch(function(){ fetched++; if (fetched === pendingCount) saveCache(); });
      }, delay);
    }

    for (var i = 0; i < daysToFetch.length; i++){
      fetchDayYear(daysToFetch[i], i * 50);
    }
  }

