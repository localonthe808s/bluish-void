        else if (currentKp < 9) { geoLabel = 'Severe Storm (G4)'; geoColor = '#cc0000'; geoDetail = 'G4 severe storm! Aurora visible ~35-40\u00b0N (southern US). Widespread voltage control problems. Satellite surface charging, tracking issues. HF radio propagation sporadic.'; }
        else { geoLabel = 'Extreme Storm (G5)'; geoColor = '#990033'; geoDetail = 'G5 EXTREME storm! Aurora visible as far south as ~30\u00b0N (Florida/Texas). Widespread power grid collapse possible. Satellite damage likely. Complete HF radio blackout.'; }

        // Modal shell (_openInsightModal) supplies the hero (title +
        // subtitle + liveStats), so skip the legacy hz-card-head and the
