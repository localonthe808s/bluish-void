  var SH = window.SH = {
    sources: {},   // { id: { name, widget, status, lastOk, failCount, retryTimer, retryFn } }
    widgets: {},   // { widgetId: { liveTagId, sourceIds:[] } }
    BACKOFF: [5000, 10000, 15000, 30000, 60000],

    register: function(id, name, widgetId) {
      if (SH.sources[id]) return;
      SH.sources[id] = { name:name, widget:widgetId, status:'pending', lastOk:null, failCount:0, retryTimer:null, retryFn:null };
      if (!SH.widgets[widgetId]) SH.widgets[widgetId] = { liveTagId:null, sourceIds:[] };
      if (SH.widgets[widgetId].sourceIds.indexOf(id) < 0) SH.widgets[widgetId].sourceIds.push(id);
    },

    ok: function(id) {
      var s = SH.sources[id]; if (!s) return;
      var wasDown = s.status === 'retry' || s.status === 'dead';
      s.status = 'ok'; s.lastOk = Date.now(); s.failCount = 0;
      if (s.retryTimer) { clearTimeout(s.retryTimer); s.retryTimer = null; }
      if (wasDown) console.log('%c[SH] ✓ ' + s.name + ' recovered', 'color:#4ade80');
      SH._updateWidget(s.widget);
    },

    fail: function(id, retryFn) {
      var s = SH.sources[id]; if (!s) return;
      s.status = 'retry'; s.failCount = Math.min(s.failCount + 1, SH.BACKOFF.length);
      s.retryFn = retryFn || s.retryFn;
      var delay = SH.BACKOFF[Math.min(s.failCount - 1, SH.BACKOFF.length - 1)];
      console.log('%c[SH] ✗ ' + s.name + ' failed (retry #' + s.failCount + ' in ' + (delay/1000) + 's)', 'color:#f97316');
      SH._scheduleRetry(id);
      SH._updateWidget(s.widget);
    },

    _scheduleRetry: function(id) {
      var s = SH.sources[id]; if (!s || !s.retryFn) return;
      if (s.retryTimer) clearTimeout(s.retryTimer);
      var delay = SH.BACKOFF[Math.min(s.failCount - 1, SH.BACKOFF.length - 1)];
      s._nextRetry = Date.now() + delay;
