              + '<span style="font-size:.44rem;font-weight:800;letter-spacing:.04em;color:' + spaceColor + ';" id="ghRainbowLabel">' + spaceLbl + '</span>'
              + '<span style="font-size:.08rem;color:var(--ink-dim);opacity:.3;">●</span>'
              + '<span style="font-size:.4rem;font-weight:600;color:var(--ink-dim);" id="ghRainbowDetail">' + spaceDetail + '</span>'
              + '</div>';
            rbBar.dataset.mode = 'space';
          }
        }

        if (!spacePicked) {
          var reason = '';
          // Determine WHY no rainbow
          var hasRain = false;
          for (var ri2 = 0; ri2 < rbResults.length; ri2++) {
            var rb2 = rbResults[ri2];
            if (!rb2 || new Date(rb2.time).getDate() !== todayDate) continue;
