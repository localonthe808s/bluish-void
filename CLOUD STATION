  // ═══════════════════════════════════════════════════════════
  // CLOUD INTELLIGENCE PANEL — Widget-level live analysis
  // ═══════════════════════════════════════════════════════════
  function populateCloudIntelPanel() {
    var el = document.getElementById('fcast-info-text');
    var titleBar = document.getElementById('fcast-info-title-bar');
    if (!el) return;
    if (titleBar) titleBar.textContent = 'CLOUD INTELLIGENCE';

    var wx = window._wxCurrent || {};
    var cL = wx.cloudLow, cM = wx.cloudMid, cH = wx.cloudHigh, cT = wx.cloudCover;
    var rh = wx.rh, dp = wx.dewpoint, temp = wx.temp, vis = wx.visibility;
    var pbl = wx.pblHeight, cape = wx.cape, frzLvl = wx.freezingLevel;
    var pTrend = wx.pressureTrend, wind = wx.wind;
    var sunrise = wx.sunrise, sunset = wx.sunset;
    var cLT = wx.cloudLowTrend, cMT = wx.cloudMidTrend, cHT = wx.cloudHighTrend;
    var fcst = wx.cloudForecast;
    var w300 = wx.wind300spd, w500 = wx.wind500spd, w700 = wx.wind700spd;
    var d300 = wx.wind300dir, d500 = wx.wind500dir, d700 = wx.wind700dir;

    var S = function(t){ return '<div class="info-heading">' + t + '</div>'; };
    var h = '';

    // ── CURRENT CLOUD DECK ──
    h += S('CLOUD DECK');
    var layers = [];
    if (cL != null && cL > 5) layers.push({name:'Low', pct:cL, base:'~1,000–6,500 ft', type: cL > 80 ? 'Stratus / Stratocumulus' : cL > 40 ? 'Cumulus / Stratocumulus' : 'Scattered cumulus'});
    if (cM != null && cM > 5) layers.push({name:'Mid', pct:cM, base:'~6,500–20,000 ft', type: cM > 80 ? 'Altostratus / Nimbostratus' : cM > 40 ? 'Altocumulus' : 'Patches of altocumulus'});
    if (cH != null && cH > 5) layers.push({name:'High', pct:cH, base:'~20,000–40,000 ft', type: cH > 80 ? 'Cirrostratus' : cH > 40 ? 'Cirrus / Cirrocumulus' : 'Thin cirrus wisps'});

    if (layers.length === 0) {
      h += '<b>Clear skies</b> — no significant cloud layers detected. ';
      if (rh != null && rh < 30) h += 'Very dry air; excellent visibility and deep blue sky.';
      else if (rh != null && rh < 50) h += 'Dry conditions; crisp sky with good definition.';
      else if (rh != null) h += 'Moderate moisture; watch for cumulus development as surface heating increases.';
    } else {
      layers.forEach(function(l) {
        h += '<span class="k">' + l.name + ' ' + l.pct + '%</span> — <b>' + l.type + '</b> ' + l.base + '<br>';
      });
      if (layers.length >= 2) {
        h += '<br>';
        if (cL > 60 && cH > 60) h += '<span class="k">Multi-layer:</span> Low + high creates complex sandwiched structure. IR channels show layered returns — Sandwich product ideal for separating layers.';
        else if (cM > 60 && cH > 60) h += '<span class="k">Multi-layer:</span> Mid + high overcast. Water vapor channels will show strong moisture signatures. Precipitation possible if mid-layer thickening.';
        else h += '<span class="k">Multi-layer:</span> ' + layers.length + ' active layers interacting. Compare visible vs IR to identify which dominates.';
      }
    }

    // ── CLOUD TYPE IDENTIFICATION ──
    var types = [];
    if (cL != null && cL > 70 && (cM == null || cM < 20) && (cH == null || cH < 20)) {
      if (vis != null && vis < 2000) types.push('<span class="k">Fog / Low Stratus</span> — Visibility ' + (vis/1000).toFixed(1) + 'km. Use <b>Band 7</b> (Shortwave IR) for fog mapping — the 3.9–10.3µm difference is definitive day and night.');
      else if (temp != null && dp != null && (temp - dp) < 3) types.push('<span class="k">Stratus / Stratocumulus</span> — Temp-dewpoint spread ' + (temp-dp).toFixed(0) + '°, saturation imminent. Watch for fog development if winds calm. <b>Band 2</b> (0.5km visible) shows finest structure.');
      else types.push('<span class="k">Low Cloud Deck</span> — Boundary layer clouds. PBL height ' + (pbl ? Math.round(pbl) + 'm' : 'unknown') + '. Responds to surface heating — expect breakup by midday.');
    }
    if (cH != null && cH > 60 && (cL == null || cL < 20) && (cM == null || cM < 20)) {
      types.push('<span class="k">Cirrus Shield</span> — High ice clouds only. <b>Band 4</b> (Cirrus) isolates perfectly. ' + (cH > 80 ? 'Dense cirrostratus — may indicate approaching warm front or upstream jet streak.' : 'Scattered cirrus — jet stream debris or distant anvil remnants.'));
    }
    if (cape != null && cape > 500 && cL != null && cL > 30) {
      types.push('<span class="k">Convective Potential</span> — CAPE ' + Math.round(cape) + ' J/kg with low-level moisture. Watch for cumulus towers on <b>Band 2</b>. Cloud-top cooling on <b>Band 13</b> (Clean IR) tracks updraft strengthening.');
    }
    if (cM != null && cM > 50 && cL != null && cL > 50 && wx.precipProb != null && wx.precipProb > 40) {
      types.push('<span class="k">Nimbostratus / Precip</span> — Multi-layer coverage, ' + wx.precipProb + '% precip probability. <b>Cloud Micro RGB</b> distinguishes rain regions (green/large drops) from non-precipitating areas.');
    }
    if (types.length > 0) {
      h += S('CLOUD TYPE ANALYSIS');
      types.forEach(function(t) { h += t + '<br><br>'; });
    }

    // ── CLOUD EVOLUTION ──
    if (cLT != null || cMT != null || cHT != null || fcst) {
      h += S('CLOUD EVOLUTION');

      // 3hr trends
      function tLabel(v, name) {
        if (v == null) return '';
        var arrow = v > 15 ? '▲' : v > 5 ? '↗' : v < -15 ? '▼' : v < -5 ? '↘' : '→';
        return '<span class="k">' + name + '</span> ' + arrow + ' ' + (v>0?'+':'') + v + '% &nbsp; ';
      }
      var tLine = tLabel(cLT,'Low') + tLabel(cMT,'Mid') + tLabel(cHT,'High');
      if (tLine) h += '<b>3hr trends:</b> ' + tLine + '<br>';

      // Pattern recognition
      if (cLT != null && cMT != null && cHT != null) {
