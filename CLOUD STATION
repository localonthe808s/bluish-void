              '</div>'+
              '<div style="font-size:10px;color:rgba(43,34,244,.6);line-height:1.4;margin-top:1px;">'+m.note+'</div>'+
            '</div>'+
          '</div>';
        });
        h += '</div>';
      }
      h += '<div style="font-size:9px;color:rgba(43,34,244,.5);font-style:italic;margin-top:4px;">'+pm.note+'</div>';
    }

    // ── THROUGH A TELESCOPE (card with icon) ──
    h += FS('Through a Telescope');
    h += '<div style="display:flex;gap:10px;align-items:flex-start;padding:10px 12px;background:rgba(43,34,244,.04);border-radius:8px;border-left:3px solid #88aaee;">'+
      '<div style="font-size:18px;line-height:1;flex-shrink:0;">\ud83d\udd2d</div>'+
      '<div style="font-size:11px;color:rgba(43,34,244,.75);line-height:1.55;flex:1;">' + pd.telescope + '</div>'+
    '</div>';

    // ── ACTIVE MISSIONS (cards with agency badges + type icons) ──
    if (missions.length > 0) {
      h += FS('Active Missions');
      var agencyCol = function(a) {
        var s = (a || '').toLowerCase();
        if (/nasa/.test(s))    return '#cc4422';
        if (/esa/.test(s))     return '#3344cc';
