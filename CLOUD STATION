              var pixAngle = Math.atan2(hDx, hDy);
              var windAngleDiff = Math.abs(pixAngle - hp.windAngle);
              if(windAngleDiff > Math.PI) windAngleDiff = 2*Math.PI - windAngleDiff;
              if(windAngleDiff < 1.2) fireHaze *= 1.3; // 30% boost downwind
              hazeAccum += fireHaze;
            }
          }
          // Terrain amplification
          var _ti = window._terrainIntel;
          if(_ti){
            hazeAccum *= (1.0 + _ti.smokeTrapping * 1.5);
            if(_ti.isRidge) hazeAccum *= 0.5;
          }
          hazeAccum = Math.min(0.30, hazeAccum);
          if(hazeAccum > 0.005){
            var hazeNoise = 0.75 + 0.25 * _sNoise(pLon * 2.5 + timeOffset * 0.04, pLat * 2.5);
            totalDensity += hazeAccum * hazeNoise;
          }
        }

        // ── Terrain density modulation for plume body ──
        // In valley/basin terrain, overall plume density is boosted (smoke trapped)
        // On ridges, density is reduced (better ventilation)
        if(totalDensity > 0.005){
          var _t2 = window._terrainIntel;
          if(_t2){
            if(_t2.isValley || _t2.terrainClass === 'basin'){
              totalDensity *= (1.0 + _t2.smokeTrapping * 0.6); // up to 1.6× in basins
            } else if(_t2.isRidge){
              totalDensity *= 0.75; // 25% less dense on ridges
            }
          }
        }

        if(totalDensity < 0.005) continue;
        totalDensity = Math.min(0.90, totalDensity);

        // ── Satellite-realistic smoke color with atmospheric perspective + smoke age ──
        // Smoke chemistry evolution: fresh = bright blue-white (fine particles scatter blue)
        // Aged (hours of transport) = yellow-tan-brown (secondary organic aerosol formation)
        var dNorm = Math.min(1, totalDensity / 0.55);

        // Distance from viewer for atmospheric perspective
        var pixDistFromViewer = Math.sqrt(
          Math.pow((pLon - lon) * Math.cos(lat * Math.PI/180) * 69, 2) +
          Math.pow((pLat - lat) * 69, 2)
        );
        var distFactor = Math.min(1, pixDistFromViewer / 400);

        // Smoke age: find closest fire source to estimate transport time
        var minSrcDist = 999;
        for(var ai = 0; ai < plumes.length; ai++){
          var sDx = (pLon - plumes[ai].fLon) * Math.cos(plumes[ai].fLat*Math.PI/180) * 69;
          var sDy = (pLat - plumes[ai].fLat) * 69;
          var sDist = Math.sqrt(sDx*sDx + sDy*sDy);
          if(sDist < minSrcDist) minSrcDist = sDist;
        }
        // ageFactor: 0 = at fire source (fresh), 1 = far downwind (aged)
        var ageFactor = Math.min(1, minSrcDist / 200);

        var sr, sg, sb;
        // Fresh smoke (ageFactor ~ 0): bright warm white (228, 225, 220)
        // Mid-age (ageFactor ~ 0.5): warm gray-tan (200, 185, 165)
        // Aged smoke (ageFactor ~ 1): golden-brown haze (175, 155, 125)
        if(dNorm < 0.3){
          var t3 = dNorm / 0.3;
          sr = Math.round((228 - 12*ageFactor) - (16 + 6*ageFactor) * t3);
          sg = Math.round((225 - 28*ageFactor) - (20 + 10*ageFactor) * t3);
          sb = Math.round((220 - 55*ageFactor) - (22 + 16*ageFactor) * t3);
        } else if(dNorm < 0.65){
          var mt = (dNorm - 0.3) / 0.35;
          sr = Math.round((212 - 18*ageFactor) - (38 + 12*ageFactor) * mt);
          sg = Math.round((205 - 32*ageFactor) - (44 + 14*ageFactor) * mt);
          sb = Math.round((198 - 58*ageFactor) - (46 + 20*ageFactor) * mt);
        } else {
          var ht = (dNorm - 0.65) / 0.35;
          sr = Math.round((174 - 12*ageFactor) - (30 + 10*ageFactor) * ht);
          sg = Math.round((161 - 28*ageFactor) - (34 + 12*ageFactor) * ht);
          sb = Math.round((152 - 48*ageFactor) - (38 + 14*ageFactor) * ht);
        }

        // Pyrocumulus: at source, smoke is brilliant white (condensed water vapor)
        if(minSrcDist < 15 && sourceHeat < 0.3){
          var pyrocuBlend = Math.max(0, 1 - minSrcDist / 15) * 0.4;
          sr = Math.round(sr * (1 - pyrocuBlend) + 240 * pyrocuBlend);
          sg = Math.round(sg * (1 - pyrocuBlend) + 238 * pyrocuBlend);
          sb = Math.round(sb * (1 - pyrocuBlend) + 235 * pyrocuBlend);
        }

        // Atmospheric perspective: blend toward blue-gray haze at distance
        if(distFactor > 0.1){
          var atmoBlend = distFactor * 0.35;
          sr = Math.round(sr * (1 - atmoBlend) + 160 * atmoBlend);
          sg = Math.round(sg * (1 - atmoBlend) + 170 * atmoBlend);
          sb = Math.round(sb * (1 - atmoBlend) + 195 * atmoBlend);
        }

        // ── Fire hot glow blend ──
        // sourceHeat: 0 = pure smoke, 1 = fire core
        // Color target: bright amber core (255,140,30) → warm orange haze (240,160,60)
        var r, g, b;
        if(sourceHeat > 0.02){
          var h = Math.min(1, sourceHeat);
          var h2 = h * h; // tighter falloff for more localized glow
          // Inner core: bright amber-orange; outer: warm tint
          var hr = Math.round(255 * h2 + 240 * (h - h2));
          var hg = Math.round(120 * h2 + 155 * (h - h2));
          var hb = Math.round(20 * h2 + 50 * (h - h2));
          // Blend factor: strong near source, soft at edges
          var blend = h * 0.85;
          r = Math.round(sr * (1 - blend) + hr * blend);
          g = Math.round(sg * (1 - blend) + hg * blend);
          b = Math.round(sb * (1 - blend) + hb * blend);
        } else {
          r = sr; g = sg; b = sb;
        }

        var a = Math.round(totalDensity * 340);
        // Boost alpha near fire source for visible hot core
        if(sourceHeat > 0.1) a = Math.round(a * (1 + sourceHeat * 0.5));
        a = Math.min(240, a);

        var idx = (py * cW + px) * 4;
        pixels[idx]     = r;
        pixels[idx + 1] = g;
        pixels[idx + 2] = b;
        pixels[idx + 3] = a;
      }
    }

    ctx.putImageData(imgData, 0, 0);

    // ── Multi-pass soft blur for photorealistic smoke edges ──
    // Adaptive blur: more at low zoom (distant satellite view), less at high zoom (detail)
    var blurRadius = zoomLevel >= 9 ? 1.2 : zoomLevel >= 7 ? 1.6 : zoomLevel >= 5 ? 2.0 : 2.5;
    var blurCanvas = document.createElement('canvas');
    blurCanvas.width = cW;
    blurCanvas.height = cH;
    var bCtx = blurCanvas.getContext('2d');
    // First pass: directional blur along wind for streaky effect
    bCtx.filter = 'blur(' + blurRadius + 'px)';
    bCtx.drawImage(_smokeCanvas, 0, 0);
    // Second pass: softer overall smoothing
    var blur2 = document.createElement('canvas');
    blur2.width = cW; blur2.height = cH;
    var b2Ctx = blur2.getContext('2d');
    b2Ctx.filter = 'blur(' + (blurRadius * 0.5) + 'px)';
    b2Ctx.drawImage(blurCanvas, 0, 0);
    b2Ctx.filter = 'none';

    // ── Performance guard: auto-reduce resolution if render is slow ──
    var _smokeRenderMs = performance.now() - _smokeRenderStart;
    if (_smokeRenderMs > 200 && !window._smokeRenderSlow) {
      window._smokeRenderSlow = true;
      console.log('Smoke render: ' + Math.round(_smokeRenderMs) + 'ms — reducing resolution for next render');
    }

    // ── Project canvas as Leaflet ImageOverlay ──
    var dataUrl = blur2.toDataURL('image/png');
    var bounds = [[minLat, minLon], [maxLat, maxLon]];
    _smokeTransportLayer = L.imageOverlay(dataUrl, bounds, {
      opacity: 1,
      interactive: false,
      className: 'smoke-transport-canvas',
      zIndex: 450
    });

    if(_smokeTransportVisible && fireMap && hazardActiveTab === 'fire'){
      _smokeTransportLayer.addTo(fireMap);
    }

    // ── Re-render on map move/zoom for alignment ──
    if(!_smokeMapListenerAdded && fireMap){
      _smokeMapListenerAdded = true;
      var _smokeRenderTimer = null;
      fireMap.on('moveend zoomend', function(){
        if(_smokeTransportVisible){
          clearTimeout(_smokeRenderTimer);
          _smokeRenderTimer = setTimeout(renderSmokeTransport, 300);
        }
      });
    }
  }

