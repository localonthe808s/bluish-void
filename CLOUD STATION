  var GOOGLE_POLLEN_KEY = 'AIzaSyDnB-WVWyu7N8F-C8eFNyEM15MNyhqSZt4';

  function classifyGooglePollen(index){
    if (index == null || index <= 0) return { label: "None", cls: "none" };
    if (index <= 1) return { label: "Very Low", cls: "low" };
    if (index <= 2) return { label: "Low", cls: "low" };
    if (index <= 3) return { label: "Moderate", cls: "moderate" };
    if (index <= 4) return { label: "High", cls: "high" };
    return { label: "Very High", cls: "very-high" };
  }

  function loadPollen(){
    var treeEl = document.getElementById("pollen-tree");
    var grassEl = document.getElementById("pollen-grass");

    var url = "https://pollen.googleapis.com/v1/forecast:lookup" +
      "?key=" + GOOGLE_POLLEN_KEY +
      "&location.latitude=" + LOCATION.lat +
      "&location.longitude=" + LOCATION.lon +
      "&days=5";

    fetchWithTimeout(url, null, 12000)
      .then(function(r){ return r.json(); })
      .then(function(data){
        try {
          if (!data || !data.dailyInfo) return;
          window._pollenData = data;
          var day = data.dailyInfo[0];
          if (!day || !day.pollenTypeInfo) return;

          var map = {};
          day.pollenTypeInfo.forEach(function(p){ map[p.code] = p; });

          var types = [
            { el: treeEl, data: map['TREE'], code: 'TREE' },
            { el: grassEl, data: map['GRASS'], code: 'GRASS' }
          ];

          types.forEach(function(t){
            if (!t.el) return;
            var parentStat = t.el.closest('.weather-stat');
            if (!t.data || !t.data.indexInfo) {
              t.el.textContent = t.data && t.data.inSeason === false ? 'Off Season' : 'None';
              t.el.className = 'pollen-val none';
            } else {
              var info = classifyGooglePollen(t.data.indexInfo.value);
              t.el.textContent = info.label;
              t.el.className = 'pollen-val ' + info.cls;
            }
            if (parentStat) {
              parentStat.style.display = '';
              parentStat.style.cursor = 'pointer';
              parentStat.onclick = function(e){ e.stopPropagation(); openPollenDetail(t.code); };
            }
          });

        } catch(e){
          console.error("Pollen parse error", e);
        }
      })
      .catch(function(err){
        console.error("Pollen load error", err);
      });
  }

