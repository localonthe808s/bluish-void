            g.details.forEach(function(d){ html += '<span class="alert-line-metric">' + d + '</span>'; });
            // Countdown
            if (g.timeWindow){
              var countdown = g.timeWindow;
              // Convert to short countdown if "Until X today/tomorrow"
              if (g._expires){
                var diffMs = g._expires.getTime() - new Date().getTime();
                if (diffMs > 0){
                  var diffH = Math.floor(diffMs / 3600000);
                  var diffM = Math.floor((diffMs % 3600000) / 60000);
                  if (diffH < 1) countdown = '⏱ ' + diffM + 'm left';
                  else if (diffH < 24) countdown = '⏱ ' + diffH + 'h left';
                  else countdown = '⏱ ' + Math.floor(diffH/24) + 'd left';
                }
              } else {
                countdown = g.timeWindow;
              }
              html += '<span class="alert-line-countdown">' + countdown + '</span>';
            }
            html += '</div>';
            html += '<span class="alert-line-chevron">›</span>';
            html += '</div>';

            // Summary (visible when collapsed)
            if (g.summary) {
              var summaryPrefix = '';
              if (hasUsableSummary) {
                var prefixCol = g.cat === 'warning' || g.cat === 'tornado' ? 'rgba(235,55,55,.95)' : g.cat === 'watch' ? 'rgba(240,170,40,.95)' : 'rgba(220,120,50,.9)';
                summaryPrefix = '<span style="color:' + prefixCol + ';font-weight:700;text-transform:uppercase;letter-spacing:.04em;">' + g.event + (g._mergeCount > 1 ? ' × ' + g._mergeCount : '') + '</span> · ';
              }
              html += '<span class="alert-line-summary">' + summaryPrefix + g.summary + '</span>';
            }
            
            // Expandable detail section
            html += '<div class="alert-detail"><div class="alert-detail-inner">';
            if (g.timeWindow) html += '<div class="alert-detail-row"><span class="alert-detail-label">When</span><span class="alert-detail-value">' + g.timeWindow + '</span></div>';
            if (g._areaDesc) html += '<div class="alert-detail-row"><span class="alert-detail-label">Areas</span><span class="alert-detail-value">' + g._areaDesc + '</span></div>';
            if (g.details.length) html += '<div class="alert-detail-row"><span class="alert-detail-label">Hazards</span><span class="alert-detail-value">' + g.details.join('&nbsp;&nbsp;') + '</span></div>';
            if (g._instruction) html += '<div class="alert-detail-row"><span class="alert-detail-label">Action</span><span class="alert-detail-value">' + g._instruction + '</span></div>';
            if (g._description) html += '<div class="alert-detail-description">' + g._description + '</div>';
            // Determine which map tab this alert routes to
            var mapLabel = 'HAZARD MAP';
            var evCheck = g.event.toLowerCase();
            if (evCheck.indexOf('tornado') >= 0 || evCheck.indexOf('severe thunderstorm') >= 0) mapLabel = 'TORNADO MAP';
            else if (evCheck.indexOf('flood') >= 0 || evCheck.indexOf('storm surge') >= 0 || evCheck.indexOf('tsunami') >= 0) mapLabel = 'FLOOD MAP';
            else if (evCheck.indexOf('fire') >= 0 || evCheck.indexOf('red flag') >= 0) mapLabel = 'WILDFIRE MAP';
            else if (evCheck.indexOf('earthquake') >= 0 || evCheck.indexOf('volcano') >= 0) mapLabel = 'EARTHQUAKE MAP';
            html += '<div class="alert-detail-map-btn" onclick="event.stopPropagation();zoomAlertOnHazardMap(' + g.idx + ')">VIEW ON ' + mapLabel + ' ›</div>';
            html += '</div></div>';
            
            html += '</div>';
          });
          
          // "Show more" toggle if alerts exceed MAX_VISIBLE
          if (hasMore) {
            var extraCount = groups.length - MAX_VISIBLE;
            html += '<div class="alert-line-sep" data-alert-show-more-sep></div>';
            html += '<div data-alert-show-more onclick="(function(el){var ov=el.closest(\'.alert-panel\').querySelectorAll(\'[data-alert-overflow]\');var show=ov[0]&&ov[0].style.display===\'none\';ov.forEach(function(e){e.style.display=show?\'\':\'none\'});el.textContent=show?\'Show less ▲\':\'' + extraCount + ' more alert' + (extraCount>1?'s':'') + ' ▼\';var sep=el.closest(\'.alert-panel\').querySelector(\'[data-alert-show-more-sep]\');if(sep)sep.style.display=show?\'none\':\'\'})(this)" style="text-align:center;padding:6px 0;font-size:.44rem;font-weight:700;color:rgba(43,34,244,.55);cursor:pointer;letter-spacing:.04em;user-select:none;">' + extraCount + ' more alert' + (extraCount>1?'s':'') + ' ▼</div>';
          }
          
          html += '</div>';
          alertsEl.innerHTML = html;
          // Refresh briefing now that alerts are loaded
          try { updateConditionsBriefing(); } catch(e){}
        }
        
        // Clear old classes
        alertsEl.classList.remove("single-alert", "many-alerts", "alerts-overflowing", "scrolled-bottom");

        // Store features globally (for radar polygon overlay)
        window.alertFeatures = allAlerts;
        
        // Draw alert zones on radar if map exists
        setTimeout(drawAlertPolygonsOnRadar, 1000);

        // Also share alert features with hazard map for cross-referencing
        window._topAlertFeatures = allAlerts;
        }); // end checkSPCTornadoRisk callback
      })
      .catch(function(err){
        console.log("Weather alerts error:", err);
        alertsEl.innerHTML = '';
      });
  }

  // Draw alert polygons on radar map
  // ── Zoom to alert on hazard map ──
  function zoomAlertOnHazardMap(alertIdx){
    var features = window._topAlertFeatures || window.alertFeatures;
    if (!features || !features[alertIdx]) return;
    
    var alertFeature = features[alertIdx];
    var geometry = alertFeature.geometry;
    var props = alertFeature.properties || alertFeature;
    var event = props.event || 'Alert';
    var evLower = event.toLowerCase();
    
    // Route to the correct hazard tab based on alert type
    var targetTab = null; // null = no tab switch, just show alert overlay
    if (evLower.indexOf('tornado') >= 0 || evLower.indexOf('severe thunderstorm') >= 0 || evLower.indexOf('hail') >= 0) {
      targetTab = 'tornado';
    } else if (evLower.indexOf('flood') >= 0 || evLower.indexOf('storm surge') >= 0 || evLower.indexOf('tsunami') >= 0 || evLower.indexOf('coastal') >= 0 || evLower.indexOf('rip current') >= 0 || evLower.indexOf('high surf') >= 0) {
      targetTab = 'flood';
    } else if (evLower.indexOf('fire') >= 0 || evLower.indexOf('red flag') >= 0 || evLower.indexOf('smoke') >= 0) {
      targetTab = 'fire';
    } else if (evLower.indexOf('earthquake') >= 0 || evLower.indexOf('volcano') >= 0 || evLower.indexOf('lahar') >= 0) {
      targetTab = 'quake';
    }
    
    // 1. Scroll to hazard map widget
    var widget = document.getElementById('hazard-widget');
    if (widget) widget.scrollIntoView({ behavior:'smooth', block:'center' });
    
    // 2. Switch to appropriate tab if matched, ensure alert layer visible
    setTimeout(function(){
      if (targetTab && window.switchHazardTab) {
        window.switchHazardTab(targetTab);
      }
      // Always show alert polygons overlay
      if (typeof L !== 'undefined' && hazardMap && window._alertLayerGroup){
        if (!hazardMap.hasLayer(window._alertLayerGroup)){
          window._alertLayerGroup.addTo(hazardMap);
        }
      }
      
      // 3. Zoom to alert geometry if available
      setTimeout(function(){
        if (geometry && geometry.coordinates && typeof L !== 'undefined' && hazardMap){
          try {
            var geoLayer = L.geoJSON(geometry);
            var bounds = geoLayer.getBounds();
            if (bounds.isValid()){
              hazardMap.flyToBounds(bounds, { padding:[40,40], duration:1.2 });
              
              // 4. Flash highlight the alert polygon
              var highlight = L.geoJSON(geometry, {
                style: {
                  fillColor:'#fff',
                  fillOpacity:0.4,
                  color:'#fff',
                  weight:3,
                  opacity:1
                }
              }).addTo(hazardMap);
              
              var flashCount = 0;
              var flashInterval = setInterval(function(){
                flashCount++;
                if (flashCount > 5){
                  clearInterval(flashInterval);
                  hazardMap.removeLayer(highlight);
                  return;
                }
                highlight.setStyle({ fillOpacity: flashCount % 2 === 0 ? 0.35 : 0.05 });
              }, 300);
              
              // 5. Open popup on matching alert polygon
              if (window._alertLayerGroup){
                window._alertLayerGroup.eachLayer(function(layer){
                  var popup = layer.getPopup();
                  if (popup){
                    var content = popup.getContent() || '';
                    if (content.indexOf(event.toUpperCase()) >= 0){
                      layer.openPopup();
                    }
                  }
                });
              }
            }
          } catch(e){ console.log('Alert zoom error:', e); }
        } else if (typeof L !== 'undefined' && hazardMap){
          // No geometry — zoom to user location at state level
          hazardMap.flyTo([LOCATION.lat, LOCATION.lon], 8, { duration:1 });
        }
      }, 400);
    }, 500);
  }
  window.zoomAlertOnHazardMap = zoomAlertOnHazardMap;

