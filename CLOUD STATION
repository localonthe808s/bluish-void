    // ═══ SOURCE 2: CWFIS (Canada) via WFS GeoJSON ═══
    var cwfisUrl = "https://cwfis.cfs.nrcan.gc.ca/geoserver/public/wfs?service=WFS&version=1.1.0&request=GetFeature&typeName=public:activefires_current&outputFormat=application/json&maxFeatures=5000";
    fetchWithTimeout(cwfisUrl, null, 15000)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var features = data && data.features || [];
        var parsed = 0;
        features.forEach(function(f) {
          var props = f.properties || {};
          var lat = parseFloat(props.lat);
          var lon = parseFloat(props.lon);
          if (isNaN(lat) || isNaN(lon)) return;

          var ha = parseFloat(props.hectares) || 0;
          var name = props.firename || 'Unknown';
          var status = props.stage_of_control || '';
          var agency = props.agency || '';

          // Skip CONUS entries (already covered by NIFC) and extinguished fires
          if (agency === 'conus') return;
          if (status === 'EX' || status === 'Out') return;

          var statusLabel = '';
          if (status === 'OC') statusLabel = 'Out of Control';
          else if (status === 'BH') statusLabel = 'Being Held';
          else if (status === 'UC') statusLabel = 'Under Control';

          allFires.push({
            type: 'Feature',
            geometry: { type: 'Point', coordinates: [lon, lat] },
            properties: {
              _country: 'CA',
              _name: name + (agency ? ' (' + agency.toUpperCase() + ')' : ''),
              _acres: ha,
              _unit: 'ha',
              _contained: status === 'UC' ? 90 : status === 'BH' ? 50 : 0,
              _status: statusLabel,
