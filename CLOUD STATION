            h += '<div style="position:relative;height:10px;border-radius:5px;background:linear-gradient(90deg,#3344cc 0%,#88aaee 18%,#cccccc 38%,#e8c060 55%,#cc8822 72%,#cc4422 88%,#990033 100%);">';
            // Lo marker
            h += '<div style="position:absolute;left:'+loPct.toFixed(2)+'%;top:-3px;bottom:-3px;width:3px;background:#3344cc;border-radius:2px;box-shadow:0 0 0 1.5px #fff;transform:translateX(-50%);"></div>';
            h += '<div style="position:absolute;left:'+loPct.toFixed(2)+'%;top:14px;transform:translateX(-50%);font-size:9px;font-weight:700;color:#3344cc;white-space:nowrap;">'+lo+'°F <span style="opacity:.6;">'+loLabel+'</span></div>';
            // Hi marker
            h += '<div style="position:absolute;left:'+hiPct.toFixed(2)+'%;top:-3px;bottom:-3px;width:3px;background:#cc4422;border-radius:2px;box-shadow:0 0 0 1.5px #fff;transform:translateX(-50%);"></div>';
            h += '<div style="position:absolute;left:'+hiPct.toFixed(2)+'%;top:14px;transform:translateX(-50%);font-size:9px;font-weight:700;color:#cc4422;white-space:nowrap;">'+hi+'°F <span style="opacity:.6;">'+hiLabel+'</span></div>';
            h += '</div>';
            // Scale labels under
            h += '<div style="display:flex;justify-content:space-between;font-size:7.5px;font-weight:700;color:rgba(43,34,244,.4);margin-top:30px;letter-spacing:.04em;"><span>-300°F</span><span>0°F</span><span>500°F</span><span>900°F</span></div>';
            // Spread label
            h += '<div style="font-size:9px;color:rgba(43,34,244,.55);margin-top:6px;text-align:center;">Range: <b style="color:#3344cc;">'+(hi-lo)+'°F</b> spread between extremes</div>';
