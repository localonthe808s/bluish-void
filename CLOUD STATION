  // ═══════════════════════════════════════════════════════════════
  // TERRAIN INTELLIGENCE ENGINE
  // Fetches elevation grid from Open-Meteo Copernicus DEM (90m res)
  // to characterize local topography: valley/ridge detection,
  // drainage channels, terrain roughness, and valley axis.
  // Results stored in window._terrainIntel for smoke dispersion.
  // ═══════════════════════════════════════════════════════════════
  window._terrainIntel = null;
  var _terrainFetched = false;

  function fetchTerrainIntelligence() {
    if (_terrainFetched) return;
    _terrainFetched = true;

    var lat = LOCATION.lat, lon = LOCATION.lon;
    var cosLat = Math.cos(lat * Math.PI / 180);

    // ── Sample grid: 16 radial directions at 3 distances ──
    // Directions: N, NNE, NE, ENE, E, ESE, SE, SSE, S, SSW, SW, WSW, W, WNW, NW, NNW
    // Distances: 3mi, 8mi, 18mi (~5km, 13km, 29km)
    var directions = [];
    for (var d = 0; d < 16; d++) directions.push(d * 22.5);
    var distances = [3, 8, 18]; // miles
    var sampleLats = [lat]; // center point first
    var sampleLons = [lon];

    directions.forEach(function(bearing) {
      var bRad = bearing * Math.PI / 180;
      distances.forEach(function(distMi) {
        var dDeg = distMi / 69.0;
        sampleLats.push(lat + dDeg * Math.cos(bRad));
        sampleLons.push(lon + dDeg * Math.sin(bRad) / cosLat);
      });
    });

    // Total: 1 center + 16×3 = 49 points
    var latStr = sampleLats.map(function(l) { return l.toFixed(4); }).join(',');
    var lonStr = sampleLons.map(function(l) { return l.toFixed(4); }).join(',');

    var url = 'https://api.open-meteo.com/v1/elevation?latitude=' + latStr + '&longitude=' + lonStr;

    fetch(url)
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.elevation || data.elevation.length < 49) return;
        processTerrainData(data.elevation, directions, distances, lat, lon);
      })
      .catch(function(e) {
        console.warn('Terrain intelligence fetch failed:', e);
      });
  }

  function processTerrainData(elevations, directions, distances, lat, lon) {
    var userElev = elevations[0]; // meters
    var intel = {
      userElevation: userElev,
      userElevationFt: Math.round(userElev * 3.281),
      profiles: [],
      isValley: false,
      isRidge: false,
      isPlain: false,
      valleyDepth: 0,
      ridgeHeight: 0,
      terrainRoughness: 0,
      drainageDirections: [],
      valleyAxis: null,
      shelterDirections: [],
      exposedDirections: [],
      terrainClass: '',
      smokeTrapping: 0,
      drainageFlowRisk: 0,
      description: ''
    };

    // ── Parse elevation by direction and distance ──
    var idx = 1;
    var allElevs = [];
    var directionProfiles = {};

    directions.forEach(function(bearing) {
      var profile = { bearing: bearing, elevations: [], avgElev: 0, maxElev: 0, minElev: 99999, slope: 0 };
      distances.forEach(function(distMi) {
        var elev = elevations[idx++];
        profile.elevations.push({ dist: distMi, elev: elev });
        allElevs.push(elev);
        if (elev > profile.maxElev) profile.maxElev = elev;
        if (elev < profile.minElev) profile.minElev = elev;
      });
      profile.avgElev = profile.elevations.reduce(function(s, e) { return s + e.elev; }, 0) / profile.elevations.length;
      profile.slope = (profile.avgElev - userElev) / 13;
      directionProfiles[bearing] = profile;
      intel.profiles.push(profile);
    });

    // ── Statistics ──
    var avgSurrounding = allElevs.reduce(function(s, e) { return s + e; }, 0) / allElevs.length;
    var variance = allElevs.reduce(function(s, e) { return s + (e - avgSurrounding) * (e - avgSurrounding); }, 0) / allElevs.length;
    intel.terrainRoughness = Math.sqrt(variance);

    // ── Valley / Ridge / Plain detection ──
    var elevDiff = userElev - avgSurrounding;
    var higherCount = 0, lowerCount = 0;
    intel.profiles.forEach(function(p) {
      if (p.avgElev > userElev + 15) { higherCount++; intel.shelterDirections.push(p.bearing); }
      else if (p.avgElev < userElev - 15) { lowerCount++; intel.exposedDirections.push(p.bearing); }
    });

    // Drainage: directions where terrain slopes DOWN toward user
    intel.profiles.forEach(function(p) {
      if (p.slope < -2) {
        intel.drainageDirections.push(p.bearing);
      }
    });

    if (elevDiff < -20 && higherCount >= 8) {
      intel.isValley = true;
      intel.valleyDepth = Math.abs(elevDiff);
      intel.terrainClass = higherCount >= 12 ? 'basin' : 'valley';
    } else if (elevDiff > 20 && lowerCount >= 8) {
      intel.isRidge = true;
      intel.ridgeHeight = elevDiff;
      intel.terrainClass = 'ridge';
    } else if (intel.terrainRoughness < 15) {
      intel.isPlain = true;
      intel.terrainClass = 'plain';
    } else {
      intel.terrainClass = 'slope';
    }

    // ── Valley axis detection ──
    var bestValleyPair = null, bestValleyElev = Infinity;
    for (var i = 0; i < 8; i++) {
      var dir1 = directions[i];
      var dir2 = directions[i + 8];
      var p1 = directionProfiles[dir1], p2 = directionProfiles[dir2];
      var pairAvg = (p1.avgElev + p2.avgElev) / 2;
      if (pairAvg < bestValleyElev) {
        bestValleyElev = pairAvg;
        bestValleyPair = [dir1, dir2];
      }
    }
    if (bestValleyPair && bestValleyElev < avgSurrounding - 5) {
      intel.valleyAxis = bestValleyPair;
    }

    // ── Smoke trapping potential (0-1) ──
    var trapScore = 0;
    if (intel.isValley || intel.terrainClass === 'basin') trapScore += 0.4;
    trapScore += Math.min(0.3, higherCount * 0.025);
    trapScore += Math.min(0.2, intel.valleyDepth * 0.002);
    if (intel.terrainRoughness > 100) trapScore += 0.1;
    intel.smokeTrapping = Math.min(1.0, trapScore);

    // ── Cold air drainage flow risk (0-1) ──
    var drainScore = 0;
    if (intel.drainageDirections.length > 0) drainScore += 0.2;
    if (intel.drainageDirections.length >= 4) drainScore += 0.2;
    if (intel.isValley) drainScore += 0.3;
    if (intel.terrainClass === 'basin') drainScore += 0.2;
    drainScore += Math.min(0.1, intel.valleyDepth * 0.001);
    intel.drainageFlowRisk = Math.min(1.0, drainScore);

    // ════════════════════════════════════════════════════════════
    // EXPANDED TERRAIN-WEATHER INTELLIGENCE
    // Research-backed analysis from Kochanski 2019, Carroll 2025,
    // Houze 2012, Feldmann 2024 on terrain-atmosphere coupling
    // ════════════════════════════════════════════════════════════

    // ── Radiation fog risk (0-1) ──
    // Valleys + cold air drainage + moisture = fog
    // Deep basins with many drainage channels are extreme fog risks
    var fogScore = 0;
    if (intel.isValley || intel.terrainClass === 'basin') fogScore += 0.4;
    if (intel.terrainClass === 'basin') fogScore += 0.15; // basins worse than valleys
    fogScore += Math.min(0.2, intel.drainageDirections.length * 0.04);
    fogScore += Math.min(0.15, intel.valleyDepth * 0.001);
    if (intel.terrainRoughness < 15) fogScore -= 0.1; // flat terrain = less pooling
    if (intel.isRidge) fogScore = Math.max(0, fogScore - 0.3); // ridges don't fog
    intel.fogRisk = Math.max(0, Math.min(1.0, fogScore));
    intel.fogClass = intel.fogRisk > 0.6 ? 'extreme' : intel.fogRisk > 0.4 ? 'high' : intel.fogRisk > 0.2 ? 'moderate' : 'low';

    // ── Orographic precipitation modifier ──
    // Determines if location gets enhanced or reduced precip from terrain
    // Windward slopes = enhanced; leeward/sheltered = reduced; ridgetops = max; valleys = variable
    intel.precipModifier = 1.0; // baseline
    intel.precipClass = 'baseline';
    if (intel.isRidge) {
      intel.precipModifier = 1.3; // ridgetops get enhanced orographic precip
      intel.precipClass = 'enhanced';
    } else if (intel.terrainClass === 'basin') {
      intel.precipModifier = 0.75; // basins are sheltered
      intel.precipClass = 'sheltered';
    } else if (intel.isValley && intel.shelterDirections.length >= 6) {
      intel.precipModifier = 0.8; // well-sheltered valleys
      intel.precipClass = 'sheltered';
    } else if (intel.terrainRoughness > 80) {
      intel.precipModifier = 1.2; // complex terrain with many ridges
      intel.precipClass = 'complex-enhanced';
    }
    // Windward detection: if current wind blows INTO a slope, orographic enhancement
    var wxHourly = window._wxHourly;
    var wxNi = window._wxNearestIdx;
    if (wxHourly && wxHourly.wind_direction_10m && wxNi != null) {
      var currentWindDir = wxHourly.wind_direction_10m[wxNi]; // direction wind is FROM
      if (currentWindDir != null) {
        // Check if wind is blowing toward higher terrain (windward)
        var windwardProfile = directionProfiles[directions[Math.round(currentWindDir / 22.5) % 16]];
        if (windwardProfile && windwardProfile.slope > 5) {
          // Wind blowing toward rising terrain = orographic lift = enhanced precip
          intel.precipModifier *= 1.25;
          intel.precipClass = 'windward-enhanced';
          intel.orographicLift = true;
        }
        var leewardDir = (currentWindDir + 180) % 360;
        var leewardProfile = directionProfiles[directions[Math.round(leewardDir / 22.5) % 16]];
        if (leewardProfile && leewardProfile.slope > 5) {
          // Wind blowing away from higher terrain = rain shadow
          intel.precipModifier *= 0.7;
          intel.precipClass = 'rain-shadow';
          intel.rainShadow = true;
        }
      }
    }

    // ── Thunderstorm initiation preference ──
    // Ridges and convergence zones initiate storms; valleys suppress (cold pool)
    var stormInitScore = 0.5; // baseline
    if (intel.isRidge) {
      stormInitScore = 0.85; // ridges are primary CI triggers
      intel.stormInitClass = 'preferred';
    } else if (intel.terrainClass === 'basin') {
      stormInitScore = 0.15; // cold pools suppress convective initiation
      intel.stormInitClass = 'suppressed';
    } else if (intel.isValley) {
      stormInitScore = 0.3; // valleys delay storm initiation
      intel.stormInitClass = 'delayed';
    } else if (intel.terrainRoughness > 60) {
      stormInitScore = 0.7; // complex terrain has convergence zones
      intel.stormInitClass = 'terrain-triggered';
    } else {
      intel.stormInitClass = 'neutral';
    }
    intel.stormInitPreference = stormInitScore;

    // ── Diurnal wind regime ──
    // Determines expected local wind pattern based on terrain
    intel.diurnalWindRegime = 'synoptic'; // default: driven by large-scale weather
    intel.katabaticRisk = false;
    intel.anabaticExpected = false;
    if (intel.terrainRoughness > 30 && (intel.isValley || intel.terrainClass === 'basin' || intel.shelterDirections.length >= 3)) {
      intel.diurnalWindRegime = 'terrain-driven';
      intel.katabaticRisk = true; // nighttime drainage flows expected
      intel.anabaticExpected = true; // daytime upslope flows expected
    } else if (intel.terrainRoughness > 15) {
      intel.diurnalWindRegime = 'terrain-modified';
    }
    // Valley corridor channeling
    if (intel.valleyAxis) {
      intel.windChanneling = true;
      intel.channelAxis = intel.valleyAxis;
    }

    // ── Fire inversion feedback loop risk ──
    // Kochanski 2019: smoke + valley + solar blocking = self-reinforcing inversion
    // High risk when: valley/basin + smoke present + daytime + stable atmosphere
    intel.fireInversionFeedback = false;
    intel.fireInversionRisk = 0;
    if (intel.isValley || intel.terrainClass === 'basin') {
      var fiRisk = intel.smokeTrapping * 0.5;
      fiRisk += Math.min(0.3, intel.valleyDepth * 0.003);
      if (intel.terrainClass === 'basin') fiRisk += 0.2;
      intel.fireInversionRisk = Math.min(1.0, fiRisk);
      intel.fireInversionFeedback = intel.fireInversionRisk > 0.4;
    }

    // ── Terrain exposure assessment ──
    // How exposed is this location to different weather threats?
    intel.exposure = {
      wind: intel.isRidge ? 'maximum' : intel.shelterDirections.length >= 8 ? 'sheltered' : intel.shelterDirections.length >= 4 ? 'partial-shelter' : 'exposed',
      precip: intel.precipClass,
      frost: (intel.isValley || intel.terrainClass === 'basin') ? 'high' : intel.isRidge ? 'low' : 'moderate',
      lightning: intel.isRidge ? 'elevated' : intel.isValley ? 'reduced' : 'normal',
      flooding: (intel.isValley || intel.terrainClass === 'basin') ? 'elevated' : intel.isRidge ? 'low' : 'normal'
    };

    // ── Human-readable description ──
    function _bc(deg) {
      var dirs = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
      return dirs[Math.round(deg / 22.5) % 16];
    }
    var desc = '';
    if (intel.terrainClass === 'basin') {
      desc = 'Located in a terrain basin \u2014 surrounded by higher ground on most sides (' +
        Math.round(intel.valleyDepth) + 'm below average). ';
      desc += 'Smoke and cold air tend to pool in basins, especially under stable nighttime conditions. ';
      if (intel.valleyAxis) desc += 'The basin opens along a ' + _bc(intel.valleyAxis[0]) + '\u2013' + _bc(intel.valleyAxis[1]) + ' corridor. ';
    } else if (intel.isValley) {
      desc = 'Located in a valley (' + Math.round(intel.valleyDepth) + 'm below surrounding ridgelines). ';
      if (intel.valleyAxis) desc += 'Valley axis runs ' + _bc(intel.valleyAxis[0]) + '\u2013' + _bc(intel.valleyAxis[1]) + '. ';
      desc += 'Valleys channel and trap smoke, particularly during nighttime temperature inversions. ';
    } else if (intel.isRidge) {
      desc = 'Located on elevated terrain (' + Math.round(intel.ridgeHeight) + 'm above average surroundings). ';
      desc += 'Ridgetop positions generally have better ventilation and less smoke accumulation. ';
    } else if (intel.isPlain) {
      desc = 'Located on relatively flat terrain (roughness: ' + Math.round(intel.terrainRoughness) + 'm). ';
      desc += 'Flat terrain allows unobstructed wind flow \u2014 smoke dispersion depends primarily on atmospheric stability. ';
    } else {
      desc = 'Located on a slope with mixed terrain (roughness: ' + Math.round(intel.terrainRoughness) + 'm). ';
    }

    if (intel.shelterDirections.length > 0) {
      desc += 'Higher terrain provides shelter from ' +
        intel.shelterDirections.slice(0, 4).map(_bc).join(', ') + ' winds. ';
    }
    if (intel.drainageDirections.length >= 3) {
      desc += 'Multiple drainage channels feed cold air into this location from ' +
        intel.drainageDirections.slice(0, 4).map(_bc).join(', ') + '. ';
    }
    if (intel.fogClass === 'extreme' || intel.fogClass === 'high') {
      desc += 'Radiation fog risk is ' + intel.fogClass + ' \u2014 cold air drainage and terrain pooling create ideal fog conditions on clear calm nights. ';
    }
    if (intel.orographicLift) {
      desc += 'Current wind direction creates orographic lift against terrain \u2014 precipitation may be enhanced. ';
    }
    if (intel.rainShadow) {
      desc += 'Currently in rain shadow \u2014 terrain blocks moisture from upwind, reducing precipitation likelihood. ';
    }
    if (intel.stormInitClass === 'preferred') {
      desc += 'Ridgetop terrain is a preferred zone for thunderstorm initiation through convergence of upslope winds. ';
    } else if (intel.stormInitClass === 'suppressed') {
      desc += 'Cold air pooling in the basin suppresses local convective initiation \u2014 thunderstorms typically develop on surrounding ridges first. ';
    }
    if (intel.fireInversionFeedback) {
      desc += 'HIGH fire inversion feedback risk: if smoke enters this terrain, it can block solar radiation, cool the surface, strengthen the inversion, and trap MORE smoke \u2014 a self-reinforcing cycle (Kochanski 2019). ';
    }
    if (intel.windChanneling && intel.channelAxis) {
      desc += 'Valley corridor channels wind along ' + _bc(intel.channelAxis[0]) + '\u2013' + _bc(intel.channelAxis[1]) + ' axis. ';
    }

    intel.description = desc.trim();
    window._terrainIntel = intel;
    console.log('[Terrain Intel]', intel.terrainClass,
      '| elev:', intel.userElevationFt + 'ft',
      '| roughness:', Math.round(intel.terrainRoughness) + 'm',
      '| smoke trap:', (intel.smokeTrapping * 100).toFixed(0) + '%',
