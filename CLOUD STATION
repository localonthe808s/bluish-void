          smokeHtml += '</div>';
        }

        firePill.querySelector('#hz-pill-fire-head').innerHTML =
          '<div style="font-size:.9rem;font-weight:800;color:'+FIRE_STRONG+';line-height:1.1;letter-spacing:-.01em;">' + total.toLocaleString() + ' FIRES' + trendHtml + '</div>' +
          '<div style="font-size:.52rem;color:'+INK_DIM+';margin-top:3px;font-weight:600;">' + wf.toLocaleString() + ' wildfire · ' + rxCount.toLocaleString() + ' prescribed</div>' +
          (satCount > 0 ? '<div style="font-size:.48rem;color:#be185d;margin-top:1px;font-weight:600;"><span style="opacity:1;">' + satCount.toLocaleString() + '</span> <span style="opacity:.7;">unconfirmed VIIRS thermal hotspots</span></div>' : '') +
          smokeHtml +
          '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px;">' +
            '<div style="padding:7px 10px;background:'+CHIP_BG+';border-radius:12px;border:1px solid '+CHIP_STROKE+';">' +
              '<div style="font-size:.34rem;color:'+INK_MUTE+';font-weight:700;letter-spacing:.08em;">VS 10-YR AVG</div>' +
              '<div style="font-size:.52rem;color:' + ratioCol + ';font-weight:800;margin-top:2px;">' + (fireRatio*100).toFixed(0) + '% <span style="font-size:.38rem;font-weight:600;opacity:.8;">' + ratioLabel + '</span></div>' +
            '</div>' +
