    /* GH widget on mobile: natural SVG aspect, H/M/L bar flows
       below the SVG. Pull the bar up via negative margin-top so it
       overlaps the empty black foreground beneath the city
       silhouette (the city's foot, not the buildings). */
    #golden-hour-sky-scene > div[style*="position:absolute"] {
      position: relative !important;
      bottom: auto !important;
      margin-top: -55px !important;
    }
    /* Shrink planet thumbnails so the row doesn't touch edge-to-edge
       on a phone-narrow screen. Higher specificity selector to beat
       any inline/parent sizing that pushes the dot to fill its flex
       container. Also increase the gap between flex items so even at
       full-fill there's spacing. */
    #planet-legend-col .today-tl-legend-item.planet-item .today-tl-legend-dot,
    #planet-legend-col .today-tl-legend-item.planet-item .today-tl-legend-moon,
    .today-tl-legend-dot,
    .today-tl-legend-moon {
      width: 60px !important;
      height: 60px !important;
      max-width: 60px !important;
      max-height: 60px !important;
    }
    #planet-legend-col > div[style*="display:flex"] {
      gap: 6px !important;
      justify-content: space-around !important;
    }
    /* Saturn & Uranus use inline SVGs with rings extending past their
       bounding box (overflow:visible). Shrink those SVGs visually so
       the rings don't bleed into adjacent planet thumbnails on mobile. */
    .today-tl-legend-item.planet-item[onclick*="saturn"] > div,
    .today-tl-legend-item.planet-item[onclick*="uranus"] > div {
      transform-origin: center !important;
