  function ciraArchLoadIdx(idx){
    if (!_allPosts || !_allPosts.length) return;
    if (idx < 0) idx = _allPosts.length - 1;
    if (idx >= _allPosts.length) idx = 0;
    _archCurrentIdx = idx;
    var m = extractMedia(_allPosts[idx]);
    var vid = document.getElementById('cira-arch-video');
    var imgEl = document.getElementById('cira-arch-img');
    var loading = document.getElementById('cira-arch-loading');
    var titleEl = document.getElementById('cira-arch-title');
    var descEl = document.getElementById('cira-arch-desc');
    var metaEl = document.getElementById('cira-arch-meta');
    if (titleEl) titleEl.textContent = m.title;
    if (descEl) descEl.textContent = m.description || '';
    var srcParts = [m.instrument, m.datePretty || m.date, m.author ? 'by ' + m.author : '', 'CIRA/RAMMB'].filter(Boolean);
    if (metaEl) metaEl.textContent = srcParts.join(' · ');
    if (loading) loading.style.display = 'flex';
    if (m.mp4) {
      imgEl.style.display = 'none'; vid.style.display = 'block';
      vid.src = m.mp4; vid.load();
      vid.oncanplay = function(){ if (loading) loading.style.display = 'none'; };
      vid.onerror = function(){ if (loading) loading.style.display = 'none'; if (m.img){ vid.style.display = 'none'; imgEl.src = m.img; imgEl.style.display = 'block'; } };
    } else if (m.img) {
      vid.style.display = 'none'; imgEl.src = m.img; imgEl.style.display = 'block';
      imgEl.onload = function(){ if (loading) loading.style.display = 'none'; };
      imgEl.onerror = function(){ if (loading) loading.style.display = 'none'; };
    } else {
      if (loading) loading.style.display = 'none';
    }
    var topLink = document.getElementById('fcast-source-link');
    if (topLink && m.link) { topLink.href = m.link; topLink.textContent = m.title; }
  }

