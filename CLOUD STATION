    /* Right column order: AQI summary first, then pollen (Tree, Grass),
       then PM2.5/PM10 (the more technical particulate readings) below. */
    .weather-stat:has(#aqi-val)        { grid-column: 2 !important; grid-row: 3 !important; }
    .weather-stat:has(#pollen-tree)    { grid-column: 2 !important; grid-row: 4 !important; }
