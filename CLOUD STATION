    if (!window._issInit) {
      window._issInit = true;
      window._issNextPass = null;
      window._fetchIssPass = function(){
        try {
          var nowS = Math.floor(Date.now()/1000);
          var times = [];
          for (var ti=0; ti<10; ti++) times.push(nowS + ti*120);
          fetch('https://api.wheretheiss.at/v1/satellites/25544/positions?timestamps='+times.join(',')+'&units=kilometers')
            .then(function(r){ return r.json(); })
            .then(function(arr){
              if (!Array.isArray(arr) || !arr.length) return;
              var lat = LOCATION.lat, lon = LOCATION.lon, R_KM = 6371;
              var best = null;
              for (var i=0; i<arr.length; i++) {
                var p = arr[i];
                var dLat = (p.latitude-lat)*Math.PI/180;
                var dLon = (p.longitude-lon)*Math.PI/180;
                var l1 = lat*Math.PI/180, l2 = p.latitude*Math.PI/180;
                var ha = Math.sin(dLat/2)*Math.sin(dLat/2) + Math.cos(l1)*Math.cos(l2)*Math.sin(dLon/2)*Math.sin(dLon/2);
                var dist = 2*R_KM*Math.asin(Math.sqrt(ha));
                if (!best || dist < best.distance) {
                  // Bearing from observer to ISS for "look NE" hint
                  var by = Math.sin(dLon)*Math.cos(l2);
                  var bx = Math.cos(l1)*Math.sin(l2) - Math.sin(l1)*Math.cos(l2)*Math.cos(dLon);
