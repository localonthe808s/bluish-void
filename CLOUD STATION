        // latitudeBar — visualize where your latitude sits relative to the
        // current aurora-visible threshold and the polar oval.
        var latitudeBar = function(yourLat, threshold) {
          var minL = 25, maxL = 90;
          var yourPct = ((Math.abs(yourLat) - minL) / (maxL - minL)) * 100;
          var thrPct = ((threshold - minL) / (maxL - minL)) * 100;
          yourPct = Math.max(0, Math.min(100, yourPct));
          thrPct = Math.max(0, Math.min(100, thrPct));
          // Gradient: equator (no aurora) → polar (always visible during dark)
          // Wrap bar + label row so absolute-positioned labels can align
