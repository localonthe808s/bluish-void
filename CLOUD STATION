    var optics = [];
    if(cH!=null&&cH>20&&cH<70&&(cL==null||cL<30)&&(cM==null||cM<30)) optics.push('💎 '+K('Halo Potential')+' \u2014 thin cirrus ('+cH+'%) + clear lower atmo. Watch for 22\u00b0 halos, sundogs on Band 4.');
