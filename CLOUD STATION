          // Your location marker
          svg += '<div style="position:absolute;left:'+yourPct.toFixed(2)+'%;top:-4px;bottom:-4px;width:4px;background:#fff;border-radius:2px;box-shadow:0 0 0 2px rgba(43,34,244,.85);transform:translateX(-50%);"></div>';
