          if (hazType === 'flood' && !isCPC) {
            // Use enriched ERO popup with cross-referencing
            var eroDay = day === 'd1' ? 'Day 1' : day === 'd2' ? 'Day 2' : 'Day ' + day.replace('d','');
            var tt = buildEROPopup(feature, riskName, riskColor, riskDesc, eroDay);
            lyr.bindPopup(tt, { className: 'hz-popup', maxWidth: 340 });
          } else if (hazType === 'flood' && isCPC) {
            // Enriched CPC precipitation outlook popup
            var cpcRange = layerId === '_cpc610' ? '6-10 Day' : '8-14 Day';
            var tt = buildCPCPopup(feature, riskName, riskColor, riskDesc, cpcRange);
            lyr.bindPopup(tt, { className: 'hz-popup', maxWidth: 340 });
          } else {
          var tt = '';
