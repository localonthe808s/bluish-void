        svg += '<text x="'+(labelX+12)+'" y="'+(ly+7)+'" fill="rgba(255,255,255,.55)" font-size="5.9" font-family="system-ui">'+layer.label+' \u00b7 '+layer.pct+'%</text>';
      }
      svg += '</svg>';
      h += svg;
      // Layer detail cards — enriched with a stats chip row + proportional thickness bar
      // Stats are parsed out of `desc` via regex (graceful degradation: missing values = no chip)
      // Display in miles, not km — source data is in km, we convert at render time.
      var _kmToMi = function(text){
        if (!text) return text;
        // Match integer or decimal km values (with optional thousand-separator commas)
        return text.replace(/([\d,]+(?:\.\d+)?)\s*km\b/gi, function(_, num){
          var km = parseFloat(num.replace(/,/g, ''));
          if (isNaN(km)) return _;
          var mi = Math.round(km * 0.621371);
          return mi.toLocaleString() + ' mi';
        });
      };
      // State inferred from label + name keywords. Covers the odd cases too
      // (metallic hydrogen, plasma, supercritical, etc.). Always returns something.
      var _inferState = function(combined) {
        var s = (combined || '').toLowerCase();
        if (/metallic h|metallic hydrogen/.test(s)) return 'Metallic';
        if (/dilute|diffuse|fuzzy|heavy-element/.test(s)) return 'Supercritical';
        if (/molten|liquid/.test(s))                return 'Liquid';
        if (/ice|frozen/.test(s))                   return 'Ice';
        if (/plasma|supercritical/.test(s))         return 'Plasma';
        if (/gas|atmosphere|cloud|hydrogen|helium|h₂|\bh2\b|\bhe\b/.test(s)) return 'Gas';
        if (/basalt|silicate|rock|crust|mantle|olivine|perovskite|bridgmanite/.test(s)) return 'Rock';
        if (/solid|crystalline|iron|nickel|fe\b/.test(s)) return 'Solid';
        return 'Solid';
      };
      // Planet radius in miles — drives thickness calc for every layer. Falls back
      // to 1 if unknown so the chip still renders (graceful degradation).
      var _radiusMi = (typeof pd !== 'undefined' && pd.diameter) ? (pd.diameter / 2) : 0;
      var _extractStats = function(desc, label, layerPct) {
        var stats = [];
        // THICKNESS — always: compute from pct × planet radius
        if (_radiusMi > 0 && layerPct) {
          var mi = Math.round(_radiusMi * layerPct / 100);
          stats.push({ label: 'THICKNESS', value: '~' + mi.toLocaleString() + ' mi' });
        }
        // STATE — always: inferred from keywords
        stats.push({ label: 'STATE', value: _inferState(label) });
        if (!desc) return stats;
        // Temperature — "~2,600°F" or "2,700–3,000°F"
        var temp = desc.match(/[~≈]?\s*([\d,]+(?:[–-][\d,]+)?)\s*°\s*F/);
        if (temp) stats.push({ label: 'TEMP', value: '~' + temp[1] + '°F' });
        // Pressure — "~40 GPa" or "300 GPa"
        var pres = desc.match(/[~≈]?\s*([\d,]+(?:\.\d+)?)\s*GPa/);
        if (pres) stats.push({ label: 'PRESSURE', value: '~' + pres[1] + ' GPa' });
        return stats;
      };
      // Precompute each layer's radial range (0% = center, 100% = surface).
