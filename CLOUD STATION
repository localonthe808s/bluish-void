              else if (fdn >= 2 || flabel.indexOf('slight') >= 0) { riskName = 'SLIGHT RISK'; riskColor = '#f97316'; riskDesc = 'Flash flooding possible in spots, especially in poor-drainage and low-lying areas.'; }
              else if (fdn >= 1 || flabel.indexOf('marginal') >= 0) { riskName = 'MARGINAL RISK'; riskColor = '#eab308'; riskDesc = 'Limited flash flood risk. Brief heavy rainfall may cause localized ponding or minor flooding.'; }
              else { riskName = 'AREA'; riskColor = '#06b6d4'; riskDesc = 'Precipitation hazard area identified.'; }
              // Inject start/end times for buildEROPopup if available
