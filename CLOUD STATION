  function loadSevereReports(){
    if (!tornadoMap) return;
    var numDays = getDaysForRange(tornadoCurrentRange);
    // Cap severe reports at 7 days to avoid overwhelming SPC with requests
    var severeDays = Math.min(numDays, 7);

    // Generate date list
    var dates = [];
    var now = new Date();
    for (var d = 0; d < severeDays; d++){
      var dt = new Date(now);
      dt.setDate(dt.getDate() - d);
      var yy = String(dt.getFullYear()).slice(-2);
      var mm = String(dt.getMonth()+1).padStart(2,'0');
      var dd = String(dt.getDate()).padStart(2,'0');
      var dateLabel = (dt.getMonth()+1)+'/'+dt.getDate();
      dates.push({str: yy+mm+dd, label: dateLabel, isToday: d === 0});
    }

    dates.forEach(function(dateObj, idx){
      var hailUrl = dateObj.isToday
        ? 'https://www.spc.noaa.gov/climo/reports/today_hail.csv'
        : 'https://www.spc.noaa.gov/climo/reports/' + dateObj.str + '_rpts_hail.csv';
      var windUrl = dateObj.isToday
        ? 'https://www.spc.noaa.gov/climo/reports/today_wind.csv'
        : 'https://www.spc.noaa.gov/climo/reports/' + dateObj.str + '_rpts_wind.csv';
      var footerDate = dateObj.isToday ? 'Today' : dateObj.label;

      // Stagger requests slightly to be nice to SPC servers
      setTimeout(function(){
        // Hail
        fetch(hailUrl).then(function(r){ return r.text(); }).then(function(csv){
          plotHailCSV(csv, footerDate);
        }).catch(function(err){ console.warn('[SPC] Hail reports failed (' + dateObj.str + '):', err.message || err); });

        // Wind
        fetch(windUrl).then(function(r){ return r.text(); }).then(function(csv){
          plotWindCSV(csv, footerDate);
        }).catch(function(err){ console.warn('[SPC] Wind reports failed (' + dateObj.str + '):', err.message || err); });
      }, idx * 150);
    });
  }

