  /* =========================================================
     MOON (approx)
     ========================================================= */
  function moonInfo(phase){
    var icon, name;
    if (phase < 0.03 || phase > 0.97){ icon="🌑"; name="New Moon"; }
    else if (phase < 0.22)          { icon="🌒"; name="Waxing Crescent"; }
    else if (phase < 0.28)          { icon="🌓"; name="First Quarter"; }
    else if (phase < 0.45)          { icon="🌔"; name="Waxing Gibbous"; }
    else if (phase < 0.55)          { icon="🌕"; name="Full Moon"; }
    else if (phase < 0.72)          { icon="🌖"; name="Waning Gibbous"; }
    else if (phase < 0.78)          { icon="🌗"; name="Last Quarter"; }
    else                            { icon="🌘"; name="Waning Crescent"; }

    var illum = Math.round((1 - Math.cos(2 * Math.PI * phase)) / 2 * 100);
if (illum >= 98) illum = 100;
if (illum <= 2) illum = 0;
    return { icon:icon, name:name, illum:illum };
  }

  function approximateMoonPhase(date){
  var lp = 2551442.8; // lunar period in seconds (29.53059 days)
  var newMoon = new Date(Date.UTC(2026,0,18,19,52,0)); // Jan 18, 2026 new moon
  var phaseSec = ((date.getTime() - newMoon.getTime())/1000) % lp;
  if (phaseSec < 0) phaseSec += lp;
  return phaseSec / lp;
}

  function findNextMoonEvent(now, targetPhase, daysAhead){
    var best = null;
    var bestErr = Infinity;
    var start = now.getTime();
    var end = start + (daysAhead*86400000);
    var prevErr = null;
    for (var t=start; t<=end; t+=3600000){
      var d = new Date(t);
      var ph = approximateMoonPhase(d);
      var err = Math.abs(ph - targetPhase);
      err = Math.min(err, 1-err);
      if (err < bestErr){
        bestErr = err;
        best = d;
      }
      // If error was decreasing and now increasing, we passed a local minimum — stop
      if (prevErr !== null && bestErr < 0.02 && err > prevErr){
        break;
      }
      prevErr = err;
    }
    return best;
  }

  /* =========================================================
     MOON CANVAS RENDERER - instant, zero network dependency
     Renders a 3D-illuminated moon sphere on canvas.
     NASA SVS image loads in background as optional upgrade.
     ========================================================= */
  window.renderMoonCanvas = function(canvasId, size) {
    var canvas = document.getElementById(canvasId);
    if (!canvas) return;
    var pf = approximateMoonPhase(new Date());
    var mi = moonInfo(pf);
    var illum = mi.illum / 100;
    var isWaxing = pf < 0.5;
    
    var w = size || canvas.width;
    var h = size || canvas.height;
    canvas.width = w; canvas.height = h;
    var ctx = canvas.getContext('2d');
    var cx = w / 2, cy = h / 2, r = w * 0.46;
    
    // Background
    ctx.clearRect(0, 0, w, h);
    
    // Moon base sphere with surface texture noise
    var imgData = ctx.createImageData(w, h);
    var data = imgData.data;
    
    // Seed a simple deterministic noise for "craters"
    var seed = 12345;
    function rand() { seed = (seed * 16807 + 0) % 2147483647; return (seed - 1) / 2147483646; }
    
    // Pre-generate crater map
    var numCraters = 60;
    var craters = [];
    for (var ci = 0; ci < numCraters; ci++) {
      craters.push({
        x: rand() * 2 - 1,
        y: rand() * 2 - 1,
        r: 0.02 + rand() * 0.12,
        d: 0.15 + rand() * 0.25
      });
    }
    // Mare (dark regions) - approximate lunar mare positions
    var mare = [
      { x: -0.15, y: -0.2, r: 0.28, d: 0.3 },  // Mare Imbrium
      { x: 0.1, y: -0.05, r: 0.2, d: 0.25 },    // Mare Serenitatis  
      { x: 0.2, y: 0.15, r: 0.22, d: 0.22 },     // Mare Tranquillitatis
      { x: -0.05, y: 0.25, r: 0.15, d: 0.2 },    // Mare Nectaris
      { x: -0.3, y: 0.0, r: 0.18, d: 0.28 },     // Oceanus Procellarum
      { x: -0.25, y: -0.35, r: 0.12, d: 0.2 },   // Mare Frigoris
      { x: 0.35, y: -0.1, r: 0.1, d: 0.18 },     // Mare Crisium
      { x: 0.05, y: 0.35, r: 0.13, d: 0.15 },    // Mare Fecunditatis
    ];
    
    // Phase angle for illumination
    // pf: 0 = new moon, 0.25 = first quarter (right lit), 0.5 = full, 0.75 = last quarter (left lit)
    // In Northern Hemisphere: waxing = right side lit, waning = left side lit
    // Light comes from the right during waxing, left during waning
    // Map pf to a light direction angle:
    //   pf=0 (new): light behind moon (lightZ negative, nothing visible)
    //   pf=0.25 (1st quarter): light from right (lightX positive)
    //   pf=0.5 (full): light from front (lightZ positive)
    //   pf=0.75 (3rd quarter): light from left (lightX negative)
    var phaseAngle = pf * 2 * Math.PI;
    var lightX = Math.sin(phaseAngle);
    var lightY = -0.1;
    var lightZ = -Math.cos(phaseAngle);
    var lightLen = Math.sqrt(lightX*lightX + lightY*lightY + lightZ*lightZ);
    lightX /= lightLen; lightY /= lightLen; lightZ /= lightLen;
    
    for (var py = 0; py < h; py++) {
      for (var px = 0; px < w; px++) {
        var idx = (py * w + px) * 4;
        var nx = (px - cx) / r;
        var ny = (py - cy) / r;
        var dist2 = nx * nx + ny * ny;
        
        if (dist2 > 1.0) {
          data[idx] = 0; data[idx+1] = 0; data[idx+2] = 0; data[idx+3] = 0;
          continue;
        }
        
        // Surface normal of sphere
        var nz = Math.sqrt(1 - dist2);
        
        // Lighting (diffuse)
        var dot = nx * lightX + ny * lightY + nz * lightZ;
        if (dot < 0) dot = 0;
        
        // Ambient + diffuse
        var brightness = 0.02 + dot * 0.98;
        
        // Limb darkening
        brightness *= (0.7 + 0.3 * nz);
        
        // Base moon color (grey with slight warm tint)
        var baseR = 200, baseG = 196, baseB = 188;
        
        // Apply mare darkening
        for (var mi2 = 0; mi2 < mare.length; mi2++) {
          var m = mare[mi2];
          var mdx = nx - m.x, mdy = ny - m.y;
          var md2 = mdx * mdx + mdy * mdy;
          if (md2 < m.r * m.r) {
            var mf = 1 - Math.sqrt(md2) / m.r;
            mf = mf * mf * m.d;
            baseR -= mf * 60; baseG -= mf * 55; baseB -= mf * 50;
          }
        }
        
        // Apply crater shadows
        for (var cj = 0; cj < craters.length; cj++) {
          var c = craters[cj];
          var cdx = nx - c.x, cdy = ny - c.y;
          var cd2 = cdx * cdx + cdy * cdy;
          if (cd2 < c.r * c.r) {
            var cf = 1 - Math.sqrt(cd2) / c.r;
            brightness *= (1 - cf * c.d);
          }
        }
        
        // Fine texture noise
        var tn = Math.sin(px * 47.3 + py * 91.7) * Math.sin(px * 13.1 - py * 67.9);
        brightness *= (0.92 + tn * 0.08);
        
        if (brightness < 0) brightness = 0;
        if (brightness > 1) brightness = 1;
        
        data[idx]   = Math.round(baseR * brightness);
        data[idx+1] = Math.round(baseG * brightness);
        data[idx+2] = Math.round(baseB * brightness);
        data[idx+3] = 255;
      }
    }
    ctx.putImageData(imgData, 0, 0);
  };

