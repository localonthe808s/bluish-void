              // 24/7). Golden-hour values are the original hand-tuned formula.
              var _wm=Math.max(0,Math.min(1,1-_renderSa/10));
              var _rd=Math.max(0,Math.min(1,1-_renderSa/5));
              var _topR,_topG,_topB,_midR,_midG,_midB,_botR,_botG,_botB,_shR,_shG,_shB,_hiR,_hiG,_hiB,_hiOp;
