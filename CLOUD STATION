      attributionControl: true,
      minZoom: 2,
      maxZoom: 10,
      worldCopyJump: false,
      maxBounds: [[-10, -180], [55, 20]]
    });

    // ── Fixed z-order panes — created once, used always ──────────────────────
    // Order (bottom → top): SST → GOES → SAL → Shear → WV → GTWO → Pathway → Waves → Track
    _hurricaneMap.createPane('hz-sst');    _hurricaneMap.getPane('hz-sst').style.zIndex    = 210;
    _hurricaneMap.createPane('hz-goes');   _hurricaneMap.getPane('hz-goes').style.zIndex   = 220;
    _hurricaneMap.createPane('hz-sal');    _hurricaneMap.getPane('hz-sal').style.zIndex    = 230;
    _hurricaneMap.createPane('hz-shear');  _hurricaneMap.getPane('hz-shear').style.zIndex  = 240;
    _hurricaneMap.createPane('hz-wv');     _hurricaneMap.getPane('hz-wv').style.zIndex     = 250;
    _hurricaneMap.createPane('hz-gtwo');   _hurricaneMap.getPane('hz-gtwo').style.zIndex   = 310;
    _hurricaneMap.createPane('hz-path');   _hurricaneMap.getPane('hz-path').style.zIndex   = 320;
    _hurricaneMap.createPane('hz-waves');  _hurricaneMap.getPane('hz-waves').style.zIndex  = 330;
    _hurricaneMap.createPane('hz-track');  _hurricaneMap.getPane('hz-track').style.zIndex  = 400;

    // ── Blend modes — each layer composites against what's beneath it ─────────
    // SST: straight alpha — it IS the base science layer, must read true colours
    _hurricaneMap.getPane('hz-sst').style.mixBlendMode   = 'normal';
    _hurricaneMap.getPane('hz-sst').style.opacity        = '1';
    // GOES GeoColor: screen — bright clouds add luminosity without killing SST colours
    _hurricaneMap.getPane('hz-goes').style.mixBlendMode  = 'screen';
    _hurricaneMap.getPane('hz-goes').style.opacity       = '0.55';
    // SAL Dust: multiply then lighten — pink dust blooms through; blue clear-air areas
    // darken ocean slightly so dust contrast pops; use 'hard-light' for vivid pinks
    _hurricaneMap.getPane('hz-sal').style.mixBlendMode   = 'hard-light';
    _hurricaneMap.getPane('hz-sal').style.opacity        = '0.65';
    // Shear (Air Mass RGB): overlay — warm amber shear zones glow over SST,
    // cool blues darken naturally, dark poles recede — ideal for scientific reading
    _hurricaneMap.getPane('hz-shear').style.mixBlendMode = 'overlay';
    _hurricaneMap.getPane('hz-shear').style.opacity      = '0.7';
    // Water Vapor (IR): screen — cold cloud tops (dark) vanish; warm surface (bright)
    // adds a subtle luminous glow showing moisture patterns without blocking SST
    _hurricaneMap.getPane('hz-wv').style.mixBlendMode    = 'screen';
    _hurricaneMap.getPane('hz-wv').style.opacity         = '0.55';

    // Pointer events: raster panes pass through, vector panes capture
    ['hz-sst','hz-goes','hz-sal','hz-shear','hz-wv'].forEach(function(p){
      _hurricaneMap.getPane(p).style.pointerEvents = 'none';
    });

    // Ocean basemap — Esri Ocean Base, color-inverted via className so labels and
    // overlays in the default panes render unfiltered on top.
    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/Ocean/World_Ocean_Base/MapServer/tile/{z}/{y}/{x}', {
      attribution: '© Esri, GEBCO, NOAA',
      maxZoom: 13, opacity: 1, updateWhenZooming: false, updateWhenIdle: true, keepBuffer: 4,
      className: 'hurricane-basemap-inverted'
    }).addTo(_hurricaneMap);

    // Reference labels on top
    L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/Canvas/World_Dark_Gray_Reference/MapServer/tile/{z}/{y}/{x}', {
      attribution: '', maxZoom: 16, opacity: 0.85, updateWhenZooming: false, updateWhenIdle: true, keepBuffer: 4
    }).addTo(_hurricaneMap);

    // Draw the classic African wave / hurricane genesis pathway annotation
    _drawAtlanticPathway();

    // Force correct tile coverage after initial render
    setTimeout(function(){ _hurricaneMap.invalidateSize(); }, 100);

    // Fetch live NHC data
    _fetchNHCCurrentStorms();
    _fetchNHCAdvisoryText();

    // Auto-refresh every 10 min
    setInterval(function(){ if (document.hidden) return; _fetchNHCCurrentStorms(); }, 600000);

    // Auto-activate default view after map tiles settle
    setTimeout(function() { window.setHurricaneView('track'); }, 500);
  }

