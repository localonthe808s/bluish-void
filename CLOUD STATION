                    var rowWave = Math.sin((pxC-xOff)/pW * Math.PI * 2 + rr * 0.9) * 4;
                    var pyC = rowYBase + rowWave + (R()-0.5)*3;
                    if (pxC < xOff+4 || pxC > xOff+pW-4) { _acGrid[rr][cc] = null; continue; }
                    if (pyC < _acYTop-4 || pyC > _acYBot+4) { _acGrid[rr][cc] = null; continue; }
                    _acGrid[rr][cc] = { x: pxC, y: pyC, used: false, depth: rowDepth };
                  }
                }

