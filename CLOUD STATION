    var btn = document.getElementById('hz-btn-' + (which === 'gtwo' ? 'gtwo' : which === 'nhc-track' ? 'nhc-track' : which));
    var on = _hurricaneLayers[which];
    if (btn) {
      btn.style.background = on ? 'rgba(139,92,246,.3)' : 'rgba(255,255,255,.06)';
      btn.style.border = on ? '1px solid rgba(139,92,246,.5)' : '1px solid rgba(255,255,255,.12)';
